<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ymsoft.springdeveloper.com.springdeveloper.mapper.UsersMapper">

    <resultMap id="usersMap" type="ymsoft.springdeveloper.com.springdeveloper.entity.Users">
        <id property="id" column="id"/>
        <result property="nickname" column="nickname"/>
        <result property="password" column="password"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="agreedTerms" column="agreed_terms"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findByNickname" resultMap="usersMap">
        SELECT * FROM users WHERE nickname = #{nickname}
    </select>

    <select id="findByEmail" resultMap="usersMap">
        SELECT * FROM users WHERE email = #{email}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (nickname, password, email, phone, agreed_terms, created_at, updated_at)
        VALUES (#{nickname}, #{password}, #{email}, #{phone}, #{agreedTerms}, NOW(), NOW())
    </insert>

</mapper>
