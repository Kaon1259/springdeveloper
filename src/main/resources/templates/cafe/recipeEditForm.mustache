{{>layouts/header}}

<style>
    body { background: #fff9f2; }

    .category-chip-group{ display:flex; flex-wrap:wrap; gap:0.5rem; }
    .category-chip{
        border-radius:999px; border:1.5px solid #e2e8f0; background:#fff;
        padding:0.32rem 0.85rem; font-size:0.88rem; cursor:pointer;
        transition: all 0.12s ease;
        white-space:nowrap; font-weight:500; color:#5b4434;
    }
    .category-chip:hover{ background:#fff9f2; border-color:#c4a882; }
    .category-chip.selected{
        background:#5b4434; color:#fff9f2; border-color:#5b4434;
        box-shadow:0 2px 8px rgba(91,68,52,0.28);
        font-weight:700;
    }

    .temp-group .btn, .cup-group .btn { min-width: 80px; }
    .temp-group .btn-outline-danger, .temp-group .btn-outline-primary { font-weight: 600; }

    .form-wrapper{
        border-radius:1rem; border:2px solid #c4a882;
        padding:1.1rem 1.35rem; background:#fff; margin-bottom:1rem;
        box-shadow:0 2px 10px rgba(91,68,52,0.07);
    }

    .step-wrapper{
        border-radius:1rem; border:2px solid #c4a882;
        padding:0.75rem 0.75rem 0.25rem; background:#fff;
        box-shadow:0 2px 10px rgba(91,68,52,0.07);
    }

    .step-time-group{ display:inline-flex; align-items:center; gap:0.25rem; margin-left:0.75rem; }
    .step-time-input{ width:70px; padding:0.1rem 0.35rem; font-size:0.8rem; text-align:right; }
    .step-time-label{ font-size:0.8rem; color:#6c757d; white-space:nowrap; }

    /* Preview modal - dark header */
    #recipePreviewModal .modal-dialog{ max-width:960px; width:95%; }
    #recipePreviewModal .modal-content{
        border-radius:1rem; border:none; overflow:hidden;
        box-shadow:0 1.5rem 4rem rgba(0,0,0,0.28);
        max-height:92vh;
    }
    #recipePreviewModal .modal-header{
        background: linear-gradient(135deg, #5b4434 0%, #3f2c20 100%);
        border-bottom:none; padding:1.1rem 1.5rem;
    }
    #recipePreviewModal .modal-header .btn-close{ filter:invert(1) brightness(2); opacity:0.75; }
    #recipePreviewModal .modal-header .btn-close:hover{ opacity:1; }
    #recipePreviewModal .modal-header .modal-title{ color:#fff9f2; font-size:1.15rem; font-weight:800; }
    #recipePreviewModal .modal-body{
        font-size:1rem; background:#fdfcfb;
        padding:1.5rem; max-height:75vh; overflow-y:auto;
    }
    #recipePreviewModal .modal-footer{ background:#fdfcfb; border-top:1px solid #ede8e3; }
    #recipePreviewMeta{ font-size:0.95rem !important; color:#6c757d; }
    #recipe-steps-content{ padding-right:0.25rem; }

    .recipe-step{
        display:flex; align-items:flex-start; gap:0.8rem;
        background:#fff; border-radius:0.875rem;
        padding:0.9rem 1.1rem; margin-bottom:0.6rem;
        border:1.5px solid #ede8e3;
        box-shadow:0 1px 4px rgba(0,0,0,0.05);
        font-size:1rem; line-height:1.5; cursor:pointer;
        transition:all 0.13s ease;
    }
    .recipe-step:hover{ border-color:#c4a882; box-shadow:0 3px 10px rgba(91,68,52,0.1); transform:translateX(2px); }
    .step-index{
        flex:0 0 auto;
        background:#5b4434; color:#fff9f2; border-radius:999px;
        padding:0.15rem 0.55rem; font-size:0.76rem; font-weight:900;
        white-space:nowrap; line-height:1.6; margin-top:0.05rem;
    }
    .step-text{ flex:1; display:block; font-weight:500; color:#374151; }

    #recipe-steps-content .recipe-step:nth-child(2){ margin-left:10px; }
    #recipe-steps-content .recipe-step:nth-child(3){ margin-left:20px; }
    #recipe-steps-content .recipe-step:nth-child(4){ margin-left:30px; }
    #recipe-steps-content .recipe-step:nth-child(5){ margin-left:40px; }
    #recipe-steps-content .recipe-step:nth-child(6){ margin-left:50px; }
    #recipe-steps-content .recipe-step:nth-child(7){ margin-left:60px; }

    .recipe-step.step-selected{
        background:#5b4434; border-color:#5b4434;
        box-shadow:0 4px 14px rgba(91,68,52,0.26); transform:translateX(2px);
    }
    .recipe-step.step-selected .step-index{ background:rgba(255,255,255,0.22); color:#fff9f2; }
    .recipe-step.step-selected .step-text{ color:#fff9f2; }
    .recipe-step.empty-step{ border-color:#e2e8f0; }
    .recipe-step.empty-step .step-index{ background:#94a3b8; }

    /* useBlender 스위치 UI */
    .blender-switch-row{
        display:flex; align-items:center; justify-content:space-between; gap:1rem;
        padding:0.65rem 0.85rem;
        border-radius:0.85rem;
        border:1px solid #e9ecef;
        background:#fff7ed;
        margin-bottom:0.75rem;
    }
    .blender-switch-title{
        display:flex; flex-direction:column; gap:0.1rem; min-width:0;
    }
    .blender-switch-title .title{
        font-weight:800; letter-spacing:-0.2px;
        display:flex; align-items:center; gap:0.4rem;
    }
    .blender-switch-title .desc{
        font-size:0.85rem; color:#6c757d; line-height:1.25;
    }

    .blender-badge-inline{
        display:inline-flex; align-items:center; justify-content:center;
        width:28px; height:28px; border-radius:999px;
        border:2px solid rgba(111,78,55,0.45);
        background:#fff;
        box-shadow:0 2px 8px rgba(0,0,0,0.08);
        overflow:hidden; position:relative;
    }
    .blender-badge-inline::before{
        content:""; position:absolute; inset:-40%;
        background: conic-gradient(
                from 0deg,
                rgba(111,78,55,0.25),
                rgba(171,120,84,0.55),
                rgba(111,78,55,0.25),
                rgba(140,92,62,0.55),
                rgba(111,78,55,0.25)
        );
        animation: blenderGradSpin 10s linear infinite;
    }
    .blender-badge-inline::after{
        content:""; position:absolute; inset:3px;
        background:#fff; border-radius:999px;
    }
    .blender-emoji-inline{
        position:relative; z-index:1; font-size:16px;
        filter: sepia(1) saturate(6) hue-rotate(340deg) brightness(0.9) contrast(1.05);
        animation: blenderEmojiSpin 10s linear infinite;
        transform-origin:50% 50%;
    }
    @keyframes blenderGradSpin{ from{transform:rotate(0deg);} to{transform:rotate(360deg);} }
    @keyframes blenderEmojiSpin{ from{transform:rotate(0deg);} to{transform:rotate(360deg);} }

    .blender-switch-row .form-check{
        margin:0; display:flex; align-items:center; gap:0.5rem; flex-shrink:0;
    }
    .blender-switch-row .form-check-input{
        cursor:pointer; width:3.2em; height:1.7em;
    }
    .blender-switch-row .form-check-label{
        font-weight:800; letter-spacing:-0.2px; user-select:none;
    }
    .blender-status-pill{
        font-size:0.85rem; font-weight:800;
        padding:0.18rem 0.55rem;
        border-radius:999px;
        border:1px solid #dee2e6;
        background:#fff; color:#6c757d;
    }
    .blender-status-pill.on{
        color:#dc3545;
        border-color: rgba(220,53,69,0.35);
        background: rgba(220,53,69,0.06);
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div class="page-form-hero mb-4" style="background:linear-gradient(135deg,#5b4434,#3f2c20);border-radius:1rem;padding:1.1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;gap:1rem;box-shadow:0 6px 20px rgba(91,68,52,0.2);">
                <div>
                    <div style="font-size:1.2rem;font-weight:900;color:#fff9f2;">✎ 레시피 수정</div>
                    <div style="font-size:0.78rem;color:rgba(255,249,242,0.6);margin-top:0.15rem;">저장된 레시피 내용을 수정하고 다시 저장할 수 있습니다. <span style="color:rgba(255,249,242,0.45)">ID: {{recipeId}}</span></div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a href="/cafe/recipe/new" class="btn btn-sm" style="background:rgba(255,249,242,0.18);border:1.5px solid rgba(255,249,242,0.4);color:#fff9f2;border-radius:999px;font-weight:700;">+ 새 레시피</a>
                    <a href="/cafe/recipes" class="btn btn-sm" style="background:rgba(255,249,242,0.1);border:1.5px solid rgba(255,249,242,0.3);color:#fff9f2;border-radius:999px;font-weight:600;">목록</a>
                </div>
            </div>

            <form method="post"
                  action="/cafe/recipe/{{recipeId}}/update"
                  id="recipe-form"
                  data-temp="{{recipe.temperature}}"
                  data-cup="{{recipe.cupSize}}"
                  data-category="{{recipe.category}}"
                  data-use-blender="{{recipe.useBlender}}">

                <input type="hidden" name="id" value="{{recipeId}}">

                <div class="form-wrapper">

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label for="menuName" class="form-label fw-semibold mb-0">메뉴 이름</label>
                            <div class="d-flex align-items-center gap-3">
                                <div class="form-check mb-0">
                                    <input class="form-check-input" type="checkbox" id="visible" name="visible" {{#recipe.visible}}checked{{/recipe.visible}}>
                                    <label class="form-check-label small" for="visible">노출 여부</label>
                                </div>
                                <div class="form-check mb-0">
                                    <input class="form-check-input" type="checkbox" id="template" name="template" {{#recipe.template}}checked{{/recipe.template}}>
                                    <label class="form-check-label small" for="template">템플릿 등록</label>
                                </div>
                            </div>
                        </div>
                        <input type="text" class="form-control" id="menuName" name="menuName" value="{{recipe.menuName}}" placeholder="예) 바닐라라떼" required>
                    </div>

                    <div class="mb-3">
                        <label for="author" class="form-label fw-semibold">작성자</label>
                        <input type="text" class="form-control" id="author" name="author" value="{{recipe.author}}" placeholder="본인 이름 또는 닉네임" required>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label fw-semibold">
                            간단 설명 <span class="text-muted small">(선택)</span>
                        </label>
                        <input type="text" class="form-control" id="description" name="description" value="{{recipe.description}}" placeholder="예) 아이스 전용, 연한 단맛, 초보 바리스타용">
                    </div>

                    <!-- ✅ 추가: 이미지 이름(imgname) - 간단설명 아래 -->
                    <!-- ✅ Mustache 안전 접근: recipe.imgname 금지 / recipe 컨텍스트 안에서 imgname -->
                    <div class="mb-3">
                        <label for="imgname" class="form-label fw-semibold">
                            이미지 이름 <span class="text-muted small">(선택)</span>
                        </label>
                        <input type="text"
                               class="form-control"
                               id="imgname"
                               name="imgname"
                               value="{{#recipe}}{{imgname}}{{/recipe}}"
                               placeholder="예) vanilla_latte.png">
                        <div class="form-text text-muted small">
                            현재 값이 없어도 정상 동작합니다. 파일명만 저장하는 용도라면 확장자 포함으로 입력해 주세요.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold d-block">온도 / 컵 사이즈</label>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <div class="btn-group temp-group" role="group" aria-label="Temperature select">
                                <input type="radio" class="btn-check" name="temperature" id="tempHot" value="HOT" autocomplete="off">
                                <label class="btn btn-outline-danger" for="tempHot">HOT</label>

                                <input type="radio" class="btn-check" name="temperature" id="tempIce" value="ICE" autocomplete="off">
                                <label class="btn btn-outline-primary" for="tempIce">ICE</label>
                            </div>

                            <div class="btn-group cup-group" role="group" aria-label="Cup size select">
                                <input type="radio" class="btn-check" name="cupSize" id="cup20" value="OZ20" autocomplete="off">
                                <label class="btn btn-outline-secondary" for="cup20">20oz</label>

                                <input type="radio" class="btn-check" name="cupSize" id="cup24" value="OZ24" autocomplete="off">
                                <label class="btn btn-outline-secondary" for="cup24">24oz</label>

                                <input type="radio" class="btn-check" name="cupSize" id="cup32" value="OZ32" autocomplete="off">
                                <label class="btn btn-outline-secondary" for="cup32">32oz</label>

                                <input type="radio" class="btn-check" name="cupSize" id="cupL17" value="L17" autocomplete="off">
                                <label class="btn btn-outline-secondary" for="cupL17">1.7L</label>

                                <input type="radio" class="btn-check" name="cupSize" id="cupL20" value="L20" autocomplete="off">
                                <label class="btn btn-outline-secondary" for="cupL20">2.0L</label>
                            </div>
                        </div>
                        <div class="form-text text-muted small">
                            HOT 선택 시 기본 20oz, ICE 선택 시 기본 24oz가 자동 선택됩니다.
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-semibold d-block">블렌더 사용</label>
                        <input type="hidden" name="_useBlender" value="on">

                        <div class="blender-switch-row">
                            <div class="blender-switch-title">
                                <div class="title">
                                    <span class="blender-badge-inline" aria-hidden="true">
                                        <span class="blender-emoji-inline">🌀</span>
                                    </span>
                                    블렌더 사용 여부
                                    <span id="blender-status-pill" class="blender-status-pill">OFF</span>
                                </div>
                                <div class="desc">
                                    블렌더를 사용하는 레시피라면 ON으로 설정해 주세요. (목록/팝업에 블렌더 표시)
                                </div>
                            </div>

                            <div class="form-check form-switch">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="useBlender"
                                       name="useBlender"
                                       value="true"
                                       {{#recipe.useBlender}}checked{{/recipe.useBlender}}>
                                <label class="form-check-label" for="useBlender">ON / OFF</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-1">
                        <label class="form-label fw-semibold d-block">카테고리</label>
                        <div class="category-chip-group" id="category-chip-group">
                            <button type="button" class="category-chip" data-value="HOT_COFFEE">Hot 커피</button>
                            <button type="button" class="category-chip" data-value="ICE_COFFEE">Ice 커피</button>
                            <button type="button" class="category-chip" data-value="HOT_LATTE">Hot 라떼</button>
                            <button type="button" class="category-chip" data-value="ICE_LATTE">Ice 라떼</button>
                            <button type="button" class="category-chip" data-value="ICE_NON_COFFEE">Ice 논커피</button>
                            <button type="button" class="category-chip" data-value="ICE_NON_COFFEE_HUKDANG">흑당</button>
                            <button type="button" class="category-chip" data-value="HOT_NON_COFFEE">Hot 논커피</button>
                            <button type="button" class="category-chip" data-value="HOT_COLD_BREW">HOT 콜드브루</button>
                            <button type="button" class="category-chip" data-value="HOT_LATTE_COLD_BREW">HOT 콜드브루라떼</button>
                            <button type="button" class="category-chip" data-value="ICE_COLD_BREW">ICE 콜드브루</button>
                            <button type="button" class="category-chip" data-value="ICE_LATTE_COLD_BREW">ICE 콜드브루라떼</button>
                            <button type="button" class="category-chip" data-value="SMOOTHIE_ADE">스무디</button>
                            <button type="button" class="category-chip" data-value="ADE">에이드</button>
                            <button type="button" class="category-chip" data-value="JUICE">주스</button>
                            <button type="button" class="category-chip" data-value="FRAPPE">프라페</button>
                            <button type="button" class="category-chip" data-value="PONG_CRUSH">퐁크러쉬</button>
                            <button type="button" class="category-chip" data-value="ICE_TEA">아이스티</button>
                            <button type="button" class="category-chip" data-value="HOT_TEA">핫티</button>
                            <button type="button" class="category-chip" data-value="FOOD">푸드</button>
                            <button type="button" class="category-chip" data-value="BASE">베이스</button>
                        </div>
                        <input type="hidden" name="category" id="category-input" required>
                        <div class="form-text text-muted small">위 카테고리 중 하나를 선택해 주세요.</div>
                    </div>

                </div>

                <div class="mb-2 d-flex justify-content-between align-items-center">
                    <label class="form-label fw-semibold mb-0">레시피 단계</label>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-success" id="btn-preview">레시피 미리보기</button>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="btn-add-step">+ 단계 추가</button>
                    </div>
                </div>

                <div class="step-wrapper mb-3">
                    <div id="steps-container" class="mb-1">
                        {{#recipe.steps}}
                            <div class="card mb-2">
                                <div class="card-body py-2">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="fw-semibold d-flex align-items-center">
                                            Step <span class="step-number ms-1">0</span>
                                            <div class="step-time-group">
                                                <input type="number" class="form-control form-control-sm step-time-input" name="stepTimes" min="1" value="10">
                                                <span class="step-time-label">초</span>
                                            </div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-remove-step">삭제</button>
                                    </div>
                                    <textarea class="form-control step-textarea" name="steps" rows="2" required>{{.}}</textarea>
                                </div>
                            </div>
                        {{/recipe.steps}}
                    </div>

                    <div id="initial-step-times" style="display:none;">
                        {{#recipe.stepTimes}}
                            <span class="init-step-time" data-time="{{.}}"></span>
                        {{/recipe.stepTimes}}
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a href="/cafe/recipes" class="btn btn-outline-secondary">목록</a>
                    <button type="button" class="btn btn-outline-danger" id="btn-delete-recipe" data-recipe-id="{{recipeId}}">삭제</button>
                    <button type="submit" class="btn btn-primary">변경사항 저장</button>
                </div>
            </form>

        </div>
    </div>
</div>

<div class="modal fade" id="recipePreviewModal" tabindex="-1" aria-labelledby="recipePreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="recipePreviewModalLabel">👁 레시피 미리보기</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="닫기"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <div class="fw-bold fs-5" id="preview-menu-name">메뉴 이름</div>
                    <div class="text-muted small" id="preview-description"></div>
                </div>
                <div class="mb-2 small text-secondary" id="preview-basic-info"></div>
                <hr class="my-2">
                <div id="recipe-steps-content"></div>
                <div class="mt-2 text-muted small">
                    현재 입력된 내용을 기준으로 한 미리보기입니다. 저장 후 실제 레시피에 반영됩니다.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">닫기</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const form = document.getElementById('recipe-form');

        /* =========================
           useBlender 스위치 초기값 + 상태표시
           ========================= */
        const useBlenderToggle = document.getElementById('useBlender');
        const blenderStatusPill = document.getElementById('blender-status-pill');

        function parseTruth(v) {
            const s = String(v || '').trim().toLowerCase();
            return (s === 'true' || s === '1' || s === 'y' || s === 'yes');
        }

        function refreshBlenderStatus() {
            if (!blenderStatusPill || !useBlenderToggle) return;
            const on = !!useBlenderToggle.checked;
            blenderStatusPill.textContent = on ? 'ON' : 'OFF';
            blenderStatusPill.classList.toggle('on', on);
        }

        (function initUseBlender() {
            if (!useBlenderToggle) return;
            const initial = parseTruth(form.dataset.useBlender);
            useBlenderToggle.checked = initial;
            refreshBlenderStatus();
            useBlenderToggle.addEventListener('change', refreshBlenderStatus);
        })();

        /* =========================
           레시피 단계 (Step) 관리
           ========================= */
        const stepsContainer = document.getElementById('steps-container');
        const addStepBtn = document.getElementById('btn-add-step');

        let stepIndex = 0;

        function createStepElement(index, content) {
            const wrapper = document.createElement('div');
            wrapper.className = 'card mb-2';

            wrapper.innerHTML = `
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="fw-semibold d-flex align-items-center">
                            Step <span class="step-number ms-1">${index + 1}</span>
                            <div class="step-time-group">
                                <input type="number"
                                       class="form-control form-control-sm step-time-input"
                                       name="stepTimes"
                                       min="1"
                                       value="10">
                                <span class="step-time-label">초</span>
                            </div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-danger btn-remove-step">삭제</button>
                    </div>
                    <textarea class="form-control step-textarea" name="steps" rows="2" required>${content || ''}</textarea>
                </div>
            `;
            return wrapper;
        }

        function refreshStepNumbers() {
            const stepCards = stepsContainer.querySelectorAll('.card');
            stepCards.forEach((card, idx) => {
                const numberSpan = card.querySelector('.step-number');
                if (numberSpan) numberSpan.textContent = idx + 1;
            });
            stepIndex = stepCards.length;
        }

        function bindRemoveEvent(card) {
            const removeBtn = card.querySelector('.btn-remove-step');
            if (!removeBtn) return;

            removeBtn.addEventListener('click', function () {
                const total = stepsContainer.querySelectorAll('.card').length;
                if (total <= 1) {
                    alert('최소 1개 이상의 단계가 필요합니다.');
                    return;
                }
                card.remove();
                refreshStepNumbers();
            });
        }

        function addStep(defaultContent) {
            const el = createStepElement(stepIndex, defaultContent);
            stepsContainer.appendChild(el);
            stepIndex++;
            bindRemoveEvent(el);
        }

        function applyInitialStepTimes() {
            const initContainer = document.getElementById('initial-step-times');
            if (!initContainer) return;

            const initTimes = initContainer.querySelectorAll('.init-step-time');
            const stepCards = stepsContainer.querySelectorAll('.card');

            stepCards.forEach((card, idx) => {
                const timeInput = card.querySelector('.step-time-input');
                if (!timeInput) return;

                const span = initTimes[idx];
                if (span) {
                    const t = span.dataset.time;
                    if (t !== undefined && t !== null && t !== '') timeInput.value = t;
                }
            });
        }

        (function initSteps() {
            const existingCards = stepsContainer.querySelectorAll('.card');
            if (existingCards.length === 0) addStep('');
            else {
                existingCards.forEach(card => bindRemoveEvent(card));
                refreshStepNumbers();
            }
            applyInitialStepTimes();
        })();

        addStepBtn.addEventListener('click', function () { addStep(''); });

        /* =========================
           HOT / ICE & 컵 사이즈 연동
           ========================= */
        const tempHot = document.getElementById('tempHot');
        const tempIce = document.getElementById('tempIce');

        const cup20 = document.getElementById('cup20');
        const cup24 = document.getElementById('cup24');
        const cup32 = document.getElementById('cup32');
        const cupL17 = document.getElementById('cupL17');
        const cupL20 = document.getElementById('cupL20');

        function setDefaultCupByTemp(temp) {
            if (temp === 'HOT') cup20.checked = true;
            else if (temp === 'ICE') cup24.checked = true;
        }

        tempHot.addEventListener('change', function () { if (tempHot.checked) setDefaultCupByTemp('HOT'); });
        tempIce.addEventListener('change', function () { if (tempIce.checked) setDefaultCupByTemp('ICE'); });

        function cupLabelByValue(v) {
            switch (v) {
                case 'OZ20': return '20oz';
                case 'OZ24': return '24oz';
                case 'OZ32': return '32oz';
                case 'L17':  return '1.7L';
                case 'L20':  return '2.0L';
                default: return v || '';
            }
        }

        (function initSelections() {
            const initialTemp = form.dataset.temp;
            const initialCup = form.dataset.cup;
            const initialCategory = form.dataset.category;

            if (initialTemp === 'ICE') tempIce.checked = true;
            else tempHot.checked = true;

            if (initialCup === 'OZ24') cup24.checked = true;
            else if (initialCup === 'OZ32') cup32.checked = true;
            else if (initialCup === 'L17') cupL17.checked = true;
            else if (initialCup === 'L20') cupL20.checked = true;
            else cup20.checked = true;

            const categoryInput = document.getElementById('category-input');
            const categoryGroup = document.getElementById('category-chip-group');
            const categoryChips = categoryGroup.querySelectorAll('.category-chip');

            categoryChips.forEach(chip => {
                chip.addEventListener('click', function () {
                    categoryChips.forEach(c => c.classList.remove('selected'));
                    chip.classList.add('selected');
                    categoryInput.value = chip.dataset.value;
                });

                if (chip.dataset.value === initialCategory) {
                    chip.classList.add('selected');
                    categoryInput.value = initialCategory;
                }
            });

            if (!categoryInput.value && categoryChips.length > 0) {
                categoryChips[0].classList.add('selected');
                categoryInput.value = categoryChips[0].dataset.value;
            }
        })();

        /* =========================
           레시피 미리보기 팝업
           ========================= */
        const previewBtn = document.getElementById('btn-preview');
        const previewModalEl = document.getElementById('recipePreviewModal');

        let previewModalInstance = null;

        function openPreviewModal() {
            if (!previewModalEl) return;
            if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                if (!previewModalInstance) previewModalInstance = new bootstrap.Modal(previewModalEl);
                previewModalInstance.show();
            } else {
                previewModalEl.style.display = 'block';
                previewModalEl.classList.add('show');
            }
        }

        function attachPreviewStepClickHandlers() {
            const container = document.getElementById('recipe-steps-content');
            if (!container) return;

            const steps = container.querySelectorAll('.recipe-step');
            steps.forEach(step => {
                step.addEventListener('click', () => {
                    steps.forEach(s => s.classList.remove('step-selected'));
                    step.classList.add('step-selected');
                });
            });
        }

        function buildPreview() {
            const menuNameInput = document.getElementById('menuName');
            const descInput = document.getElementById('description');
            const imgInput = document.getElementById('imgname');

            const selectedTemp = form.querySelector('input[name="temperature"]:checked');
            const selectedCup = form.querySelector('input[name="cupSize"]:checked');
            const selectedChip = document.querySelector('.category-chip.selected');

            const menuName = menuNameInput ? menuNameInput.value.trim() : '';
            const description = descInput ? descInput.value.trim() : '';
            const imgname = imgInput ? imgInput.value.trim() : '';

            const tempValue = selectedTemp ? selectedTemp.value : '';
            const cupValue = selectedCup ? selectedCup.value : '';
            const categoryLabel = selectedChip ? selectedChip.textContent.trim() : '';

            const previewMenuNameEl = document.getElementById('preview-menu-name');
            const previewDescriptionEl = document.getElementById('preview-description');
            const previewBasicInfoEl = document.getElementById('preview-basic-info');

            if (previewMenuNameEl) previewMenuNameEl.textContent = menuName || '메뉴 이름 미입력';

            if (previewDescriptionEl) {
                const descLine = description || '';
                const imgLine = imgname ? ` (img: ${imgname})` : '';
                previewDescriptionEl.textContent = (descLine + imgLine).trim();
            }

            const infoParts = [];
            if (tempValue) infoParts.push(tempValue === 'HOT' ? 'HOT (핫)' : 'ICE (아이스)');
            if (cupValue) infoParts.push('컵: ' + cupLabelByValue(cupValue));
            if (categoryLabel) infoParts.push('카테고리: ' + categoryLabel);
            if (useBlenderToggle) infoParts.push('블렌더: ' + (useBlenderToggle.checked ? 'ON' : 'OFF'));

            if (previewBasicInfoEl) previewBasicInfoEl.textContent = infoParts.join(' · ');

            const previewStepsEl = document.getElementById('recipe-steps-content');
            if (!previewStepsEl) return;

            previewStepsEl.innerHTML = '';

            const stepCards = stepsContainer.querySelectorAll('.card');
            let visibleIndex = 0;

            stepCards.forEach((card) => {
                const textarea = card.querySelector('.step-textarea');
                if (!textarea) return;

                const text = (textarea.value || '').trim();
                if (!text) return;

                const timeInput = card.querySelector('.step-time-input');
                const timeVal = timeInput ? (timeInput.value || '').trim() : '';

                const row = document.createElement('div');
                row.className = 'recipe-step';

                const safeText = text.replace(/\n/g, '<br>');

                let timeHtml = '';
                if (timeVal) {
                    timeHtml = `<span class="step-time-preview ms-2 text-muted" style="font-size:2.0rem;">(${timeVal}초)</span>`;
                }

                row.innerHTML = `
                    <span class="step-index">Step ${visibleIndex + 1}.</span>
                    <span class="step-text">${safeText}</span>
                    ${timeHtml}
                `;

                previewStepsEl.appendChild(row);
                visibleIndex++;
            });

            if (visibleIndex === 0) {
                const emptyRow = document.createElement('div');
                emptyRow.className = 'recipe-step empty-step';
                emptyRow.innerHTML = `
                    <span class="step-index">Step 1.</span>
                    <span class="step-text text-muted">등록된 단계가 없습니다. 단계 내용을 입력해 주세요.</span>
                `;
                previewStepsEl.appendChild(emptyRow);
            }

            attachPreviewStepClickHandlers();

            const firstStep = previewStepsEl.querySelector('.recipe-step');
            if (firstStep) {
                previewStepsEl.querySelectorAll('.recipe-step').forEach(s => s.classList.remove('step-selected'));
                firstStep.classList.add('step-selected');
            }
        }

        if (previewBtn) {
            previewBtn.addEventListener('click', function () {
                buildPreview();
                openPreviewModal();
            });
        }

        /* =========================
           삭제 버튼 처리
           ========================= */
        const deleteBtn = document.getElementById('btn-delete-recipe');

        async function deleteRecipe(recipeId) {
            const ok = confirm('이 레시피를 삭제하시겠습니까?\n삭제 후에는 되돌릴 수 없습니다.');
            if (!ok) return;

            try {
                const res = await fetch('/api/cafe/recipe/' + recipeId + '/delete', { method: 'POST' });

                if (!res.ok && res.status !== 204) {
                    alert('레시피 삭제에 실패했습니다. (' + res.status + ')');
                    return;
                }

                window.location.href = '/cafe/recipes';
            } catch (e) {
                console.error(e);
                alert('레시피 삭제 중 오류가 발생했습니다.');
            }
        }

        if (deleteBtn) {
            deleteBtn.addEventListener('click', function () {
                const recipeId = deleteBtn.dataset.recipeId || document.querySelector('input[name="id"]')?.value;
                if (!recipeId) {
                    alert('레시피 ID를 찾을 수 없습니다.');
                    return;
                }
                deleteRecipe(recipeId);
            });
        }
    })();
</script>

{{>layouts/footer}}
