{{>layouts/header}}

<style>
    body { background: #fff9f2; }

    .recipe-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.5rem 1rem 3rem;
    }

    .page-title {
        font-size: 1.35rem;
        font-weight: 800;
        color: #5b4434;
        margin-bottom: 0.3rem;
    }

    .page-sub {
        font-size: 0.82rem;
        color: #9ca3af;
        margin-bottom: 1.8rem;
    }

    /* =========================================
       공통 컨트롤 바
    ========================================= */
    .ctrl-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.85rem;
        padding: 0.5rem 0.75rem;
        background: #fff;
        border-radius: 0.75rem;
        border: 1px solid #f0f2f5;
        box-shadow: 0 1px 4px rgba(15,23,42,0.04);
    }

    .cols-btn-group { display: flex; gap: 0; }
    .cols-btn {
        padding: 0.28rem 0.85rem;
        border: 1.5px solid #e2e8f0;
        background: #f8fafc;
        color: #5b4434;
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.12s, border-color 0.12s, color 0.12s;
        line-height: 1.5;
    }
    .cols-btn:first-child { border-radius: 999px 0 0 999px; }
    .cols-btn:last-child  { border-radius: 0 999px 999px 0; }
    .cols-btn:not(:first-child) { border-left: none; }
    .cols-btn:hover   { background: #fff9f2; border-color: #c4a882; color: #3f2c20; }
    .cols-btn.active  { background: #5b4434; border-color: #5b4434; color: #fff9f2; }

    .btn-save {
        font-size: 0.8rem;
        padding: 0.28rem 1rem;
        border-radius: 999px;
        border: 1.5px solid #16a34a;
        background: #16a34a;
        color: #fff;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.12s, opacity 0.12s;
        white-space: nowrap;
    }
    .btn-save:disabled {
        opacity: 0.35;
        cursor: default;
        background: #94a3b8;
        border-color: #94a3b8;
    }
    .btn-save:not(:disabled):hover { background: #15803d; border-color: #15803d; }

    /* =========================================
       검색 박스
    ========================================= */
    .search-wrap {
        position: relative;
        margin-bottom: 1rem;
    }
    .search-input {
        width: 100%;
        padding: 0.65rem 2.8rem 0.65rem 1.1rem;
        border: 2px solid #e2e8f0;
        border-radius: 999px;
        font-size: 0.95rem;
        font-weight: 500;
        color: #374151;
        background: #fff;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .search-input::placeholder { color: #b0b8c4; font-weight: 400; }
    .search-input:focus {
        border-color: #5b4434;
        box-shadow: 0 0 0 3px rgba(91,68,52,0.12);
    }
    .search-clear {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: none;
        font-size: 1.15rem;
        color: #94a3b8;
        cursor: pointer;
        padding: 0.2rem;
        line-height: 1;
        display: none;
    }
    .search-clear:hover { color: #5b4434; }

    /* 검색 결과 영역 */
    .search-result-area {
        display: none;
        margin-bottom: 1.5rem;
    }
    .search-result-title {
        font-size: 0.88rem;
        font-weight: 700;
        color: #5b4434;
        margin-bottom: 0.6rem;
    }
    .search-no-result {
        text-align: center;
        color: #9ca3af;
        font-size: 0.9rem;
        padding: 2rem 0;
    }
    .search-result-grid {
        display: grid;
        gap: 0.85rem;
        grid-template-columns: repeat(4, 1fr);
    }
    .search-result-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
    .search-result-grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
    .search-result-grid.cols-5 { grid-template-columns: repeat(5, 1fr); }

    @media (max-width: 900px) {
        .search-result-grid.cols-5 { grid-template-columns: repeat(3, 1fr); }
        .search-result-grid.cols-4 { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 575px) {
        .search-result-grid, .search-result-grid.cols-3, .search-result-grid.cols-4, .search-result-grid.cols-5 {
            grid-template-columns: repeat(2, 1fr);
            gap: 0.6rem;
        }
    }

    /* =========================================
       PHASE 1 – 카테고리 선택 화면 (큰 카드)
    ========================================= */
    .cat-select-hint {
        text-align: center;
        font-size: 1rem;
        color: #adb5bd;
        margin-bottom: 1rem;
        letter-spacing: 0.02em;
    }

    .cat-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(4, 1fr);
    }
    .cat-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
    .cat-grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
    .cat-grid.cols-5 { grid-template-columns: repeat(5, 1fr); }

    .cat-big-card {
        border-radius: 1.25rem;
        border: 2px solid #e8ecf0;
        background: #fff;
        padding: 2rem 1.25rem 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: transform 0.14s, box-shadow 0.14s, border-color 0.14s, background 0.14s, opacity 0.13s;
        box-shadow: 0 4px 16px rgba(15,23,42,0.06);
        user-select: none;
        position: relative;
    }

    .cat-big-card:hover:not(.dragging) {
        transform: translateY(-5px);
        box-shadow: 0 14px 36px rgba(15,23,42,0.12);
    }

    .cat-big-card .cat-icon  { font-size: 2.6rem; margin-bottom: 0.55rem; line-height: 1; }
    .cat-big-card .cat-name  { font-size: 1.2rem; font-weight: 800; color: #374151; margin-bottom: 0.3rem; }
    .cat-big-card .cat-count { font-size: 0.78rem; color: #9ca3af; }

    .cat-big-card.cat-ice  { border-color: #bfdbfe; }
    .cat-big-card.cat-ice:hover:not(.dragging)  { border-color: #3b82f6; background: #eff6ff; }
    .cat-big-card.cat-ice .cat-name  { color: #1d4ed8; }
    .cat-big-card.cat-hot  { border-color: #fecaca; }
    .cat-big-card.cat-hot:hover:not(.dragging)  { border-color: #ef4444; background: #fef2f2; }
    .cat-big-card.cat-hot .cat-name  { color: #b91c1c; }
    .cat-big-card.cat-ade  { border-color: #fde68a; }
    .cat-big-card.cat-ade:hover:not(.dragging)  { border-color: #f59e0b; background: #fffbeb; }
    .cat-big-card.cat-ade .cat-name  { color: #b45309; }
    .cat-big-card.cat-special  { border-color: #ddd6fe; }
    .cat-big-card.cat-special:hover:not(.dragging) { border-color: #7c3aed; background: #f5f3ff; }
    .cat-big-card.cat-special .cat-name  { color: #5b21b6; }

    /* 드래그 핸들 아이콘 (카테고리 카드) */
    .cat-big-card::before {
        content: "⠿";
        position: absolute;
        top: 8px;
        left: 10px;
        font-size: 1rem;
        color: #cbd5e1;
        cursor: grab;
        opacity: 0;
        transition: opacity 0.15s;
        line-height: 1;
    }
    .cat-big-card:hover::before { opacity: 1; }

    /* 드래그 상태 */
    .cat-big-card.dragging {
        opacity: 0.35;
        cursor: grabbing;
        transform: scale(0.97);
        box-shadow: 0 2px 4px rgba(15,23,42,0.08);
    }
    .cat-big-card.drag-over-before {
        border-left: 3px solid #5b4434 !important;
        background: #fff9f2 !important;
        transform: translateX(4px);
    }
    .cat-big-card.drag-over-after {
        border-right: 3px solid #5b4434 !important;
        background: #fff9f2 !important;
        transform: translateX(-4px);
    }

    /* =========================================
       PHASE 2 – 카테고리 상단 pill + 레시피 그리드
    ========================================= */
    .cat-pills-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-bottom: 0.75rem;
        padding: 0.75rem 1rem;
        background: #fff;
        border-radius: 1rem;
        border: 1px solid #f0f2f5;
        box-shadow: 0 2px 8px rgba(15,23,42,0.04);
    }

    .cat-pill-btn {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 1.1rem;
        border-radius: 999px;
        border: 2px solid #e2e8f0;
        background: #f8fafc;
        font-size: 0.84rem;
        font-weight: 600;
        color: #5b4434;
        cursor: pointer;
        transition: all 0.14s ease;
        white-space: nowrap;
        line-height: 1.4;
    }
    .cat-pill-btn:hover { border-color: #c4a882; background: #fff9f2; }
    .cat-pill-btn.cat-back-btn {
        border-color: #c4a882; background: #fff9f2; color: #5b4434; font-weight: 700;
    }
    .cat-pill-btn.cat-back-btn:hover {
        background: #5b4434; border-color: #5b4434; color: #fff9f2;
    }
    .cat-pill-btn.active { background: #5b4434; border-color: #5b4434; color: #fff9f2; box-shadow: 0 2px 8px rgba(91,68,52,0.22); }
    .cat-pill-btn.active.cat-ice     { background: #1d4ed8; border-color: #1d4ed8; color: #fff; }
    .cat-pill-btn.active.cat-hot     { background: #b91c1c; border-color: #b91c1c; color: #fff; }
    .cat-pill-btn.active.cat-ade     { background: #b45309; border-color: #b45309; color: #fff; }
    .cat-pill-btn.active.cat-special { background: #5b21b6; border-color: #5b21b6; color: #fff; }

    /* ===== 레시피 카드 그리드 ===== */
    .recipe-grid {
        display: grid;
        gap: 0.85rem;
        grid-template-columns: repeat(4, 1fr);
    }
    .recipe-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
    .recipe-grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
    .recipe-grid.cols-5 { grid-template-columns: repeat(5, 1fr); }

    /* ===== 레시피 카드 ===== */
    .recipe-card {
        background: #fff;
        border-radius: 1rem;
        border: 2px solid #e8ecf0;
        padding: 1rem 0.75rem 0.85rem;
        text-align: center;
        cursor: pointer;
        transition: transform 0.13s, box-shadow 0.13s, border-color 0.13s, background 0.13s, opacity 0.13s;
        box-shadow: 0 2px 8px rgba(15,23,42,0.05);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.45rem;
        user-select: none;
        position: relative;
    }
    .recipe-card:hover:not(.dragging) {
        transform: translateY(-4px);
        box-shadow: 0 10px 28px rgba(15,23,42,0.11);
    }
    .recipe-card[data-temp="HOT"] { border-color: #fecaca; }
    .recipe-card[data-temp="HOT"]:hover:not(.dragging) { border-color: #ef4444; background: #fef7f7; }
    .recipe-card[data-temp="ICE"] { border-color: #bfdbfe; }
    .recipe-card[data-temp="ICE"]:hover:not(.dragging) { border-color: #3b82f6; background: #f0f7ff; }

    .recipe-card::before {
        content: "⠿";
        position: absolute;
        top: 6px; left: 8px;
        font-size: 0.9rem;
        color: #cbd5e1;
        cursor: grab;
        opacity: 0;
        transition: opacity 0.15s;
        line-height: 1;
    }
    .recipe-card:hover::before { opacity: 1; }

    .recipe-card.dragging {
        opacity: 0.35; cursor: grabbing;
        transform: scale(0.97);
        box-shadow: 0 2px 4px rgba(15,23,42,0.08);
    }
    .recipe-card.drag-over-before {
        border-left: 3px solid #5b4434 !important;
        background: #fff9f2 !important;
        transform: translateX(4px);
    }
    .recipe-card.drag-over-after {
        border-right: 3px solid #5b4434 !important;
        background: #fff9f2 !important;
        transform: translateX(-4px);
    }
    .recipe-grid.drag-active .recipe-card:not(.dragging) { cursor: copy; }

    .recipe-card-thumb {
        width: 60px; height: 60px;
        border-radius: 0.7rem; object-fit: contain;
        border: 1px solid #e8ecf0; background: #fff;
    }
    .recipe-card-thumb-placeholder {
        width: 60px; height: 60px;
        border-radius: 0.7rem; background: #f1f5f9;
        border: 1px dashed #cbd5e1;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem;
    }
    .recipe-card-name {
        font-size: 0.88rem; font-weight: 700; color: #374151;
        line-height: 1.3; word-break: keep-all;
    }
    .recipe-card-badges { display: flex; gap: 0.28rem; flex-wrap: wrap; justify-content: center; }
    .badge-temp {
        font-size: 0.67rem; font-weight: 700;
        padding: 0.12rem 0.48rem; border-radius: 999px; border: 1.5px solid;
    }
    .badge-temp.temp-hot { color: #b91c1c; border-color: #fca5a5; background: #fef2f2; }
    .badge-temp.temp-ice { color: #1d4ed8; border-color: #93c5fd; background: #eff6ff; }
    .badge-cup {
        font-size: 0.67rem; font-weight: 700;
        padding: 0.12rem 0.48rem; border-radius: 999px;
        border: 1.5px solid #6ee7b7; color: #065f46; background: #f0fdf4;
    }
    .badge-blender {
        font-size: 0.67rem; font-weight: 700;
        padding: 0.12rem 0.48rem; border-radius: 999px;
        border: 1.5px solid #fca5a5; color: #b91c1c; background: #fef2f2;
    }

    /* =========================================
       MODAL
    ========================================= */
    #recipeDetailModal .modal-dialog { max-width: 1200px; width: 95%; }
    #recipeDetailModal .modal-content {
        border-radius: 1rem;
        box-shadow: 0 1.5rem 4rem rgba(0,0,0,0.28);
        max-height: 92vh; border: none; overflow: hidden;
    }
    #recipeDetailModal .modal-header {
        background: linear-gradient(135deg, #5b4434 0%, #3f2c20 100%);
        border-bottom: none; padding: 1.25rem 1.5rem;
        border-radius: 1rem 1rem 0 0;
    }
    #recipeDetailModal .modal-header .btn-close { filter: invert(1) brightness(2); opacity: 0.75; }
    #recipeDetailModal .modal-header .btn-close:hover { opacity: 1; }

    .modal-title-wrap { display: flex; align-items: center; gap: 0.55rem; flex-wrap: wrap; }
    .modal-title-name { font-size: 1.6rem; font-weight: 900; letter-spacing: -0.3px; color: #fff9f2; margin-right: 0.1rem; }
    .meta-chip {
        display: inline-flex; align-items: center; gap: 0.3rem;
        padding: 0.22rem 0.7rem; border-radius: 999px;
        border: 1.5px solid rgba(255,255,255,0.35); background: rgba(255,255,255,0.12);
        font-size: 0.82rem; font-weight: 700; line-height: 1; white-space: nowrap; color: #fff9f2;
    }
    .meta-chip.temp-hot    { border-color: #fca5a5; color: #fca5a5; background: rgba(239,68,68,0.15); }
    .meta-chip.temp-ice    { border-color: #93c5fd; color: #93c5fd; background: rgba(59,130,246,0.15); }
    .meta-chip.cup-chip    { border-color: #6ee7b7; color: #6ee7b7; background: rgba(16,185,129,0.12); }
    .meta-chip.blender-yes { border-color: #fca5a5; color: #fca5a5; background: rgba(239,68,68,0.13); }
    .meta-chip.blender-no  { border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.55); }
    .blender-img-modal { height: 2.2rem; width: auto; object-fit: contain; display: inline-block; vertical-align: middle; border-radius: 0.3rem; }

    #recipeDetailModal .modal-body {
        font-size: 1rem; max-height: 75vh; overflow-y: auto;
        padding: 1.5rem; background: #fdfcfb;
    }
    .modal-recipe-img {
        width: 100%; max-height: 280px; height: auto;
        object-fit: contain; border-radius: 0.85rem;
        border: 1px solid #ede8e3; background: #fff;
        margin-bottom: 1.25rem; display: block;
    }
    #recipeDetailMeta { display: none; }

    .recipe-step {
        display: flex; align-items: flex-start; gap: 0.8rem;
        background: #fff; border-radius: 0.875rem;
        padding: 0.95rem 1.2rem; margin-bottom: 0.6rem;
        border: 1.5px solid #ede8e3; box-shadow: 0 1px 5px rgba(0,0,0,0.05);
        font-size: 1rem; line-height: 1.5;
        cursor: pointer; transition: all 0.14s ease;
    }
    .recipe-step:hover { border-color: #c4a882; box-shadow: 0 3px 12px rgba(91,68,52,0.12); transform: translateX(3px); }
    .step-index {
        flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
        background: #5b4434; color: #fff9f2; border-radius: 999px;
        padding: 0.18rem 0.6rem; font-size: 0.78rem; font-weight: 900;
        white-space: nowrap; line-height: 1.5; margin-top: 0.05rem;
    }
    .step-text { flex: 1; display: block; font-weight: 500; color: #374151; }
    .recipe-step.step-selected {
        background: #5b4434; border-color: #5b4434;
        box-shadow: 0 4px 16px rgba(91,68,52,0.28); transform: translateX(3px);
    }
    .recipe-step.step-selected .step-index { background: rgba(255,255,255,0.22); color: #fff9f2; }
    .recipe-step.step-selected .step-text { color: #fff9f2; }
    .recipe-step.empty-step { border-color: #e2e8f0; }
    .recipe-step.empty-step .step-index { background: #94a3b8; }
    #recipe-steps-content .recipe-step:nth-child(2) { margin-left: 12px; }
    #recipe-steps-content .recipe-step:nth-child(3) { margin-left: 24px; }
    #recipe-steps-content .recipe-step:nth-child(4) { margin-left: 36px; }
    #recipe-steps-content .recipe-step:nth-child(5) { margin-left: 48px; }
    #recipe-steps-content .recipe-step:nth-child(6) { margin-left: 60px; }
    #recipe-steps-content .recipe-step:nth-child(7) { margin-left: 72px; }

    #recipeDetailModal .modal-footer { background: #fdfcfb; border-top: 1px solid #ede8e3; padding: 0.9rem 1.5rem; }

    /* =========================================
       모바일 반응형
    ========================================= */
    @media (max-width: 900px) {
        .cat-grid.cols-5 { grid-template-columns: repeat(4, 1fr); }
        .recipe-grid.cols-5 { grid-template-columns: repeat(3, 1fr); }
        .recipe-grid.cols-4 { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 680px) {
        .cat-grid, .cat-grid.cols-3, .cat-grid.cols-4, .cat-grid.cols-5 { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 575px) {
        #recipe-steps-content .recipe-step:nth-child(n) { margin-left: 0 !important; }
        #recipeDetailModal .modal-body { padding: 0.9rem; }
        .recipe-grid, .recipe-grid.cols-3, .recipe-grid.cols-4, .recipe-grid.cols-5 { grid-template-columns: repeat(2, 1fr); gap: 0.6rem; }
        .recipe-card { padding: 0.75rem 0.5rem 0.65rem; gap: 0.35rem; }
        .recipe-card-thumb { width: 48px; height: 48px; }
        .recipe-card-thumb-placeholder { width: 48px; height: 48px; font-size: 1.3rem; }
        .recipe-card-name { font-size: 0.8rem; }
        .cat-pills-bar { padding: 0.5rem 0.6rem; gap: 0.35rem; }
        .cat-pill-btn { font-size: 0.78rem; padding: 0.28rem 0.8rem; }
        .modal-title-name { font-size: 1.25rem; }
        .meta-chip { font-size: 0.75rem; padding: 0.18rem 0.55rem; }
    }
    @media (max-width: 360px) {
        .cat-grid { gap: 0.45rem; }
        .cat-big-card { padding: 1.4rem 0.9rem 1.1rem; }
        .cat-big-card .cat-icon { font-size: 2.1rem; }
        .cat-big-card .cat-name { font-size: 1rem; }
    }
</style>

<!-- ========== 숨김 데이터 저장소 ========== -->
<div id="recipe-data-store" style="display:none">
{{#recipeGroups}}
    <div class="rg-group" data-cat="{{categoryLabel}}" data-cat-key="{{categoryKey}}">
        {{#recipes}}
        <div class="rg-recipe"
             data-id="{{id}}"
             data-name="{{menuName}}"
             data-temp="{{temperature}}"
             data-cup="{{cupSize}}"
             data-use-blender="{{useBlender}}"
             data-imgname="{{imgname}}">
            <div id="recipe-steps-{{id}}">
                {{#steps}}
                <div class="recipe-step" data-step="{{stepOrder}}">
                    <span class="step-index">Step {{stepOrder}}</span>
                    <span class="step-text">{{content}}</span>
                </div>
                {{/steps}}
                {{^steps}}
                <div class="recipe-step empty-step">
                    <span class="step-index">Step 1</span>
                    <span class="step-text">등록된 스텝이 없습니다.</span>
                </div>
                {{/steps}}
            </div>
        </div>
        {{/recipes}}
    </div>
{{/recipeGroups}}
</div>

<!-- ========== 메인 화면 ========== -->
<div class="recipe-page">

    <div class="page-title">☕ 레시피</div>
    <div class="page-sub">카테고리를 선택하면 레시피 목록이 표시됩니다</div>

    <!-- Phase 1: 카테고리 큰 카드 선택 -->
    <div id="phase-categories">

        <!-- 검색 박스 -->
        <div class="search-wrap">
            <input type="text" class="search-input" id="recipe-search-input"
                   placeholder="레시피 이름을 검색하세요" autocomplete="off">
            <button class="search-clear" id="search-clear-btn" type="button">&times;</button>
        </div>

        <!-- 검색 결과 -->
        <div class="search-result-area" id="search-result-area">
            <div class="search-result-title" id="search-result-title"></div>
            <div class="search-result-grid cols-4" id="search-result-grid"></div>
        </div>

        <div class="cat-select-hint">카테고리를 선택하세요</div>

        <!-- 카테고리 컨트롤 바 -->
        <div class="ctrl-bar">
            <div class="cols-btn-group" id="cat-cols-btn-group">
                <button class="cols-btn" data-cols="3">3열</button>
                <button class="cols-btn active" data-cols="4">4열</button>
                <button class="cols-btn" data-cols="5">5열</button>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted" style="font-size:0.75rem;">드래그하여 순서 변경 (자동 저장)</span>
                <span id="cat-save-status" style="font-size:0.75rem;color:#5b4434;font-weight:600;"></span>
            </div>
        </div>

        <div class="cat-grid cols-4" id="cat-grid"></div>
    </div>

    <!-- Phase 2: 카테고리 pill 바 + 레시피 그리드 -->
    <div id="phase-browse" style="display:none">
        <div class="cat-pills-bar" id="cat-pills-bar"></div>

        <!-- 레시피 컨트롤 바 -->
        <div class="ctrl-bar">
            <div class="cols-btn-group" id="recipe-cols-btn-group">
                <button class="cols-btn" data-cols="3">3열</button>
                <button class="cols-btn active" data-cols="4">4열</button>
                <button class="cols-btn" data-cols="5">5열</button>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted" style="font-size:0.75rem;">드래그하여 순서 변경 (자동 저장)</span>
                <span id="recipe-save-status" style="font-size:0.75rem;color:#5b4434;font-weight:600;"></span>
            </div>
        </div>

        <div class="recipe-grid cols-4" id="recipe-grid"></div>
    </div>

</div>

<!-- ========== 팝업 모달 ========== -->
<div class="modal fade" id="recipeDetailModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-fullscreen-sm-down">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title fw-bold" id="recipeDetailModalLabel">레시피 상세</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="닫기"></button>
            </div>
            <div class="modal-body">
                <div id="recipeDetailImgWrap"></div>
                <div id="recipeDetailMeta"></div>
                <div id="recipe-steps-content"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">닫기</button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {

    /* ===== 유틸 ===== */
    function parseTruth(v) {
        var s = String(v || '').trim().toLowerCase();
        return s === 'true' || s === '1' || s === 'y' || s === 'yes' || s === 'on';
    }
    function escHtml(s) {
        return String(s || '')
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function displayCup(raw) {
        var r = String(raw || '').trim().toUpperCase();
        if (r === 'L17' || r === '17L' || r === '57' || r === '17') return '1.7L';
        if (r === 'L20' || r === '20L' || r === '67' || r === '20') return '2.0L';
        var m = r.match(/(\d{2})/);
        return m ? m[1] + 'oz' : r;
    }
    function modalCup(raw) {
        var r = String(raw || '').trim().toUpperCase();
        if (r === 'L17' || r === '17' || r === '17L' || r === '57') return '1.7L';
        if (r === 'L20' || r === '20' || r === '20L' || r === '67') return '2.0L';
        var m = r.match(/(\d{2})/);
        return m ? m[1] + 'oz' : r;
    }
    function catClass(cat) {
        var t = (cat || '').toLowerCase();
        if (t.includes('ice') || t.includes('아이스') || t.includes('흑당') ||
            t.includes('주스') || t.includes('스무디') || t.includes('퐁'))  return 'cat-ice';
        if (t.includes('hot') || t.includes('핫'))                           return 'cat-hot';
        if (t.includes('에이드') || t.includes('ade'))                       return 'cat-ade';
        return 'cat-special';
    }
    function catIcon(cat) {
        var t = (cat || '').toLowerCase();
        if (t.includes('ice') || t.includes('아이스')) return '🧊';
        if (t.includes('hot') || t.includes('핫'))     return '☕';
        if (t.includes('에이드'))                       return '🍹';
        if (t.includes('흑당'))                         return '🧋';
        if (t.includes('스무디') || t.includes('퐁'))   return '🥤';
        if (t.includes('주스'))                         return '🧃';
        if (t.includes('base'))                         return '🫙';
        if (t.includes('푸드'))                         return '🍱';
        if (t.includes('티'))                           return '🍵';
        if (t.includes('프라페'))                       return '🧋';
        return '🍵';
    }

    /* ===== 간단 토스트 ===== */
    function showToast(msg, isError) {
        var t = document.getElementById('recipe-toast');
        if (!t) {
            t = document.createElement('div');
            t.id = 'recipe-toast';
            Object.assign(t.style, {
                position: 'fixed', bottom: '1.5rem', left: '50%',
                transform: 'translateX(-50%)',
                padding: '0.6rem 1.4rem', borderRadius: '999px',
                fontSize: '0.88rem', fontWeight: '600',
                boxShadow: '0 4px 16px rgba(0,0,0,0.25)',
                zIndex: '9999', transition: 'opacity 0.3s',
                pointerEvents: 'none'
            });
            document.body.appendChild(t);
        }
        t.style.background = isError ? '#dc2626' : '#1e293b';
        t.style.color = '#f8fafc';
        t.textContent = msg;
        t.style.opacity = '1';
        clearTimeout(t._tid);
        t._tid = setTimeout(function () { t.style.opacity = '0'; }, 2500);
    }

    /* ===== 데이터 파싱 ===== */
    var store  = document.getElementById('recipe-data-store');
    var groups = Array.from(store.querySelectorAll('.rg-group')).map(function (g) {
        var recipes = Array.from(g.querySelectorAll('.rg-recipe')).map(function (r) {
            return {
                id:         r.dataset.id,
                name:       r.dataset.name,
                temp:       r.dataset.temp,
                cup:        r.dataset.cup,
                useBlender: parseTruth(r.dataset.useBlender),
                imgname:    r.dataset.imgname,
                stepsEl:    r.querySelector('[id^="recipe-steps-"]')
            };
        });
        return { cat: g.dataset.cat, catKey: g.dataset.catKey, recipes: recipes };
    });

    /* ===== State ===== */
    var activeCat        = null;
    var catOrderChanged  = false;
    var recipeOrderChanged = false;

    /* ===== localStorage ===== */
    function loadCatCols() {
        var v = parseInt(localStorage.getItem('cat_cols') || '4', 10);
        return (v === 3 || v === 4 || v === 5) ? v : 4;
    }
    function saveCatCols(n) { localStorage.setItem('cat_cols', String(n)); }
    function loadRecipeCols() {
        var v = parseInt(localStorage.getItem('recipe_cols') || '4', 10);
        return (v === 3 || v === 4 || v === 5) ? v : 4;
    }
    function saveRecipeCols(n) { localStorage.setItem('recipe_cols', String(n)); }

    /* ===== 요소 참조 ===== */
    var catGridEl          = document.getElementById('cat-grid');
    var catColsBtnGroup    = document.getElementById('cat-cols-btn-group');
    var catSaveStatus      = document.getElementById('cat-save-status');
    var recipeGridEl       = document.getElementById('recipe-grid');
    var recipeColsBtnGroup = document.getElementById('recipe-cols-btn-group');
    var recipeSaveStatus   = document.getElementById('recipe-save-status');

    /* ===== 카테고리 열 수 버튼 ===== */
    function applyCatColsUI(n) {
        catColsBtnGroup.querySelectorAll('.cols-btn').forEach(function (b) {
            b.classList.toggle('active', parseInt(b.dataset.cols, 10) === n);
        });
        catGridEl.className = 'cat-grid cols-' + n;
        saveCatCols(n);
    }
    catColsBtnGroup.querySelectorAll('.cols-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            applyCatColsUI(parseInt(btn.dataset.cols, 10));
        });
    });
    applyCatColsUI(loadCatCols());

    /* ===== 레시피 열 수 버튼 ===== */
    function applyRecipeColsUI(n) {
        recipeColsBtnGroup.querySelectorAll('.cols-btn').forEach(function (b) {
            b.classList.toggle('active', parseInt(b.dataset.cols, 10) === n);
        });
        recipeGridEl.className = 'recipe-grid cols-' + n;
        saveRecipeCols(n);
    }
    recipeColsBtnGroup.querySelectorAll('.cols-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            applyRecipeColsUI(parseInt(btn.dataset.cols, 10));
        });
    });
    applyRecipeColsUI(loadRecipeCols());

    /* ============================================================
       Phase 1: 카테고리 큰 카드 렌더링 + 드래그앤드롭
    ============================================================ */
    var catDragSrc = null;

    function renderCategoryCards() {
        catGridEl.innerHTML = '';
        groups.forEach(function (g) {
            var cc   = catClass(g.cat);
            var card = document.createElement('div');
            card.className         = 'cat-big-card ' + cc;
            card.dataset.catKey    = g.catKey;
            card.setAttribute('draggable', 'true');
            card.innerHTML =
                '<div class="cat-icon">'  + catIcon(g.cat)          + '</div>' +
                '<div class="cat-name">'  + escHtml(g.cat)          + '</div>' +
                '<div class="cat-count">' + g.recipes.length + '가지 레시피</div>';

            card.addEventListener('click', function () {
                if (card._wasDragged) { card._wasDragged = false; return; }
                selectCategory(g.cat);
            });
            card.addEventListener('dragstart',  onCatDragStart);
            card.addEventListener('dragend',    onCatDragEnd);
            card.addEventListener('dragover',   onCatDragOver);
            card.addEventListener('dragleave',  onCatDragLeave);
            card.addEventListener('drop',       onCatDrop);

            catGridEl.appendChild(card);
        });
    }

    function onCatDragStart(e) {
        catDragSrc = this;
        this.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', this.dataset.catKey);
    }
    function onCatDragEnd(e) {
        catDragSrc = null;
        catGridEl.querySelectorAll('.cat-big-card').forEach(function (c) {
            c.classList.remove('dragging', 'drag-over-before', 'drag-over-after');
        });
    }
    function onCatDragOver(e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        if (!catDragSrc || this === catDragSrc) return;
        var rect = this.getBoundingClientRect();
        catGridEl.querySelectorAll('.cat-big-card').forEach(function (c) {
            c.classList.remove('drag-over-before', 'drag-over-after');
        });
        if (e.clientX < rect.left + rect.width / 2) {
            this.classList.add('drag-over-before');
        } else {
            this.classList.add('drag-over-after');
        }
    }
    function onCatDragLeave(e) {
        this.classList.remove('drag-over-before', 'drag-over-after');
    }
    function onCatDrop(e) {
        e.preventDefault();
        e.stopPropagation();
        if (!catDragSrc || catDragSrc === this) return;

        var rect   = this.getBoundingClientRect();
        var before = e.clientX < rect.left + rect.width / 2;
        this.classList.remove('drag-over-before', 'drag-over-after');

        if (before) {
            catGridEl.insertBefore(catDragSrc, this);
        } else {
            catGridEl.insertBefore(catDragSrc, this.nextSibling);
        }

        catDragSrc._wasDragged = true;
        catOrderChanged = true;

        // groups 배열도 DOM 순서에 맞게 동기화
        var newOrder = Array.from(catGridEl.querySelectorAll('.cat-big-card'))
            .map(function (card) {
                return groups.find(function (g) { return g.catKey === card.dataset.catKey; });
            }).filter(Boolean);
        groups.length = 0;
        newOrder.forEach(function (g) { groups.push(g); });

        saveCategoryOrder();
    }

    /* ===== 카테고리 배치 자동 저장 ===== */
    async function saveCategoryOrder() {
        var cards = Array.from(catGridEl.querySelectorAll('.cat-big-card'));
        var orders = cards.map(function (card, i) {
            return { categoryName: card.dataset.catKey, sortOrder: i };
        });
        if (catSaveStatus) catSaveStatus.textContent = '저장 중...';
        await doSave('/cafe/categories/reorder', { orders: orders }, function (ok) {
            catOrderChanged = false;
            if (catSaveStatus) catSaveStatus.textContent = '';
            if (ok) {
                showToast('✅ 카테고리 순서가 저장되었습니다.');
            } else {
                showToast('❌ 카테고리 배치 저장 실패', true);
            }
        });
    }

    /* ============================================================
       Phase 2 전환
    ============================================================ */
    function selectCategory(cat) {
        activeCat = cat;
        recipeOrderChanged = false;
        document.getElementById('phase-categories').style.display = 'none';
        document.getElementById('phase-browse').style.display     = '';
        renderCatPills();
        renderRecipes();
    }

    function backToCategories() {
        document.getElementById('phase-browse').style.display     = 'none';
        document.getElementById('phase-categories').style.display = '';
        activeCat = null;
        recipeOrderChanged = false;
    }

    /* ===== 상단 pill 바 렌더링 ===== */
    function renderCatPills() {
        var bar = document.getElementById('cat-pills-bar');
        bar.innerHTML = '';

        var backBtn = document.createElement('button');
        backBtn.className   = 'cat-pill-btn cat-back-btn';
        backBtn.textContent = '← 전체';
        backBtn.addEventListener('click', backToCategories);
        bar.appendChild(backBtn);

        groups.forEach(function (g) {
            var cc  = catClass(g.cat);
            var btn = document.createElement('button');
            btn.className = 'cat-pill-btn ' + cc + (g.cat === activeCat ? ' active' : '');
            btn.textContent = g.cat;
            btn.addEventListener('click', function () {
                activeCat = g.cat;
                recipeOrderChanged = false;
                renderCatPills();
                renderRecipes();
            });
            bar.appendChild(btn);
        });
    }

    /* ===== 레시피 그리드 렌더링 ===== */
    function renderRecipes() {
        recipeGridEl.innerHTML = '';
        var group = groups.find(function (g) { return g.cat === activeCat; });
        if (!group) return;

        group.recipes.forEach(function (r) {
            var card      = document.createElement('div');
            card.className    = 'recipe-card';
            card.dataset.temp = r.temp;
            card.dataset.id   = r.id;

            var tempU = (r.temp || '').toUpperCase();
            var cup   = displayCup(r.cup);

            var thumbHtml;
            if (r.imgname) {
                thumbHtml =
                    '<img class="recipe-card-thumb" src="/img/' + escHtml(r.imgname) + '" ' +
                    'alt="' + escHtml(r.name) + '" loading="lazy" ' +
                    'onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">' +
                    '<div class="recipe-card-thumb-placeholder" style="display:none">☕</div>';
            } else {
                thumbHtml = '<div class="recipe-card-thumb-placeholder">☕</div>';
            }

            var tempBadge    = tempU ? '<span class="badge-temp ' + (tempU === 'HOT' ? 'temp-hot' : 'temp-ice') + '">' + tempU + '</span>' : '';
            var cupBadge     = cup   ? '<span class="badge-cup">' + escHtml(cup) + '</span>' : '';
            var blenderBadge = r.useBlender ? '<span class="badge-blender">블렌더</span>' : '';

            card.innerHTML =
                thumbHtml +
                '<div class="recipe-card-name">' + escHtml(r.name) + '</div>' +
                '<div class="recipe-card-badges">' + tempBadge + cupBadge + blenderBadge + '</div>';

            card.addEventListener('click', function () {
                if (card._wasDragged) { card._wasDragged = false; return; }
                openRecipeModal(r);
            });

            recipeGridEl.appendChild(card);
        });

        initRecipeDragDrop();
    }

    /* ===== 레시피 드래그앤드롭 ===== */
    var recipeDragSrc = null;

    function initRecipeDragDrop() {
        recipeGridEl.querySelectorAll('.recipe-card').forEach(function (card) {
            card.setAttribute('draggable', 'true');
            card.addEventListener('dragstart',  onRecipeDragStart);
            card.addEventListener('dragend',    onRecipeDragEnd);
            card.addEventListener('dragover',   onRecipeDragOver);
            card.addEventListener('dragleave',  onRecipeDragLeave);
            card.addEventListener('drop',       onRecipeDrop);
        });
    }

    function onRecipeDragStart(e) {
        recipeDragSrc = this;
        this.classList.add('dragging');
        recipeGridEl.classList.add('drag-active');
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', this.dataset.id);
    }
    function onRecipeDragEnd(e) {
        recipeDragSrc = null;
        recipeGridEl.querySelectorAll('.recipe-card').forEach(function (c) {
            c.classList.remove('dragging', 'drag-over-before', 'drag-over-after');
        });
        recipeGridEl.classList.remove('drag-active');
    }
    function onRecipeDragOver(e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        if (!recipeDragSrc || this === recipeDragSrc) return;
        var rect = this.getBoundingClientRect();
        recipeGridEl.querySelectorAll('.recipe-card').forEach(function (c) {
            c.classList.remove('drag-over-before', 'drag-over-after');
        });
        if (e.clientX < rect.left + rect.width / 2) {
            this.classList.add('drag-over-before');
        } else {
            this.classList.add('drag-over-after');
        }
    }
    function onRecipeDragLeave(e) {
        this.classList.remove('drag-over-before', 'drag-over-after');
    }
    function onRecipeDrop(e) {
        e.preventDefault();
        e.stopPropagation();
        if (!recipeDragSrc || recipeDragSrc === this) return;
        var rect   = this.getBoundingClientRect();
        var before = e.clientX < rect.left + rect.width / 2;
        this.classList.remove('drag-over-before', 'drag-over-after');
        if (before) {
            recipeGridEl.insertBefore(recipeDragSrc, this);
        } else {
            recipeGridEl.insertBefore(recipeDragSrc, this.nextSibling);
        }
        recipeDragSrc._wasDragged = true;
        recipeOrderChanged = true;
        saveRecipeOrder();
    }

    /* ===== 레시피 배치 자동 저장 ===== */
    async function saveRecipeOrder() {
        var cards = Array.from(recipeGridEl.querySelectorAll('.recipe-card'));
        if (cards.length === 0) return;

        var orders = cards.map(function (card, i) {
            return { id: parseInt(card.dataset.id, 10), sortOrder: i };
        });

        var invalid = orders.some(function (o) { return isNaN(o.id); });
        if (invalid) { showToast('❌ 레시피 ID 오류', true); return; }

        var activeGroup = groups.find(function (g) { return g.cat === activeCat; });
        var catKey = activeGroup ? activeGroup.catKey : null;

        if (recipeSaveStatus) recipeSaveStatus.textContent = '저장 중...';
        await doSave('/cafe/recipes/reorder', { catKey: catKey, orders: orders }, function (ok) {
            recipeOrderChanged = false;
            if (recipeSaveStatus) recipeSaveStatus.textContent = '';
            if (ok) {
                showToast('✅ 레시피 순서가 저장되었습니다.');
            } else {
                showToast('❌ 배치 저장 실패', true);
            }
        });
    }

    /* ===== 공통 저장 함수 ===== */
    async function doSave(url, body, callback) {
        try {
            var res = await fetch(url, {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(body)
            });
            if (res.ok) {
                var data = await res.json().catch(function () { return { success: true }; });
                callback(data.success !== false);
            } else {
                var errText = await res.text().catch(function () { return ''; });
                console.error('[저장 오류]', res.status, errText);
                callback(false);
            }
        } catch (err) {
            console.error('[네트워크 오류]', err);
            callback(false);
        }
    }

    /* ===== 모달 ===== */
    function setModalTitle(name, useBlender, temp, cupRaw) {
        var titleEl = document.getElementById('recipeDetailModalLabel');
        if (!titleEl) return;
        var t        = String(temp || '').toUpperCase();
        var cupLabel = modalCup(cupRaw);
        titleEl.innerHTML = '';
        var wrap = document.createElement('span');
        wrap.className = 'modal-title-wrap';

        var nameSpan = document.createElement('span');
        nameSpan.className   = 'modal-title-name';
        nameSpan.textContent = name;
        wrap.appendChild(nameSpan);

        var bChip = document.createElement('span');
        bChip.className   = 'meta-chip ' + (useBlender ? 'blender-yes' : 'blender-no');
        bChip.textContent = useBlender ? '블렌더 사용' : '블렌더 미사용';
        wrap.appendChild(bChip);

        if (useBlender) {
            var bImg = document.createElement('img');
            bImg.className = 'blender-img-modal';
            bImg.alt = '블렌더 사용';
            bImg.src = '/img/blender.jpg';
            wrap.appendChild(bImg);
        }

        var tChip = document.createElement('span');
        tChip.className   = 'meta-chip ' + (t === 'HOT' ? 'temp-hot' : t === 'ICE' ? 'temp-ice' : '');
        tChip.textContent = t || 'TEMP';
        wrap.appendChild(tChip);

        var cChip = document.createElement('span');
        cChip.className   = 'meta-chip cup-chip';
        cChip.textContent = cupLabel || '컵';
        wrap.appendChild(cChip);

        titleEl.appendChild(wrap);
    }

    function setModalImage(imgname, altText) {
        var wrap = document.getElementById('recipeDetailImgWrap');
        if (!wrap) return;
        wrap.innerHTML = '';
        var name = String(imgname || '').trim();
        if (!name) return;
        var img       = document.createElement('img');
        img.className = 'modal-recipe-img';
        img.src       = '/img/' + name;
        img.alt       = altText || '레시피 이미지';
        img.loading   = 'lazy';
        img.onerror   = function () { wrap.innerHTML = ''; };
        wrap.appendChild(img);
    }

    function attachStepClickHandlers() {
        var container = document.getElementById('recipe-steps-content');
        if (!container) return;
        var steps = container.querySelectorAll('.recipe-step');
        steps.forEach(function (step) {
            step.addEventListener('click', function () {
                steps.forEach(function (s) { s.classList.remove('step-selected'); });
                step.classList.add('step-selected');
            });
        });
    }

    function openRecipeModal(r) {
        setModalTitle(r.name, r.useBlender, r.temp, r.cup);
        setModalImage(r.imgname, r.name);
        document.getElementById('recipe-steps-content').innerHTML =
            r.stepsEl ? r.stepsEl.innerHTML : '<p>스텝 없음</p>';
        var modal = new bootstrap.Modal(document.getElementById('recipeDetailModal'));
        modal.show();
        attachStepClickHandlers();
        setTimeout(function () {
            var first = document.querySelector('#recipe-steps-content .recipe-step');
            if (first) {
                document.querySelectorAll('#recipe-steps-content .recipe-step')
                    .forEach(function (s) { s.classList.remove('step-selected'); });
                first.classList.add('step-selected');
            }
        }, 50);
    }

    /* ============================================================
       검색 기능
    ============================================================ */
    var searchInput    = document.getElementById('recipe-search-input');
    var searchClearBtn = document.getElementById('search-clear-btn');
    var searchArea     = document.getElementById('search-result-area');
    var searchGrid     = document.getElementById('search-result-grid');
    var searchTitle    = document.getElementById('search-result-title');

    function searchRecipes(keyword) {
        var kw = (keyword || '').trim().toLowerCase();
        if (!kw) {
            searchArea.style.display = 'none';
            searchClearBtn.style.display = 'none';
            return;
        }
        searchClearBtn.style.display = 'block';

        var results = [];
        groups.forEach(function (g) {
            g.recipes.forEach(function (r) {
                if (r.name.toLowerCase().indexOf(kw) !== -1) {
                    results.push(r);
                }
            });
        });

        renderSearchResults(results, kw);
    }

    function renderSearchResults(results, keyword) {
        searchArea.style.display = 'block';
        searchGrid.innerHTML = '';

        // 열 수 동기화
        var cols = loadCatCols();
        searchGrid.className = 'search-result-grid cols-' + cols;

        if (results.length === 0) {
            searchTitle.textContent = '';
            searchGrid.innerHTML = '<div class="search-no-result">검색 결과가 없습니다</div>';
            return;
        }

        searchTitle.textContent = '"' + keyword + '" 검색 결과 (' + results.length + '건)';

        results.forEach(function (r) {
            var card      = document.createElement('div');
            card.className    = 'recipe-card';
            card.dataset.temp = r.temp;
            card.dataset.id   = r.id;

            var tempU = (r.temp || '').toUpperCase();
            var cup   = displayCup(r.cup);

            var thumbHtml;
            if (r.imgname) {
                thumbHtml =
                    '<img class="recipe-card-thumb" src="/img/' + escHtml(r.imgname) + '" ' +
                    'alt="' + escHtml(r.name) + '" loading="lazy" ' +
                    'onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">' +
                    '<div class="recipe-card-thumb-placeholder" style="display:none">☕</div>';
            } else {
                thumbHtml = '<div class="recipe-card-thumb-placeholder">☕</div>';
            }

            var tempBadge    = tempU ? '<span class="badge-temp ' + (tempU === 'HOT' ? 'temp-hot' : 'temp-ice') + '">' + tempU + '</span>' : '';
            var cupBadge     = cup   ? '<span class="badge-cup">' + escHtml(cup) + '</span>' : '';
            var blenderBadge = r.useBlender ? '<span class="badge-blender">블렌더</span>' : '';

            card.innerHTML =
                thumbHtml +
                '<div class="recipe-card-name">' + escHtml(r.name) + '</div>' +
                '<div class="recipe-card-badges">' + tempBadge + cupBadge + blenderBadge + '</div>';

            card.addEventListener('click', function () {
                openRecipeModal(r);
            });

            searchGrid.appendChild(card);
        });
    }

    searchInput.addEventListener('input', function () {
        searchRecipes(this.value);
    });

    searchClearBtn.addEventListener('click', function () {
        searchInput.value = '';
        searchArea.style.display = 'none';
        searchClearBtn.style.display = 'none';
        searchInput.focus();
    });

    /* ===== 카테고리 열 수 변경 시 검색 결과 그리드도 동기화 ===== */
    var origApplyCatColsUI = applyCatColsUI;
    applyCatColsUI = function (n) {
        origApplyCatColsUI(n);
        searchGrid.className = 'search-result-grid cols-' + n;
    };

    /* ===== 초기 실행 ===== */
    renderCategoryCards();

})();
</script>

{{>layouts/footer}}
