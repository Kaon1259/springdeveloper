        let weekGanttPendingChanges = {}; // { `${memberId}_${iso}`: { memberId, iso, segments } }

        // 🔵 하단 개별 그리드용 주간 데이터
        let baseWeekDaysMap = {};      // 템플릿(왼쪽)
        let selectedWeekDaysMap = {};  // 일정(오른쪽)

        let slotMinutes = 60;
        let memberGridStep = 60;
        let selectedBarInfo = null;   // { iso, start, end } 선택된 바 정보

        // 요일 상세 패널 상태
        let dayDetailIso = null;
        let dayDetailBarInfo = null;
        let _dayDetailDragState = null;
        let _dayDetailDragInited = false;
        let _dayDetailJustDragged = false;
        const GRID_DAY_LABELS = ['월','화','수','목','금','토','일'];

        // 모달/일편집 상태
        const START_MIN = HOUR_START * 60;
        const END_MIN   = HOUR_END   * 60;
        let stepMinutes  = 30;
        let totalRows    = (END_MIN - START_MIN) / stepMinutes;
        let originalSegments = [];
        let originalSlotSet  = new Set();
        let slotState        = new Set();

        try { allMembers = JSON.parse(document.getElementById('membersData').textContent || '[]'); } catch(e){ allMembers = []; }

        (function safeInitStatus(){
            if (!statusSelect) return;
            const initial = statusSelect.value || 'WORKING';
            const hasInInitial = (allMembers||[]).some(m => m.status === initial);
            if (!hasInInitial) {
                const counts = (allMembers||[]).reduce((acc,m)=>{ acc[m.status]=(acc[m.status]||0)+1; return acc; },{});
                const best = Object.entries(counts).sort((a,b)=>b[1]-a[1])[0]?.[0];
                if (best && Array.from(statusSelect.options).some(o=>o.value===best)) {
                    statusSelect.value = best;
                }
            }
        })();

        attachHandlers();

        (async () => {
            await handleStatusChange();
            updateCurrentTimeHighlight();
            setInterval(updateCurrentTimeHighlight, 5000);
        })();

        function attachHandlers(){
            statusSelect.addEventListener('change', async ()=> { await handleStatusChange(); });

            dataTypeSelect.addEventListener('change', async function() {
                currentDataType = this.value;
                weekGanttPendingChanges = {};
                closeWgDayPopup();
                updateWeekGanttSaveBar();
                await fetchAndRenderWeekTable(currentStatusMembers, currentWeekStart);
            });

            if (btnSlot10) btnSlot10.addEventListener('click', ()=> { setSlotMinutes(10); });
            if (btnSlot30) btnSlot30.addEventListener('click', ()=> { setSlotMinutes(30); });
            if (btnSlot60) btnSlot60.addEventListener('click', ()=> { setSlotMinutes(60); });

            if (btnOpenGraphPage) {
                btnOpenGraphPage.addEventListener('click', () => {
                    openGraphPage();
                });
            }

            if (btnPrevWeek) btnPrevWeek.addEventListener('click', async (e)=>{ e.preventDefault(); currentWeekStart = addDays(currentWeekStart, -7); await handleStatusChange(); });
            if (btnThisWeek) btnThisWeek.addEventListener('click', async (e)=>{ e.preventDefault(); currentWeekStart = toMonday(new Date()); await handleStatusChange(); });
            if (btnNextWeek) btnNextWeek.addEventListener('click', async (e)=>{ e.preventDefault(); currentWeekStart = addDays(currentWeekStart, +7); await handleStatusChange(); });

            if (btnOpenPrintPage) {
                btnOpenPrintPage.addEventListener('click', () => {
                    openPrintPage();
                });
            }

            if (btnOpenPrintMemberPage) {
                btnOpenPrintMemberPage.addEventListener('click', () => {
                    openPrintMemberPage();
                });
            }

            if (btnToggleWeeklyCard && weeklyCardBody) {
                btnToggleWeeklyCard.addEventListener('click', () => {
                    const collapsed = weeklyCardBody.classList.toggle('d-none');
                    btnToggleWeeklyCard.textContent = collapsed ? '타임테이블 펼치기' : '타임테이블 접기';
                });
            }

            if (weekStaffTable) {
                weekStaffTable.addEventListener('click', async (e) => {
                    const td = e.target.closest('td.staff-cell');
                    if (!td || !selectedMember) return;

                    const dayIdx = parseInt(td.dataset.dayIdx || '-1', 10);
                    if (dayIdx < 0 || dayIdx > 6) return;

                    const iso = toIso(addDays(currentWeekStart, dayIdx));
                    const hasSel = td.dataset.hasSelected === '1';

                    if (hasSel) {
                        showDayEditButton(dayIdx, iso);
                    } else {
                        showDayCreateButton(dayIdx, iso);
                    }
                });
            }

            if (memberSlotButtonsWrapper) {
                memberSlotButtonsWrapper.querySelectorAll('button[data-member-slot]').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const mins = parseInt(btn.dataset.memberSlot, 10);
                        if (!mins || memberGridStep === mins) return;
                        memberGridStep = mins;
                        memberSlotButtonsWrapper.querySelectorAll('button[data-member-slot]').forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                        if (selectedMember) {
                            buildMemberWeekGantt();
                        }
                    });
                });
            }

            if (btnToggleMemberWeek && memberWeekBody) {
                btnToggleMemberWeek.addEventListener('click', () => {
                    const collapsed = memberWeekBody.classList.toggle('d-none');
                    btnToggleMemberWeek.textContent = collapsed ? '펼치기' : '접기';
                });
            }

            btnSaveEdit.addEventListener('click', onSaveEdit);
            btnCancelEdit.addEventListener('click', onCancelEdit);
            btnCloseModal.addEventListener('click', closeEditModal);
            editModal.addEventListener('click', (e)=>{ if(e.target===editModal) closeEditModal(); });

            if (slotStepButtons) {
                slotStepButtons.querySelectorAll('button[data-step]').forEach(btn=>{
                    btn.addEventListener('click', ()=>{
                        const newStep = parseInt(btn.dataset.step,10);
                        if(!newStep || newStep === stepMinutes){
                            slotStepButtons.querySelectorAll('button[data-step]').forEach(b=>b.classList.remove('active'));
                            btn.classList.add('active');
                            updateModalSaveButton();
                            return;
                        }
                        stepMinutes = newStep;
                        totalRows = (END_MIN - START_MIN) / stepMinutes;
                        slotStepButtons.querySelectorAll('button[data-step]').forEach(b=>b.classList.remove('active'));
                        btn.classList.add('active');

                        summaryStepBadge.textContent = `슬롯: ${stepMinutes===60?'1시간':(stepMinutes+'분')}`;
                        originalSlotSet = segmentsToSlotSet(originalSegments, stepMinutes);
                        slotState = new Set([...originalSlotSet]);

                        buildDayGrid();
                        updateSelectedMinutes();
                        renderLeftSummary();
                        updateModalSaveButton();
                    });
                });
            }
            window.addEventListener('mouseup', ()=>{ modalDragging=false; });

            // 삭제 버튼 핸들러 (개별 주간 일정 바 삭제)
            const btnDeleteBar = document.getElementById('btnDeleteSelectedBar');
            if (btnDeleteBar) {
                btnDeleteBar.addEventListener('click', function() {
                    if (!selectedBarInfo) return;
                    const { type, iso, start, end } = selectedBarInfo;

                    if (type === 'template') {
                        // 일정(WorkSchedule) 바 삭제
                        const segs = (ganttTemplatePendingChanges[iso] || (baseWeekDaysMap[iso]?.segments) || []).map(s => ({...s}));
                        const idx = segs.findIndex(s => s.start === start && s.end === end);
                        if (idx >= 0) {
                            segs.splice(idx, 1);
                            if (segs.length > 0) {
                                ganttTemplatePendingChanges[iso] = segs;
                            } else {
                                const origSegs = (baseWeekDaysMap[iso]?.segments) || [];
                                if (origSegs.length === 0) {
                                    delete ganttTemplatePendingChanges[iso];
                                } else {
                                    ganttTemplatePendingChanges[iso] = segs;
                                }
                            }
                        }
                    } else {
                        // 실제근무(ActualWorkSchedule) 바 삭제
                        const segs = (ganttPendingChanges[iso] || (selectedWeekDaysMap[iso]?.segments) || []).map(s => ({...s}));
                        const idx = segs.findIndex(s => s.start === start && s.end === end);
                        if (idx >= 0) {
                            segs.splice(idx, 1);
                            if (segs.length > 0) {
                                ganttPendingChanges[iso] = segs;
                            } else {
                                const origSegs = (selectedWeekDaysMap[iso]?.segments) || [];
                                if (origSegs.length === 0) {
                                    delete ganttPendingChanges[iso];
                                } else {
                                    ganttPendingChanges[iso] = segs;
                                }
                            }
                        }
                    }

                    selectedBarInfo = null;
                    btnDeleteBar.classList.add('d-none');
                    updateGanttSaveBar();
                    buildMemberWeekGantt();
                });
            }

            // 요일 상세 패널 삭제 버튼 핸들러
            var btnDeleteDayDetailBar = document.getElementById('btnDeleteDayDetailBar');
            if (btnDeleteDayDetailBar) {
                btnDeleteDayDetailBar.addEventListener('click', function() {
                    if (!dayDetailBarInfo || !dayDetailIso) return;
                    var type = dayDetailBarInfo.type;
                    var iso = dayDetailBarInfo.iso;
                    var start = dayDetailBarInfo.start;
                    var end = dayDetailBarInfo.end;

                    if (type === 'template') {
                        var segs = (ganttTemplatePendingChanges[iso] || (baseWeekDaysMap[iso] && baseWeekDaysMap[iso].segments) || []).map(function(s){ return Object.assign({}, s); });
                        var idx = segs.findIndex(function(s){ return s.start === start && s.end === end; });
                        if (idx >= 0) {
                            segs.splice(idx, 1);
                            if (segs.length > 0) {
                                ganttTemplatePendingChanges[iso] = segs;
                            } else {
                                var origSegs = (baseWeekDaysMap[iso] && baseWeekDaysMap[iso].segments) || [];
                                if (origSegs.length === 0) {
                                    delete ganttTemplatePendingChanges[iso];
                                } else {
                                    ganttTemplatePendingChanges[iso] = segs;
                                }
                            }
                        }
                    } else {
                        var segs2 = (ganttPendingChanges[iso] || (selectedWeekDaysMap[iso] && selectedWeekDaysMap[iso].segments) || []).map(function(s){ return Object.assign({}, s); });
                        var idx2 = segs2.findIndex(function(s){ return s.start === start && s.end === end; });
                        if (idx2 >= 0) {
                            segs2.splice(idx2, 1);
                            if (segs2.length > 0) {
                                ganttPendingChanges[iso] = segs2;
                            } else {
                                var origSegs2 = (selectedWeekDaysMap[iso] && selectedWeekDaysMap[iso].segments) || [];
                                if (origSegs2.length === 0) {
                                    delete ganttPendingChanges[iso];
                                } else {
                                    ganttPendingChanges[iso] = segs2;
                                }
                            }
                        }
                    }

                    dayDetailBarInfo = null;
                    btnDeleteDayDetailBar.classList.add('d-none');
                    updateGanttSaveBar();
                    buildDayDetailGantt();
                    buildMemberWeekGantt();
                    updateDdPopupButtons();
                });
            }

            // 요일 상세 팝업 닫기 버튼
            var btnCloseDayDetail = document.getElementById('btnCloseDayDetail');
            if (btnCloseDayDetail) {
                btnCloseDayDetail.addEventListener('click', closeDayDetailPanel);
            }

            // 요일 상세 팝업 overlay 클릭 (배경) → 닫기
            var ddOverlay = document.getElementById('ddPopupOverlay');
            if (ddOverlay) {
                ddOverlay.addEventListener('click', function(e) {
                    if (e.target === ddOverlay) closeDayDetailPanel();
                });
            }

            // 요일 상세 팝업 저장 버튼
            var btnDdPopupSave = document.getElementById('btnDdPopupSave');
            if (btnDdPopupSave) {
                btnDdPopupSave.addEventListener('click', async function() {
                    if (!selectedMember || !dayDetailIso) return;
                    var mid = selectedMember.id;
                    var iso = dayDetailIso;

                    btnDdPopupSave.disabled = true;
                    btnDdPopupSave.textContent = '저장 중...';
                    try {
                        // 실제근무 저장
                        if (ganttPendingChanges[iso]) {
                            var cleanSegs = ganttPendingChanges[iso].map(function(s){ return { start: s.start, end: s.end }; });
                            var resp = await fetch(API_ACTUAL_UPDATE, {
                                method: 'POST',
                                headers: {'Content-Type':'application/json', 'Accept':'application/json'},
                                body: JSON.stringify({ memberId: mid, date: iso, segments: cleanSegs })
                            });
                            if (!resp.ok) {
                                var text = await resp.text().catch(function(){ return ''; });
                                alert('실제근무 저장 실패: ' + resp.status + ' ' + text);
                                return;
                            }
                            delete ganttPendingChanges[iso];
                        }
                        // 일정 저장
                        if (ganttTemplatePendingChanges[iso]) {
                            var cleanSegs2 = ganttTemplatePendingChanges[iso].map(function(s){ return { start: s.start, end: s.end }; });
                            var resp2 = await fetch(API_UPDATE, {
                                method: 'POST',
                                headers: {'Content-Type':'application/json', 'Accept':'application/json'},
                                body: JSON.stringify({ memberId: mid, date: iso, segments: cleanSegs2 })
                            });
                            if (!resp2.ok) {
                                var text2 = await resp2.text().catch(function(){ return ''; });
                                alert('일정 저장 실패: ' + resp2.status + ' ' + text2);
                                return;
                            }
                            delete ganttTemplatePendingChanges[iso];
                        }

                        updateGanttSaveBar();
                        await fetchAndRenderWeekTable(currentStatusMembers, currentWeekStart);
                        await loadSelectedMemberWeek();
                        clearAllDayEditButtons();
                        updateCurrentTimeHighlight();

                        // 스냅샷 갱신 후 팝업 갱신
                        var tSegs = (baseWeekDaysMap[iso] && baseWeekDaysMap[iso].segments) || [];
                        var aSegs = (selectedWeekDaysMap[iso] && selectedWeekDaysMap[iso].segments) || [];
                        ddPopupOrigSnapshot = {
                            template: JSON.parse(JSON.stringify(tSegs)),
                            actual: JSON.parse(JSON.stringify(aSegs)),
                            hadTemplatePending: false,
                            hadActualPending: false
                        };
                        buildDayDetailGantt();
                        updateDdPopupButtons();
                    } catch(e) {
                        console.error(e);
                        alert('저장 중 오류가 발생했습니다.');
                    } finally {
                        btnDdPopupSave.disabled = false;
                        btnDdPopupSave.textContent = '저장';
                    }
                });
            }

            // 요일 상세 팝업 취소 버튼
            var btnDdPopupCancel = document.getElementById('btnDdPopupCancel');
            if (btnDdPopupCancel) {
                btnDdPopupCancel.addEventListener('click', function() {
                    if (!dayDetailIso) return;
                    var iso = dayDetailIso;

                    // 스냅샷으로 복원
                    if (ddPopupOrigSnapshot.hadTemplatePending) {
                        ganttTemplatePendingChanges[iso] = JSON.parse(JSON.stringify(ddPopupOrigSnapshot.template));
                    } else {
                        delete ganttTemplatePendingChanges[iso];
                    }
                    if (ddPopupOrigSnapshot.hadActualPending) {
                        ganttPendingChanges[iso] = JSON.parse(JSON.stringify(ddPopupOrigSnapshot.actual));
                    } else {
                        delete ganttPendingChanges[iso];
                    }

                    dayDetailBarInfo = null;
                    var delBtn = document.getElementById('btnDeleteDayDetailBar');
                    if (delBtn) delBtn.classList.add('d-none');
                    updateGanttSaveBar();
                    buildDayDetailGantt();
                    buildMemberWeekGantt();
                    updateDdPopupButtons();
                });
            }
        }

        function openPrintPage() {
            const status = statusSelect.value;
            const weekStartIso = toIso(currentWeekStart);
            const slot = slotMinutes;

            const url = `/schedules/work/weekly/print?status=${encodeURIComponent(status)}&weekStart=${encodeURIComponent(weekStartIso)}&slot=${encodeURIComponent(slot)}`;
            window.open(url, '_blank');
        }

        function openPrintMemberPage() {
            if (!selectedMember) {
                alert('선택된 아르바이트생이 없습니다.');
                return;
            }
            const weekStartIso = toIso(currentWeekStart);
            const slot = slotMinutes;

            const url =
                    `/schedules/work/weekly/print/individual` +
                    `?memberId=${encodeURIComponent(selectedMember.id)}` +
                    `&weekStart=${encodeURIComponent(weekStartIso)}` +
                    `&slot=${encodeURIComponent(slot)}`;

            window.open(url, '_blank');
        }

        // 🔵 그래프 보기 팝업
        function openGraphPage() {
            const status = statusSelect.value;
            const weekStartIso = toIso(currentWeekStart);
            const slot = slotMinutes;

            const url =
                    `/schedules/work/weekly/graph` +
                    `?status=${encodeURIComponent(status)}` +
                    `&weekStart=${encodeURIComponent(weekStartIso)}` +
                    `&slot=${encodeURIComponent(slot)}`;

            window.open(
                    url,
                    'weekStaffGraphWindow',
                    'width=1200,height=800,scrollbars=yes,resizable=yes'
            );
        }

        function setSlotMinutes(mins){
            if (slotMinutes === mins) return;
            slotMinutes = mins;
            updateSlotButtons();
        }
        function updateSlotButtons(){
            [btnSlot10, btnSlot30, btnSlot60].forEach(btn=>{ if (!btn) return; btn.classList.remove('active'); });
            if (slotMinutes === 10 && btnSlot10) btnSlot10.classList.add('active');
            if (slotMinutes === 30 && btnSlot30) btnSlot30.classList.add('active');
            if (slotMinutes === 60 && btnSlot60) btnSlot60.classList.add('active');
        }

        async function handleStatusChange(){
            const status = statusSelect.value;
            currentStatusMembers = (allMembers || []).filter(m => m.status === status);

            if (selectedMember && !currentStatusMembers.some(x => String(x.id) === String(selectedMember.id))) {
                selectedMember = null;
            }

            // 주간 Gantt 변경사항 초기화
            weekGanttPendingChanges = {};
            updateWeekGanttSaveBar();

            renderMemberList(currentStatusMembers);
            renderWeekRangeLabel(currentWeekStart);

            if (currentStatusMembers.length === 0) {
                const wgWrap = document.getElementById('weekGanttWrap');
                if (wgWrap) wgWrap.innerHTML = '';
                noMemberState.classList.remove('d-none');
                timetableWrapper.classList.add('d-none');
                hideMemberWeekCard();
                clearAllDayEditButtons();
                // 상태에 아무도 없으면 타임테이블은 접지 말고 그냥 그대로
                if (weeklyCardBody) {
                    weeklyCardBody.classList.remove('d-none');
                    if (btnToggleWeeklyCard) btnToggleWeeklyCard.textContent = '타임테이블 접기';
                }
                return;
            }

            noMemberState.classList.add('d-none');
            timetableWrapper.classList.remove('d-none');

            updatePillActive();

            await fetchAndRenderWeekTable(currentStatusMembers, currentWeekStart);
            await loadSelectedMemberWeek();
            clearAllDayEditButtons();
            updateCurrentTimeHighlight();
        }

        function renderMemberList(members){
            memberList.innerHTML = '';
            memberCountBadge.textContent = `${members.length}명`;

            if (members.length === 0) {
                memberList.innerHTML = `<span class="text-light small">해당 상태의 아르바이트생이 없습니다.</span>`;
                return;
            }

            members.slice().sort((a,b)=>(a.name||'').localeCompare(b.name||'', 'ko')).forEach(m => {
                const color = colorForMember(m);
                const pill = document.createElement('button');
                pill.type = 'button';
                pill.className = 'pill';
                pill.dataset.memberId = String(m.id);
                pill.innerHTML = `
                <span class="dot" style="background:${color}"></span>
                <span class="name">${escapeHtml(m.name ?? '-')}</span>
            `;
                pill.addEventListener('click', async (evt) => {
                    evt.preventDefault();
                    evt.stopPropagation();
                    // 토글 선택
                    if (selectedMember && String(selectedMember.id) === String(m.id)) {
                        selectedMember = null;
                    } else {
                        selectedMember = m;
                    }
                    updatePillActive();
                    await fetchAndRenderWeekTable(currentStatusMembers, currentWeekStart);
                    await loadSelectedMemberWeek();
                    clearAllDayEditButtons();
                    updateCurrentTimeHighlight();

                    // 🔵 선택/해제에 따라 레이아웃 토글
                    updateLayoutForSelection();
                });
                memberList.appendChild(pill);
            });

            updatePillActive();
        }

        function updatePillActive(){
            const pills = memberList.querySelectorAll('.pill');
            pills.forEach(p => {
                if (!selectedMember) { p.classList.remove('active'); return; }
                const id = p.dataset.memberId;
                if (String(id) === String(selectedMember.id)) p.classList.add('active');
                else p.classList.remove('active');
            });

            if (selectedMember) {
                document.body.classList.add('alba-has-selected');
            } else {
                document.body.classList.remove('alba-has-selected');
            }
        }

        // 🔵 선택 여부에 따른 상단/하단 카드 레이아웃 토글
        function updateLayoutForSelection() {
            if (selectedMember) {
                // 개별 주간 카드 보이기 + 펼치기
                memberWeekCard.classList.remove('d-none');
                if (memberWeekBody) memberWeekBody.classList.remove('d-none');
                if (btnToggleMemberWeek) btnToggleMemberWeek.textContent = '접기';

                // 주간 타임테이블 접기
                if (weeklyCardBody) weeklyCardBody.classList.add('d-none');
                if (btnToggleWeeklyCard) btnToggleWeeklyCard.textContent = '타임테이블 펼치기';
            } else {
                // 개별 카드 숨기기
                hideMemberWeekCard();
                // 주간 타임테이블 펼치기
                if (weeklyCardBody) weeklyCardBody.classList.remove('d-none');
                if (btnToggleWeeklyCard) btnToggleWeeklyCard.textContent = '타임테이블 접기';
            }
        }

        function renderWeekRangeLabel(weekStart){
            const weekEnd = addDays(weekStart, 6);

            const sY = weekStart.getFullYear();
            const sM = pad2(weekStart.getMonth()+1);
            const sD = pad2(weekStart.getDate());
            const eM = pad2(weekEnd.getMonth()+1);
            const eD = pad2(weekEnd.getDate());
            const label = `${sY}.${sM}.${sD} ~ ${eM}.${eD}`;

            if (weekRangeLabel) weekRangeLabel.textContent = label;
            if (weekRangeLabelRight) weekRangeLabelRight.textContent = label;

            if (dayHeaderCells && dayHeaderCells.length === 7) {
                const weekDates = [];
                for (let i=0; i<7; i++) {
                    const d = addDays(weekStart, i);
                    weekDates.push(toIso(d));

                    const mm = pad2(d.getMonth()+1);
                    const dd = pad2(d.getDate());
                    const cell = dayHeaderCells[i];
                    const dateSpan = cell.querySelector('.day-date');
                    if (dateSpan) dateSpan.textContent = `${mm}/${dd}`;

                    cell.classList.remove('today-col-head');
                }

                const today    = new Date();
                const todayIso = toIso(today);
                const todayIdx = weekDates.indexOf(todayIso);
                if (todayIdx !== -1) {
                    dayHeaderCells[todayIdx].classList.add('today-col-head');
                }
            }
        }

        async function fetchAndRenderWeekTable(members, weekStart){
            const weekEnd  = addDays(weekStart, 6);
            const startIso = toIso(weekStart);
            const endIso   = toIso(weekEnd);
            const weekDates = Array.from({length:7}, (_,i) => toIso(addDays(weekStart, i)));

            allMemberWeekData = {};
            try {
                const fetchBase = (currentDataType === 'actual') ? API_ACTUAL_BASE : API_BASE;
                await Promise.all(members.map(async (m) => {
                    const url = `${fetchBase}/${encodeURIComponent(m.id)}/${startIso}/${endIso}`;
                    const resp = await fetch(url, { headers:{'Accept':'application/json'} });
                    if (!resp.ok) { console.warn('[weekGantt] fetch fail:', m.id, resp.status); return; }
                    const data = await resp.json().catch(()=>null);
                    allMemberWeekData[m.id] = normalizeDays(data);
                }));
            } catch(e){ console.error('[weekGantt] error:', e); }

            // 카드 헤더 subtitle 동적 업데이트
            const cardSub = document.getElementById('weeklyCardSubtitle');
            if (cardSub) {
                cardSub.textContent = (currentDataType === 'actual')
                    ? '근무자별 실제 근무시간을 시간대별로 표시 · 바를 드래그하여 수정'
                    : '근무자별 일정을 시간대별로 표시 · 바를 드래그하여 일정 수정';
            }

            buildWeekGantt(members, weekStart, weekDates);
            updateCurrentTimeHighlight();
        }

        /* ============================================================
           주간 Gantt 차트 렌더링
        ============================================================ */
        function buildWeekGantt(members, weekStart, weekDates) {
            const wrap = document.getElementById('weekGanttWrap');
            if (!wrap) return;

            const TOTAL_MIN = (HOUR_END - HOUR_START) * 60;
            const DAY_NAMES = ['월','화','수','목','금','토','일'];
            const todayIso  = toIso(new Date());
            const LANE_H = 24;
            const BAR_H  = 20;
            const PAD    = 4;

            // 이름순 정렬 → 일관된 레인 순서
            const sortedMembers = [...members].sort((a,b) => (a.name||'').localeCompare(b.name||'','ko'));

            // ─── 헤더 행 (시간 눈금) ───
            let html = '<div class="mw-gantt-header-row">';
            html += '<div class="mw-gantt-label-cell"><span style="font-size:0.73rem;color:#9ca3af;">요일</span></div>';
            html += '<div class="mw-gantt-track-header">';
            for (let h = HOUR_START; h < HOUR_END; h++) {
                const pct = ((h - HOUR_START) * 60 / TOTAL_MIN * 100).toFixed(3);
                html += `<div class="mw-gantt-time-label" style="left:${pct}%">${pad2(h)}:00</div>`;
                const halfPct = ((h - HOUR_START) * 60 + 30) / TOTAL_MIN * 100;
                html += `<div class="mw-gantt-time-label minor" style="left:${halfPct.toFixed(3)}%">:30</div>`;
            }
            html += '</div>';
            html += '<div class="wg-hours-cell">근무시간</div>';
            html += '</div>';

            // 현재 시각(분)
            const now = new Date();
            const nowMin = now.getHours() * 60 + now.getMinutes();

            // ─── 요일 행들 ───
            html += '<div class="mw-gantt-body-wrap" id="weekGanttBodyWrap" style="position:relative;">';
            for (let offset = 0; offset < 7; offset++) {
                const date    = addDays(weekStart, offset);
                const iso     = toIso(date);
                const isToday = (iso === todayIso);
                const isPast  = (iso < todayIso);
                const isFuture = (iso > todayIso);

                // 이 날 근무하는 멤버들 (레인 순서 유지)
                const dayMembers = [];
                sortedMembers.forEach(m => {
                    const key  = `${m.id}_${iso}`;
                    const orig = allMemberWeekData[m.id]?.[iso];
                    const segs = weekGanttPendingChanges[key]?.segments || orig?.segments || [];
                    if (segs.length > 0) {
                        dayMembers.push({ member: m, segments: segs, modified: !!weekGanttPendingChanges[key] });
                    }
                });

                const rowH = Math.max(62, dayMembers.length * LANE_H + PAD * 2);
                const rowCls = ['mw-gantt-row', isToday ? 'today-row' : '', isPast ? 'past-day' : ''].filter(Boolean).join(' ');

                html += `<div class="${rowCls}" data-iso="${iso}" data-offset="${offset}" style="height:${rowH}px;">`;
                html += `<div class="mw-gantt-label-cell" style="height:${rowH}px;">`;
                html += `<div class="mw-gantt-day-name">${DAY_NAMES[offset]}</div>`;
                html += `<div class="mw-gantt-day-date">${pad2(date.getMonth()+1)}/${pad2(date.getDate())}</div>`;
                html += `<button class="btn-wg-day-view" data-wg-iso="${iso}" data-wg-offset="${offset}">보기</button>`;
                html += `</div>`;
                html += `<div class="mw-gantt-track-cell">`;

                const memberMinutes = []; // 멤버별 근무시간

                dayMembers.forEach((dm, laneIdx) => {
                    const m = dm.member;
                    const color = colorForMember(m);
                    const topPx = laneIdx * LANE_H + PAD;
                    const modCls = dm.modified ? ' wg-modified' : '';
                    const selCls = (selectedMember && String(m.id) === String(selectedMember.id)) ? ' wg-selected' : '';
                    const dimCls = (selectedMember && String(m.id) !== String(selectedMember.id)) ? ' wg-dimmed' : '';
                    let memberMin = 0;

                    dm.segments.forEach((seg, segIdx) => {
                        const effStart = Math.max(hmToMin(seg.start), HOUR_START * 60);
                        const effEnd   = Math.min(hmToMin(seg.end),   HOUR_END * 60);
                        if (effEnd <= effStart) return;

                        const baseAttrs = `data-member-id="${m.id}" data-iso="${iso}" data-seg-idx="${segIdx}" data-start="${seg.start}" data-end="${seg.end}"`;

                        if (isToday) {
                            // ─── 오늘: 지난 시간=솔리드, 안 온 시간=점선 ───
                            if (nowMin >= effEnd) {
                                // 전체 완료 → 솔리드
                                const leftPct  = (effStart - HOUR_START * 60) / TOTAL_MIN * 100;
                                const widthPct = (effEnd - effStart) / TOTAL_MIN * 100;
                                memberMin += (effEnd - effStart);
                                html += `<div class="wg-gantt-bar wg-past-bar${modCls}${selCls}${dimCls}" ${baseAttrs} style="left:${leftPct.toFixed(3)}%;width:${widthPct.toFixed(3)}%;top:${topPx}px;height:${BAR_H}px;background:${color};">`;
                                html += `<div class="bar-handle bar-handle-left"></div><div class="bar-handle bar-handle-right"></div>`;
                                html += `<span class="wg-bar-name">${escapeHtml(m.name||'')}</span><span class="wg-bar-time">${seg.start}~${seg.end}</span>`;
                                html += `<div class="mw-gantt-bar-tooltip">${seg.start} ~ ${seg.end}</div></div>`;
                            } else if (nowMin <= effStart) {
                                // 전체 미래 → 점선
                                const leftPct  = (effStart - HOUR_START * 60) / TOTAL_MIN * 100;
                                const widthPct = (effEnd - effStart) / TOTAL_MIN * 100;
                                html += `<div class="wg-gantt-bar wg-future-part${modCls}${selCls}${dimCls}" ${baseAttrs} style="left:${leftPct.toFixed(3)}%;width:${widthPct.toFixed(3)}%;top:${topPx}px;height:${BAR_H}px;--wg-bar-color:${color};">`;
                                html += `<div class="bar-handle bar-handle-left"></div><div class="bar-handle bar-handle-right"></div>`;
                                html += `<span class="wg-bar-name">${escapeHtml(m.name||'')}</span><span class="wg-bar-time">${seg.start}~${seg.end}</span>`;
                                html += `<div class="mw-gantt-bar-tooltip">${seg.start} ~ ${seg.end}</div></div>`;
                            } else {
                                // 걸쳐있음 → 솔리드(완료) + 점선(미래)
                                const doneStart = effStart, doneEnd = nowMin;
                                const futStart  = nowMin,   futEnd  = effEnd;
                                memberMin += (doneEnd - doneStart);

                                // 솔리드 부분
                                const dl = (doneStart - HOUR_START*60)/TOTAL_MIN*100;
                                const dw = (doneEnd - doneStart)/TOTAL_MIN*100;
                                html += `<div class="wg-gantt-bar wg-past-bar${modCls}${selCls}${dimCls}" ${baseAttrs} style="left:${dl.toFixed(3)}%;width:${dw.toFixed(3)}%;top:${topPx}px;height:${BAR_H}px;background:${color};border-top-right-radius:0;border-bottom-right-radius:0;">`;
                                html += `<div class="bar-handle bar-handle-left"></div>`;
                                html += `<span class="wg-bar-name">${escapeHtml(m.name||'')}</span><span class="wg-bar-time">${seg.start}~${seg.end}</span>`;
                                html += `<div class="mw-gantt-bar-tooltip">${seg.start} ~ ${seg.end}</div></div>`;

                                // 점선 부분
                                const fl = (futStart - HOUR_START*60)/TOTAL_MIN*100;
                                const fw = (futEnd - futStart)/TOTAL_MIN*100;
                                html += `<div class="wg-gantt-bar wg-future-part${dimCls}" data-member-id="${m.id}" data-iso="${iso}" style="left:${fl.toFixed(3)}%;width:${fw.toFixed(3)}%;top:${topPx}px;height:${BAR_H}px;--wg-bar-color:${color};border-top-left-radius:0;border-bottom-left-radius:0;">`;
                                html += `<div class="bar-handle bar-handle-right"></div></div>`;
                            }
                        } else {
                            // ─── 과거/미래: 동일 스타일 (솔리드) ───
                            const leftPct  = (effStart - HOUR_START * 60) / TOTAL_MIN * 100;
                            const widthPct = (effEnd - effStart) / TOTAL_MIN * 100;
                            if (isPast) memberMin += (effEnd - effStart);

                            html += `<div class="wg-gantt-bar${modCls}${selCls}${dimCls}" ${baseAttrs} style="left:${leftPct.toFixed(3)}%;width:${widthPct.toFixed(3)}%;top:${topPx}px;height:${BAR_H}px;background:${color};">`;
                            html += `<div class="bar-handle bar-handle-left"></div><div class="bar-handle bar-handle-right"></div>`;
                            html += `<span class="wg-bar-name">${escapeHtml(m.name||'')}</span><span class="wg-bar-time">${seg.start}~${seg.end}</span>`;
                            html += `<div class="mw-gantt-bar-tooltip">${seg.start} ~ ${seg.end}</div></div>`;
                        }
                    });
                    memberMinutes.push({ name: m.name, min: memberMin, color: color });
                });

                html += '</div>';

                // 근무시간 셀: 멤버별 표기
                html += `<div class="wg-hours-cell" style="height:${rowH}px;justify-content:flex-start;padding-top:${PAD}px;">`;
                if (memberMinutes.length === 0) {
                    html += `<span class="zero-hours" style="margin-top:auto;margin-bottom:auto;">-</span>`;
                } else {
                    memberMinutes.forEach(function(mm) {
                        const t = mm.min > 0
                            ? (Math.floor(mm.min/60) + 'h' + (mm.min%60 > 0 ? (mm.min%60) + 'm' : ''))
                            : (isPast || isToday ? '0h' : '-');
                        const c = mm.min > 0 ? mm.color : '#c4a882';
                        html += `<div style="height:${LANE_H}px;display:flex;align-items:center;justify-content:center;color:${c};font-size:.65rem;white-space:nowrap;">${t}</div>`;
                    });
                }
                html += '</div>';

                html += '</div>';
            }
            html += '</div>';
            wrap.innerHTML = html;

            initWeekGanttDrag(wrap);

            // ─── 보기 버튼 클릭 이벤트 ───
            wrap.querySelectorAll('.btn-wg-day-view').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var iso = this.dataset.wgIso;
                    openWgDayPopup(iso);
                });
            });
        }

        /* ============================================================
           주간 Gantt 드래그/리사이즈 핸들러
        ============================================================ */
        let _wgDragState = null;
        let _wgDragInited = false;
        function initWeekGanttDrag(wrap) {
            if (_wgDragInited) return;
            _wgDragInited = true;
            const TOTAL_MIN = (HOUR_END - HOUR_START) * 60;

            function getTrackRect(bar) {
                const tc = bar.closest('.mw-gantt-track-cell');
                return tc ? tc.getBoundingClientRect() : null;
            }
            function pxToMin(px, tw) { return Math.round(px / tw * TOTAL_MIN / 10) * 10; }
            function clampMin(m) { return Math.max(0, Math.min(m, TOTAL_MIN)); }

            wrap.addEventListener('mousedown', function(e) {
                const bar = e.target.closest('.wg-gantt-bar');
                if (!bar) return;
                e.preventDefault(); e.stopPropagation();

                const trackRect = getTrackRect(bar);
                if (!trackRect) return;

                const memberId = bar.dataset.memberId;
                const iso      = bar.dataset.iso;
                const segIdx   = parseInt(bar.dataset.segIdx, 10);
                const startMin = hmToMin(bar.dataset.start) - HOUR_START * 60;
                const endMin   = hmToMin(bar.dataset.end)   - HOUR_START * 60;

                let mode = 'move';
                if (e.target.classList.contains('bar-handle-left'))  mode = 'resize-left';
                if (e.target.classList.contains('bar-handle-right')) mode = 'resize-right';

                bar.classList.add(mode === 'move' ? 'dragging' : 'resizing');

                _wgDragState = {
                    bar, memberId, iso, segIdx, mode, trackRect,
                    origStartMin: startMin, origEndMin: endMin, origDuration: endMin - startMin,
                    mouseStartX: e.clientX,
                    currentStartMin: startMin, currentEndMin: endMin,
                    targetIso: iso
                };
                // 플로팅 툴팁 표시
                const dtt = document.getElementById('dragTimeTooltip');
                if (dtt) {
                    const origS = minToHm(startMin + HOUR_START*60), origE = minToHm(endMin + HOUR_START*60);
                    dtt.innerHTML = `${origS} <span class="dtt-arrow">→</span> ${origE}`;
                    dtt.style.left = (e.clientX + 14) + 'px';
                    dtt.style.top  = (e.clientY - 36) + 'px';
                    dtt.classList.add('visible');
                }
            });

            document.addEventListener('mousemove', function(e) {
                if (!_wgDragState || !_wgDragState.bar.closest('.wg-gantt-wrap')) return;
                e.preventDefault();
                const { bar, mode, trackRect, origStartMin, origEndMin, origDuration, mouseStartX } = _wgDragState;
                const dx = e.clientX - mouseStartX;
                const deltaMin = pxToMin(dx, trackRect.width);

                let ns, ne;
                if (mode === 'move') {
                    ns = clampMin(origStartMin + deltaMin); ne = ns + origDuration;
                    if (ne > TOTAL_MIN) { ne = TOTAL_MIN; ns = ne - origDuration; }
                    if (ns < 0) { ns = 0; ne = origDuration; }
                } else if (mode === 'resize-left') {
                    ns = clampMin(origStartMin + deltaMin); ne = origEndMin;
                    if (ns >= ne - 10) ns = ne - 10;
                } else {
                    ns = origStartMin; ne = clampMin(origEndMin + deltaMin);
                    if (ne <= ns + 10) ne = ns + 10;
                }
                _wgDragState.currentStartMin = ns; _wgDragState.currentEndMin = ne;

                bar.style.left  = (ns / TOTAL_MIN * 100).toFixed(3) + '%';
                bar.style.width = ((ne - ns) / TOTAL_MIN * 100).toFixed(3) + '%';

                // 플로팅 툴팁 업데이트
                const dtt = document.getElementById('dragTimeTooltip');
                if (dtt) {
                    const newS = minToHm(ns + HOUR_START*60), newE = minToHm(ne + HOUR_START*60);
                    const origS = minToHm(_wgDragState.origStartMin + HOUR_START*60);
                    const origE = minToHm(_wgDragState.origEndMin + HOUR_START*60);
                    const changed = (newS !== origS || newE !== origE);
                    dtt.innerHTML = changed
                        ? `<span class="dtt-changed">${newS} <span class="dtt-arrow">→</span> ${newE}</span>`
                        : `${newS} <span class="dtt-arrow">→</span> ${newE}`;
                    dtt.style.left = (e.clientX + 14) + 'px';
                    dtt.style.top  = (e.clientY - 36) + 'px';
                }

                if (mode === 'move') {
                    const rows = wrap.querySelectorAll('.mw-gantt-row');
                    rows.forEach(r => r.classList.remove('drop-target'));
                    rows.forEach(r => {
                        const rr = r.getBoundingClientRect();
                        if (e.clientY >= rr.top && e.clientY <= rr.bottom) {
                            if (r.dataset.iso !== _wgDragState.iso) r.classList.add('drop-target');
                            _wgDragState.targetIso = r.dataset.iso;
                        }
                    });
                }
            });

            document.addEventListener('mouseup', function(e) {
                if (!_wgDragState || !_wgDragState.bar.closest('.wg-gantt-wrap')) return;
                const { bar, memberId, iso, segIdx, currentStartMin, currentEndMin, targetIso } = _wgDragState;
                bar.classList.remove('dragging', 'resizing');
                // 플로팅 툴팁 숨기기
                const dtt = document.getElementById('dragTimeTooltip');
                if (dtt) dtt.classList.remove('visible');
                wrap.querySelectorAll('.mw-gantt-row').forEach(r => r.classList.remove('drop-target'));

                const newStart  = minToHm(currentStartMin + HOUR_START * 60);
                const newEnd    = minToHm(currentEndMin   + HOUR_START * 60);
                const origStart = bar.dataset.start;
                const origEnd   = bar.dataset.end;

                if (newStart !== origStart || newEnd !== origEnd || targetIso !== iso) {
                    const srcKey  = `${memberId}_${iso}`;
                    const srcData = allMemberWeekData[memberId]?.[iso];
                    const srcSegs = (weekGanttPendingChanges[srcKey]?.segments || srcData?.segments || []).map(s=>({...s}));

                    if (targetIso !== iso) {
                        srcSegs.splice(segIdx, 1);
                        weekGanttPendingChanges[srcKey] = { memberId, iso, segments: srcSegs };

                        const dstKey  = `${memberId}_${targetIso}`;
                        const dstData = allMemberWeekData[memberId]?.[targetIso];
                        const dstSegs = (weekGanttPendingChanges[dstKey]?.segments || dstData?.segments || []).map(s=>({...s}));
                        dstSegs.push({ start: newStart, end: newEnd });
                        dstSegs.sort((a,b) => hmToMin(a.start) - hmToMin(b.start));
                        weekGanttPendingChanges[dstKey] = { memberId, iso: targetIso, segments: mergeOverlappingSegments(dstSegs) };
                    } else {
                        srcSegs[segIdx] = { start: newStart, end: newEnd };
                        srcSegs.sort((a,b) => hmToMin(a.start) - hmToMin(b.start));
                        weekGanttPendingChanges[srcKey] = { memberId, iso, segments: mergeOverlappingSegments(srcSegs) };
                    }

                    updateWeekGanttSaveBar();
                    const wd = Array.from({length:7}, (_,i) => toIso(addDays(currentWeekStart, i)));
                    buildWeekGantt(currentStatusMembers, currentWeekStart, wd);
                }
                _wgDragState = null;
            });
        }

        /* ============================================================
           주간 Gantt 저장 바
        ============================================================ */
        function updateWeekGanttSaveBar() {
            const el = document.getElementById('weekGanttSaveBar');
            const info = document.getElementById('weekGanttSaveInfo');
            if (!el) return;
            const cnt = Object.keys(weekGanttPendingChanges).length;
            if (cnt > 0) {
                el.classList.add('visible');
                if (info) info.textContent = `${cnt}건의 일정이 변경되었습니다`;
            } else {
                el.classList.remove('visible');
            }
        }
        function resetWeekGanttChanges() {
            weekGanttPendingChanges = {};
            closeWgDayPopup();
            updateWeekGanttSaveBar();
            const wd = Array.from({length:7}, (_,i) => toIso(addDays(currentWeekStart, i)));
            buildWeekGantt(currentStatusMembers, currentWeekStart, wd);
        }
        (function initWeekGanttSaveHandlers(){
            const btnCancel = document.getElementById('btnWeekGanttCancel');
            const btnSave   = document.getElementById('btnWeekGanttSave');
            if (btnCancel) btnCancel.addEventListener('click', resetWeekGanttChanges);
            if (btnSave) btnSave.addEventListener('click', async function(){
                const entries = Object.entries(weekGanttPendingChanges);
                if (entries.length === 0) return;
                btnSave.disabled = true; btnSave.textContent = '저장 중...';
                const saveUrl = (currentDataType === 'actual') ? API_ACTUAL_UPDATE : API_UPDATE;
                try {
                    for (const [key, data] of entries) {
                        const body = { memberId: data.memberId, date: data.iso, segments: data.segments };
                        const resp = await fetch(saveUrl, {
                            method:'POST',
                            headers:{'Content-Type':'application/json','Accept':'application/json'},
                            body: JSON.stringify(body)
                        });
                        if (!resp.ok) {
                            const text = await resp.text().catch(()=>'');
                            alert(`저장 실패 (${data.iso}): ${resp.status} ${text}`);
                            btnSave.disabled = false; btnSave.textContent = '저장'; return;
                        }
                    }
                    weekGanttPendingChanges = {};
                    closeWgDayPopup();
                    updateWeekGanttSaveBar();
                    await fetchAndRenderWeekTable(currentStatusMembers, currentWeekStart);
                    await loadSelectedMemberWeek();
                    updateCurrentTimeHighlight();
                } catch(e) { console.error(e); alert('저장 중 오류가 발생했습니다.'); }
                finally { btnSave.disabled = false; btnSave.textContent = '저장'; }
            });
        })();

        /* ============================================================
           현재 시간 표시 (세로 빨간 선)
        ============================================================ */
        function updateCurrentTimeHighlight(){
            document.querySelectorAll('.wg-time-now-line').forEach(el => el.remove());
            document.querySelectorAll('.wg-gantt-bar.wg-now-active').forEach(el => el.classList.remove('wg-now-active'));

            const now = new Date();
            const todayIso = toIso(now);
            const minutes  = now.getHours() * 60 + now.getMinutes();
            const startMin = HOUR_START * 60;
            const endMin   = HOUR_END * 60;
            if (minutes < startMin || minutes >= endMin) return;

            const TOTAL_MIN = endMin - startMin;
            const timePct   = ((minutes - startMin) / TOTAL_MIN * 100).toFixed(3);

            const bodyWrap = document.getElementById('weekGanttBodyWrap');
            if (!bodyWrap) return;

            // 각 트랙 셀에 세로선 추가
            bodyWrap.querySelectorAll('.mw-gantt-track-cell').forEach(tc => {
                const line = document.createElement('div');
                line.className = 'wg-time-now-line';
                line.style.left = timePct + '%';
                tc.appendChild(line);
            });

            // 오늘 행의 현재 시간 근무 바 펄스
            const todayRow = bodyWrap.querySelector(`.mw-gantt-row[data-iso="${todayIso}"]`);
            if (todayRow) {
                todayRow.querySelectorAll('.wg-gantt-bar').forEach(bar => {
                    const bs = hmToMin(bar.dataset.start), be = hmToMin(bar.dataset.end);
                    if (minutes >= bs && minutes < be) bar.classList.add('wg-now-active');
                });
            }
        }

        /* ============================================================
           주간 타임테이블 요일별 보기 팝업
        ============================================================ */
        let wgPopupIso = null;
        let wgPopupBarInfo = null; // { memberId, iso, start, end }
        let _wgPopupDragState = null;
        let _wgPopupDragInited = false;
        let _wgPopupJustDragged = false;
        let wgPopupOrigSnapshot = {};  // 팝업 열 때의 원본 스냅샷 { key: segments }

        function openWgDayPopup(iso) {
            wgPopupIso = iso;
            wgPopupBarInfo = null;

            // 원본 스냅샷 저장: 이 날짜에 관련된 모든 멤버의 현재 상태
            wgPopupOrigSnapshot = {};
            var sortedMembers = currentStatusMembers || [];
            sortedMembers.forEach(function(m) {
                var key = m.id + '_' + iso;
                var origData = allMemberWeekData[m.id] && allMemberWeekData[m.id][iso];
                var currentSegs = (weekGanttPendingChanges[key] && weekGanttPendingChanges[key].segments) || (origData && origData.segments) || [];
                wgPopupOrigSnapshot[key] = JSON.stringify(currentSegs);
            });

            var overlay = document.getElementById('wgDayPopupOverlay');
            var title = document.getElementById('wgPopupTitle');
            var delBtn = document.getElementById('btnWgPopupDelete');
            if (!overlay) return;

            var date = new Date(iso + 'T00:00:00');
            var dayNames = ['일','월','화','수','목','금','토'];
            var dayName = dayNames[date.getDay()];
            title.textContent = dayName + '요일 (' + iso + ')';
            var popupSub = document.getElementById('wgPopupSubtitle');
            if (popupSub) {
                popupSub.textContent = (currentDataType === 'actual')
                    ? '전체 아르바이트생 근무시간 · 바를 드래그하여 편집'
                    : '전체 아르바이트생 일정 · 바를 드래그하여 편집';
            }
            if (delBtn) delBtn.classList.add('d-none');

            overlay.classList.remove('d-none');
            document.body.style.overflow = 'hidden';

            buildWgDayPopupGantt();
            initWgPopupDrag();
            updateWgPopupButtons();
        }

        function closeWgDayPopup() {
            var overlay = document.getElementById('wgDayPopupOverlay');
            if (overlay) overlay.classList.add('d-none');
            document.body.style.overflow = '';
            wgPopupIso = null;
            wgPopupBarInfo = null;
            wgPopupOrigSnapshot = {};
        }

        // 팝업 내 해당 일자에 변경이 있는지 확인 → 저장/취소 버튼 표시
        function updateWgPopupButtons() {
            var btnSave = document.getElementById('btnWgPopupSave');
            var btnCancel = document.getElementById('btnWgPopupCancel');
            var infoEl = document.getElementById('wgPopupChangeInfo');
            if (!btnSave || !btnCancel) return;

            var hasChanges = false;
            var changeCount = 0;
            if (wgPopupIso) {
                var sortedMembers = currentStatusMembers || [];
                sortedMembers.forEach(function(m) {
                    var key = m.id + '_' + wgPopupIso;
                    var origData = allMemberWeekData[m.id] && allMemberWeekData[m.id][wgPopupIso];
                    var currentSegs = (weekGanttPendingChanges[key] && weekGanttPendingChanges[key].segments) || (origData && origData.segments) || [];
                    var currentJson = JSON.stringify(currentSegs);
                    var origJson = wgPopupOrigSnapshot[key] || '[]';
                    if (currentJson !== origJson) {
                        hasChanges = true;
                        changeCount++;
                    }
                });
            }

            if (hasChanges) {
                btnSave.classList.remove('d-none');
                btnCancel.classList.remove('d-none');
                if (infoEl) infoEl.textContent = changeCount + '명 변경됨';
            } else {
                btnSave.classList.add('d-none');
                btnCancel.classList.add('d-none');
                if (infoEl) infoEl.textContent = '';
            }
        }

        function buildWgDayPopupGantt() {
            var wrap = document.getElementById('wgDayPopupGanttWrap');
            if (!wrap || !wgPopupIso) return;

            var iso = wgPopupIso;
            var TOTAL_MIN = (HOUR_END - HOUR_START) * 60;
            var sortedMembers = [...currentStatusMembers].sort(function(a,b){ return (a.name||'').localeCompare(b.name||'','ko'); });

            // 시간 눈금 헤더
            var html = '<div class="mw-gantt-header-row">';
            html += '<div class="mw-gantt-label-cell" style="width:100px;min-width:100px;flex:0 0 100px;"><span style="font-size:0.73rem;color:#9ca3af;">이름</span></div>';
            html += '<div class="mw-gantt-track-header">';
            for (var h = HOUR_START; h < HOUR_END; h++) {
                var pct = ((h - HOUR_START) * 60 / TOTAL_MIN * 100).toFixed(3);
                html += '<div class="mw-gantt-time-label" style="left:' + pct + '%">' + pad2(h) + ':00</div>';
                var hPct = ((h - HOUR_START) * 60 + 30) / TOTAL_MIN * 100;
                html += '<div class="mw-gantt-time-label minor" style="left:' + hPct.toFixed(3) + '%">:30</div>';
            }
            html += '</div>';
            html += '<div class="wg-popup-hours-cell">시간</div>';
            html += '</div>';

            // 멤버별 행
            html += '<div class="mw-gantt-body-wrap">';
            sortedMembers.forEach(function(m) {
                var mid = m.id;
                var key = mid + '_' + iso;
                var origData = allMemberWeekData[mid] && allMemberWeekData[mid][iso];
                var segs = (weekGanttPendingChanges[key] && weekGanttPendingChanges[key].segments) || (origData && origData.segments) || [];
                var isModified = !!weekGanttPendingChanges[key];
                var color = colorForMember(m);

                html += '<div class="mw-gantt-row" data-popup-member-id="' + mid + '" data-iso="' + iso + '">';
                html += '<div class="mw-gantt-label-cell" style="width:100px;min-width:100px;flex:0 0 100px;height:42px;display:flex;align-items:center;padding-left:10px;">';
                html += '<span class="wg-popup-member-chip" style="background:' + color + ';"></span>';
                html += '<span class="wg-popup-member-name">' + escapeHtml(m.name || '') + '</span>';
                html += '</div>';
                html += '<div class="mw-gantt-track-cell">';

                segs.forEach(function(seg, segIdx) {
                    var effStart = Math.max(hmToMin(seg.start), HOUR_START * 60);
                    var effEnd = Math.min(hmToMin(seg.end), HOUR_END * 60);
                    if (effEnd <= effStart) return;
                    var leftPct = (effStart - HOUR_START * 60) / TOTAL_MIN * 100;
                    var widthPct = (effEnd - effStart) / TOTAL_MIN * 100;
                    var modClass = isModified ? ' modified' : '';
                    var selClass = (wgPopupBarInfo && String(wgPopupBarInfo.memberId) === String(mid) && wgPopupBarInfo.start === seg.start && wgPopupBarInfo.end === seg.end) ? ' wg-popup-bar-selected' : '';

                    html += '<div class="wg-popup-bar' + modClass + selClass + '" data-member-id="' + mid + '" data-iso="' + iso + '" data-seg-idx="' + segIdx + '" data-start="' + seg.start + '" data-end="' + seg.end + '" style="left:' + leftPct.toFixed(3) + '%;width:' + widthPct.toFixed(3) + '%;background:' + color + ';">';
                    html += '<div class="bar-handle bar-handle-left"></div>';
                    html += '<span class="wg-popup-bar-time">' + seg.start + '~' + seg.end + '</span>';
                    html += '<div class="bar-handle bar-handle-right"></div>';
                    html += '<div class="mw-gantt-bar-tooltip">' + seg.start + ' ~ ' + seg.end + '</div>';
                    html += '</div>';
                });

                html += '</div>';

                // 시간 표시
                var totalMin = 0;
                segs.forEach(function(seg) { totalMin += Math.max(0, hmToMin(seg.end) - hmToMin(seg.start)); });
                var hrsText = totalMin > 0 ? (Math.floor(totalMin/60) + 'h' + (totalMin%60>0 ? (totalMin%60)+'m' : '')) : '-';
                html += '<div class="wg-popup-hours-cell" style="color:' + (totalMin>0 ? color : '#9ca3af') + ';">' + hrsText + '</div>';
                html += '</div>';
            });

            html += '</div>';
            wrap.innerHTML = html;

            // 변경 정보 업데이트
            var infoEl = document.getElementById('wgPopupChangeInfo');
            if (infoEl) {
                var cnt = Object.keys(weekGanttPendingChanges).length;
                infoEl.textContent = cnt > 0 ? (cnt + '건 변경됨') : '';
            }
        }

        function initWgPopupDrag() {
            var wrap = document.getElementById('wgDayPopupGanttWrap');
            if (!wrap || _wgPopupDragInited) return;
            _wgPopupDragInited = true;
            var TOTAL_MIN = (HOUR_END - HOUR_START) * 60;

            function getTrackRect(bar) {
                var tc = bar.closest('.mw-gantt-track-cell');
                return tc ? tc.getBoundingClientRect() : null;
            }
            function pxToMin(px, tw) { return Math.round(px / tw * TOTAL_MIN / 10) * 10; }
            function clampMin(m) { return Math.max(0, Math.min(m, TOTAL_MIN)); }

            // mousedown
            wrap.addEventListener('mousedown', function(e) {
                var bar = e.target.closest('.wg-popup-bar');
                if (!bar) return;
                e.preventDefault();
                e.stopPropagation();

                var trackRect = getTrackRect(bar);
                if (!trackRect) return;

                var memberId = bar.dataset.memberId;
                var iso = bar.dataset.iso;
                var segIdx = parseInt(bar.dataset.segIdx, 10);
                var startMin = hmToMin(bar.dataset.start) - HOUR_START * 60;
                var endMin = hmToMin(bar.dataset.end) - HOUR_START * 60;
                var duration = endMin - startMin;

                var mode = 'move';
                if (e.target.classList.contains('bar-handle-left')) mode = 'resize-left';
                if (e.target.classList.contains('bar-handle-right')) mode = 'resize-right';

                bar.classList.add(mode === 'move' ? 'dragging' : 'resizing');

                _wgPopupDragState = {
                    bar: bar, memberId: memberId, iso: iso, segIdx: segIdx, mode: mode, trackRect: trackRect,
                    origStartMin: startMin, origEndMin: endMin, origDuration: duration,
                    mouseStartX: e.clientX, startX: e.clientX, startY: e.clientY,
                    hasMoved: false, currentStartMin: startMin, currentEndMin: endMin
                };

                var dtt = document.getElementById('dragTimeTooltip');
                if (dtt) {
                    var origS = minToHm(startMin + HOUR_START*60), origE = minToHm(endMin + HOUR_START*60);
                    dtt.innerHTML = origS + ' <span class="dtt-arrow">\u2192</span> ' + origE;
                    dtt.style.left = (e.clientX + 14) + 'px';
                    dtt.style.top = (e.clientY - 36) + 'px';
                    dtt.classList.add('visible');
                }
            });

            // mousemove
            document.addEventListener('mousemove', function(e) {
                if (!_wgPopupDragState) return;
                e.preventDefault();
                var st = _wgPopupDragState;
                if (!st.hasMoved) {
                    var dist = Math.abs(e.clientX - st.startX) + Math.abs(e.clientY - st.startY);
                    if (dist < 3) return;
                    st.hasMoved = true;
                }

                var dx = e.clientX - st.mouseStartX;
                var deltaMin = pxToMin(dx, st.trackRect.width);
                var newStart, newEnd;

                if (st.mode === 'move') {
                    newStart = clampMin(st.origStartMin + deltaMin);
                    newEnd = newStart + st.origDuration;
                    if (newEnd > TOTAL_MIN) { newEnd = TOTAL_MIN; newStart = newEnd - st.origDuration; }
                    if (newStart < 0) { newStart = 0; newEnd = st.origDuration; }
                } else if (st.mode === 'resize-left') {
                    newStart = clampMin(st.origStartMin + deltaMin);
                    newEnd = st.origEndMin;
                    if (newStart >= newEnd - 10) newStart = newEnd - 10;
                } else {
                    newStart = st.origStartMin;
                    newEnd = clampMin(st.origEndMin + deltaMin);
                    if (newEnd <= newStart + 10) newEnd = newStart + 10;
                }

                st.currentStartMin = newStart;
                st.currentEndMin = newEnd;

                var leftPct = newStart / TOTAL_MIN * 100;
                var widthPct = (newEnd - newStart) / TOTAL_MIN * 100;
                st.bar.style.left = leftPct.toFixed(3) + '%';
                st.bar.style.width = widthPct.toFixed(3) + '%';

                var dtt = document.getElementById('dragTimeTooltip');
                if (dtt) {
                    var newS = minToHm(newStart + HOUR_START*60), newE = minToHm(newEnd + HOUR_START*60);
                    var origS = minToHm(st.origStartMin + HOUR_START*60);
                    var origE = minToHm(st.origEndMin + HOUR_START*60);
                    var changed = (newS !== origS || newE !== origE);
                    dtt.innerHTML = changed
                        ? '<span class="dtt-changed">' + newS + ' <span class="dtt-arrow">\u2192</span> ' + newE + '</span>'
                        : newS + ' <span class="dtt-arrow">\u2192</span> ' + newE;
                    dtt.style.left = (e.clientX + 14) + 'px';
                    dtt.style.top = (e.clientY - 36) + 'px';
                }
            });

            // mouseup
            document.addEventListener('mouseup', function(e) {
                if (!_wgPopupDragState) return;
                var st = _wgPopupDragState;
                st.bar.classList.remove('dragging', 'resizing');
                var dtt = document.getElementById('dragTimeTooltip');
                if (dtt) dtt.classList.remove('visible');

                if (!st.hasMoved) {
                    _wgPopupDragState = null;
                    return;
                }
                _wgPopupJustDragged = true;
                setTimeout(function(){ _wgPopupJustDragged = false; }, 0);

                wgPopupBarInfo = null;
                var delBtnEl = document.getElementById('btnWgPopupDelete');
                if (delBtnEl) delBtnEl.classList.add('d-none');

                var newStart = minToHm(st.currentStartMin + HOUR_START * 60);
                var newEnd = minToHm(st.currentEndMin + HOUR_START * 60);
                var origStart = st.bar.dataset.start;
                var origEnd = st.bar.dataset.end;
                var memberId = st.memberId;
                var iso = st.iso;

                if (newStart !== origStart || newEnd !== origEnd) {
                    var key = memberId + '_' + iso;
                    var origData = allMemberWeekData[memberId] && allMemberWeekData[memberId][iso];
                    var srcSegs = ((weekGanttPendingChanges[key] && weekGanttPendingChanges[key].segments) || (origData && origData.segments) || []).map(function(s){ return Object.assign({}, s); });
                    srcSegs[st.segIdx] = { start: newStart, end: newEnd };
                    srcSegs.sort(function(a, b){ return hmToMin(a.start) - hmToMin(b.start); });
                    weekGanttPendingChanges[key] = { memberId: memberId, iso: iso, segments: mergeOverlappingSegments(srcSegs) };

                    updateWeekGanttSaveBar();
                    buildWgDayPopupGantt();
                    updateWgPopupButtons();
                    var wd = Array.from({length:7}, function(_,i){ return toIso(addDays(currentWeekStart, i)); });
                    buildWeekGantt(currentStatusMembers, currentWeekStart, wd);
                }
                _wgPopupDragState = null;
            });

            // click: 바 선택 + 빈 트랙 클릭 생성
            wrap.addEventListener('click', function(e) {
                if (_wgPopupJustDragged) return;
                var delBtn = document.getElementById('btnWgPopupDelete');

                // 바 클릭 → 선택/해제
                var clickedBar = e.target.closest('.wg-popup-bar');
                if (clickedBar) {
                    var barMid = clickedBar.dataset.memberId;
                    var barStart = clickedBar.dataset.start;
                    var barEnd = clickedBar.dataset.end;

                    if (wgPopupBarInfo && String(wgPopupBarInfo.memberId) === String(barMid) && wgPopupBarInfo.start === barStart && wgPopupBarInfo.end === barEnd) {
                        wgPopupBarInfo = null;
                        if (delBtn) delBtn.classList.add('d-none');
                    } else {
                        wgPopupBarInfo = { memberId: barMid, iso: clickedBar.dataset.iso, start: barStart, end: barEnd };
                        if (delBtn) delBtn.classList.remove('d-none');
                    }
                    buildWgDayPopupGantt();
                    return;
                }

                // 빈 트랙 클릭 → 새 바 생성
                wgPopupBarInfo = null;
                if (delBtn) delBtn.classList.add('d-none');

                var track = e.target.closest('.mw-gantt-track-cell');
                if (!track) return;
                var row = track.closest('.mw-gantt-row');
                if (!row) return;
                var memberId = row.dataset.popupMemberId;
                var iso = row.dataset.iso;
                if (!memberId || !iso) return;

                var rect = track.getBoundingClientRect();
                var clickX = e.clientX - rect.left;
                var clickMin = Math.round(clickX / rect.width * TOTAL_MIN / 10) * 10;
                clickMin = Math.max(0, Math.min(clickMin, TOTAL_MIN - 60));
                var startHm = minToHm(clickMin + HOUR_START * 60);
                var endHm = minToHm(clickMin + 60 + HOUR_START * 60);

                var key = memberId + '_' + iso;
                var origData = allMemberWeekData[memberId] && allMemberWeekData[memberId][iso];
                var segs = ((weekGanttPendingChanges[key] && weekGanttPendingChanges[key].segments) || (origData && origData.segments) || []).map(function(s){ return Object.assign({}, s); });
                segs.push({ start: startHm, end: endHm });
                segs.sort(function(a, b){ return hmToMin(a.start) - hmToMin(b.start); });
                weekGanttPendingChanges[key] = { memberId: memberId, iso: iso, segments: mergeOverlappingSegments(segs) };

                updateWeekGanttSaveBar();
                buildWgDayPopupGantt();
                updateWgPopupButtons();
                var wd = Array.from({length:7}, function(_,i){ return toIso(addDays(currentWeekStart, i)); });
                buildWeekGantt(currentStatusMembers, currentWeekStart, wd);
            });
        }

        // 팝업 닫기/삭제 이벤트 등록
        (function initWgPopupHandlers() {
            var btnClose = document.getElementById('btnWgPopupClose');
            if (btnClose) btnClose.addEventListener('click', closeWgDayPopup);

            var overlay = document.getElementById('wgDayPopupOverlay');
            if (overlay) {
                overlay.addEventListener('click', function(e) {
                    if (e.target === overlay) closeWgDayPopup();
                });
            }

            // ESC 키로 닫기
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    if (dayDetailIso) closeDayDetailPanel();
                    else if (wgPopupIso) closeWgDayPopup();
                }
            });

            var btnDelete = document.getElementById('btnWgPopupDelete');
            if (btnDelete) {
                btnDelete.addEventListener('click', function() {
                    if (!wgPopupBarInfo) return;
                    var memberId = wgPopupBarInfo.memberId;
                    var iso = wgPopupBarInfo.iso;
                    var start = wgPopupBarInfo.start;
                    var end = wgPopupBarInfo.end;

                    var key = memberId + '_' + iso;
                    var origData = allMemberWeekData[memberId] && allMemberWeekData[memberId][iso];
                    var segs = ((weekGanttPendingChanges[key] && weekGanttPendingChanges[key].segments) || (origData && origData.segments) || []).map(function(s){ return Object.assign({}, s); });
                    var idx = segs.findIndex(function(s){ return s.start === start && s.end === end; });
                    if (idx >= 0) {
                        segs.splice(idx, 1);
                        if (segs.length > 0) {
                            weekGanttPendingChanges[key] = { memberId: memberId, iso: iso, segments: segs };
                        } else {
                            var origSegs = (origData && origData.segments) || [];
                            if (origSegs.length === 0) {
                                delete weekGanttPendingChanges[key];
                            } else {
                                weekGanttPendingChanges[key] = { memberId: memberId, iso: iso, segments: segs };
                            }
                        }
                    }

                    wgPopupBarInfo = null;
                    btnDelete.classList.add('d-none');
                    updateWeekGanttSaveBar();
                    buildWgDayPopupGantt();
                    updateWgPopupButtons();
                    var wd = Array.from({length:7}, function(_,i){ return toIso(addDays(currentWeekStart, i)); });
                    buildWeekGantt(currentStatusMembers, currentWeekStart, wd);
                });
            }

            // 팝업 내 취소 버튼: 해당 일자 변경 사항을 원래대로 되돌림
            var btnPopupCancel = document.getElementById('btnWgPopupCancel');
            if (btnPopupCancel) {
                btnPopupCancel.addEventListener('click', function() {
                    if (!wgPopupIso) return;
                    var iso = wgPopupIso;
                    // 원본 스냅샷으로 복원
                    var sortedMembers = currentStatusMembers || [];
                    sortedMembers.forEach(function(m) {
                        var key = m.id + '_' + iso;
                        var origData = allMemberWeekData[m.id] && allMemberWeekData[m.id][iso];
                        var origSegs = (origData && origData.segments) || [];
                        var origJson = wgPopupOrigSnapshot[key] || '[]';
                        var snapshotSegs = JSON.parse(origJson);
                        // 스냅샷과 원본이 같으면 pending에서 제거, 다르면 복원
                        if (JSON.stringify(origSegs) === origJson) {
                            delete weekGanttPendingChanges[key];
                        } else {
                            weekGanttPendingChanges[key] = { memberId: String(m.id), iso: iso, segments: snapshotSegs };
                        }
                    });
                    wgPopupBarInfo = null;
                    var delBtnEl = document.getElementById('btnWgPopupDelete');
                    if (delBtnEl) delBtnEl.classList.add('d-none');
                    updateWeekGanttSaveBar();
                    buildWgDayPopupGantt();
                    updateWgPopupButtons();
                    var wd = Array.from({length:7}, function(_,i){ return toIso(addDays(currentWeekStart, i)); });
                    buildWeekGantt(currentStatusMembers, currentWeekStart, wd);
                });
            }

            // 팝업 내 저장 버튼: 해당 일자의 변경된 멤버만 API 호출 후 저장
            var btnPopupSave = document.getElementById('btnWgPopupSave');
            if (btnPopupSave) {
                btnPopupSave.addEventListener('click', async function() {
                    if (!wgPopupIso) return;
                    var iso = wgPopupIso;
                    var sortedMembers = currentStatusMembers || [];

                    // 변경된 멤버만 찾기
                    var toSave = [];
                    sortedMembers.forEach(function(m) {
                        var key = m.id + '_' + iso;
                        var origData = allMemberWeekData[m.id] && allMemberWeekData[m.id][iso];
                        var currentSegs = (weekGanttPendingChanges[key] && weekGanttPendingChanges[key].segments) || (origData && origData.segments) || [];
                        var currentJson = JSON.stringify(currentSegs);
                        var origJson = wgPopupOrigSnapshot[key] || '[]';
                        if (currentJson !== origJson) {
                            toSave.push({ memberId: m.id, iso: iso, segments: currentSegs, key: key });
                        }
                    });

                    if (toSave.length === 0) return;

                    btnPopupSave.disabled = true;
                    btnPopupSave.textContent = '저장 중...';
                    var popupSaveUrl = (currentDataType === 'actual') ? API_ACTUAL_UPDATE : API_UPDATE;
                    try {
                        for (var i = 0; i < toSave.length; i++) {
                            var item = toSave[i];
                            var cleanSegs = item.segments.map(function(s){ return { start: s.start, end: s.end }; });
                            var body = { memberId: item.memberId, date: item.iso, segments: cleanSegs };
                            var resp = await fetch(popupSaveUrl, {
                                method: 'POST',
                                headers: {'Content-Type':'application/json', 'Accept':'application/json'},
                                body: JSON.stringify(body)
                            });
                            if (!resp.ok) {
                                var text = await resp.text().catch(function(){ return ''; });
                                alert('저장 실패: ' + resp.status + ' ' + text);
                                btnPopupSave.disabled = false;
                                btnPopupSave.textContent = '저장';
                                return;
                            }
                            // 저장 성공 → pending에서 제거
                            delete weekGanttPendingChanges[item.key];
                        }

                        // 저장 완료 후 새로고침
                        updateWeekGanttSaveBar();
                        await fetchAndRenderWeekTable(currentStatusMembers, currentWeekStart);
                        await loadSelectedMemberWeek();
                        updateCurrentTimeHighlight();

                        // 스냅샷 갱신 (저장된 상태가 새 원본)
                        sortedMembers.forEach(function(m) {
                            var key = m.id + '_' + iso;
                            var origData = allMemberWeekData[m.id] && allMemberWeekData[m.id][iso];
                            var segs = (origData && origData.segments) || [];
                            wgPopupOrigSnapshot[key] = JSON.stringify(segs);
                        });

                        // 팝업 갱신
                        buildWgDayPopupGantt();
                        updateWgPopupButtons();
                    } catch(e) {
