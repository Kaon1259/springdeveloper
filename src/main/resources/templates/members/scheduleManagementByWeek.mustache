        async function loadSelectedMemberWeek(){
            if (!selectedMember) {
                hideMemberWeekCard();
                return;
            }
            const weekStart = currentWeekStart;
            const weekEnd   = addDays(weekStart, 6);
            const startIso  = toIso(weekStart);
            const endIso    = toIso(weekEnd);

            memberWeekCard.classList.remove('d-none');
            memberWeekNameBadge.textContent = selectedMember.name || '-';
            memberWeekTitle.textContent = `개별 주간 일정 (${startIso} ~ ${endIso})`;

            const currentWeekDates = Array.from({length:7}, (_,i) => toIso(addDays(weekStart, i)));
            baseWeekDaysMap    = {};
            selectedWeekDaysMap = {};

            try {
                // 실제 근무시간 (ActualWorkSchedule) → 상단 바
                try {
                    const urlActual = `/api/schedule/${encodeURIComponent(selectedMember.id)}/${startIso}/${endIso}`;
                    const respActual = await fetch(urlActual, { headers:{'Accept':'application/json'} });
                    if (respActual.ok) {
                        const data = await respActual.json().catch(()=>null);
                        selectedWeekDaysMap = normalizeDays(data) || {};
                    }
                } catch(e){ console.error('[memberWeek] actual fetch error:', e); selectedWeekDaysMap = {}; }

                // 일정 (WorkSchedule) → 하단 바 (주간 타임테이블과 동일 데이터)
                try {
                    const url = `${API_BASE}/${encodeURIComponent(selectedMember.id)}/${startIso}/${endIso}`;
                    const resp = await fetch(url, { headers:{'Accept':'application/json'} });
                    if (resp.ok) {
                        const data = await resp.json().catch(()=>null);
                        baseWeekDaysMap = normalizeDays(data) || {};
                    } else {
                        baseWeekDaysMap = {};
                    }
                } catch(e){ console.error('[memberWeek] work fetch error:', e); baseWeekDaysMap = {}; }
            } catch(e){ console.error('[memberWeek] unexpected error:', e); }

            ganttPendingChanges = {};
            ganttTemplatePendingChanges = {};
            selectedBarInfo = null;
            closeDayDetailPanel();
            var _delBtn = document.getElementById('btnDeleteSelectedBar');
            if (_delBtn) _delBtn.classList.add('d-none');
            updateGanttSaveBar();
            updateNoPlanAlert(baseWeekDaysMap);
            buildMemberWeekGantt();
        }

        function hideMemberWeekCard(){
            closeDayDetailPanel();
            memberWeekCard.classList.add('d-none');
            if (memberWeekBody) memberWeekBody.classList.add('d-none');
            if (btnToggleMemberWeek) btnToggleMemberWeek.textContent = '펼치기';
        }

        function updateNoPlanAlert(dayMap){
            const hasAny = hasAnySegments(dayMap);
            if (noPlanAlert) noPlanAlert.classList.toggle('d-none', hasAny);
        }

        /* ============================================================
           Gantt 드래그앤드롭 상태
        ============================================================ */
        let ganttPendingChanges = {};  // { iso: [{ start:"HH:mm", end:"HH:mm" }, ...] }
        let ganttTemplatePendingChanges = {};  // { iso: [{ start:"HH:mm", end:"HH:mm" }, ...] } 일정(WorkSchedule) 변경
        const ganttSaveBar    = document.getElementById('ganttSaveBar');
        const ganttSaveInfo   = document.getElementById('ganttSaveInfo');
        const btnGanttSave    = document.getElementById('btnGanttSave');
        const btnGanttCancel  = document.getElementById('btnGanttCancel');

        function ganttHasChanges() {
            return Object.keys(ganttPendingChanges).length > 0 || Object.keys(ganttTemplatePendingChanges).length > 0;
        }
        function updateGanttSaveBar() {
            const actualCount = Object.keys(ganttPendingChanges).length;
            const templateCount = Object.keys(ganttTemplatePendingChanges).length;
            const total = actualCount + templateCount;
            if (total > 0) {
                ganttSaveBar.classList.add('visible');
                if (actualCount > 0 && templateCount > 0) {
                    ganttSaveInfo.textContent = `실제근무 ${actualCount}건 + 일정 ${templateCount}건 변경됨`;
                } else if (actualCount > 0) {
                    ganttSaveInfo.textContent = `${actualCount}건의 실제근무가 변경되었습니다`;
                } else {
                    ganttSaveInfo.textContent = `${templateCount}건의 일정이 변경되었습니다`;
                }
            } else {
                ganttSaveBar.classList.remove('visible');
            }
        }
        function resetGanttChanges() {
            ganttPendingChanges = {};
            ganttTemplatePendingChanges = {};
            closeDayDetailPanel();
            updateGanttSaveBar();
            buildMemberWeekGantt();
        }

        if (btnGanttCancel) btnGanttCancel.addEventListener('click', resetGanttChanges);
        if (btnGanttSave) btnGanttSave.addEventListener('click', async function() {
            if (!selectedMember) return;
            const mid = selectedMember.id;
            const actualEntries = Object.entries(ganttPendingChanges);
            const templateEntries = Object.entries(ganttTemplatePendingChanges);
            if (actualEntries.length === 0 && templateEntries.length === 0) return;

            btnGanttSave.disabled = true;
            btnGanttSave.textContent = '저장 중...';
            try {
                // 실제근무(ActualWorkSchedule) 저장
                for (const [dateIso, segments] of actualEntries) {
                    const cleanSegs = segments.map(function(s){ return { start: s.start, end: s.end }; });
                    const body = { memberId: mid, date: dateIso, segments: cleanSegs };
                    const resp = await fetch(API_ACTUAL_UPDATE, {
                        method: 'POST',
                        headers: {'Content-Type':'application/json', 'Accept':'application/json'},
                        body: JSON.stringify(body)
                    });
                    if (!resp.ok) {
                        const text = await resp.text().catch(()=>'');
                        alert(`실제근무 저장 실패 (${dateIso}): ${resp.status} ${text}`);
                        btnGanttSave.disabled = false;
                        btnGanttSave.textContent = '저장';
                        return;
                    }
                }
                // 일정(WorkSchedule) 저장
                for (const [dateIso, segments] of templateEntries) {
                    const cleanSegs = segments.map(function(s){ return { start: s.start, end: s.end }; });
                    const body = { memberId: mid, date: dateIso, segments: cleanSegs };
                    const resp = await fetch(API_UPDATE, {
                        method: 'POST',
                        headers: {'Content-Type':'application/json', 'Accept':'application/json'},
                        body: JSON.stringify(body)
                    });
                    if (!resp.ok) {
                        const text = await resp.text().catch(()=>'');
                        alert(`일정 저장 실패 (${dateIso}): ${resp.status} ${text}`);
                        btnGanttSave.disabled = false;
                        btnGanttSave.textContent = '저장';
                        return;
                    }
                }
                ganttPendingChanges = {};
                ganttTemplatePendingChanges = {};
                updateGanttSaveBar();
                await fetchAndRenderWeekTable(currentStatusMembers, currentWeekStart);
                await loadSelectedMemberWeek();
                clearAllDayEditButtons();
                updateCurrentTimeHighlight();
            } catch(e) {
                console.error(e);
                alert('저장 중 오류가 발생했습니다.');
            } finally {
                btnGanttSave.disabled = false;
                btnGanttSave.textContent = '저장';
            }
        });

        /* ============================================================
           Gantt 차트 렌더링 + 드래그앤드롭
        ============================================================ */
        function buildMemberWeekGantt(){
            const wrap = document.getElementById('memberGanttWrap');
            if (!wrap) return;
            const TOTAL_MIN = (HOUR_END - HOUR_START) * 60;
            const DAY_NAMES = ['월','화','수','목','금','토','일'];
            const todayIso  = toIso(new Date());

            // 멤버 고유색 → 빗살무늬 inline style 생성
            const mColor = selectedMember ? colorForMember(selectedMember) : '#198754';
            const _r = parseInt(mColor.slice(1,3),16), _g = parseInt(mColor.slice(3,5),16), _b = parseInt(mColor.slice(5,7),16);
            const barStyle = `background:rgba(${_r},${_g},${_b},0.55);border-color:rgba(${_r},${_g},${_b},0.7);`;

            // ─── 헤더 행 (시간 눈금) ───
            let html = '<div class="mw-gantt-header-row">';
            html += '<div class="mw-gantt-label-cell"><span style="font-size:0.73rem;color:#9ca3af;">요일</span></div>';
            html += '<div class="mw-gantt-track-header">';
            for (let h = HOUR_START; h < HOUR_END; h++) {
                const pct = ((h - HOUR_START) * 60 / TOTAL_MIN * 100).toFixed(3);
                html += `<div class="mw-gantt-time-label" style="left:${pct}%">${pad2(h)}:00</div>`;
                if (memberGridStep <= 30) {
                    const hPct = ((h - HOUR_START) * 60 + 30) / TOTAL_MIN * 100;
                    html += `<div class="mw-gantt-time-label minor" style="left:${hPct.toFixed(3)}%">:30</div>`;
                }
            }
            html += '</div>';
            html += '<div class="mw-gantt-hours-cell">근무시간</div>';
            html += '</div>';

            // ─── 요일 행들 ───
            html += '<div class="mw-gantt-body-wrap" id="ganttBodyWrap">';
            let weekTotalMin = 0;
            for (let offset = 0; offset < 7; offset++) {
                const date         = addDays(currentWeekStart, offset);
                const iso          = toIso(date);
                const isToday      = (iso === todayIso);
                const isPast       = (iso < todayIso);
                const isFuture     = (iso > todayIso);
                const templateSegs = ganttTemplatePendingChanges[iso] || (baseWeekDaysMap[iso]?.segments) || [];
                // 변경사항이 있으면 pending 데이터 사용, 없으면 원본
                const actualSegs   = ganttPendingChanges[iso] || (selectedWeekDaysMap[iso]?.segments) || [];
                const hasTemplate  = templateSegs.length > 0;
                const hasActual    = actualSegs.length > 0;
                const isModified   = !!ganttPendingChanges[iso];

                // 하단=일정(WorkSchedule) 모든 요일, 상단=실제근무(ActualWorkSchedule) 과거+오늘
                const showTemplate = true;      // 일정: 모든 요일에서 표시
                const showActual   = !isFuture; // 실제 근무: 과거 + 오늘만
                const onlyOne      = (showTemplate && !showActual) || (showActual && !showTemplate);
                const rowClasses   = [
                    'mw-gantt-row',
                    isToday ? 'today-row' : '',
                    isPast  ? 'past-day'  : '',
                    isFuture ? 'future-day' : '',
                    onlyOne ? 'single-bar-mode' : '',
                    (!hasTemplate || !showTemplate) ? 'no-template' : ''
                ].filter(Boolean).join(' ');

                html += `<div class="${rowClasses}" data-iso="${iso}" data-offset="${offset}">`;
                const detailActive = (dayDetailIso === iso) ? ' active-detail' : '';
                html += `<div class="mw-gantt-label-cell"><div class="mw-gantt-day-name">${DAY_NAMES[offset]}</div><div class="mw-gantt-day-date">${pad2(date.getMonth()+1)}/${pad2(date.getDate())}</div><button class="btn-day-detail${detailActive}" data-detail-iso="${iso}" data-detail-offset="${offset}">보기</button></div>`;
                html += `<div class="mw-gantt-track-cell">`;

                // 일정(WorkSchedule): 모든 요일 표시
                if (showTemplate) {
                    const renderTemplateSegs = ganttTemplatePendingChanges[iso] || templateSegs;
                    const isTemplateModified = !!ganttTemplatePendingChanges[iso];

                    renderTemplateSegs.forEach((seg, tSegIdx) => {
                        const effStart = Math.max(hmToMin(seg.start), HOUR_START * 60);
                        const effEnd   = Math.min(hmToMin(seg.end),   HOUR_END   * 60);
                        const leftPct  = (effStart - HOUR_START * 60) / TOTAL_MIN * 100;
                        const widthPct = Math.max(0, effEnd - effStart) / TOTAL_MIN * 100;
                        const tModClass = isTemplateModified ? ' modified' : '';
                        const tSelClass = (selectedBarInfo && selectedBarInfo.type === 'template' && selectedBarInfo.iso === iso && selectedBarInfo.start === seg.start && selectedBarInfo.end === seg.end) ? ' mw-bar-selected' : '';
                        const tNewAttr = seg.isNew ? ' data-is-new="true"' : '';
                        if (widthPct > 0) {
                            html += `<div class="mw-gantt-bar mw-gantt-bar-template${tModClass}${tSelClass}"${tNewAttr} data-seg-idx="${tSegIdx}" data-iso="${iso}" data-start="${seg.start}" data-end="${seg.end}" data-bar-type="template" style="left:${leftPct.toFixed(3)}%;width:${widthPct.toFixed(3)}%;">`;
                            html += `<div class="bar-handle bar-handle-left"></div>`;
                            html += `<span class="mw-gantt-bar-time">${seg.start}~${seg.end}</span>`;
                            html += `<div class="bar-handle bar-handle-right"></div>`;
                            html += `<div class="mw-gantt-bar-tooltip">${seg.start} ~ ${seg.end}</div>`;
                            html += `</div>`;
                        }
                    });
                }

                // 실제 근무시간(ActualWorkSchedule): 과거 + 오늘만 표시
                if (showActual) {
                    actualSegs.forEach((seg, segIdx) => {
                        const effStart = Math.max(hmToMin(seg.start), HOUR_START * 60);
                        const effEnd   = Math.min(hmToMin(seg.end),   HOUR_END   * 60);
                        const leftPct  = (effStart - HOUR_START * 60) / TOTAL_MIN * 100;
                        const widthPct = Math.max(0, effEnd - effStart) / TOTAL_MIN * 100;
                        const modClass = isModified ? ' modified' : '';
                        const selClass = (selectedBarInfo && selectedBarInfo.type === 'actual' && selectedBarInfo.iso === iso && selectedBarInfo.start === seg.start && selectedBarInfo.end === seg.end) ? ' mw-bar-selected' : '';
                        const isNewAttr = seg.isNew ? ' data-is-new="true"' : '';
                        if (widthPct > 0) {
                            html += `<div class="mw-gantt-bar mw-gantt-bar-actual${modClass}${selClass}"${isNewAttr} data-seg-idx="${segIdx}" data-iso="${iso}" data-start="${seg.start}" data-end="${seg.end}" style="left:${leftPct.toFixed(3)}%;width:${widthPct.toFixed(3)}%;${barStyle}">`;
                            html += `<div class="bar-handle bar-handle-left"></div>`;
                            html += `<span class="mw-gantt-bar-time">${seg.start}~${seg.end}</span>`;
                            html += `<div class="bar-handle bar-handle-right"></div>`;
                            html += `<div class="mw-gantt-bar-tooltip">${seg.start} ~ ${seg.end}</div>`;
                            html += `</div>`;
                        }
                    });
                }

                html += '</div>';

                // 근무시간 셀: 일정(WorkSchedule) 기준
                let dayMin = 0;
                const segsForHours = templateSegs;
                segsForHours.forEach(function(seg) {
                    dayMin += Math.max(0, hmToMin(seg.end) - hmToMin(seg.start));
                });
                weekTotalMin += dayMin;
                const hrsClass = dayMin > 0 ? 'has-hours' : 'zero-hours';
                const hrsText = dayMin > 0
                    ? (Math.floor(dayMin / 60) + 'h' + (dayMin % 60 > 0 ? ' ' + (dayMin % 60) + 'm' : ''))
                    : '-';
                html += `<div class="mw-gantt-hours-cell ${hrsClass}">${hrsText}</div>`;

                html += '</div>';
            }
            // 주간 합계 행
            const wkH = Math.floor(weekTotalMin / 60);
            const wkM = weekTotalMin % 60;
            const wkText = weekTotalMin > 0 ? (wkH + 'h' + (wkM > 0 ? ' ' + wkM + 'm' : '')) : '-';
            html += '<div class="mw-gantt-row" style="background:#f5f7fa;border-top:2px solid #dde3ea;height:36px;">';
            html += '<div class="mw-gantt-label-cell" style="height:36px;"><div class="mw-gantt-day-name" style="font-size:.75rem;color:#5b4434;">합계</div></div>';
            html += '<div class="mw-gantt-track-cell"></div>';
            html += `<div class="mw-gantt-hours-cell has-hours" style="font-weight:700;font-size:.8rem;">${wkText}</div>`;
            html += '</div>';

            html += '</div>';
            wrap.innerHTML = html;

            // ─── 바 드래그 이벤트 등록 ───
            initGanttBarDrag(wrap);

            // ─── 보기 버튼 클릭 이벤트 ───
            wrap.querySelectorAll('.btn-day-detail').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var iso = this.dataset.detailIso;
                    if (dayDetailIso === iso) {
                        closeDayDetailPanel();
                    } else {
                        openDayDetailPanel(iso);
                    }
                });
            });

            // 상세 패널이 열려 있으면 동기화
            if (dayDetailIso) {
                buildDayDetailGantt();
                var activeBtn = wrap.querySelector('.btn-day-detail[data-detail-iso="' + dayDetailIso + '"]');
                if (activeBtn) activeBtn.classList.add('active-detail');
            }
        }

        /* ============================================================
           요일 상세 편집 팝업
        ============================================================ */
        // 팝업용 스냅샷 (취소 시 복원)
        let ddPopupOrigSnapshot = {}; // { template: [...], actual: [...] }

        function openDayDetailPanel(iso) {
            if (!selectedMember) return;
            dayDetailIso = iso;
            dayDetailBarInfo = null;

            var overlay = document.getElementById('ddPopupOverlay');
            var title = document.getElementById('dayDetailTitle');
            var subtitle = document.getElementById('dayDetailSubtitle');
            var delBtn = document.getElementById('btnDeleteDayDetailBar');
            if (!overlay) return;

            var date = new Date(iso + 'T00:00:00');
            var dayNames = ['일','월','화','수','목','금','토'];
            var dayName = dayNames[date.getDay()];
            title.textContent = dayName + '요일 (' + iso + ')';
            subtitle.textContent = (selectedMember.name || '-') + ' · 바를 드래그하여 편집';
            if (delBtn) delBtn.classList.add('d-none');

            // 스냅샷 저장 (취소 시 복원)
            var tSegs = ganttTemplatePendingChanges[iso] || (baseWeekDaysMap[iso] && baseWeekDaysMap[iso].segments) || [];
            var aSegs = ganttPendingChanges[iso] || (selectedWeekDaysMap[iso] && selectedWeekDaysMap[iso].segments) || [];
            ddPopupOrigSnapshot = {
                template: JSON.parse(JSON.stringify(tSegs)),
                actual: JSON.parse(JSON.stringify(aSegs)),
                hadTemplatePending: !!ganttTemplatePendingChanges[iso],
                hadActualPending: !!ganttPendingChanges[iso]
            };

            overlay.classList.remove('d-none');
            document.body.style.overflow = 'hidden';

            // 보기 버튼 활성 상태 토글
            document.querySelectorAll('.btn-day-detail').forEach(function(b) { b.classList.remove('active-detail'); });
            var activeBtn = document.querySelector('.btn-day-detail[data-detail-iso="' + iso + '"]');
            if (activeBtn) activeBtn.classList.add('active-detail');

            buildDayDetailGantt();
            initDayDetailBarDrag();
            updateDdPopupButtons();
        }

        function closeDayDetailPanel() {
            var overlay = document.getElementById('ddPopupOverlay');
            if (overlay) overlay.classList.add('d-none');
            document.body.style.overflow = '';
            dayDetailIso = null;
            dayDetailBarInfo = null;
            document.querySelectorAll('.btn-day-detail').forEach(function(b) { b.classList.remove('active-detail'); });
        }

        function updateDdPopupButtons() {
            var saveBtn = document.getElementById('btnDdPopupSave');
            var cancelBtn = document.getElementById('btnDdPopupCancel');
            var changeInfo = document.getElementById('ddPopupChangeInfo');
            if (!saveBtn || !cancelBtn || !changeInfo) return;

            var iso = dayDetailIso;
            if (!iso) { saveBtn.classList.add('d-none'); cancelBtn.classList.add('d-none'); changeInfo.textContent = ''; return; }

            var currentT = ganttTemplatePendingChanges[iso] || (baseWeekDaysMap[iso] && baseWeekDaysMap[iso].segments) || [];
            var currentA = ganttPendingChanges[iso] || (selectedWeekDaysMap[iso] && selectedWeekDaysMap[iso].segments) || [];
            var origT = ddPopupOrigSnapshot.template || [];
            var origA = ddPopupOrigSnapshot.actual || [];

            var tChanged = JSON.stringify(currentT) !== JSON.stringify(origT);
            var aChanged = JSON.stringify(currentA) !== JSON.stringify(origA);
            var hasChanges = tChanged || aChanged;

            if (hasChanges) {
                saveBtn.classList.remove('d-none');
                cancelBtn.classList.remove('d-none');
                var parts = [];
                if (tChanged) parts.push('일정');
                if (aChanged) parts.push('실제근무');
                changeInfo.textContent = parts.join(', ') + ' 변경됨';
            } else {
                saveBtn.classList.add('d-none');
                cancelBtn.classList.add('d-none');
                changeInfo.textContent = '';
            }
        }

        function buildDayDetailGantt() {
            var wrap = document.getElementById('dayDetailGanttWrap');
            if (!wrap || !dayDetailIso) return;

            var iso = dayDetailIso;
            var TOTAL_MIN = (HOUR_END - HOUR_START) * 60;
            var todayIso = toIso(new Date());
            var isFuture = (iso > todayIso);

            var mColor = selectedMember ? colorForMember(selectedMember) : '#198754';
            var _r = parseInt(mColor.slice(1,3),16), _g = parseInt(mColor.slice(3,5),16), _b = parseInt(mColor.slice(5,7),16);
            var barStyle = 'background:rgba(' + _r + ',' + _g + ',' + _b + ',0.55);border-color:rgba(' + _r + ',' + _g + ',' + _b + ',0.7);';

            // ─── 헤더 행 (시간 눈금) ───
            var html = '<div class="mw-gantt-header-row">';
            html += '<div class="mw-gantt-label-cell"><span style="font-size:0.73rem;color:#9ca3af;">구분</span></div>';
            html += '<div class="mw-gantt-track-header">';
            for (var h = HOUR_START; h < HOUR_END; h++) {
                var pct = ((h - HOUR_START) * 60 / TOTAL_MIN * 100).toFixed(3);
                html += '<div class="mw-gantt-time-label" style="left:' + pct + '%">' + pad2(h) + ':00</div>';
                var hPct = ((h - HOUR_START) * 60 + 30) / TOTAL_MIN * 100;
                html += '<div class="mw-gantt-time-label minor" style="left:' + hPct.toFixed(3) + '%">:30</div>';
            }
            html += '</div>';
            html += '<div class="mw-gantt-hours-cell">합계</div>';
            html += '</div>';

            var templateSegs = ganttTemplatePendingChanges[iso] || (baseWeekDaysMap[iso] && baseWeekDaysMap[iso].segments) || [];
            var actualSegs = ganttPendingChanges[iso] || (selectedWeekDaysMap[iso] && selectedWeekDaysMap[iso].segments) || [];
            var showActual = !isFuture;

            html += '<div class="mw-gantt-body-wrap">';

            // ─── Row 1: 일정 (WorkSchedule) ───
            var isTemplateModified = !!ganttTemplatePendingChanges[iso];
            html += '<div class="mw-gantt-row single-bar-mode" data-iso="' + iso + '" data-detail-bar-type="template">';
            html += '<div class="mw-gantt-label-cell"><div class="mw-gantt-day-name" style="font-size:.75rem;">일정</div></div>';
            html += '<div class="mw-gantt-track-cell">';
            templateSegs.forEach(function(seg, idx) {
                var effStart = Math.max(hmToMin(seg.start), HOUR_START * 60);
                var effEnd = Math.min(hmToMin(seg.end), HOUR_END * 60);
                var leftPct = (effStart - HOUR_START * 60) / TOTAL_MIN * 100;
                var widthPct = Math.max(0, effEnd - effStart) / TOTAL_MIN * 100;
                var modClass = isTemplateModified ? ' modified' : '';
                var selClass = (dayDetailBarInfo && dayDetailBarInfo.type === 'template' && dayDetailBarInfo.start === seg.start && dayDetailBarInfo.end === seg.end) ? ' mw-bar-selected' : '';
                if (widthPct > 0) {
                    html += '<div class="mw-gantt-bar mw-gantt-bar-template' + modClass + selClass + '" data-seg-idx="' + idx + '" data-iso="' + iso + '" data-start="' + seg.start + '" data-end="' + seg.end + '" data-bar-type="template" style="left:' + leftPct.toFixed(3) + '%;width:' + widthPct.toFixed(3) + '%;">';
                    html += '<div class="bar-handle bar-handle-left"></div>';
                    html += '<span class="mw-gantt-bar-time">' + seg.start + '~' + seg.end + '</span>';
                    html += '<div class="bar-handle bar-handle-right"></div>';
                    html += '<div class="mw-gantt-bar-tooltip">' + seg.start + ' ~ ' + seg.end + '</div>';
                    html += '</div>';
                }
            });
            html += '</div>';
            var templateMin = 0;
            templateSegs.forEach(function(seg) { templateMin += Math.max(0, hmToMin(seg.end) - hmToMin(seg.start)); });
            var tHrs = templateMin > 0 ? (Math.floor(templateMin/60) + 'h' + (templateMin%60>0 ? ' '+(templateMin%60)+'m' : '')) : '-';
            html += '<div class="mw-gantt-hours-cell ' + (templateMin>0?'has-hours':'zero-hours') + '">' + tHrs + '</div>';
            html += '</div>';

            // ─── Row 2: 실제근무 (ActualWorkSchedule) ───
            if (showActual) {
                var isActualModified = !!ganttPendingChanges[iso];
                html += '<div class="mw-gantt-row single-bar-mode" data-iso="' + iso + '" data-detail-bar-type="actual">';
                html += '<div class="mw-gantt-label-cell"><div class="mw-gantt-day-name" style="font-size:.75rem;">실제근무</div></div>';
                html += '<div class="mw-gantt-track-cell">';
                actualSegs.forEach(function(seg, idx) {
                    var effStart = Math.max(hmToMin(seg.start), HOUR_START * 60);
                    var effEnd = Math.min(hmToMin(seg.end), HOUR_END * 60);
                    var leftPct = (effStart - HOUR_START * 60) / TOTAL_MIN * 100;
                    var widthPct = Math.max(0, effEnd - effStart) / TOTAL_MIN * 100;
                    var modClass = isActualModified ? ' modified' : '';
                    var selClass = (dayDetailBarInfo && dayDetailBarInfo.type === 'actual' && dayDetailBarInfo.start === seg.start && dayDetailBarInfo.end === seg.end) ? ' mw-bar-selected' : '';
                    if (widthPct > 0) {
                        html += '<div class="mw-gantt-bar mw-gantt-bar-actual' + modClass + selClass + '" data-seg-idx="' + idx + '" data-iso="' + iso + '" data-start="' + seg.start + '" data-end="' + seg.end + '" data-bar-type="actual" style="left:' + leftPct.toFixed(3) + '%;width:' + widthPct.toFixed(3) + '%;' + barStyle + '">';
                        html += '<div class="bar-handle bar-handle-left"></div>';
                        html += '<span class="mw-gantt-bar-time">' + seg.start + '~' + seg.end + '</span>';
                        html += '<div class="bar-handle bar-handle-right"></div>';
                        html += '<div class="mw-gantt-bar-tooltip">' + seg.start + ' ~ ' + seg.end + '</div>';
                        html += '</div>';
                    }
                });
                html += '</div>';
                var actualMin = 0;
                actualSegs.forEach(function(seg) { actualMin += Math.max(0, hmToMin(seg.end) - hmToMin(seg.start)); });
                var aHrs = actualMin > 0 ? (Math.floor(actualMin/60) + 'h' + (actualMin%60>0 ? ' '+(actualMin%60)+'m' : '')) : '-';
                html += '<div class="mw-gantt-hours-cell ' + (actualMin>0?'has-hours':'zero-hours') + '">' + aHrs + '</div>';
                html += '</div>';
            }

            html += '</div>';
            wrap.innerHTML = html;
        }

        /* ============================================================
           Gantt 바 드래그/리사이즈 핸들러
        ============================================================ */
        let _memberDragState = null;
        let _memberDragInited = false;
        let _memberJustDragged = false;
        function initGanttBarDrag(wrap) {
            if (_memberDragInited) return;
            _memberDragInited = true;
            const TOTAL_MIN = (HOUR_END - HOUR_START) * 60;

            function getTrackRect(bar) {
                const trackCell = bar.closest('.mw-gantt-track-cell');
                return trackCell ? trackCell.getBoundingClientRect() : null;
            }

            function pxToMin(px, trackWidth) {
                return Math.round(px / trackWidth * TOTAL_MIN / 10) * 10;
            }

            function clampMin(m) {
                return Math.max(0, Math.min(m, TOTAL_MIN));
            }

            wrap.addEventListener('mousedown', function(e) {
                const bar = e.target.closest('.mw-gantt-bar-actual') || e.target.closest('.mw-gantt-bar-template');
                if (!bar) return;
                e.preventDefault();
                e.stopPropagation();

                const trackRect = getTrackRect(bar);
                if (!trackRect) return;

                const iso      = bar.dataset.iso;
                const segIdx   = parseInt(bar.dataset.segIdx, 10);
                const barType  = bar.dataset.barType || 'actual';  // 'actual' or 'template'
                const dayCode  = bar.dataset.dayCode || '';
                const startMin = hmToMin(bar.dataset.start) - HOUR_START * 60;
                const endMin   = hmToMin(bar.dataset.end) - HOUR_START * 60;
                const duration = endMin - startMin;

                // 핸들인지 이동인지 구분
                let mode = 'move';
                if (e.target.classList.contains('bar-handle-left'))  mode = 'resize-left';
                if (e.target.classList.contains('bar-handle-right')) mode = 'resize-right';

                bar.classList.add(mode === 'move' ? 'dragging' : 'resizing');

                _memberDragState = {
                    bar, iso, segIdx, mode, trackRect,
                    barType, dayCode,
                    origStartMin: startMin,
                    origEndMin: endMin,
                    origDuration: duration,
                    mouseStartX: e.clientX,
                    startX: e.clientX,
                    startY: e.clientY,
                    hasMoved: false,
                    currentStartMin: startMin,
                    currentEndMin: endMin,
                    targetIso: iso
                };
                // 플로팅 툴팁 표시
                const dtt = document.getElementById('dragTimeTooltip');
                if (dtt) {
                    const origS = minToHm(startMin + HOUR_START*60), origE = minToHm(endMin + HOUR_START*60);
                    dtt.innerHTML = `${origS} <span class="dtt-arrow">→</span> ${origE}`;
                    dtt.style.left = (e.clientX + 14) + 'px';
                    dtt.style.top  = (e.clientY - 36) + 'px';
                    dtt.classList.add('visible');
                }
            });

            document.addEventListener('mousemove', function(e) {
                if (!_memberDragState) return;
                e.preventDefault();

                const st = _memberDragState;
                if (!st.hasMoved) {
                    const dist = Math.abs(e.clientX - st.startX) + Math.abs(e.clientY - st.startY);
                    if (dist < 3) return;
                    st.hasMoved = true;
                }

                const { bar, mode, trackRect, origStartMin, origEndMin, origDuration, mouseStartX } = _memberDragState;
                const dx = e.clientX - mouseStartX;
                const deltaMin = pxToMin(dx, trackRect.width);

                let newStart, newEnd;
                if (mode === 'move') {
                    newStart = clampMin(origStartMin + deltaMin);
                    newEnd   = newStart + origDuration;
                    if (newEnd > TOTAL_MIN) { newEnd = TOTAL_MIN; newStart = newEnd - origDuration; }
                    if (newStart < 0) { newStart = 0; newEnd = origDuration; }
                } else if (mode === 'resize-left') {
                    newStart = clampMin(origStartMin + deltaMin);
                    newEnd   = origEndMin;
                    if (newStart >= newEnd - 10) newStart = newEnd - 10;
                } else {
                    newStart = origStartMin;
                    newEnd   = clampMin(origEndMin + deltaMin);
                    if (newEnd <= newStart + 10) newEnd = newStart + 10;
                }

                _memberDragState.currentStartMin = newStart;
                _memberDragState.currentEndMin   = newEnd;

                // 바 위치 업데이트
                const leftPct  = newStart / TOTAL_MIN * 100;
                const widthPct = (newEnd - newStart) / TOTAL_MIN * 100;
                bar.style.left  = leftPct.toFixed(3) + '%';
                bar.style.width = widthPct.toFixed(3) + '%';

                // 플로팅 툴팁 업데이트
                const dtt = document.getElementById('dragTimeTooltip');
                if (dtt) {
                    const newS = minToHm(newStart + HOUR_START*60), newE = minToHm(newEnd + HOUR_START*60);
                    const origS = minToHm(_memberDragState.origStartMin + HOUR_START*60);
                    const origE = minToHm(_memberDragState.origEndMin + HOUR_START*60);
                    const changed = (newS !== origS || newE !== origE);
                    dtt.innerHTML = changed
                        ? `<span class="dtt-changed">${newS} <span class="dtt-arrow">→</span> ${newE}</span>`
                        : `${newS} <span class="dtt-arrow">→</span> ${newE}`;
                    dtt.style.left = (e.clientX + 14) + 'px';
                    dtt.style.top  = (e.clientY - 36) + 'px';
                }

                // 다른 행으로 이동 감지 (move 모드만)
                if (mode === 'move') {
                    const rows = wrap.querySelectorAll('.mw-gantt-row');
                    rows.forEach(r => r.classList.remove('drop-target'));
                    rows.forEach(r => {
                        const rRect = r.getBoundingClientRect();
                        if (e.clientY >= rRect.top && e.clientY <= rRect.bottom) {
                            if (r.dataset.iso !== _memberDragState.iso) {
                                r.classList.add('drop-target');
                            }
                            _memberDragState.targetIso = r.dataset.iso;
                        }
                    });
                }
            });

            document.addEventListener('mouseup', function(e) {
                if (!_memberDragState) return;

                const st = _memberDragState;
                st.bar.classList.remove('dragging', 'resizing');
                wrap.querySelectorAll('.mw-gantt-row').forEach(r => r.classList.remove('drop-target'));
                // 플로팅 툴팁 숨기기
                const dtt = document.getElementById('dragTimeTooltip');
                if (dtt) dtt.classList.remove('visible');

                // 움직임이 없었으면 드래그 아님 (클릭으로 처리)
                if (!st.hasMoved) {
                    _memberDragState = null;
                    return;
                }
                _memberJustDragged = true;
                setTimeout(function(){ _memberJustDragged = false; }, 0);

                // 드래그 후 선택 해제
                selectedBarInfo = null;
                const _delBtnEl = document.getElementById('btnDeleteSelectedBar');
                if (_delBtnEl) _delBtnEl.classList.add('d-none');

                const { bar, iso, segIdx, mode, currentStartMin, currentEndMin, targetIso, barType, dayCode } = st;
                const newStart = minToHm(currentStartMin + HOUR_START * 60);
                const newEnd   = minToHm(currentEndMin   + HOUR_START * 60);
                const origStart = bar.dataset.start;
                const origEnd   = bar.dataset.end;

                // 변경이 있는 경우만 처리
                if (newStart !== origStart || newEnd !== origEnd || targetIso !== iso) {
                    if (barType === 'template') {
                        // ─── 일정(WorkSchedule) 바 변경 ───
                        const srcSegs = (ganttTemplatePendingChanges[iso] || (baseWeekDaysMap[iso]?.segments) || []).map(s => ({...s}));

                        if (targetIso !== iso) {
                            // 다른 요일로 이동
                            srcSegs.splice(segIdx, 1);
                            ganttTemplatePendingChanges[iso] = srcSegs;

                            const destSegs = (ganttTemplatePendingChanges[targetIso] || (baseWeekDaysMap[targetIso]?.segments) || []).map(s => ({...s}));
                            destSegs.push({ start: newStart, end: newEnd });
                            destSegs.sort((a, b) => hmToMin(a.start) - hmToMin(b.start));
                            ganttTemplatePendingChanges[targetIso] = mergeOverlappingSegments(destSegs);
                        } else {
                            // 같은 요일 내 이동/리사이즈
                            srcSegs[segIdx] = { start: newStart, end: newEnd };
                            srcSegs.sort((a, b) => hmToMin(a.start) - hmToMin(b.start));
                            ganttTemplatePendingChanges[iso] = mergeOverlappingSegments(srcSegs);
                        }
                    } else {
                        // ─── 확정 일정 바 변경 ───
                        const sourceSegs = (ganttPendingChanges[iso] || (selectedWeekDaysMap[iso]?.segments) || []).map(s => ({...s}));
                        const wasNew = sourceSegs[segIdx] && sourceSegs[segIdx].isNew;

                        if (targetIso !== iso) {
                            sourceSegs.splice(segIdx, 1);
                            ganttPendingChanges[iso] = sourceSegs;

                            const destSegs = (ganttPendingChanges[targetIso] || (selectedWeekDaysMap[targetIso]?.segments) || []).map(s => ({...s}));
                            const newSeg = { start: newStart, end: newEnd };
                            if (wasNew) newSeg.isNew = true;
                            destSegs.push(newSeg);
                            destSegs.sort((a, b) => hmToMin(a.start) - hmToMin(b.start));
                            ganttPendingChanges[targetIso] = mergeOverlappingSegments(destSegs);
                        } else {
                            const newSeg = { start: newStart, end: newEnd };
                            if (wasNew) newSeg.isNew = true;
                            sourceSegs[segIdx] = newSeg;
                            sourceSegs.sort((a, b) => hmToMin(a.start) - hmToMin(b.start));
                            ganttPendingChanges[iso] = mergeOverlappingSegments(sourceSegs);
                        }
                    }

                    updateGanttSaveBar();
                    buildMemberWeekGantt();
                }

                _memberDragState = null;
            });

            // ─── 클릭: 바 선택/삭제 + 빈 트랙 → 새 일정 생성 ───
            wrap.addEventListener('click', function(e) {
                if (_memberJustDragged) return;
                const delBtn = document.getElementById('btnDeleteSelectedBar');

                // 실제 근무 바(상단) 클릭 → 선택/해제 토글
                const actualBar = e.target.closest('.mw-gantt-bar-actual');
                if (actualBar) {
                    const barIso   = actualBar.dataset.iso;
                    const barStart = actualBar.dataset.start;
                    const barEnd   = actualBar.dataset.end;

                    if (selectedBarInfo && selectedBarInfo.type === 'actual' && selectedBarInfo.iso === barIso && selectedBarInfo.start === barStart && selectedBarInfo.end === barEnd) {
                        selectedBarInfo = null;
                        if (delBtn) delBtn.classList.add('d-none');
                    } else {
                        selectedBarInfo = { type: 'actual', iso: barIso, start: barStart, end: barEnd };
                        if (delBtn) delBtn.classList.remove('d-none');
                    }
                    buildMemberWeekGantt();
                    return;
                }

                // 일정 바(하단) 클릭 → 선택/해제 토글
                const templateBar = e.target.closest('.mw-gantt-bar-template');
                if (templateBar) {
                    const barIso   = templateBar.dataset.iso;
                    const barStart = templateBar.dataset.start;
                    const barEnd   = templateBar.dataset.end;

                    if (selectedBarInfo && selectedBarInfo.type === 'template' && selectedBarInfo.iso === barIso && selectedBarInfo.start === barStart && selectedBarInfo.end === barEnd) {
                        selectedBarInfo = null;
                        if (delBtn) delBtn.classList.add('d-none');
                    } else {
                        selectedBarInfo = { type: 'template', iso: barIso, start: barStart, end: barEnd };
                        if (delBtn) delBtn.classList.remove('d-none');
                    }
                    buildMemberWeekGantt();
                    return;
                }

                // 빈 트랙 클릭 → 선택 해제 + 보기(dataType)에 따라 새 바 생성
                selectedBarInfo = null;
                if (delBtn) delBtn.classList.add('d-none');

                var track = e.target.closest('.mw-gantt-track-cell');
                if (!track) return;
                var row = track.closest('.mw-gantt-row');
                if (!row) return;
                var iso = row.dataset.iso;
                if (!iso) return;

                var rect = track.getBoundingClientRect();
                var clickX = e.clientX - rect.left;
                var clickMin = Math.round(clickX / rect.width * TOTAL_MIN / 10) * 10;
                clickMin = Math.max(0, Math.min(clickMin, TOTAL_MIN - 60));
                var startHm = minToHm(clickMin + HOUR_START * 60);
                var endHm = minToHm(clickMin + 60 + HOUR_START * 60);

                if (currentDataType === 'actual') {
                    // 근무시간(ActualWorkSchedule) 바 생성
                    var segs = (ganttPendingChanges[iso] || (selectedWeekDaysMap[iso] && selectedWeekDaysMap[iso].segments) || []).map(function(s){ return Object.assign({}, s); });
                    segs.push({ start: startHm, end: endHm, isNew: true });
                    segs.sort(function(a, b){ return hmToMin(a.start) - hmToMin(b.start); });
                    ganttPendingChanges[iso] = mergeOverlappingSegments(segs);
                } else {
                    // 일정(WorkSchedule) 바 생성
                    var segs = (ganttTemplatePendingChanges[iso] || (baseWeekDaysMap[iso] && baseWeekDaysMap[iso].segments) || []).map(function(s){ return Object.assign({}, s); });
                    segs.push({ start: startHm, end: endHm, isNew: true });
                    segs.sort(function(a, b){ return hmToMin(a.start) - hmToMin(b.start); });
                    ganttTemplatePendingChanges[iso] = mergeOverlappingSegments(segs);
                }
                updateGanttSaveBar();
                buildMemberWeekGantt();
            });
        }

        function mergeConsecutive(arr){
            const out=[]; if(!arr.length) return out;
            arr.sort((a,b)=>a-b);
            let s=arr[0], p=arr[0];
            for(let i=1;i<arr.length;i++){
                if(arr[i]===p+1){ p=arr[i]; continue; }
                out.push([s,p]); s=p=arr[i];
            }
            out.push([s,p]);
            return out;
        }

        // 겹치는 세그먼트 자동 병합
        function mergeOverlappingSegments(segments) {
            if (!segments || segments.length <= 1) return segments;
            const sorted = [...segments].sort((a, b) => hmToMin(a.start) - hmToMin(b.start));
            const merged = [{ ...sorted[0] }];
            for (let i = 1; i < sorted.length; i++) {
                const last = merged[merged.length - 1];
                const curr = sorted[i];
                if (hmToMin(curr.start) <= hmToMin(last.end)) {
                    // 겹침 또는 인접 → 병합
                    if (hmToMin(curr.end) > hmToMin(last.end)) {
                        last.end = curr.end;
                    }
                    if (curr.isNew) last.isNew = true;
                } else {
                    merged.push({ ...curr });
                }
            }
            return merged;
        }

        /* ============================================================
           요일 상세 패널 드래그/리사이즈/클릭 핸들러
        ============================================================ */
        function initDayDetailBarDrag() {
            var wrap = document.getElementById('dayDetailGanttWrap');
            if (!wrap) return;
            if (_dayDetailDragInited) return;
            _dayDetailDragInited = true;
            var TOTAL_MIN = (HOUR_END - HOUR_START) * 60;

            function getTrackRect(bar) {
                var trackCell = bar.closest('.mw-gantt-track-cell');
                return trackCell ? trackCell.getBoundingClientRect() : null;
            }
            function pxToMin(px, trackWidth) {
                return Math.round(px / trackWidth * TOTAL_MIN / 10) * 10;
            }
            function clampMin(m) {
                return Math.max(0, Math.min(m, TOTAL_MIN));
            }

            // mousedown: 바 드래그 시작
            wrap.addEventListener('mousedown', function(e) {
                var bar = e.target.closest('.mw-gantt-bar-actual') || e.target.closest('.mw-gantt-bar-template');
                if (!bar) return;
                e.preventDefault();
                e.stopPropagation();

                var trackRect = getTrackRect(bar);
                if (!trackRect) return;

                var iso = bar.dataset.iso;
                var segIdx = parseInt(bar.dataset.segIdx, 10);
                var barType = bar.dataset.barType || 'actual';
                var startMin = hmToMin(bar.dataset.start) - HOUR_START * 60;
                var endMin = hmToMin(bar.dataset.end) - HOUR_START * 60;
                var duration = endMin - startMin;

                var mode = 'move';
                if (e.target.classList.contains('bar-handle-left')) mode = 'resize-left';
                if (e.target.classList.contains('bar-handle-right')) mode = 'resize-right';

                bar.classList.add(mode === 'move' ? 'dragging' : 'resizing');

                _dayDetailDragState = {
                    bar: bar, iso: iso, segIdx: segIdx, mode: mode, trackRect: trackRect,
                    barType: barType,
                    origStartMin: startMin, origEndMin: endMin, origDuration: duration,
                    mouseStartX: e.clientX, startX: e.clientX, startY: e.clientY,
                    hasMoved: false, currentStartMin: startMin, currentEndMin: endMin
                };
                var dtt = document.getElementById('dragTimeTooltip');
                if (dtt) {
                    var origS = minToHm(startMin + HOUR_START*60), origE = minToHm(endMin + HOUR_START*60);
                    dtt.innerHTML = origS + ' <span class="dtt-arrow">\u2192</span> ' + origE;
                    dtt.style.left = (e.clientX + 14) + 'px';
                    dtt.style.top = (e.clientY - 36) + 'px';
                    dtt.classList.add('visible');
                }
            });

            // mousemove
            document.addEventListener('mousemove', function(e) {
                if (!_dayDetailDragState) return;
                e.preventDefault();
                var st = _dayDetailDragState;
                if (!st.hasMoved) {
                    var dist = Math.abs(e.clientX - st.startX) + Math.abs(e.clientY - st.startY);
                    if (dist < 3) return;
                    st.hasMoved = true;
                }

                var dx = e.clientX - st.mouseStartX;
                var deltaMin = pxToMin(dx, st.trackRect.width);
                var newStart, newEnd;

                if (st.mode === 'move') {
                    newStart = clampMin(st.origStartMin + deltaMin);
                    newEnd = newStart + st.origDuration;
                    if (newEnd > TOTAL_MIN) { newEnd = TOTAL_MIN; newStart = newEnd - st.origDuration; }
                    if (newStart < 0) { newStart = 0; newEnd = st.origDuration; }
                } else if (st.mode === 'resize-left') {
                    newStart = clampMin(st.origStartMin + deltaMin);
                    newEnd = st.origEndMin;
                    if (newStart >= newEnd - 10) newStart = newEnd - 10;
                } else {
                    newStart = st.origStartMin;
                    newEnd = clampMin(st.origEndMin + deltaMin);
                    if (newEnd <= newStart + 10) newEnd = newStart + 10;
                }

                st.currentStartMin = newStart;
                st.currentEndMin = newEnd;

                var leftPct = newStart / TOTAL_MIN * 100;
                var widthPct = (newEnd - newStart) / TOTAL_MIN * 100;
                st.bar.style.left = leftPct.toFixed(3) + '%';
                st.bar.style.width = widthPct.toFixed(3) + '%';

                var dtt = document.getElementById('dragTimeTooltip');
                if (dtt) {
                    var newS = minToHm(newStart + HOUR_START*60), newE = minToHm(newEnd + HOUR_START*60);
                    var origS = minToHm(st.origStartMin + HOUR_START*60);
                    var origE = minToHm(st.origEndMin + HOUR_START*60);
                    var changed = (newS !== origS || newE !== origE);
                    dtt.innerHTML = changed
                        ? '<span class="dtt-changed">' + newS + ' <span class="dtt-arrow">\u2192</span> ' + newE + '</span>'
                        : newS + ' <span class="dtt-arrow">\u2192</span> ' + newE;
                    dtt.style.left = (e.clientX + 14) + 'px';
                    dtt.style.top = (e.clientY - 36) + 'px';
                }
            });

            // mouseup: 드래그 완료
            document.addEventListener('mouseup', function(e) {
                if (!_dayDetailDragState) return;
                var st = _dayDetailDragState;
                st.bar.classList.remove('dragging', 'resizing');
                var dtt = document.getElementById('dragTimeTooltip');
                if (dtt) dtt.classList.remove('visible');

                if (!st.hasMoved) {
                    _dayDetailDragState = null;
                    return;
                }
                _dayDetailJustDragged = true;
                setTimeout(function(){ _dayDetailJustDragged = false; }, 0);

                dayDetailBarInfo = null;
                var delBtnEl = document.getElementById('btnDeleteDayDetailBar');
                if (delBtnEl) delBtnEl.classList.add('d-none');

                var newStart = minToHm(st.currentStartMin + HOUR_START * 60);
                var newEnd = minToHm(st.currentEndMin + HOUR_START * 60);
                var origStart = st.bar.dataset.start;
                var origEnd = st.bar.dataset.end;
                var iso = st.iso;

                if (newStart !== origStart || newEnd !== origEnd) {
                    if (st.barType === 'template') {
                        var srcSegs = (ganttTemplatePendingChanges[iso] || (baseWeekDaysMap[iso] && baseWeekDaysMap[iso].segments) || []).map(function(s){ return Object.assign({}, s); });
                        srcSegs[st.segIdx] = { start: newStart, end: newEnd };
                        srcSegs.sort(function(a, b){ return hmToMin(a.start) - hmToMin(b.start); });
                        ganttTemplatePendingChanges[iso] = mergeOverlappingSegments(srcSegs);
                    } else {
                        var srcSegs2 = (ganttPendingChanges[iso] || (selectedWeekDaysMap[iso] && selectedWeekDaysMap[iso].segments) || []).map(function(s){ return Object.assign({}, s); });
                        var wasNew = srcSegs2[st.segIdx] && srcSegs2[st.segIdx].isNew;
                        var newSeg = { start: newStart, end: newEnd };
                        if (wasNew) newSeg.isNew = true;
                        srcSegs2[st.segIdx] = newSeg;
                        srcSegs2.sort(function(a, b){ return hmToMin(a.start) - hmToMin(b.start); });
                        ganttPendingChanges[iso] = mergeOverlappingSegments(srcSegs2);
                    }
                    updateGanttSaveBar();
                    buildDayDetailGantt();
                    buildMemberWeekGantt();
                    updateDdPopupButtons();
                }
                _dayDetailDragState = null;
            });

            // click: 바 선택/삭제 + 빈 트랙 → 새 일정 생성
            wrap.addEventListener('click', function(e) {
                if (_dayDetailJustDragged) return;
                var delBtn = document.getElementById('btnDeleteDayDetailBar');

                // 바 클릭 → 선택/해제 토글
                var clickedBar = e.target.closest('.mw-gantt-bar-actual') || e.target.closest('.mw-gantt-bar-template');
                if (clickedBar) {
                    var barType = clickedBar.dataset.barType || (clickedBar.classList.contains('mw-gantt-bar-template') ? 'template' : 'actual');
                    var barStart = clickedBar.dataset.start;
                    var barEnd = clickedBar.dataset.end;
                    var barIso = clickedBar.dataset.iso;

                    if (dayDetailBarInfo && dayDetailBarInfo.type === barType && dayDetailBarInfo.iso === barIso && dayDetailBarInfo.start === barStart && dayDetailBarInfo.end === barEnd) {
                        dayDetailBarInfo = null;
                        if (delBtn) delBtn.classList.add('d-none');
                    } else {
                        dayDetailBarInfo = { type: barType, iso: barIso, start: barStart, end: barEnd };
                        if (delBtn) delBtn.classList.remove('d-none');
                    }
                    buildDayDetailGantt();
                    return;
                }

                // 빈 트랙 클릭 → 새 바 생성
                dayDetailBarInfo = null;
                if (delBtn) delBtn.classList.add('d-none');

                var track = e.target.closest('.mw-gantt-track-cell');
                if (!track) return;
                var row = track.closest('.mw-gantt-row');
                if (!row) return;
                var iso = row.dataset.iso;
                if (!iso) return;
                var rowBarType = row.dataset.detailBarType; // 'template' or 'actual'

                var rect = track.getBoundingClientRect();
                var clickX = e.clientX - rect.left;
                var clickMin = Math.round(clickX / rect.width * TOTAL_MIN / 10) * 10;
                clickMin = Math.max(0, Math.min(clickMin, TOTAL_MIN - 60));
                var startHm = minToHm(clickMin + HOUR_START * 60);
                var endHm = minToHm(clickMin + 60 + HOUR_START * 60);

                if (rowBarType === 'actual') {
                    // 실제근무 행에 생성
                    var segs = (ganttPendingChanges[iso] || (selectedWeekDaysMap[iso] && selectedWeekDaysMap[iso].segments) || []).map(function(s){ return Object.assign({}, s); });
                    segs.push({ start: startHm, end: endHm, isNew: true });
                    segs.sort(function(a, b){ return hmToMin(a.start) - hmToMin(b.start); });
                    ganttPendingChanges[iso] = mergeOverlappingSegments(segs);
                } else {
                    // 일정 행에 생성 (기본)
                    var segs2 = (ganttTemplatePendingChanges[iso] || (baseWeekDaysMap[iso] && baseWeekDaysMap[iso].segments) || []).map(function(s){ return Object.assign({}, s); });
                    segs2.push({ start: startHm, end: endHm, isNew: true });
                    segs2.sort(function(a, b){ return hmToMin(a.start) - hmToMin(b.start); });
                    ganttTemplatePendingChanges[iso] = mergeOverlappingSegments(segs2);
                }
                updateGanttSaveBar();
                buildDayDetailGantt();
                buildMemberWeekGantt();
                updateDdPopupButtons();
            });
        }

        let modalDragging = false, modalDragAdding = true;

        function openEditModal(dateIso, member, segments, mode){
            if(!member) return;
            editTitleDate.textContent = dateIso;
            editTitleMember.textContent = member.name ?? '-';

            btnSaveEdit.textContent = (mode === 'create') ? '일정생성하기' : '저장';

            stepMinutes = 30;
            totalRows = (END_MIN - START_MIN) / stepMinutes;
            slotStepButtons.querySelectorAll('button[data-step]').forEach(b=>b.classList.remove('active'));
            slotStepButtons.querySelector('button[data-step="30"]').classList.add('active');
            summaryStepBadge.textContent = '슬롯: 30분';

            originalSegments = Array.isArray(segments) ? segments.slice() : [];
            originalSlotSet  = segmentsToSlotSet(originalSegments, stepMinutes);
            slotState        = new Set([...originalSlotSet]);

            buildDayGrid();
            updateSelectedMinutes();
            renderLeftSummary();
            updateModalSaveButton();

            editModal.dataset.memberId = String(member.id);
            editModal.dataset.dateIso = dateIso;

            editModal.style.display = 'block';
        }
        function closeEditModal(){ editModal.style.display = 'none'; }
        function onCancelEdit(){
            slotState = new Set([...originalSlotSet]);
            buildDayGrid();
            updateSelectedMinutes();
            renderLeftSummary();
        }
        async function onSaveEdit(){
            if(stepMinutes !== 10){
                alert('저장은 10분 단위에서만 가능합니다.');
                return;
            }
            const mid = editModal.dataset.memberId;
            const dateIso = editModal.dataset.dateIso;
            if(!mid || !dateIso) return;

            const segments = slotSetToSegments(slotState, stepMinutes);
            try{
                const body = { memberId: mid, date: dateIso, segments };
                const resp = await fetch(API_UPDATE, {
                    method: 'POST',
                    headers: {'Content-Type':'application/json', 'Accept':'application/json'},
                    body: JSON.stringify(body)
                });
                if(!resp.ok){
                    const text = await resp.text().catch(()=> '');
                    alert(`저장 실패: ${resp.status} ${text}`);
                    return;
                }
                closeEditModal();
                await fetchAndRenderWeekTable(currentStatusMembers, currentWeekStart);
                await loadSelectedMemberWeek();
                clearAllDayEditButtons();
                updateCurrentTimeHighlight();
            }catch(e){
                console.error(e);
                alert('저장 중 오류가 발생했습니다.');
            }
        }
        function updateModalSaveButton(){ btnSaveEdit.disabled = (stepMinutes !== 10); }

        function buildDayGrid(){
            dayGridBody.innerHTML = '';
            const rows = (END_MIN - START_MIN) / stepMinutes;
            for(let idx=0; idx<rows; idx++){
                const tMin = START_MIN + idx*stepMinutes;
                const h = Math.floor(tMin/60);
                const m = tMin%60;
                const hmLabel = `${pad2(h)}:${pad2(m)}`;

                const tr = document.createElement('tr');
                if(m===0) tr.classList.add('row-hour-start');

                const th = document.createElement('th');
                th.className = 'timecell';
                th.textContent = (m%30===0) ? hmLabel : '';
                tr.appendChild(th);

                const td = document.createElement('td');
                const div = document.createElement('div');
                div.className = 'slot-cell';
                div.dataset.hm = hmLabel;

                if(slotState.has(hmLabel)){
                    div.classList.add('selected');
                    if(!originalSlotSet.has(hmLabel)){
                        div.classList.add('selected-diff');
                    }
                }
                td.appendChild(div);
                tr.appendChild(td);
                dayGridBody.appendChild(tr);
            }
            attachDayGridDragHandlers();
        }

        function attachDayGridDragHandlers(){
            modalDragging = false;
            dayGridBody.querySelectorAll('.slot-cell').forEach(div=>{
                div.addEventListener('mousedown', (e)=>{
                    e.preventDefault();
                    modalDragging = true;
                    const hm = div.dataset.hm;
                    const has = slotState.has(hm);
                    modalDragAdding = !has;
                    toggleModalSlot(div, modalDragAdding);
                });
                div.addEventListener('mouseenter', ()=>{
                    if(!modalDragging) return;
                    toggleModalSlot(div, modalDragAdding);
                });
            });
            window.addEventListener('mouseup', ()=>{ if(modalDragging) modalDragging=false; });
        }

        function toggleModalSlot(el, on){
            const hm = el.dataset.hm;
            if(on){
                if(!slotState.has(hm)){
                    slotState.add(hm);
                    el.classList.add('selected');
                    if(!originalSlotSet.has(hm)) el.classList.add('selected-diff');
                }
            }else{
                if(slotState.has(hm)){
                    slotState.delete(hm);
                    el.classList.remove('selected','selected-diff');
                }
            }
            updateSelectedMinutes();
            renderLeftSummary();
        }
        function updateSelectedMinutes(){ selectedMinutesEl.textContent = (slotState.size * stepMinutes)|0; }

        function renderLeftSummary(){
            summaryOriginal.innerHTML = originalSegments.length
                    ? originalSegments.map(s => chipHtml('#198754', s.start, s.end)).join(' ')
                    : '<span class="text-muted">-</span>';

            const currentSegments = slotSetToSegments(slotState, stepMinutes);
            summaryCurrent.innerHTML = currentSegments.length
                    ? currentSegments.map(s => chipHtml('#0d6efd', s.start, s.end)).join(' ')
                    : '<span class="text-muted">-</span>';

            const orgMin = segmentsMinutes(originalSegments);
            const curMin = segmentsMinutes(currentSegments);
            summaryOriginalTotal.textContent = `${orgMin}분`;
            summaryCurrentTotal.textContent  = `${curMin}분`;
            const diff = curMin - orgMin;
            summaryDiffTotal.textContent = (diff>=0?'+':'') + `${diff}분`;
            summaryDiffTotal.classList.toggle('text-primary', diff>0);
            summaryDiffTotal.classList.toggle('text-danger', diff<0);
        }

        // ===== Utils =====
        function toMonday(date){
            const d = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            const day = d.getDay();
            const diff = (day === 0 ? -6 : 1 - day);
            d.setDate(d.getDate() + diff);
            return d;
        }
        function addDays(d, n){ const x = new Date(d); x.setDate(x.getDate()+n); return x; }
        function pad2(n){ return String(n).padStart(2,'0'); }
        function toIso(d){ return `${d.getFullYear()}-${pad2(d.getMonth()+1)}-${pad2(d.getDate())}`; }

        function normalizeDays(apiData){
            const map = {};
            if (!apiData) return map;

            if (Array.isArray(apiData.days)) {
                apiData.days.forEach(d => {
                    const date = String(d.date);
                    const segments = Array.isArray(d.segments) ? d.segments : [];
                    const minutes = (typeof d.minutes === 'number') ? d.minutes
                            : segments.reduce((acc, s) => acc + (hmToMin(s.end)-hmToMin(s.start)), 0);
                    map[date] = { segments, minutes };
                });
                return map;
            }
            if (Array.isArray(apiData)) {
                apiData.forEach(d => {
                    const date = String(d.date);
                    const segments = Array.isArray(d.segments) ? d.segments : [];
                    const minutes = (typeof d.minutes === 'number') ? d.minutes
                            : segments.reduce((acc, s) => acc + (hmToMin(s.end)-hmToMin(s.start)), 0);
                    map[date] = { segments, minutes };
                });
                return map;
            }
            if (typeof apiData === 'object') {
                Object.keys(apiData).forEach(date => {
                    const v = apiData[date] || {};
                    const segments = Array.isArray(v.segments) ? v.segments : [];
                    const minutes = (typeof v.minutes === 'number') ? v.minutes
                            : segments.reduce((acc, s) => acc + (hmToMin(s.end)-hmToMin(s.start)), 0);
                    map[String(date)] = { segments, minutes };
                });
                return map;
            }
            return map;
        }

        function normalizeWeeklyTemplate(apiRows, weekDates){
            const map = {};
            const arr = Array.isArray(apiRows) ? apiRows : [];

            const dates = Array.isArray(weekDates) ? weekDates : [];
            const dayOrder = ['MON','TUE','WED','THU','FRI','SAT','SUN'];

            const byDayCode = {};

            arr.forEach(row => {
                const dayCode = String(row.day || '').toUpperCase();
                if(!dayCode) return;

                if(!byDayCode[dayCode]) {
                    byDayCode[dayCode] = [];
                }

                const startHm = (row.start || '').slice(0,5);
                const endHm   = (row.end   || '').slice(0,5);

                byDayCode[dayCode].push({
                    start: startHm,
                    end: endHm
                });
            });

            dates.forEach((iso, idx) => {
                const dayCode = dayOrder[idx];
                const segs    = byDayCode[dayCode] || [];

                const minutes = segs.reduce((acc, s) => {
                    return acc + diffMinutes(s.start, s.end);
                }, 0);

                map[iso] = {
                    segments: segs,
                    minutes: minutes
                };
            });

            return map;
        }

        function hasAnySegments(dayMap){
            return Object.values(dayMap || {}).some(v => Array.isArray(v.segments) && v.segments.length > 0);
        }

        function diffMinutes(startHm, endHm){
            const s = hmToMin(startHm);
            const e = hmToMin(endHm);
            return Math.max(0, e - s);
        }

        function hmToMin(hm){
            if(!hm) return 0;
            const [h,m] = String(hm).split(':').map(n=>parseInt(n,10));
            return (h||0)*60 + (m||0);
        }
        function minToHm(min){ const h = Math.floor(min/60); const m = min%60; return `${pad2(h)}:${pad2(m)}`; }
        function isoToDayCode(iso) {
            const d = new Date(iso + 'T00:00:00');
            const jsDay = d.getDay(); // 0=일, 1=월, ...
            return ['SUN','MON','TUE','WED','THU','FRI','SAT'][jsDay];
        }

        function colorForMember(m){
            const key = (m?.id!=null ? String(m.id) : (m?.name || 'x'));
            const h = seededHash(key)%360, s=65, l=55;
            return hslToHex(h,s,l);
        }
        function seededHash(str){
            let h=2166136261>>>0;
            for(let i=0;i<str.length;i++){ h^=str.charCodeAt(i); h=(h*16777619)>>>0; }
            return h>>>0;
        }
        function hslToHex(h,s,l){
            s/=100; l/=100;
            const c=(1-Math.abs(2*l-1))*s;
            const x=c*(1-Math.abs((h/60)%2-1));
            const m=l-c/2;
            let r=0,g=0,b=0;
            if(0<=h&&h<60){ r=c; g=x; b=0; }
            else if(60<=h&&h<120){ r=x; g=c; b=0; }
            else if(120<=h&&h<180){ r=0; g=c; b=x; }
            else if(180<=h&&h<240){ r=0; g=x; b=c; }
            else if(240<=h&&h<300){ r=x; g=0; b=c; }
            else { r=c; g=0; b=x; }
            const toHex = v => Math.round((v+m)*255).toString(16).padStart(2,'0');
            return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
        }
        function escapeHtml(s){
            if(s==null) return '';
            return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;')
                    .replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
        }

        function segmentsToSlotSet(segments, step){
            const set = new Set();
            (segments||[]).forEach(seg=>{
                let s = Math.max(hmToMin(seg.start), START_MIN);
                let e = Math.min(hmToMin(seg.end),   END_MIN);
                for(let t=s; t<e; t+=step){ set.add(minToHm(t)); }
            });
            return set;
        }
        function slotSetToSegments(set, step){
            const sorted = Array.from(set).map(hmToMin).sort((a,b)=>a-b);
            const res = [];
            let i=0;
            while(i<sorted.length){
                let s = sorted[i], t = s + step; i++;
                while(i<sorted.length && sorted[i]===t){ t += step; i++; }
                res.push({start:minToHm(s), end:minToHm(t)});
            }
            return res;
        }
        function chipHtml(color, start, end){
            return `<span class="chip"><span class="dot" style="background:${color}"></span><span class="small">${start} ~ ${end}</span></span>`;
        }
        function segmentsMinutes(segs){ return (segs||[]).reduce((acc,s)=> acc + (hmToMin(s.end)-hmToMin(s.start)), 0); }

    })();
</script>

