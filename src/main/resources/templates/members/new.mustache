<!-- 드래그 툴팁 -->
<div class="tg-drag-tooltip" id="tgDragTooltip"></div>

<script>
(function () {
    const HOUR_START = 6;
    const HOUR_END   = 22;
    const TOTAL_MIN  = (HOUR_END - HOUR_START) * 60;
    const QUANT      = 10;
    const DAY_CODES  = ['MON','TUE','WED','THU','FRI','SAT','SUN'];
    const DOW_LABELS = ['월','화','수','목','금','토','일'];

    const wrap       = document.getElementById('tplGanttWrap');
    const form       = document.getElementById('memberEditForm');
    const btnClear   = document.getElementById('btnGridClear');
    const btnDelete  = document.getElementById('tplBarDelete');
    const tooltip    = document.getElementById('tgDragTooltip');

    /* ===== state ===== */
    let schedMap = {};                // { MON: [{s:360,e:480}, ...], ... }
    DAY_CODES.forEach(d => schedMap[d] = []);
    let selectedBar = null;           // { day, idx }
    let dragState   = null;

    /* ===== helpers ===== */
    function pad2(n) { return String(n).padStart(2, '0'); }
    function minToHm(m) { return pad2(Math.floor(m / 60)) + ':' + pad2(m % 60); }
    function minToHms(m) { return minToHm(m) + ':00'; }
    function clamp(v) { return Math.max(0, Math.min(TOTAL_MIN, v)); }
    function quantize(v) { return Math.round(v / QUANT) * QUANT; }

    function mergeSegs(segs) {
        if (!segs.length) return [];
        segs.sort((a, b) => a.s - b.s);
        const out = [{ ...segs[0] }];
        for (let i = 1; i < segs.length; i++) {
            const last = out[out.length - 1];
            if (segs[i].s <= last.e) {
                last.e = Math.max(last.e, segs[i].e);
            } else {
                out.push({ ...segs[i] });
            }
        }
        return out;
    }

    function calcHours(day) {
        const segs = schedMap[day] || [];
        let total = 0;
        segs.forEach(s => total += (s.e - s.s));
        return total;
    }

    /* ===== render ===== */
    function render() {
        wrap.innerHTML = '';

        // header row
        const headerRow = document.createElement('div');
        headerRow.className = 'tg-gantt-header-row';
        headerRow.innerHTML = '<div class="tg-gantt-label-cell">요일</div>';

        const trackHeader = document.createElement('div');
        trackHeader.className = 'tg-gantt-track-header';
        for (let h = HOUR_START; h <= HOUR_END; h++) {
            const pct = ((h - HOUR_START) * 60 / TOTAL_MIN * 100).toFixed(4);
            const cls = 'tg-gantt-time-label' + (h === HOUR_START ? '' : '');
            trackHeader.innerHTML += `<div class="${cls}" style="left:${pct}%">${pad2(h)}</div>`;
        }
        headerRow.appendChild(trackHeader);
        headerRow.innerHTML += '<div class="tg-gantt-hours-cell">시간</div>';
        wrap.appendChild(headerRow);

        // day rows
        DAY_CODES.forEach((day, di) => {
            const row = document.createElement('div');
            row.className = 'tg-gantt-row';
            row.dataset.day = day;

            // label
            const label = document.createElement('div');
            label.className = 'tg-gantt-label-cell';
            label.innerHTML = `<span class="tg-gantt-day-name">${DOW_LABELS[di]}</span>`;
            row.appendChild(label);

            // track
            const track = document.createElement('div');
            track.className = 'tg-gantt-track-cell';
            track.dataset.day = day;

            // grid lines
            for (let h = HOUR_START; h <= HOUR_END; h++) {
                for (let q = 0; q < 2; q++) {
                    const m = (h - HOUR_START) * 60 + q * 30;
                    if (m > TOTAL_MIN) break;
                    const pct = (m / TOTAL_MIN * 100).toFixed(4);
                    const cls = q === 0 ? 'tg-gantt-grid-line major' : 'tg-gantt-grid-line minor';
                    track.innerHTML += `<div class="${cls}" style="left:${pct}%"></div>`;
                }
            }

            // bars
            const segs = schedMap[day] || [];
            segs.forEach((seg, si) => {
                const leftPct  = ((seg.s - HOUR_START * 60) / TOTAL_MIN * 100).toFixed(4);
                const widthPct = ((seg.e - seg.s) / TOTAL_MIN * 100).toFixed(4);
                const label2   = minToHm(seg.s) + '~' + minToHm(seg.e);
                const selCls   = (selectedBar && selectedBar.day === day && selectedBar.idx === si) ? ' tg-selected' : '';

                const bar = document.createElement('div');
                bar.className = 'tg-gantt-bar' + selCls;
                bar.style.left  = leftPct + '%';
                bar.style.width = widthPct + '%';
                bar.dataset.day = day;
                bar.dataset.idx = si;
                bar.dataset.s   = seg.s;
                bar.dataset.e   = seg.e;
                bar.innerHTML = `<div class="bar-handle bar-handle-left"></div>${label2}<div class="bar-handle bar-handle-right"></div>`;
                track.appendChild(bar);
            });

            row.appendChild(track);

            // hours cell
            const hrs = document.createElement('div');
            const totalM = calcHours(day);
            hrs.className = 'tg-gantt-hours-cell' + (totalM > 0 ? ' has-hours' : '');
            const hh = Math.floor(totalM / 60);
            const mm = totalM % 60;
            hrs.textContent = totalM > 0 ? (mm > 0 ? hh + 'h' + mm + 'm' : hh + 'h') : '-';
            row.appendChild(hrs);

            wrap.appendChild(row);
        });
    }

    /* ===== selection ===== */
    function clearSelection() {
        selectedBar = null;
        btnDelete.classList.add('d-none');
        wrap.querySelectorAll('.tg-gantt-bar.tg-selected').forEach(b => b.classList.remove('tg-selected'));
    }

    function selectBar(day, idx) {
        clearSelection();
        selectedBar = { day, idx };
        btnDelete.classList.remove('d-none');
        const bar = wrap.querySelector(`.tg-gantt-bar[data-day="${day}"][data-idx="${idx}"]`);
        if (bar) bar.classList.add('tg-selected');
    }

    /* ===== pxToMin ===== */
    function pxToMin(px, trackWidth) {
        const raw = (px / trackWidth) * TOTAL_MIN + HOUR_START * 60;
        return clamp(quantize(raw - HOUR_START * 60)) + HOUR_START * 60;
    }

    /* ===== interaction ===== */
    wrap.addEventListener('mousedown', function (e) {
        const bar = e.target.closest('.tg-gantt-bar');

        if (bar) {
            e.preventDefault();
            const track = bar.closest('.tg-gantt-track-cell');
            const rect  = track.getBoundingClientRect();
            const day   = bar.dataset.day;
            const idx   = parseInt(bar.dataset.idx, 10);
            const s     = parseInt(bar.dataset.s, 10);
            const eVal  = parseInt(bar.dataset.e, 10);

            const isLeft  = e.target.classList.contains('bar-handle-left');
            const isRight = e.target.classList.contains('bar-handle-right');
            const mode    = isLeft ? 'resize-left' : (isRight ? 'resize-right' : 'move');

            dragState = {
                mode, day, idx, origS: s, origE: eVal,
                startX: e.clientX,
                trackRect: rect,
                hasMoved: false
            };
            bar.classList.add(mode === 'move' ? 'dragging' : 'resizing');
            return;
        }

        // empty space click → create bar
        const track = e.target.closest('.tg-gantt-track-cell');
        if (track && !bar) {
            const rect = track.getBoundingClientRect();
            const day  = track.dataset.day;
            const clickMin = pxToMin(e.clientX - rect.left, rect.width);
            const newSeg = { s: clickMin, e: Math.min(clickMin + 60, HOUR_END * 60) };
            if (newSeg.e <= newSeg.s) return;
            schedMap[day].push(newSeg);
            schedMap[day] = mergeSegs(schedMap[day]);
            clearSelection();
            render();
        }
    });

    document.addEventListener('mousemove', function (e) {
        if (!dragState) return;
        const dx = e.clientX - dragState.startX;
        if (!dragState.hasMoved && Math.abs(dx) < 3) return;
        dragState.hasMoved = true;

        const rect  = dragState.trackRect;
        const dMin  = quantize((dx / rect.width) * TOTAL_MIN);
        const seg   = schedMap[dragState.day][dragState.idx];
        if (!seg) return;

        let newS = dragState.origS, newE = dragState.origE;

        if (dragState.mode === 'move') {
            let shift = dMin;
            if (dragState.origS + shift < HOUR_START * 60) shift = HOUR_START * 60 - dragState.origS;
            if (dragState.origE + shift > HOUR_END * 60)   shift = HOUR_END * 60 - dragState.origE;
            newS = dragState.origS + shift;
            newE = dragState.origE + shift;
        } else if (dragState.mode === 'resize-left') {
            newS = clamp(dragState.origS + dMin - HOUR_START * 60) + HOUR_START * 60;
            if (newS >= newE - QUANT) newS = newE - QUANT;
        } else {
            newE = clamp(dragState.origE + dMin - HOUR_START * 60) + HOUR_START * 60;
            if (newE <= newS + QUANT) newE = newS + QUANT;
        }

        seg.s = newS;
        seg.e = newE;

        // live update bar position
        const bar = wrap.querySelector(`.tg-gantt-bar[data-day="${dragState.day}"][data-idx="${dragState.idx}"]`);
        if (bar) {
            const leftPct  = ((newS - HOUR_START * 60) / TOTAL_MIN * 100).toFixed(4);
            const widthPct = ((newE - newS) / TOTAL_MIN * 100).toFixed(4);
            bar.style.left  = leftPct + '%';
            bar.style.width = widthPct + '%';
            bar.childNodes.forEach(n => {
                if (n.nodeType === 3) n.textContent = minToHm(newS) + '~' + minToHm(newE);
            });
            // update text (between handles)
            const textNodes = Array.from(bar.childNodes).filter(n => n.nodeType === 3);
            if (textNodes.length) textNodes[0].textContent = minToHm(newS) + '~' + minToHm(newE);
        }

        // tooltip
        tooltip.textContent = minToHm(newS) + ' ~ ' + minToHm(newE);
        tooltip.style.left = (e.clientX + 14) + 'px';
        tooltip.style.top  = (e.clientY - 30) + 'px';
        tooltip.classList.add('visible');
    });

    document.addEventListener('mouseup', function (e) {
        if (!dragState) return;
        const wasDrag = dragState.hasMoved;
        const day = dragState.day;
        const idx = dragState.idx;

        // clean up classes
        wrap.querySelectorAll('.tg-gantt-bar.dragging, .tg-gantt-bar.resizing')
            .forEach(b => { b.classList.remove('dragging', 'resizing'); });
        tooltip.classList.remove('visible');

        if (wasDrag) {
            schedMap[day] = mergeSegs(schedMap[day]);
            clearSelection();
            render();
        } else {
            // click → select/deselect
            if (selectedBar && selectedBar.day === day && selectedBar.idx === idx) {
                clearSelection();
            } else {
                selectBar(day, idx);
            }
        }
        dragState = null;
    });

    /* ===== delete ===== */
    btnDelete.addEventListener('click', function () {
        if (!selectedBar) return;
        const segs = schedMap[selectedBar.day];
        if (segs && segs[selectedBar.idx] != null) {
            segs.splice(selectedBar.idx, 1);
        }
        clearSelection();
        render();
    });

    /* ===== clear ===== */
    btnClear.addEventListener('click', function () {
        DAY_CODES.forEach(d => schedMap[d] = []);
        clearSelection();
        render();
    });

    /* ===== form submit: inject hidden fields ===== */
    function normalizeBooleanCheckbox(id, fieldName) {
        if (!form) return;
        const cb = document.getElementById(id);
        if (!cb) return;
        Array.from(form.querySelectorAll('input[type="hidden"][name="' + fieldName + '"]'))
                .forEach(el => el.remove());
        if (cb.hasAttribute('name')) cb.removeAttribute('name');
        appendHidden(fieldName, cb.checked ? 'true' : 'false');
    }

    function appendHidden(name, value) {
        const input = document.createElement('input');
        input.type  = 'hidden';
        input.name  = name;
        input.value = value;
        form.appendChild(input);
    }

    if (form) {
        form.addEventListener('submit', function () {
            normalizeBooleanCheckbox('includeWeeklyHolidayAllowance', 'includeWeeklyHolidayAllowance');
            normalizeBooleanCheckbox('hasHealthCertificate', 'hasHealthCertificate');
            normalizeBooleanCheckbox('applyTax', 'applyTax');

            Array.from(form.querySelectorAll('input[name^="schedule["]')).forEach(el => el.remove());

            let idx = 0;
            DAY_CODES.forEach(dayCode => {
                const segs = schedMap[dayCode] || [];
                segs.forEach(seg => {
                    appendHidden(`schedule[${idx}].day`,   dayCode);
                    appendHidden(`schedule[${idx}].start`, minToHms(seg.s));
                    appendHidden(`schedule[${idx}].end`,   minToHms(seg.e));
                    idx++;
                });
            });
        });
    }

    // initial render
    render();
})();

// ===== 전화번호 자동 포맷 (010-0000-0000 등) =====
document.addEventListener('DOMContentLoaded', function () {
    const phoneInput = document.getElementById('phone');
    if (phoneInput) {
        phoneInput.addEventListener('input', function () {
            const cursorPos = this.selectionStart;
            const beforeLength = this.value.length;
            this.value = formatKoreanPhone(this.value);
            const afterLength = this.value.length;
            const diff = afterLength - beforeLength;
            this.setSelectionRange(cursorPos + diff, cursorPos + diff);
        });
        phoneInput.addEventListener('blur', function () {
            this.value = formatKoreanPhone(this.value);
        });
    }

    // 주민등록번호 자동 포맷 (000000-0000000)
    const ssnInput = document.getElementById('ssn');
    if (ssnInput) {
        ssnInput.addEventListener('input', function () {
            let digits = this.value.replace(/\D/g, '').slice(0, 13);
            if (digits.length > 6) digits = digits.slice(0, 6) + '-' + digits.slice(6);
            this.value = digits;
        });
    }

    // 계좌번호: 숫자와 하이픈만 허용
    const bankInput = document.getElementById('bankAccount');
    if (bankInput) {
        bankInput.addEventListener('input', function () {
            this.value = this.value.replace(/[^\d-]/g, '');
        });
    }

    // 예상 급여 버튼: 신규등록에서는 항상 경고
    const btn = document.getElementById('btnOpenPayEstimate');
    if (btn) {
        btn.addEventListener('click', function () {
            alert('예상 급여 조회는 아르바이트 정보 저장 후 이용 가능합니다.');
        });
    }
});

// 한국 전화번호 포맷 함수
function formatKoreanPhone(value) {
    let digits = String(value).replace(/\D/g, '');
    if (digits.length === 0) return '';
    if (digits.startsWith('02')) {
        if (digits.length <= 2) return digits;
        else if (digits.length <= 5) return digits.slice(0, 2) + '-' + digits.slice(2);
        else return digits.slice(0, 2) + '-' + digits.slice(2, digits.length - 4) + '-' + digits.slice(-4);
    }
    if (digits.length <= 3) return digits;
    else if (digits.length <= 7) return digits.slice(0, 3) + '-' + digits.slice(3);
    else if (digits.length <= 11) return digits.slice(0, 3) + '-' + digits.slice(3, digits.length - 4) + '-' + digits.slice(-4);
    else {
        digits = digits.slice(-11);
        return digits.slice(0, 3) + '-' + digits.slice(3, 7) + '-' + digits.slice(7);
    }
}
