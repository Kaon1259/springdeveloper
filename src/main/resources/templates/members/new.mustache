{{>layouts/header}}
{{>layouts/toast}}

<main class="schedule-shell py-4">
    <div class="schedule-layout container">

        <!-- ============ 상단 파란 패널 + 아래 전체 폼/테이블을 하나의 패널로 합침 ============ -->
        <section class="panel panel-merged mb-3">

            <!-- 🔵 상단: 아르바이트 정보 입력 헤더 (status-panel-blue 스타일 적용) -->
            <div class="member-header-blue status-panel-blue">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="title-sm text-light-emphasis">STAFF CREATE</span>
                        </div>

                        <div>
                            <div class="status-title mt-1">
                                아르바이트 정보 입력
                            </div>
                            <div class="status-subtitle-small">
                                기본 인적사항과 급여 정보, 주간 템플릿까지 한 번에 등록할 수 있습니다.
                            </div>
                        </div>

                        <!-- ✅ 신규등록 텍스트 바로 아래: 상태 + 이름 (파란 배경 영역 안) -->
                        <div class="mt-3 d-flex flex-wrap align-items-end gap-2 status-inline-row">
                            <div class="d-flex flex-column">
                                <span class="status-period-label-caption mb-1">상태</span>
                                <select id="statusSelectTop"
                                        class="form-select form-select-sm status-select-top"
                                        name="status"
                                        form="memberEditForm"
                                        required>
                                    <option value="WAITING">시작전</option>
                                    <option value="WORKING">근무중</option>
                                    <option value="RESTING">휴식중</option>
                                    <option value="PAUSED">일시중지</option>
                                    <option value="RESIGNED">퇴사</option>
                                </select>
                            </div>

                            <div class="d-flex flex-column">
                                <span class="status-period-label-caption mb-1">이름</span>
                                <input type="text"
                                       class="form-control form-control-sm status-name-input"
                                       name="name"
                                       form="memberEditForm"
                                       placeholder="이름 입력"
                                       required>
                            </div>
                        </div>
                    </div>

                    <!-- 오른쪽: 저장하기 버튼만 -->
                    <div class="d-flex flex-column align-items-end gap-2">
                        <button type="submit"
                                form="memberEditForm"
                                class="btn btn-sm btn-light fw-semibold shadow-sm member-save-btn">
                            저장하기
                        </button>
                    </div>
                </div>
            </div>

            <!-- ============ 아래: 아르바이트 입력정보 + 주간 템플릿 (하나의 패널-바디 안에 배치) ============ -->
            <div class="panel-body panel-body-merged">

                <!-- 🔹 action 은 프로젝트에 맞게 변경 -->
                <form id="memberEditForm" method="post" action="/members/create" autocomplete="off">

                    <!-- ✅ 1줄: 성별 / 이메일 / 전화번호 / 주민등록번호 -->
                    <div class="info-grid mb-3">
                        <div class="info-item">
                            <div class="label">성별</div>
                            <select class="form-select form-select-sm"
                                    name="gender"
                                    required>
                                <option value="">선택</option>
                                <option value="M">남</option>
                                <option value="F">여</option>
                            </select>
                        </div>

                        <div class="info-item">
                            <div class="label">이메일</div>
                            <input type="email"
                                   class="form-control form-control-sm"
                                   name="email"
                                   placeholder="example@email.com"
                                   value="">
                        </div>

                        <div class="info-item">
                            <div class="label">전화번호</div>
                            <input type="text"
                                   class="form-control form-control-sm"
                                   name="phone"
                                   id="phone"
                                   inputmode="tel"
                                   maxlength="13"
                                   placeholder="010-0000-0000"
                                   value="">
                        </div>

                        <div class="info-item">
                            <div class="label">주민등록번호</div>
                            <input type="text"
                                   class="form-control form-control-sm"
                                   name="ssn"
                                   id="ssn"
                                   inputmode="numeric"
                                   maxlength="14"
                                   placeholder="000000-0000000"
                                   value="">
                        </div>
                    </div>

                    <!-- 2줄: 시작일 / 시급 2종 / 주휴수당 적용 -->
                    <div class="info-grid mb-3">
                        <div class="info-item">
                            <div class="label">시작일(근무)</div>
                            <input type="date"
                                   class="form-control form-control-sm"
                                   name="startDate"
                                   value="">
                        </div>

                        <!-- ✅ 기존 시급 라벨 수정: 시급(원: >=15h) -->
                        <div class="info-item">
                            <div class="label">시급(원: 근무시간&gt;=15h)</div>
                            <input type="number"
                                   min="0"
                                   step="10"
                                   class="form-control form-control-sm text-end"
                                   name="hourlyWage"
                                   placeholder="10030"
                                   value="">
                        </div>

                        <!-- ✅ 신규 시급 필드: 시급(원: 15h>) / name=hourlyWage2 -->
                        <div class="info-item">
                            <div class="label">시급(원: 15h&gt;근무시간)</div>
                            <input type="number"
                                   min="0"
                                   step="10"
                                   class="form-control form-control-sm text-end"
                                   name="hourlyWage2"
                                   placeholder="10030"
                                   value="">
                        </div>

                        <!-- ✅ 주휴수당 적용: 시급 옆 다음 위치 -->
                        <div class="info-item">
                            <div class="label">주휴수당 적용</div>
                            <div class="form-check form-switch mt-1">
                                <input class="form-check-input"
                                       type="checkbox"
                                       role="switch"
                                       id="includeWeeklyHolidayAllowance"
                                       name="includeWeeklyHolidayAllowance">
                                <label class="form-check-label text-xs text-muted" for="includeWeeklyHolidayAllowance">
                                    주 15시간 이상 근무 시 자동 계산
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- 3줄: 급여지급일 / 은행 / 계좌 / 세금 적용 -->
                    <div class="info-grid mb-3">
                        <!-- ✅ 급여지급일을 이 줄 맨 앞으로 이동 -->
                        <div class="info-item">
                            <div class="label">급여지급일</div>
                            <select class="form-select form-select-sm"
                                    name="payday"
                                    required>
                                <option value="">선택</option>
                                <option value="EOM">말일</option>
                                <!-- 🔹 1 ~ 31일까지 모두 표시 -->
                                <option value="1">1일</option>
                                <option value="2">2일</option>
                                <option value="3">3일</option>
                                <option value="4">4일</option>
                                <option value="5">5일</option>
                                <option value="6">6일</option>
                                <option value="7">7일</option>
                                <option value="8">8일</option>
                                <option value="9">9일</option>
                                <option value="10">10일</option>
                                <option value="11">11일</option>
                                <option value="12">12일</option>
                                <option value="13">13일</option>
                                <option value="14">14일</option>
                                <option value="15">15일</option>
                                <option value="16">16일</option>
                                <option value="17">17일</option>
                                <option value="18">18일</option>
                                <option value="19">19일</option>
                                <option value="20">20일</option>
                                <option value="21">21일</option>
                                <option value="22">22일</option>
                                <option value="23">23일</option>
                                <option value="24">24일</option>
                                <option value="25">25일</option>
                                <option value="26">26일</option>
                                <option value="27">27일</option>
                                <option value="28">28일</option>
                                <option value="29">29일</option>
                                <option value="30">30일</option>
                                <option value="31">31일</option>
                            </select>
                        </div>

                        <!-- ✅ 그다음 은행 -->
                        <div class="info-item">
                            <div class="label">은행</div>
                            <!-- 🔹 은행 리스트 select 로 변경 -->
                            <select class="form-select form-select-sm"
                                    name="bankName">
                                <option value="">선택</option>
                                <option value="KB국민은행">KB국민은행</option>
                                <option value="신한은행">신한은행</option>
                                <option value="하나은행">하나은행</option>
                                <option value="우리은행">우리은행</option>
                                <option value="NH농협은행">NH농협은행</option>
                                <option value="IBK기업은행">IBK기업은행</option>
                                <option value="SC제일은행">SC제일은행</option>
                                <option value="씨티은행">씨티은행</option>
                                <option value="카카오뱅크">카카오뱅크</option>
                                <option value="토스뱅크">토스뱅크</option>
                                <option value="부산은행">부산은행</option>
                                <option value="경남은행">경남은행</option>
                                <option value="대구은행">대구은행</option>
                                <option value="광주은행">광주은행</option>
                                <option value="전북은행">전북은행</option>
                                <option value="제주은행">제주은행</option>
                            </select>
                        </div>

                        <div class="info-item">
                            <div class="label">계좌번호</div>
                            <input type="text"
                                   class="form-control form-control-sm"
                                   name="bankAccount"
                                   id="bankAccount"
                                   inputmode="numeric"
                                   placeholder="숫자만 입력"
                                   value="">
                        </div>

                        <!-- ✅ 마지막 세금 적용 -->
                        <div class="info-item">
                            <div class="label">세금 적용</div>
                            <div class="form-check form-switch mt-1">
                                <input class="form-check-input"
                                       type="checkbox"
                                       role="switch"
                                       id="applyTax"
                                       name="applyTax">
                                <label class="form-check-label text-xs text-muted" for="applyTax">
                                    3.3% 등 소득세 공제 적용
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- 4줄: 보건증 + 예상 급여 버튼 -->
                    <div class="info-grid mb-4">
                        <div class="info-item">
                            <div class="label">보건증 보유 여부</div>
                            <div class="form-check form-switch mt-1">
                                <input class="form-check-input"
                                       type="checkbox"
                                       role="switch"
                                       id="hasHealthCertificate"
                                       name="hasHealthCertificate">
                                <label class="form-check-label text-xs text-muted" for="hasHealthCertificate">
                                    보건증 소지
                                </label>
                            </div>
                        </div>

                        <div class="info-item">
                            <div class="label">보건증 유효기간</div>
                            <div class="d-flex align-items-center gap-2">
                                <input type="date"
                                       class="form-control form-control-sm"
                                       name="healthCertExpiry"
                                       id="healthCertExpiry"
                                       value="">
                            </div>
                        </div>

                        <div class="info-item"></div>

                        <div class="info-item">
                            <button type="button"
                                    id="btnOpenPayEstimate"
                                    class="btn btn-sm btn-outline-primary mt-3">
                                예상 급여 보기
                            </button>
                        </div>
                    </div>

                    <!-- 메모 -->
                    <div class="info-grid mb-4">
                        <div class="info-item">
                            <div class="label">메모</div>
                            <textarea class="form-control form-control-sm"
                                      name="memo"
                                      rows="2"
                                      placeholder="간단 메모를 남겨두세요."></textarea>
                        </div>
                    </div>

                    <!-- ============ 주간 템플릿 편집 (바 타입 간트 차트) ============ -->
                    <section class="panel-schedule mb-3 mt-4">
                        <header class="panel-schedule-header-blue">
                            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                                <div>
                                    <div class="title-sm schedule-header-kicker">SCHEDULE TEMPLATE</div>
                                    <h3 class="title-md mb-1 text-white">
                                        아르바이트 — 주간 템플릿 (월~일)
                                    </h3>
                                    <div class="text-xs schedule-header-text">
                                        빈 공간 클릭으로 추가 · 바를 드래그하여 이동/리사이즈 · 클릭하여 선택 후 삭제<br>
                                        <span class="schedule-header-strong">폼 저장 시 현재 템플릿이 함께 저장됩니다.</span>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <button type="button" class="btn btn-sm btn-danger d-none" id="tplBarDelete">삭제</button>
                                    <button type="button" class="btn btn-sm btn-outline-light subtle-outline-btn" id="btnGridClear">초기화</button>
                                </div>
                            </div>
                        </header>

                        <div class="panel-schedule-body p-0">
                            <div class="tg-gantt-outer">
                                <div class="tg-gantt-wrap" id="tplGanttWrap">
                                    <!-- JS 렌더 -->
                                </div>
                            </div>
                            <div class="d-flex gap-3 small text-muted align-items-center px-3 py-2">
                                <span><span class="tg-legend-box" style="background:rgba(102,187,106,0.5);border:1px solid rgba(46,160,67,0.6);"></span> 근무 일정</span>
                                <span class="ms-auto" style="font-size:0.72rem;color:#9ca3af;">빈 공간을 클릭하면 1시간 일정이 생성됩니다</span>
                            </div>
                        </div>
                    </section>
                </form>

            </div>
        </section>

    </div>
</main>

<style>
    /* ===== 전체 배경/레이아웃 ===== */
    body {
        background:
                radial-gradient(circle at top left, #f5f7ff 0, #eef3ff 36%, transparent 70%),
                radial-gradient(circle at bottom right, #fef6f3 0, #ffe8da 40%, #ffe1f0 75%);
    }
    .schedule-shell {
        min-height: calc(100vh - 80px);
    }

    .schedule-layout {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .panel {
        border-radius: 18px;
        background: rgba(255,255,255,0.9);
        box-shadow: 0 18px 40px rgba(15,23,42,0.08);
        border: 1px solid rgba(148,163,184,0.18);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }

    .panel-body {
        padding: 0.9rem 1.3rem 1.2rem 1.3rem;
    }

    .panel-merged .panel-body-merged {
        padding-top: 1.2rem;
    }

    /* ===== 🔵 상단 아르바이트 정보 입력 파란 헤더 ===== */
    .status-panel-blue {
        background: linear-gradient(135deg, #1d4ed8, #2563eb);
        border-radius: 18px 18px 0 0;
        padding: 16px 20px 18px;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.28);
        color: #e5eeff;
    }
    .member-header-blue {
        margin: -1px -1px 0 -1px; /* 패널 테두리와 자연스럽게 붙도록 */
    }

    .status-title {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: .02em;
    }
    .status-subtitle-small {
        font-size: .8rem;
        margin-top: 2px;
        color: rgba(226, 232, 255, 0.78);
    }
    .status-period-label-caption {
        font-size: .75rem;
        color: rgba(226, 232, 255, 0.9);
    }

    .status-select-top {
        background: rgba(15, 23, 42, 0.2);
        border-color: rgba(191, 219, 254, 0.9);
        color: #e5eeff;
        min-width: 120px;
    }
    .status-select-top:focus {
        background: rgba(15, 23, 42, 0.35);
        border-color: #bfdbfe;
        box-shadow: 0 0 0 0.18rem rgba(191, 219, 254, 0.45);
        color: #f9fbff;
    }
    .status-select-top option {
        color: #111827;
    }

    .status-name-input {
        min-width: 160px;
        background: rgba(15, 23, 42, 0.15);
        border-color: rgba(191,219,254,0.9);
        color: #e5eeff;
    }
    .status-name-input::placeholder {
        color: rgba(226,232,255,0.8);
    }
    .status-name-input:focus {
        background: rgba(15,23,42,0.25);
        border-color: #bfdbfe;
        box-shadow: 0 0 0 0.18rem rgba(191,219,254,0.45);
        color: #f9fbff;
    }

    .member-save-btn {
        border-radius: 999px;
        padding-inline: 14px;
    }

    .title-sm {
        font-size: 0.7rem;
        letter-spacing: .16em;
        text-transform: uppercase;
        color: #cbd5f5;
        font-weight: 600;
    }
    .title-md {
        font-size: 0.98rem;
        font-weight: 600;
        color: #111827;
    }
    .text-xs {
        font-size: 0.75rem;
    }

    .info-grid {
        display:grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap:0.9rem 1.2rem;
    }
    .info-item .label {
        font-size:0.7rem;
        text-transform:uppercase;
        letter-spacing:.12em;
        color:#9ca3af;
        margin-bottom:0.25rem;
    }

    .form-control-sm,
    .form-select-sm {
        font-size:0.82rem;
        padding:.25rem .5rem;
        border-radius:0.6rem;
    }

    .form-control-sm:focus,
    .form-select-sm:focus {
        box-shadow:0 0 0 1px rgba(59,130,246,0.3);
        border-color:#2563eb;
    }

    /* ===== 주간 템플릿 섹션 (카드 느낌, 같은 패널 내부) ===== */
    .panel-schedule {
        border-radius: 14px;
        border: 1px solid rgba(226,232,240,0.9);
        background: rgba(248,250,252,0.8);
        padding: 0;
        overflow: hidden;
    }

    /* 🔵 주간템플릿 파란 헤더 */
    .panel-schedule-header-blue {
        background: linear-gradient(135deg, #1d4ed8, #2563eb);
        padding: 0.9rem 1rem 0.9rem 1rem;
        border-bottom: 1px solid rgba(191, 219, 254, 0.7);
        color: #e5eeff;
    }
    .schedule-header-kicker {
        color: rgba(226,232,255,0.85);
    }
    .schedule-header-text {
        color: rgba(226,232,255,0.85);
    }
    .schedule-header-strong {
        color: #facc15;
    }
    .panel-schedule-toolbar {
        min-width: 260px;
    }

    .panel-schedule-body {
        padding: 0;
    }

    /* 🔹 파란헤더 안의 보조 버튼(초기화/원래대로)을 조금 더 잔잔하게 */
    .subtle-outline-btn {
        border-radius: 999px;
        border-color: rgba(191, 219, 254, 0.85);
        color: rgba(226, 232, 255, 0.9);
        background: transparent;
        font-size: 0.76rem;
        padding-inline: 0.7rem;
    }
    .subtle-outline-btn:hover {
        background: rgba(15, 23, 42, 0.25);
        color: #ffffff;
    }

    /* ====== 간트 차트 스타일 ====== */
    .tg-gantt-outer {
        overflow-x: auto;
        border-radius: 0;
        background: #fff;
    }
    .tg-gantt-wrap { min-width: 600px; }
    .tg-gantt-header-row {
        display: flex;
        align-items: stretch;
        position: sticky;
        top: 0;
        z-index: 5;
        background: linear-gradient(180deg, #f5f7fa 0%, #eef1f5 100%);
        border-bottom: 2px solid #dde3ea;
        height: 30px;
    }
    .tg-gantt-label-cell {
        width: 70px; min-width: 70px; flex: 0 0 70px;
        padding: 0 8px;
        font-size: 0.75rem; font-weight: 600; color: #1d4ed8;
        border-right: 1px solid #e5e7eb;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        position: sticky; left: 0;
        background: inherit;
        z-index: 3;
    }
    .tg-gantt-track-header {
        flex: 1; position: relative; min-height: 30px;
    }
    .tg-gantt-time-label {
        position: absolute; top: 0; height: 100%;
        border-left: 1px solid rgba(37,99,235,0.35);
        display: flex; align-items: center;
        padding-left: 4px;
        font-size: 0.7rem; font-weight: 600; color: #374151;
        font-variant-numeric: tabular-nums;
        pointer-events: none; user-select: none; white-space: nowrap;
    }
    .tg-gantt-time-label.minor {
        border-left-color: rgba(203,213,225,0.5);
        font-weight: 400; color: #9ca3af; font-size: 0.62rem;
    }
    .tg-gantt-hours-cell {
        width: 58px; min-width: 58px; flex: 0 0 58px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.73rem; font-weight: 600; color: #374151;
