{{>layouts/header_}}

<main class="container my-4">

    <!-- ============ 상단: 아르바이트 상태별 보기 (헤더 포함 전체 파란 패널) ============ -->
    <div class="card mb-3">
        <div class="card-body p-0">
            <!-- 🔵 헤더까지 모두 포함하는 파란 라운드 패널 -->
            <div class="status-panel-blue">
                <!-- 타이틀 + 기간 -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <div class="status-title">아르바이트 상태별 보기</div>
                        <div class="status-subtitle-small">
                            상태별로 아르바이트생을 필터링하고, 선택한 상태의 월간 일정을 함께 확인할 수 있습니다.
                        </div>
                    </div>
                    <div class="d-flex flex-column align-items-end">
                        <span class="status-period-label-caption">조회 기간</span>
                        <span id="statusPeriodLabel" class="status-period-label-value">0000.00.01 ~ 00.00</span>
                    </div>
                </div>

                <!-- 본문: 상태 선택 + 칩 리스트 -->
                <div class="row g-2 align-items-start">
                    <!-- 왼쪽: 상태 선택 + 보기 선택 -->
                    <div class="col-6 col-md-2">
                        <label class="form-label small status-label mb-1" for="statusSelect" style="font-size:.72rem;">상태</label>
                        <select id="statusSelect" class="form-select form-select-sm status-select">
                            <option value="WORKING" selected>근무중</option>
                            <option value="WAITING">시작전</option>
                            <option value="RESTING">휴식중</option>
                            <option value="PAUSED">일시중지</option>
                            <option value="RESIGNED">퇴사</option>
                        </select>
                    </div>
                    <div class="col-6 col-md-2">
                        <label class="form-label small status-label mb-1" for="dataTypeSelect" style="font-size:.72rem;">보기</label>
                        <select id="dataTypeSelect" class="form-select form-select-sm status-select">
                            <option value="schedule" selected>일정</option>
                            <option value="actual">근무시간</option>
                        </select>
                    </div>

                    <!-- 오른쪽: 필터된 아르바이트 생 칩 리스트 -->
                    <div class="col-12 col-md-8">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="small status-subtitle" style="font-size:.72rem;">필터된 아르바이트생</span>
                            <span id="statusCountBadgeTop" class="badge bg-light text-dark status-count-badge">0명</span>
                        </div>

                        <!-- 칩( pill ) 리스트 -->
                        <div id="memberPills" class="vlist status-pill-list"></div>
                    </div>
                </div>
            </div>
            <!-- // status-panel-blue -->
        </div>
    </div>

    <!-- ============ 하단: 월간 매트릭스 (모든 근로자 표시) ============ -->
    <div class="card">
        <div id="monthCardHeader"
             class="card-header fw-bold d-flex align-items-center justify-content-between">

            <!-- 🔵 왼쪽: 제목 -->
            <div class="d-flex align-items-center gap-2">
                <span>
                    선택 월 실제 일정 (모든 근로자)
                    <small id="selectedMemberNameRight" class="text-muted ms-2">[하이라이트: 전체]</small>
                    <span id="selectedMemberStatusRight" class="badge bg-secondary ms-2 d-none">-</span>
                </span>
            </div>

            <!-- 오른쪽: 월 이동 버튼 -->
            <div class="d-flex align-items-center gap-2">
                <button id="btnMonthPrev" class="btn btn-sm btn-outline-secondary">◀ 이전 달</button>
                <span id="monthRangeLabel" class="small text-muted">0000.00.01 ~ 00.00</span>
                <button id="btnMonthThis" class="btn btn-sm btn-outline-secondary">이번 달</button>
                <button id="btnMonthNext" class="btn btn-sm btn-outline-secondary">다음 달 ▶</button>
            </div>
        </div>

        <div class="card-body">

            <!-- ✅ 비어있음/생성 유도 상태 -->
            <div id="emptyState" class="text-center py-4 d-none">
                <div id="emptyTitle" class="mb-2 text-muted">이 달에는 저장된 일정이 없습니다.</div>
                <button id="btnCreateFromEmpty" class="btn btn-primary btn-sm">일정 생성하기</button>
                <div id="emptyHint" class="small text-muted mt-2">* 상단 칩에서 아르바이트생을 선택한 후 눌러주세요.</div>
            </div>

            <!-- ✅ 매트릭스 뷰 -->
            <div id="monthMatrixOuter" class="mm-outer d-none">
                <div id="monthMatrixWrap" class="mm-wrap">
                    <!-- JS가 buildMonthMatrix()로 렌더링 -->
                </div>
            </div>

            <div class="mt-3">
                <div class="d-flex justify-content-between">
                    <div class="small text-muted">
                        월 합계(전체)
                        <span id="monthSelectedMemberTotalWrap" class="ms-2 d-none">· 선택 <span id="monthSelectedMemberNameLabel"></span>: <span id="monthSelectedMemberTotal"></span></span>
                    </div>
                    <div class="fw-semibold" id="monthActualTotalCell">0시간</div>
                </div>
            </div>
            <span id="monthLabel" class="d-none">0000-00-01</span>
        </div>
    </div>

    <!-- ============ 하단: 멤버 선택 시 월간 캘린더 뷰 ============ -->
    <div class="card mt-3 d-none" id="memberCalendarCard">
        <div class="card-header fw-bold d-flex justify-content-between align-items-center" style="background:#5b4434;color:#fff;border-radius:12px 12px 0 0;">
            <span id="memberCalendarTitle">홍길동 - 2026년 3월 일정</span>
        </div>
        <div class="card-body p-2">
            <div id="memberCalendarWrap"></div>
        </div>
    </div>
</main>

<!-- ===== Gantt 팝업 (풀스크린 overlay) ===== -->
<div class="dg-popup-overlay d-none" id="dgPopupOverlay">
    <div class="dg-popup">
        <div class="dg-popup-header">
            <div>
                <div class="dg-popup-title" id="dgPopupTitle">0000-00-00 (월)</div>
                <div class="dg-popup-subtitle" id="dgPopupSubtitle">전체 아르바이트생 일정 · 바를 드래그하여 편집</div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button type="button" class="btn btn-sm btn-outline-light d-none" id="dgBtnDelete" style="border-radius:999px;font-size:.73rem;padding:.25rem .8rem;font-weight:600;">삭제</button>
                <button type="button" class="dg-popup-close-btn" id="dgBtnClose">닫기</button>
            </div>
        </div>
        <div class="dg-popup-body">
            <div class="dg-popup-gantt-outer">
                <div class="dg-popup-gantt-wrap" id="dgPopupGanttWrap">
                    <!-- JS가 buildDgPopupGantt()로 렌더링 -->
                </div>
            </div>
        </div>
        <div class="dg-popup-footer">
            <div class="dg-popup-legend">
                <span class="dg-legend-item"><span class="dg-legend-swatch dg-legend-modified"></span> 변경됨</span>
                <span class="dg-legend-item"><span class="dg-legend-swatch dg-legend-selected"></span> 선택됨</span>
                <span id="dgChangeInfo" class="small ms-2" style="color:rgba(255,255,255,.7);"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm d-none" id="dgBtnCancel" style="background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3);border-radius:999px;font-size:.73rem;padding:.3rem 1rem;">취소</button>
                <button type="button" class="btn btn-sm d-none" id="dgBtnSave" style="background:#16a34a;color:#fff;border:none;border-radius:999px;font-size:.73rem;padding:.3rem 1rem;font-weight:600;">저장</button>
            </div>
        </div>
    </div>
</div>

<!-- ===== 플로팅 드래그 툴팁 ===== -->
<div id="dragTimeTooltip" class="drag-time-tooltip"></div>

<style>
    /* ===== 🔵 상단 아르바이트 상태 패널 ===== */
    .status-panel-blue {
        background: linear-gradient(135deg, #1d4ed8, #2563eb);
        border-radius: 14px;
        padding: 10px 16px 12px;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.22);
        color: #e5eeff;
    }
    .status-title {
        font-size: .95rem;
        font-weight: 700;
        letter-spacing: .02em;
    }
    .status-subtitle-small {
        font-size: .72rem;
        margin-top: 1px;
        color: rgba(226, 232, 255, 0.78);
    }
    .status-period-label-caption {
        font-size: .68rem;
        color: rgba(226, 232, 255, 0.7);
    }
    .status-period-label-value {
        font-size: .78rem;
        font-weight: 600;
        margin-top: 1px;
        padding: 1px 7px;
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.32);
        border: 1px solid rgba(191, 219, 254, 0.6);
    }
    .status-label {
        color: rgba(226, 232, 255, 0.9) !important;
    }
    .status-subtitle {
        color: rgba(226, 232, 255, 0.9);
    }
    .status-count-badge {
        border-radius: 999px;
        padding: 1px 8px;
        font-size: .75rem;
        font-weight: 600;
    }
    .status-select {
        background: rgba(15, 23, 42, 0.25);
        border-color: rgba(191, 219, 254, 0.6);
        color: #e5eeff;
    }
    .status-select:focus {
        background: rgba(15, 23, 42, 0.35);
        border-color: #bfdbfe;
        box-shadow: 0 0 0 0.2rem rgba(191, 219, 254, 0.45);
        color: #f9fbff;
    }
    .status-select option {
        color: #111827;
    }
    .status-pill-list {
        margin-top: 2px;
    }

    /* ===== 아르바이트 칩 스타일 ===== */
    .vlist { display:flex; flex-wrap:wrap; gap:5px; }
    .pill {
        display:flex; align-items:center; gap:5px; padding:4px 10px;
        border-radius:999px;
        border:1px solid rgba(191, 219, 254, 0.7);
        background: rgba(15, 23, 42, 0.18);
        cursor:pointer;
        font-size:.78rem;
        transition: background .15s, box-shadow .15s, border-color .15s, transform .08s;
        color:#e5eeff;
        white-space: nowrap;
    }
    .pill:hover {
        background: rgba(15, 23, 42, 0.28);
        border-color: rgba(248, 250, 252, 0.95);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.4);
    }
    .pill.active {
        border-color: rgba(191, 219, 254, 0.95);
        box-shadow: 0 0 0 2px rgba(191, 219, 254, 0.7), 0 6px 16px rgba(15, 23, 42, 0.45);
        background: rgba(15, 23, 42, 0.4);
        transform: translateY(-1px);
    }
    .pill .dot {
        width:9px; height:9px; border-radius:50%;
        border:1px solid rgba(15, 23, 42,.15);
        flex:0 0 9px;
        box-shadow: 0 0 0 1.5px rgba(15, 23, 42, 0.2);
    }
    .pill .name { font-weight:600; white-space:nowrap; }

    /* ✅ 카드 헤더 sticky */
    #monthCardHeader { position: sticky; top: 0; z-index: 30; background: #fff; }

    /* ===== 매트릭스 뷰 (.mm-*) ===== */
    .mm-outer {
        overflow-x: auto;
        padding-bottom: 4px;
    }
    .mm-wrap {
        min-width: 700px;
    }
    .mm-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        table-layout: fixed;
    }
    .mm-corner {
        width: 100px;
        min-width: 100px;
        background: #f8f9fa;
        position: sticky;
        left: 0;
        z-index: 3;
        border-bottom: 1.5px solid #dee2e6;
        border-right: 1px solid #e9ecef;
    }
    .mm-date-head {
        text-align: center;
        padding: 6px 2px;
        font-size: .75rem;
        font-weight: 600;
        color: #495057;
        border-bottom: 1.5px solid #dee2e6;
        cursor: pointer;
        user-select: none;
    }
    .mm-date-head:hover {
        background: #e8f0fe;
    }
    .mm-date-head.mm-weekend {
        color: #dc3545;
    }
    .mm-date-head.mm-today {
        background: #e8f5e9;
        font-weight: 700;
    }
    .mm-member-label {
        position: sticky;
        left: 0;
        z-index: 2;
        background: #fff;
        padding: 4px 8px;
        font-size: .8rem;
        font-weight: 600;
        white-space: nowrap;
        border-right: 1px solid #e9ecef;
        border-bottom: 1px solid #f0f2f5;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100px;
    }
    .mm-member-label .mm-label-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-right: 4px;
        vertical-align: middle;
    }
    .mm-day-cell {
        height: 30px;
        border: 1px solid #f0f2f5;
        border-radius: 4px;
        cursor: pointer;
        transition: opacity .12s, box-shadow .12s;
        position: relative;
    }
    .mm-day-cell.mm-filled {
        opacity: 0.8;
    }
    .mm-day-cell.mm-filled:hover {
        opacity: 1;
        box-shadow: inset 0 0 0 2px rgba(0,0,0,.18);
    }
    .mm-day-cell.mm-empty {
        background: #fff;
    }
    .mm-day-cell.mm-empty:hover {
        background: #f8f9fa;
    }
    .mm-day-cell .mm-minutes-text {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .62rem;
        font-weight: 600;
        color: rgba(255,255,255,.9);
        text-shadow: 0 1px 2px rgba(0,0,0,.3);
        pointer-events: none;
    }

    /* ===== Gantt 팝업 overlay ===== */
    .dg-popup-overlay {
        position: fixed; inset: 0; z-index: 2000;
        background: rgba(15,23,42,.55);
        backdrop-filter: blur(2px);
        display: flex; align-items: center; justify-content: center;
    }
    .dg-popup {
        width: 96vw; max-width: 1200px; max-height: 90vh;
        background: #1e293b; color: #f1f5f9;
        border-radius: 18px;
        box-shadow: 0 20px 60px rgba(0,0,0,.5);
        display: flex; flex-direction: column;
        overflow: hidden;
    }
    .dg-popup-header {
        display: flex; justify-content: space-between; align-items: center;
        padding: 14px 20px 10px;
        border-bottom: 1px solid rgba(255,255,255,.1);
    }
    .dg-popup-title { font-size: 1.05rem; font-weight: 700; }
    .dg-popup-subtitle { font-size: .72rem; color: rgba(241,245,249,.6); margin-top: 2px; }
    .dg-popup-close-btn {
        background: rgba(255,255,255,.12); color: #f1f5f9; border: 1px solid rgba(255,255,255,.2);
        border-radius: 999px; padding: .3rem 1.2rem; font-size: .78rem; font-weight: 600; cursor: pointer;
    }
    .dg-popup-close-btn:hover { background: rgba(255,255,255,.22); }
    .dg-popup-body {
        flex: 1; overflow-y: auto; padding: 12px 20px;
    }
    .dg-popup-gantt-outer { min-width: 700px; }
    .dg-popup-footer {
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 20px 12px;
        border-top: 1px solid rgba(255,255,255,.1);
    }
    .dg-popup-legend { display: flex; align-items: center; gap: 12px; font-size: .7rem; color: rgba(255,255,255,.55); }
    .dg-legend-item { display: flex; align-items: center; gap: 4px; }
    .dg-legend-swatch { width: 14px; height: 10px; border-radius: 3px; }
    .dg-legend-modified { background: #fb923c; outline: 1.5px dashed rgba(255,255,255,.5); outline-offset: 1px; }
    .dg-legend-selected { background: #60a5fa; box-shadow: 0 0 0 2px #2563eb; }

    /* Gantt 행 (팝업 내부) */
    .dg-popup-gantt-wrap .mw-gantt-header-row { display:flex; align-items:flex-end; border-bottom:1px solid rgba(255,255,255,.08); padding-bottom:2px; margin-bottom:4px; }
    .dg-popup-gantt-wrap .mw-gantt-label-cell { width:100px; min-width:100px; flex:0 0 100px; display:flex; align-items:center; padding-left:10px; }
    .dg-popup-gantt-wrap .mw-gantt-track-header { flex:1; position:relative; height:22px; }
    .dg-popup-gantt-wrap .mw-gantt-time-label { position:absolute; font-size:.65rem; color:rgba(255,255,255,.4); transform:translateX(-50%); }
    .dg-popup-gantt-wrap .mw-gantt-time-label.minor { font-size:.55rem; color:rgba(255,255,255,.2); }
    .dg-popup-gantt-wrap .dg-hours-cell { width:60px; min-width:60px; flex:0 0 60px; text-align:center; font-size:.68rem; font-weight:600; color:rgba(255,255,255,.4); }

    .dg-popup-gantt-wrap .mw-gantt-row { display:flex; align-items:center; min-height:42px; border-bottom:1px solid rgba(255,255,255,.06); padding:2px 0; }
    .dg-popup-gantt-wrap .mw-gantt-row .mw-gantt-label-cell { height:42px; }
    .dg-popup-gantt-wrap .dg-member-chip { display:inline-block; width:8px; height:8px; border-radius:50%; margin-right:6px; flex-shrink:0; }
    .dg-popup-gantt-wrap .dg-member-name { font-size:.78rem; font-weight:600; color:#f1f5f9; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .dg-popup-gantt-wrap .mw-gantt-track-cell { flex:1; position:relative; height:34px; background:rgba(255,255,255,.04); border-radius:6px; }

    .dg-popup-bar {
        position:absolute; top:3px; height:28px; border-radius:5px; cursor:grab; z-index:2;
        display:flex; align-items:center; justify-content:center;
        font-size:.68rem; color:#fff; font-weight:600; text-shadow:0 1px 2px rgba(0,0,0,.25);
        user-select:none; transition:filter .1s;
    }
    .dg-popup-bar:hover { filter:brightness(1.1); }
    .dg-popup-bar.dragging { cursor:grabbing; filter:brightness(1.15); box-shadow:0 4px 14px rgba(0,0,0,.35); z-index:10; }
    .dg-popup-bar.resizing { z-index:10; }
    .dg-popup-bar.modified { outline:2px dashed rgba(255,255,255,.5); outline-offset:1px; }
    .dg-popup-bar.dg-bar-selected { box-shadow:0 0 0 2.5px #2563eb, 0 0 0 4.5px rgba(37,99,235,.35); z-index:5; }
    .dg-popup-bar .bar-handle-left,
    .dg-popup-bar .bar-handle-right { position:absolute; top:0; width:8px; height:100%; cursor:col-resize; z-index:3; opacity:0; transition:opacity .15s; }
    .dg-popup-bar:hover .bar-handle-left,
    .dg-popup-bar:hover .bar-handle-right { opacity:1; background:rgba(255,255,255,.22); border-radius:3px; }
    .dg-popup-bar .bar-handle-left { left:-2px; }
    .dg-popup-bar .bar-handle-right { right:-2px; }
    .dg-popup-bar .dg-bar-time { font-size:.65rem; pointer-events:none; }
    .dg-popup-bar .dg-bar-tooltip { display:none; position:absolute; bottom:calc(100% + 6px); left:50%; transform:translateX(-50%); background:#0f172a; color:#e2e8f0; font-size:.68rem; padding:3px 8px; border-radius:6px; white-space:nowrap; z-index:20; pointer-events:none; }
    .dg-popup-bar:hover .dg-bar-tooltip { display:block; }

    /* ===== 플로팅 드래그 툴팁 ===== */
    .drag-time-tooltip {
        position: fixed;
        z-index: 9999;
        pointer-events: none;
        background: #1e293b;
        color: #f1f5f9;
        font-size: .78rem;
        font-weight: 600;
        padding: 5px 10px;
        border-radius: 6px;
        box-shadow: 0 4px 14px rgba(0,0,0,.35);
        white-space: nowrap;
        opacity: 0;
        transition: opacity .12s;
        font-variant-numeric: tabular-nums;
    }
    .drag-time-tooltip.visible {
        opacity: 1;
    }
    .drag-time-tooltip .dtt-arrow {
        position: absolute;
        bottom: -4px;
        left: 50%;
        transform: translateX(-50%) rotate(45deg);
        width: 8px;
        height: 8px;
        background: #1e293b;
    }
    .drag-time-tooltip .dtt-changed {
        color: #60a5fa;
    }

    /* ===== 빈 상태 메시지 ===== */
    .dg-empty-msg {
        text-align: center;
        padding: 24px;
        color: #6b7280;
        font-size: .9rem;
    }

    /* ===== 월간 캘린더 뷰 (.mc-*) ===== */
    .mc-table { width:100%; border-collapse:separate; border-spacing:3px; table-layout:fixed; }
    .mc-dow-head { text-align:center; font-size:.75rem; font-weight:700; padding:6px 2px; color:#5b4434; background:#fff9f2; border-radius:6px; }
    .mc-dow-head.mc-weekend { color:#dc3545; }
    .mc-day-cell {
        vertical-align:top; min-height:70px; padding:5px 6px;
        border:1px solid #e9ecef; border-radius:8px; background:#fff; cursor:pointer;
        transition: background .12s, box-shadow .12s;
    }
    .mc-day-cell:hover { background:#f8f9fa; box-shadow:0 2px 8px rgba(0,0,0,.06); }
    .mc-day-cell.mc-today { background:#f0fdf4; border-color:#86efac; }
    .mc-day-cell.mc-other-month { opacity:.3; pointer-events:none; }
    .mc-day-num { font-size:.72rem; font-weight:700; color:#374151; margin-bottom:3px; }
    .mc-day-num.mc-weekend-num { color:#dc3545; }
    .mc-schedule-pill {
        display:block; padding:2px 7px; margin:2px 0; border-radius:999px;
        font-size:.62rem; font-weight:600; color:#fff; cursor:pointer;
        transition:box-shadow .12s, filter .1s; white-space:nowrap;
        overflow:hidden; text-overflow:ellipsis;
    }
    .mc-schedule-pill:hover { filter:brightness(1.1); }
    .mc-schedule-pill.mc-pill-selected { box-shadow:0 0 0 2px #1d4ed8, 0 0 0 4px rgba(37,99,235,.25); }
    .mc-no-schedule { font-size:.6rem; color:#9ca3af; }
    .mc-pill-actions {
        display:inline-flex; gap:3px; margin-left:4px; vertical-align:middle;
    }
    .mc-pill-del-btn {
        display:inline-flex; align-items:center; justify-content:center;
        width:16px; height:16px; border-radius:50%;
        background:rgba(220,38,38,.15); color:#dc3545; border:none;
        font-size:.6rem; font-weight:700; cursor:pointer; line-height:1;
        padding:0;
    }
    .mc-pill-del-btn:hover { background:rgba(220,38,38,.3); }
</style>

<script id="membersData" type="application/json">
{{{membersJson}}}
</script>

<script>
    (function(){
        // ===== DOM =====
        const statusSelect = document.getElementById('statusSelect');
        const memberPills = document.getElementById('memberPills');

        const selectedMemberNameRight = document.getElementById('selectedMemberNameRight');
        const selectedMemberStatusRight = document.getElementById('selectedMemberStatusRight');

        const monthMatrixOuter = document.getElementById('monthMatrixOuter');
        const monthMatrixWrap  = document.getElementById('monthMatrixWrap');
        const emptyState       = document.getElementById('emptyState');
        const emptyTitle       = document.getElementById('emptyTitle');
        const emptyHint        = document.getElementById('emptyHint');
        const btnCreateFromEmpty = document.getElementById('btnCreateFromEmpty');

        const monthLabel = document.getElementById('monthLabel');
        const monthRangeLabel = document.getElementById('monthRangeLabel');
        const btnMonthPrev = document.getElementById('btnMonthPrev');
        const btnMonthThis = document.getElementById('btnMonthThis');
        const btnMonthNext = document.getElementById('btnMonthNext');
        const monthActualTotalCell = document.getElementById('monthActualTotalCell');

        const monthSelectedMemberTotalWrap = document.getElementById('monthSelectedMemberTotalWrap');
        const monthSelectedMemberNameLabel = document.getElementById('monthSelectedMemberNameLabel');
        const monthSelectedMemberTotal = document.getElementById('monthSelectedMemberTotal');

        const monthCardHeader = document.getElementById('monthCardHeader');
        const statusPeriodLabel = document.getElementById('statusPeriodLabel');
        const statusCountBadgeTop = document.getElementById('statusCountBadgeTop');

        // 캘린더 뷰 DOM
        const memberCalendarCard = document.getElementById('memberCalendarCard');
        const memberCalendarTitle = document.getElementById('memberCalendarTitle');
        const memberCalendarWrap = document.getElementById('memberCalendarWrap');
        let selectedCalPill = null; // { memberId, iso, start, end }

        // ===== Gantt 팝업 DOM =====
        const dgPopupOverlay = document.getElementById('dgPopupOverlay');
        const dgPopupTitle   = document.getElementById('dgPopupTitle');
        const dgPopupSubtitle= document.getElementById('dgPopupSubtitle');
        const dgBtnSave      = document.getElementById('dgBtnSave');
        const dgBtnCancel    = document.getElementById('dgBtnCancel');
        const dgBtnClose     = document.getElementById('dgBtnClose');
        const dgBtnDelete    = document.getElementById('dgBtnDelete');
        const dgChangeInfo   = document.getElementById('dgChangeInfo');
        const dgPopupGanttWrap = document.getElementById('dgPopupGanttWrap');

        // ===== API =====
        const API_ENDPOINT = '/api/schedule/work';
        const API_UPDATE_ENDPOINT = '/api/schedule/work/update';
        const API_ACTUAL_ENDPOINT = '/api/schedule';
        const API_ACTUAL_UPDATE_ENDPOINT = '/api/schedule/update';
        const dataTypeSelect = document.getElementById('dataTypeSelect');
        let currentDataType = 'schedule';

        // ===== 상태 =====
        let allMembers = [];
        try { allMembers = JSON.parse(document.getElementById('membersData').textContent || '[]'); } catch(e){ allMembers = []; }

        let currentMember = null;
        let currentMonthStart = firstDayOfMonth(new Date());
        let currentStatusMembers = [];

        let monthAllMembersDayMap = {};
        let lastMonthTotalByMember = {};
        let lastMonthTotalAll = 0;

        // Gantt 팝업 상태
        let dgPopupIso = null;
        let dgPopupFilterMemberId = null;  // null=전체, id=특정멤버
        let dgBarInfo = null;               // 선택된 바 { memberId, iso, start, end }
        let dgOrigSnapshot = {};            // 스냅샷
        let dgPendingChanges = {};          // { `${mid}_${iso}`: { memberId, iso, segments } }
        let _dgDragState = null;
        let _dgJustDragged = false;
        let _dgDragInited = false;

        const HOUR_START = 6;
        const HOUR_END = 22;
        const TOTAL_MIN = (HOUR_END - HOUR_START) * 60;

        function updateMonthHeaderOffset() {
            if (!monthCardHeader) return;
            const fixedHeader = document.querySelector('.navbar.fixed-top, .fixed-top, header.sticky-top');
            const navH = fixedHeader ? fixedHeader.getBoundingClientRect().height : 0;
            monthCardHeader.style.top = navH + 'px';
        }
        updateMonthHeaderOffset();
        window.addEventListener('resize', updateMonthHeaderOffset);

        // 초기
        attachHandlers();
        renderMembersByStatus();

        function attachHandlers(){
            statusSelect.addEventListener('change', ()=> renderMembersByStatus());
            dataTypeSelect.addEventListener('change', ()=> {
                currentDataType = dataTypeSelect.value;
                renderAllMembersMonth(currentMonthStart);
            });
            btnMonthPrev.addEventListener('click', (e)=>{ e.preventDefault(); shiftMonth(-1); });
            btnMonthNext.addEventListener('click', (e)=>{ e.preventDefault(); shiftMonth(+1); });
            btnMonthThis.addEventListener('click', (e)=>{ e.preventDefault(); goToThisMonth(); });

            if(btnCreateFromEmpty){
                btnCreateFromEmpty.addEventListener('click', ()=>{
                    if(!currentMember){
                        alert('먼저 상단 칩에서 아르바이트생을 선택하세요.');
                        return;
                    }
                    const baseMonthIso = (monthLabel.textContent || '').trim() || toIso(currentMonthStart);
                    const url = `/schedules/generator?memberId=${encodeURIComponent(currentMember.id)}&baseMonth=${encodeURIComponent(baseMonthIso)}`;
                    window.open(url, 'scheduleGenerator', 'width=1200,height=800,top=80,left=80,scrollbars=yes,resizable=yes');
                });
            }

            // Gantt 팝업 버튼
            dgBtnClose.addEventListener('click', closeDgPopup);
            dgPopupOverlay.addEventListener('click', (e)=>{ if(e.target===dgPopupOverlay) closeDgPopup(); });
            document.addEventListener('keydown', (e)=>{ if(e.key==='Escape' && dgPopupIso) closeDgPopup(); });
            dgBtnSave.addEventListener('click', onSaveDgPopup);
            dgBtnCancel.addEventListener('click', onCancelDgPopup);
            dgBtnDelete.addEventListener('click', onDeleteDgBar);
        }

        function renderMembersByStatus(){
            const status = statusSelect.value;
            const filtered = (allMembers||[]).filter(m=>m.status===status);
            currentStatusMembers = filtered;

            if(statusCountBadgeTop){
                statusCountBadgeTop.textContent = `${filtered.length}명`;
            }

            memberPills.innerHTML = '';

            if(!filtered.length){
                memberPills.innerHTML = `<span class="text-light small">해당 상태의 아르바이트생이 없습니다.</span>`;
                setHighlight(null);
                clearMatrixOnly();
                syncStatusPeriodWithMonthRange();
                return;
            }

            filtered
                .slice()
                .sort((a,b)=>(a.name||'').localeCompare(b.name||'', 'ko'))
                .forEach(m=>{
                    const color = colorForMember(m);
                    const row = document.createElement('button');
                    row.type = 'button';
                    row.className = 'pill';
                    row.dataset.memberId = String(m.id);
                    row.setAttribute('title','하이라이트 토글');
                    row.innerHTML = `
                        <span class="dot" style="background:${color}"></span>
                        <span class="name">${escapeHtml(m.name ?? '-')}</span>
                    `;
                    row.addEventListener('click', (evt)=>{
                        evt.preventDefault();
                        evt.stopPropagation();
                        if(currentMember && String(currentMember.id)===String(m.id)){
                            setHighlight(null);
                        }else{
                            setHighlight(m);
                        }
                    });
                    memberPills.appendChild(row);
                });

            setHighlight(null);
            renderAllMembersMonth(currentMonthStart);
        }

        function setHighlight(member){
            currentMember = member || null;

            Array.from(memberPills.querySelectorAll('.pill')).forEach(el=>el.classList.remove('active'));
            if(currentMember){
                const active = memberPills.querySelector(`.pill[data-member-id="${currentMember.id}"]`);
                if(active) active.classList.add('active');
                selectedMemberNameRight.textContent = `(하이라이트: ${currentMember.name ?? '-'})`;
                selectedMemberStatusRight.classList.remove('d-none');
                const badgeMap={WORKING:'bg-success',WAITING:'bg-secondary',RESTING:'bg-info',PAUSED:'bg-warning',RESIGNED:'bg-danger'};
                selectedMemberStatusRight.textContent = currentMember.status || '-';
                selectedMemberStatusRight.className = `badge ${badgeMap[currentMember.status]||'bg-secondary'} ms-2`;
                monthSelectedMemberNameLabel.textContent = currentMember.name ?? '-';
                monthSelectedMemberTotalWrap.classList.remove('d-none');
            }else{
                selectedMemberNameRight.textContent = '[하이라이트: 전체]';
                selectedMemberStatusRight.classList.add('d-none');
                selectedMemberStatusRight.textContent = '-';
                selectedMemberStatusRight.className = 'badge bg-secondary ms-2 d-none';
                monthSelectedMemberTotalWrap.classList.add('d-none');
            }

            renderAllMembersMonth(currentMonthStart);
        }

        function clearMatrixOnly(){
            monthMatrixWrap.innerHTML='';
            monthRangeLabel.textContent='0000.00.01 ~ 00.00';
            monthActualTotalCell.textContent='0시간';
            emptyTitle.textContent = '이 달에는 저장된 일정이 없습니다.';
            emptyHint.textContent = '* 상단 칩에서 아르바이트생을 선택한 후 눌러주세요.';
            emptyState.classList.remove('d-none');
            monthMatrixOuter.classList.add('d-none');
            showMemberCalendar(null);
        }

        function shiftMonth(offset){
            currentMonthStart = firstDayOfMonth(new Date(
                currentMonthStart.getFullYear(),
                currentMonthStart.getMonth()+offset,
                1
            ));
            renderAllMembersMonth(currentMonthStart);
        }
        function goToThisMonth(){
            currentMonthStart = firstDayOfMonth(new Date());
            renderAllMembersMonth(currentMonthStart);
        }

        // ===== 월간 데이터 로드 + 매트릭스 빌드 =====
        async function renderAllMembersMonth(baseDate){
            const ms = firstDayOfMonth(baseDate);
            const me = lastDayOfMonth(baseDate);
            currentMonthStart = ms;

            const monthStartIso = toIso(ms), monthEndIso = toIso(me);
            monthLabel.textContent = monthStartIso;
            const rangeText = `${ms.getFullYear()}.${pad2(ms.getMonth()+1)}.01 ~ ${pad2(me.getMonth()+1)}.${pad2(me.getDate())}`;
            monthRangeLabel.textContent = rangeText;
            syncStatusPeriodWithMonthRange(rangeText);

            // 렌더링할 멤버: 하이라이트 시 해당 멤버만, 아니면 전체
            const membersToShow = currentMember
                ? currentStatusMembers.filter(m => String(m.id) === String(currentMember.id))
                : currentStatusMembers;

            // 모든 근로자 해당 월 데이터 로딩
            monthAllMembersDayMap = {};
            await Promise.all((currentStatusMembers||[]).map(async m=>{
                try{
                    const fetchEp = (currentDataType === 'actual') ? API_ACTUAL_ENDPOINT : API_ENDPOINT;
                    const url = `${fetchEp}/${encodeURIComponent(m.id)}/${monthStartIso}/${monthEndIso}`;
                    const resp = await fetch(url, { headers: { 'Accept':'application/json' } });
                    if(!resp.ok) return;
                    const data = await resp.json();
                    monthAllMembersDayMap[m.id] = normalizeActualDays(data);
                }catch(e){ console.error(e); }
            }));

            // 합계 계산
            lastMonthTotalAll = 0;
            lastMonthTotalByMember = {};
            (currentStatusMembers||[]).forEach(m=>{
                const dayMap = monthAllMembersDayMap[m.id] || {};
                let memberTotal = 0;
                Object.values(dayMap).forEach(v=>{
                    const mins = v.minutes || 0;
                    memberTotal += mins;
                    lastMonthTotalAll += mins;
                });
                lastMonthTotalByMember[m.id] = memberTotal;
            });

            monthActualTotalCell.textContent = formatMins(lastMonthTotalAll);
            updateSelectedMemberMonthTotal();

            // 빈 상태 처리
            if(currentMember){
                const selTotal = lastMonthTotalByMember[currentMember.id] || 0;
                if(selTotal === 0 && membersToShow.length > 0){
                    const monthStr = `${ms.getFullYear()}.${pad2(ms.getMonth()+1)}`;
                    emptyTitle.textContent = `${currentMember.name ?? '선택한 근로자'}의 ${monthStr} 일정이 없습니다.`;
                    emptyHint.textContent  = '버튼을 눌러 일정 템플릿에서 생성하세요.';
                    emptyState.classList.remove('d-none');
                    monthMatrixOuter.classList.add('d-none');
                    showMemberCalendar(currentMember);
                    return;
                }
            } else {
                if(lastMonthTotalAll === 0){
                    emptyState.classList.remove('d-none');
                    monthMatrixOuter.classList.add('d-none');
                    showMemberCalendar(null);
                    return;
                }
            }

            emptyState.classList.add('d-none');
            monthMatrixOuter.classList.remove('d-none');

            // 매트릭스 빌드
            buildMonthMatrix(ms, me, membersToShow);

            // 캘린더 뷰 갱신
            showMemberCalendar(currentMember);
        }

        // ===== 매트릭스 빌드 =====
        function buildMonthMatrix(ms, me, members){
            const todayIso = toIso(new Date());
            const daysInMonth = me.getDate();
            const DOW_SHORT = ['일','월','화','수','목','금','토'];

            // 멤버 정렬
            const sorted = members.slice().sort((a,b)=>(a.name||'').localeCompare(b.name||'','ko'));

            let html = '<table class="mm-table"><thead><tr>';
            // 코너
            html += '<th class="mm-corner"></th>';

            // 날짜 헤더
            for(let d=1; d<=daysInMonth; d++){
                const dt = new Date(ms.getFullYear(), ms.getMonth(), d);
                const dow = dt.getDay();
                const iso = toIso(dt);
                const isWeekend = (dow === 0 || dow === 6);
                const isToday = (iso === todayIso);
                let cls = 'mm-date-head';
                if(isWeekend) cls += ' mm-weekend';
                if(isToday) cls += ' mm-today';
                html += `<th class="${cls}" data-date="${iso}" title="${iso} (${DOW_SHORT[dow]})">${d}<br><span style="font-size:.62rem;font-weight:400;">${DOW_SHORT[dow]}</span></th>`;
            }
            html += '</tr></thead><tbody>';

            // 멤버 행
            sorted.forEach(m=>{
                const color = colorForMember(m);
                const dayMap = monthAllMembersDayMap[m.id] || {};

                html += '<tr>';
                html += `<td class="mm-member-label"><span class="mm-label-dot" style="background:${color}"></span>${escapeHtml(m.name ?? '-')}</td>`;

                for(let d=1; d<=daysInMonth; d++){
                    const dt = new Date(ms.getFullYear(), ms.getMonth(), d);
                    const iso = toIso(dt);
                    const day = dayMap[iso];
                    const hasMins = day && (day.minutes||0) > 0;

                    if(hasMins){
                        const hrs = Math.round(day.minutes / 60 * 10) / 10;
                        html += `<td class="mm-day-cell mm-filled" data-date="${iso}" data-member="${m.id}" style="background:${color};">`;
                        html += `<span class="mm-minutes-text">${hrs}</span>`;
                        html += `</td>`;
                    } else {
                        html += `<td class="mm-day-cell mm-empty" data-date="${iso}" data-member="${m.id}"></td>`;
                    }
                }
                html += '</tr>';
            });

            html += '</tbody></table>';
            monthMatrixWrap.innerHTML = html;

            // 날짜 헤더 클릭 → 전체 멤버 팝업
            monthMatrixWrap.querySelectorAll('.mm-date-head').forEach(th=>{
                th.addEventListener('click', ()=>{
                    const iso = th.dataset.date;
                    if(iso) openDayGanttPopup(iso, null);
                });
            });

            // 셀 클릭 → 해당 멤버만 팝업
            monthMatrixWrap.querySelectorAll('.mm-day-cell').forEach(td=>{
                td.addEventListener('click', ()=>{
                    const iso = td.dataset.date;
                    const memberId = td.dataset.member;
                    if(iso && memberId) openDayGanttPopup(iso, memberId);
                });
            });
        }

        function updateSelectedMemberMonthTotal(){
            if(currentMember){
                const v = lastMonthTotalByMember[currentMember.id]||0;
                monthSelectedMemberTotal.textContent = formatMins(v);
            }
        }

        // ===== Gantt 팝업 =====
        function openDayGanttPopup(iso, filterMemberId){
            dgPopupIso = iso;
            dgPopupFilterMemberId = filterMemberId || null;
            dgBarInfo = null;
            dgPendingChanges = {};

            // 스냅샷 저장
            dgOrigSnapshot = {};
            var membersForPopup = getPopupMembers();
            membersForPopup.forEach(function(m){
                var key = m.id + '_' + iso;
                var dayMap = monthAllMembersDayMap[m.id] || {};
                var day = dayMap[iso];
                var segs = (day && day.segments) ? day.segments : [];
                dgOrigSnapshot[key] = JSON.stringify(segs);
            });

            // 제목
            var dt = new Date(iso + 'T00:00:00');
            var DOW = ['일','월','화','수','목','금','토'];
            dgPopupTitle.textContent = DOW[dt.getDay()] + '요일 (' + iso + ')';

            var typeLabel = (currentDataType === 'actual') ? '근무시간' : '일정';
            if(dgPopupFilterMemberId){
                var fm = currentStatusMembers.find(function(m){ return String(m.id) === String(dgPopupFilterMemberId); });
                dgPopupSubtitle.textContent = (fm ? fm.name : '') + ' ' + typeLabel + ' · 바를 드래그하여 편집';
            } else {
                dgPopupSubtitle.textContent = '전체 아르바이트생 ' + typeLabel + ' · 바를 드래그하여 편집';
            }

            dgPopupOverlay.classList.remove('d-none');
            document.body.style.overflow = 'hidden';

            buildDgPopupGantt();
            initDgPopupDrag();
            updateDgPopupButtons();
        }

        function closeDgPopup(){
            dgPopupOverlay.classList.add('d-none');
            document.body.style.overflow = '';
            dgPopupIso = null;
            dgPopupFilterMemberId = null;
            dgBarInfo = null;
            dgOrigSnapshot = {};
        }

        function getPopupMembers(){
            var all = (currentStatusMembers || []).slice().sort(function(a,b){ return (a.name||'').localeCompare(b.name||'','ko'); });
            if(dgPopupFilterMemberId){
                return all.filter(function(m){ return String(m.id) === String(dgPopupFilterMemberId); });
            }
            return all;
        }

        function buildDgPopupGantt(){
            var wrap = dgPopupGanttWrap;
            if(!wrap || !dgPopupIso) return;
            var iso = dgPopupIso;
            var members = getPopupMembers();

            // 시간 눈금 헤더
            var html = '<div class="mw-gantt-header-row">';
            html += '<div class="mw-gantt-label-cell"><span style="font-size:0.73rem;color:rgba(255,255,255,.4);">이름</span></div>';
            html += '<div class="mw-gantt-track-header">';
            for(var h = HOUR_START; h < HOUR_END; h++){
                var pct = ((h - HOUR_START) * 60 / TOTAL_MIN * 100).toFixed(3);
                html += '<div class="mw-gantt-time-label" style="left:' + pct + '%">' + pad2(h) + ':00</div>';
                var hPct = ((h - HOUR_START) * 60 + 30) / TOTAL_MIN * 100;
                html += '<div class="mw-gantt-time-label minor" style="left:' + hPct.toFixed(3) + '%">:30</div>';
            }
            html += '</div>';
            html += '<div class="dg-hours-cell">시간</div>';
            html += '</div>';

            // 멤버별 행
            html += '<div class="mw-gantt-body-wrap">';
            members.forEach(function(m){
                var mid = m.id;
                var key = mid + '_' + iso;
                var dayMap = monthAllMembersDayMap[mid] || {};
                var origDay = dayMap[iso];
                var origSegs = (origDay && origDay.segments) ? origDay.segments : [];
                var segs = (dgPendingChanges[key]) ? dgPendingChanges[key].segments : origSegs;
                var isModified = !!dgPendingChanges[key];
                var color = colorForMember(m);

                html += '<div class="mw-gantt-row" data-popup-member-id="' + mid + '" data-iso="' + iso + '">';
                html += '<div class="mw-gantt-label-cell" style="height:42px;">';
                html += '<span class="dg-member-chip" style="background:' + color + ';"></span>';
                html += '<span class="dg-member-name">' + escapeHtml(m.name || '') + '</span>';
                html += '</div>';
                html += '<div class="mw-gantt-track-cell">';

                segs.forEach(function(seg, segIdx){
                    var effStart = Math.max(hmToMin(seg.start), HOUR_START * 60);
                    var effEnd = Math.min(hmToMin(seg.end), HOUR_END * 60);
                    if(effEnd <= effStart) return;
                    var leftPct = (effStart - HOUR_START * 60) / TOTAL_MIN * 100;
                    var widthPct = (effEnd - effStart) / TOTAL_MIN * 100;
                    var modClass = isModified ? ' modified' : '';
                    var selClass = (dgBarInfo && String(dgBarInfo.memberId) === String(mid) && dgBarInfo.start === seg.start && dgBarInfo.end === seg.end) ? ' dg-bar-selected' : '';

                    html += '<div class="dg-popup-bar' + modClass + selClass + '" data-member-id="' + mid + '" data-iso="' + iso + '" data-seg-idx="' + segIdx + '" data-start="' + seg.start + '" data-end="' + seg.end + '" style="left:' + leftPct.toFixed(3) + '%;width:' + widthPct.toFixed(3) + '%;background:' + color + ';">';
                    html += '<div class="bar-handle-left"></div>';
                    html += '<span class="dg-bar-time">' + seg.start + '~' + seg.end + '</span>';
                    html += '<div class="bar-handle-right"></div>';
                    html += '<div class="dg-bar-tooltip">' + seg.start + ' ~ ' + seg.end + '</div>';
                    html += '</div>';
                });

                html += '</div>'; // track-cell

                // 시간 표시
                var totalMin = 0;
                segs.forEach(function(seg){ totalMin += Math.max(0, hmToMin(seg.end) - hmToMin(seg.start)); });
                var hrsText = totalMin > 0 ? (Math.floor(totalMin/60) + 'h' + (totalMin%60>0 ? (totalMin%60)+'m' : '')) : '-';
                html += '<div class="dg-hours-cell" style="color:' + (totalMin>0 ? color : 'rgba(255,255,255,.3)') + ';">' + hrsText + '</div>';
                html += '</div>'; // row
            });
            html += '</div>';

            wrap.innerHTML = html;

            // 변경 정보 업데이트
            if(dgChangeInfo){
                var cnt = Object.keys(dgPendingChanges).length;
                dgChangeInfo.textContent = cnt > 0 ? (cnt + '건 변경됨') : '';
            }
        }

        function initDgPopupDrag(){
            var wrap = dgPopupGanttWrap;
            if(!wrap || _dgDragInited) return;
            _dgDragInited = true;

            function pxToMin(px, tw){ return Math.round(px / tw * TOTAL_MIN / 10) * 10; }
            function clampMin(m){ return Math.max(0, Math.min(m, TOTAL_MIN)); }

            // mousedown
            wrap.addEventListener('mousedown', function(e){
                var bar = e.target.closest('.dg-popup-bar');
                if(!bar) return;
                e.preventDefault();
                e.stopPropagation();

                var tc = bar.closest('.mw-gantt-track-cell');
                var trackRect = tc ? tc.getBoundingClientRect() : null;
                if(!trackRect) return;

                var memberId = bar.dataset.memberId;
                var iso = bar.dataset.iso;
                var segIdx = parseInt(bar.dataset.segIdx, 10);
                var startMin = hmToMin(bar.dataset.start) - HOUR_START * 60;
                var endMin = hmToMin(bar.dataset.end) - HOUR_START * 60;
                var duration = endMin - startMin;

                var mode = 'move';
                if(e.target.classList.contains('bar-handle-left')) mode = 'resize-left';
                if(e.target.classList.contains('bar-handle-right')) mode = 'resize-right';

                bar.classList.add(mode === 'move' ? 'dragging' : 'resizing');

                _dgDragState = {
                    bar: bar, memberId: memberId, iso: iso, segIdx: segIdx, mode: mode, trackRect: trackRect,
                    origStartMin: startMin, origEndMin: endMin, origDuration: duration,
                    mouseStartX: e.clientX, startX: e.clientX, startY: e.clientY,
                    hasMoved: false, currentStartMin: startMin, currentEndMin: endMin
                };

                var dtt = document.getElementById('dragTimeTooltip');
                if(dtt){
                    var origS = minToHm(startMin + HOUR_START*60), origE = minToHm(endMin + HOUR_START*60);
                    dtt.innerHTML = origS + ' <span class="dtt-arrow">\u2192</span> ' + origE;
                    dtt.style.left = (e.clientX + 14) + 'px';
                    dtt.style.top = (e.clientY - 36) + 'px';
                    dtt.classList.add('visible');
                }
            });

            // mousemove
            document.addEventListener('mousemove', function(e){
                if(!_dgDragState) return;
                e.preventDefault();
                var st = _dgDragState;
                if(!st.hasMoved){
                    var dist = Math.abs(e.clientX - st.startX) + Math.abs(e.clientY - st.startY);
                    if(dist < 3) return;
                    st.hasMoved = true;
                }

                var dx = e.clientX - st.mouseStartX;
                var deltaMin = pxToMin(dx, st.trackRect.width);
                var newStart, newEnd;

                if(st.mode === 'move'){
                    newStart = clampMin(st.origStartMin + deltaMin);
                    newEnd = newStart + st.origDuration;
                    if(newEnd > TOTAL_MIN){ newEnd = TOTAL_MIN; newStart = newEnd - st.origDuration; }
                    if(newStart < 0){ newStart = 0; newEnd = st.origDuration; }
                } else if(st.mode === 'resize-left'){
                    newStart = clampMin(st.origStartMin + deltaMin);
                    newEnd = st.origEndMin;
                    if(newStart >= newEnd - 10) newStart = newEnd - 10;
                } else {
                    newStart = st.origStartMin;
                    newEnd = clampMin(st.origEndMin + deltaMin);
                    if(newEnd <= newStart + 10) newEnd = newStart + 10;
                }

                st.currentStartMin = newStart;
                st.currentEndMin = newEnd;

                var leftPct = newStart / TOTAL_MIN * 100;
                var widthPct = (newEnd - newStart) / TOTAL_MIN * 100;
                st.bar.style.left = leftPct.toFixed(3) + '%';
                st.bar.style.width = widthPct.toFixed(3) + '%';

                var dtt = document.getElementById('dragTimeTooltip');
                if(dtt){
                    var newS = minToHm(newStart + HOUR_START*60), newE = minToHm(newEnd + HOUR_START*60);
                    var origS = minToHm(st.origStartMin + HOUR_START*60);
                    var origE = minToHm(st.origEndMin + HOUR_START*60);
                    var changed = (newS !== origS || newE !== origE);
                    dtt.innerHTML = changed
                        ? '<span class="dtt-changed">' + newS + ' <span class="dtt-arrow">\u2192</span> ' + newE + '</span>'
                        : newS + ' <span class="dtt-arrow">\u2192</span> ' + newE;
                    dtt.style.left = (e.clientX + 14) + 'px';
                    dtt.style.top = (e.clientY - 36) + 'px';
                }
            });

            // mouseup
            document.addEventListener('mouseup', function(e){
                if(!_dgDragState) return;
                var st = _dgDragState;
                st.bar.classList.remove('dragging', 'resizing');
                var dtt = document.getElementById('dragTimeTooltip');
                if(dtt) dtt.classList.remove('visible');

                if(!st.hasMoved){
                    _dgDragState = null;
                    return;
                }
                _dgJustDragged = true;
                setTimeout(function(){ _dgJustDragged = false; }, 0);

                dgBarInfo = null;
                if(dgBtnDelete) dgBtnDelete.classList.add('d-none');

                var newStart = minToHm(st.currentStartMin + HOUR_START * 60);
                var newEnd = minToHm(st.currentEndMin + HOUR_START * 60);
                var memberId = st.memberId;
                var iso = st.iso;

                var key = memberId + '_' + iso;
                var dayMap = monthAllMembersDayMap[memberId] || {};
                var origDay = dayMap[iso];
                var origSegs = (origDay && origDay.segments) ? origDay.segments : [];
                var srcSegs = ((dgPendingChanges[key] && dgPendingChanges[key].segments) || origSegs).map(function(s){ return {start:s.start, end:s.end}; });
                srcSegs[st.segIdx] = { start: newStart, end: newEnd };
                srcSegs.sort(function(a,b){ return hmToMin(a.start) - hmToMin(b.start); });
                dgPendingChanges[key] = { memberId: memberId, iso: iso, segments: mergeSegs(srcSegs) };

                buildDgPopupGantt();
                updateDgPopupButtons();

                _dgDragState = null;
            });

            // click: 바 선택 + 빈 트랙 클릭 생성
            wrap.addEventListener('click', function(e){
                if(_dgJustDragged) return;

                // 바 클릭 → 선택/해제
                var clickedBar = e.target.closest('.dg-popup-bar');
                if(clickedBar){
                    var barMid = clickedBar.dataset.memberId;
                    var barStart = clickedBar.dataset.start;
                    var barEnd = clickedBar.dataset.end;

                    if(dgBarInfo && String(dgBarInfo.memberId) === String(barMid) && dgBarInfo.start === barStart && dgBarInfo.end === barEnd){
                        dgBarInfo = null;
                        if(dgBtnDelete) dgBtnDelete.classList.add('d-none');
                    } else {
                        dgBarInfo = { memberId: barMid, iso: clickedBar.dataset.iso, start: barStart, end: barEnd };
                        if(dgBtnDelete) dgBtnDelete.classList.remove('d-none');
                    }
                    buildDgPopupGantt();
                    return;
                }

                // 빈 트랙 클릭 → 새 바 생성
                dgBarInfo = null;
                if(dgBtnDelete) dgBtnDelete.classList.add('d-none');

                var track = e.target.closest('.mw-gantt-track-cell');
                if(!track) return;
                var row = track.closest('.mw-gantt-row');
                if(!row) return;
                var memberId = row.dataset.popupMemberId;
                var iso = row.dataset.iso;
                if(!memberId || !iso) return;

                var rect = track.getBoundingClientRect();
                var clickX = e.clientX - rect.left;
                var clickMin = Math.round(clickX / rect.width * TOTAL_MIN / 10) * 10;
                clickMin = Math.max(0, Math.min(clickMin, TOTAL_MIN - 60));
                var startHm = minToHm(clickMin + HOUR_START * 60);
                var endHm = minToHm(clickMin + 60 + HOUR_START * 60);

                var key = memberId + '_' + iso;
                var dayMap = monthAllMembersDayMap[memberId] || {};
                var origDay = dayMap[iso];
                var origSegs = (origDay && origDay.segments) ? origDay.segments : [];
                var segs = ((dgPendingChanges[key] && dgPendingChanges[key].segments) || origSegs).map(function(s){ return {start:s.start, end:s.end}; });
                segs.push({ start: startHm, end: endHm });
                segs.sort(function(a,b){ return hmToMin(a.start) - hmToMin(b.start); });
                dgPendingChanges[key] = { memberId: memberId, iso: iso, segments: mergeSegs(segs) };

                buildDgPopupGantt();
                updateDgPopupButtons();
            });
        }

        // 겹치는 세그먼트 병합
        function mergeSegs(segs){
            if(!segs || segs.length <= 1) return segs;
            var sorted = segs.slice().sort(function(a,b){ return hmToMin(a.start) - hmToMin(b.start); });
            var merged = [sorted[0]];
            for(var i = 1; i < sorted.length; i++){
                var last = merged[merged.length - 1];
                if(hmToMin(sorted[i].start) <= hmToMin(last.end)){
                    last.end = hmToMin(sorted[i].end) > hmToMin(last.end) ? sorted[i].end : last.end;
                } else {
                    merged.push(sorted[i]);
                }
            }
            return merged;
        }

        function updateDgPopupButtons(){
            if(!dgBtnSave || !dgBtnCancel) return;
            var iso = dgPopupIso;
            if(!iso){ dgBtnSave.classList.add('d-none'); dgBtnCancel.classList.add('d-none'); return; }

            var hasChanges = false;
            var members = getPopupMembers();
            members.forEach(function(m){
                var key = m.id + '_' + iso;
                var currentSegs = dgPendingChanges[key] ? JSON.stringify(dgPendingChanges[key].segments) : (dgOrigSnapshot[key] || '[]');
                var origSegs = dgOrigSnapshot[key] || '[]';
                if(currentSegs !== origSegs) hasChanges = true;
            });

            if(hasChanges){
                dgBtnSave.classList.remove('d-none');
                dgBtnCancel.classList.remove('d-none');
            } else {
                dgBtnSave.classList.add('d-none');
                dgBtnCancel.classList.add('d-none');
            }
        }

        function onDeleteDgBar(){
            if(!dgBarInfo) return;
            var memberId = dgBarInfo.memberId;
            var iso = dgBarInfo.iso;
            var start = dgBarInfo.start;
            var end = dgBarInfo.end;

            var key = memberId + '_' + iso;
            var dayMap = monthAllMembersDayMap[memberId] || {};
            var origDay = dayMap[iso];
            var origSegs = (origDay && origDay.segments) ? origDay.segments : [];
            var segs = ((dgPendingChanges[key] && dgPendingChanges[key].segments) || origSegs).map(function(s){ return {start:s.start, end:s.end}; });
            var idx = segs.findIndex(function(s){ return s.start === start && s.end === end; });
            if(idx >= 0){
                segs.splice(idx, 1);
                if(segs.length > 0 || origSegs.length > 0){
                    dgPendingChanges[key] = { memberId: memberId, iso: iso, segments: segs };
                } else {
                    delete dgPendingChanges[key];
                }
            }

            dgBarInfo = null;
            dgBtnDelete.classList.add('d-none');
            buildDgPopupGantt();
            updateDgPopupButtons();
        }

        function onCancelDgPopup(){
            if(!dgPopupIso) return;
            var iso = dgPopupIso;
            var members = getPopupMembers();
            members.forEach(function(m){
                var key = m.id + '_' + iso;
                var dayMap = monthAllMembersDayMap[m.id] || {};
                var origDay = dayMap[iso];
                var origSegs = (origDay && origDay.segments) ? origDay.segments : [];
                var origJson = dgOrigSnapshot[key] || '[]';
                if(JSON.stringify(origSegs) === origJson){
                    delete dgPendingChanges[key];
                } else {
                    dgPendingChanges[key] = { memberId: String(m.id), iso: iso, segments: JSON.parse(origJson) };
                }
            });
            dgBarInfo = null;
            if(dgBtnDelete) dgBtnDelete.classList.add('d-none');
            buildDgPopupGantt();
            updateDgPopupButtons();
        }

        async function onSaveDgPopup(){
            var entries = Object.entries(dgPendingChanges);
            if(entries.length === 0) return;

            dgBtnSave.textContent = '저장 중...';
            dgBtnSave.disabled = true;

            var saveEp = (currentDataType === 'actual') ? API_ACTUAL_UPDATE_ENDPOINT : API_UPDATE_ENDPOINT;
            try {
                for(var i = 0; i < entries.length; i++){
                    var data = entries[i][1];
                    var cleanSegs = data.segments.map(function(s){ return { start: s.start, end: s.end }; });
                    var body = { memberId: data.memberId, date: data.iso, segments: cleanSegs };
                    var resp = await fetch(saveEp, {
                        method: 'POST',
                        headers: {'Content-Type':'application/json', 'Accept':'application/json'},
                        body: JSON.stringify(body)
                    });
                    if(!resp.ok){
                        var text = await resp.text().catch(function(){ return ''; });
                        alert('저장 실패: ' + resp.status + ' ' + text);
                        dgBtnSave.disabled = false;
                        dgBtnSave.textContent = '저장';
                        return;
                    }
                }

                // 저장 완료
                dgPendingChanges = {};
                updateDgPopupButtons();
                await renderAllMembersMonth(currentMonthStart);

                // 스냅샷 갱신
                var members = getPopupMembers();
                var iso = dgPopupIso;
                members.forEach(function(m){
                    var key = m.id + '_' + iso;
                    var dayMap = monthAllMembersDayMap[m.id] || {};
                    var day = dayMap[iso];
                    var segs = (day && day.segments) ? day.segments : [];
                    dgOrigSnapshot[key] = JSON.stringify(segs);
                });

                buildDgPopupGantt();
                updateDgPopupButtons();
            } catch(e){
                console.error(e);
                alert('저장 중 오류가 발생했습니다.');
            } finally {
                dgBtnSave.disabled = false;
                dgBtnSave.textContent = '저장';
            }
        }

        // ===== 월간 캘린더 뷰 =====
        function buildMemberCalendar(member, monthStart){
            if(!memberCalendarCard || !memberCalendarWrap) return;
            selectedCalPill = null;

            var ms = firstDayOfMonth(monthStart);
            var me = lastDayOfMonth(monthStart);
            var color = colorForMember(member);
            var dayMap = monthAllMembersDayMap[member.id] || {};
            var todayIso = toIso(new Date());
            var typeLabel = (currentDataType === 'actual') ? '근무시간' : '일정';

            memberCalendarTitle.textContent = member.name + ' - ' + ms.getFullYear() + '년 ' + (ms.getMonth()+1) + '월 ' + typeLabel;

            var DOW_NAMES = ['월','화','수','목','금','토','일'];
            var html = '<table class="mc-table"><thead><tr>';
            DOW_NAMES.forEach(function(d, i){
                var cls = 'mc-dow-head';
                if(i >= 5) cls += ' mc-weekend';
                html += '<th class="' + cls + '">' + d + '</th>';
            });
            html += '</tr></thead><tbody>';

            // 월 시작 요일 (월=0 ... 일=6)
            var startDow = (ms.getDay() + 6) % 7; // 0=월
            var daysInMonth = me.getDate();

            // 이전 달 채우기
            var prevMonth = new Date(ms.getFullYear(), ms.getMonth(), 0);
            var prevDays = prevMonth.getDate();

            var cells = [];
            // 이전 달 빈 칸
            for(var p = startDow - 1; p >= 0; p--){
                var prevD = prevDays - p;
                var prevDt = new Date(prevMonth.getFullYear(), prevMonth.getMonth(), prevD);
                cells.push({ iso: toIso(prevDt), day: prevD, otherMonth: true, dow: (prevDt.getDay()+6)%7 });
            }
            // 현재 달
            for(var d = 1; d <= daysInMonth; d++){
                var dt = new Date(ms.getFullYear(), ms.getMonth(), d);
                cells.push({ iso: toIso(dt), day: d, otherMonth: false, dow: (dt.getDay()+6)%7 });
            }
            // 다음 달 채우기 (7의 배수까지)
            var nextD = 1;
            while(cells.length % 7 !== 0){
                var nextDt = new Date(me.getFullYear(), me.getMonth()+1, nextD);
                cells.push({ iso: toIso(nextDt), day: nextD, otherMonth: true, dow: (nextDt.getDay()+6)%7 });
                nextD++;
            }

            // 행 렌더링
            for(var i = 0; i < cells.length; i++){
                if(i % 7 === 0) html += '<tr>';
                var c = cells[i];
                var cls = 'mc-day-cell';
                if(c.otherMonth) cls += ' mc-other-month';
                if(c.iso === todayIso) cls += ' mc-today';

                html += '<td class="' + cls + '" data-cal-date="' + c.iso + '" data-cal-member="' + member.id + '">';
                var numCls = 'mc-day-num';
                if(c.dow >= 5) numCls += ' mc-weekend-num';
                html += '<div class="' + numCls + '">' + c.day + '</div>';

                // 일정 pills
                if(!c.otherMonth){
                    var day = dayMap[c.iso];
                    var segs = (day && day.segments) ? day.segments : [];
                    if(segs.length > 0){
                        segs.forEach(function(seg, si){
                            html += '<div class="mc-schedule-pill" data-cal-date="' + c.iso + '" data-cal-seg-idx="' + si + '" data-cal-start="' + seg.start + '" data-cal-end="' + seg.end + '" style="background:' + color + ';">';
                            html += seg.start + '~' + seg.end;
                            html += '</div>';
                        });
                    }
                }

                html += '</td>';
                if(i % 7 === 6) html += '</tr>';
            }

            html += '</tbody></table>';
            memberCalendarWrap.innerHTML = html;

            // 이벤트 바인딩: pill 클릭 → 선택/해제 + 삭제 버튼
            memberCalendarWrap.querySelectorAll('.mc-schedule-pill').forEach(function(pill){
                pill.addEventListener('click', function(e){
                    e.stopPropagation();
                    var pIso = pill.dataset.calDate;
                    var pStart = pill.dataset.calStart;
                    var pEnd = pill.dataset.calEnd;

                    // 이미 선택된 pill 토글
                    if(selectedCalPill && selectedCalPill.iso === pIso && selectedCalPill.start === pStart && selectedCalPill.end === pEnd){
                        selectedCalPill = null;
                        buildMemberCalendar(member, monthStart);
                        return;
                    }

                    selectedCalPill = { memberId: String(member.id), iso: pIso, start: pStart, end: pEnd };
                    // 선택 표시 리렌더
                    memberCalendarWrap.querySelectorAll('.mc-schedule-pill').forEach(function(p){ p.classList.remove('mc-pill-selected'); });
                    pill.classList.add('mc-pill-selected');

                    // 기존 삭제 버튼 제거
                    memberCalendarWrap.querySelectorAll('.mc-pill-actions').forEach(function(a){ a.remove(); });

                    // 삭제 버튼 추가
                    var actions = document.createElement('span');
                    actions.className = 'mc-pill-actions';
                    var delBtn = document.createElement('button');
                    delBtn.className = 'mc-pill-del-btn';
                    delBtn.type = 'button';
                    delBtn.textContent = '×';
                    delBtn.title = '삭제';
                    delBtn.addEventListener('click', async function(ev){
                        ev.stopPropagation();
                        await deleteCalPill(member, pIso, pStart, pEnd, monthStart);
                    });
                    actions.appendChild(delBtn);
                    pill.appendChild(actions);
                });
            });

            // 셀 클릭 (pill 아닌 영역) → 팝업 편집
            memberCalendarWrap.querySelectorAll('.mc-day-cell:not(.mc-other-month)').forEach(function(td){
                td.addEventListener('click', function(e){
                    if(e.target.closest('.mc-schedule-pill')) return;
                    var iso = td.dataset.calDate;
                    var mid = td.dataset.calMember;
                    if(iso && mid) openDayGanttPopup(iso, mid);
                });
            });
        }

        async function deleteCalPill(member, iso, start, end, monthStart){
            var dayMap = monthAllMembersDayMap[member.id] || {};
            var day = dayMap[iso];
            var segs = (day && day.segments) ? day.segments.slice() : [];
            var idx = segs.findIndex(function(s){ return s.start === start && s.end === end; });
            if(idx < 0) return;

            segs.splice(idx, 1);
            var cleanSegs = segs.map(function(s){ return { start: s.start, end: s.end }; });
            var saveEp = (currentDataType === 'actual') ? API_ACTUAL_UPDATE_ENDPOINT : API_UPDATE_ENDPOINT;
            var body = { memberId: String(member.id), date: iso, segments: cleanSegs };

            try {
                var resp = await fetch(saveEp, {
                    method: 'POST',
                    headers: {'Content-Type':'application/json', 'Accept':'application/json'},
                    body: JSON.stringify(body)
                });
                if(!resp.ok){
                    alert('삭제 실패: ' + resp.status);
                    return;
                }
                selectedCalPill = null;
                await renderAllMembersMonth(currentMonthStart);
            } catch(e){
                console.error(e);
                alert('삭제 중 오류가 발생했습니다.');
            }
        }

        function showMemberCalendar(member){
            if(!memberCalendarCard) return;
            if(member){
                memberCalendarCard.classList.remove('d-none');
                buildMemberCalendar(member, currentMonthStart);
            } else {
                memberCalendarCard.classList.add('d-none');
                memberCalendarWrap.innerHTML = '';
            }
        }

        // ===== 유틸 =====
        function firstDayOfMonth(d){ return new Date(d.getFullYear(), d.getMonth(), 1); }
        function lastDayOfMonth(d){ return new Date(d.getFullYear(), d.getMonth()+1, 0); }
        function pad2(n){ return String(n).padStart(2,'0'); }
        function toIso(d){ return `${d.getFullYear()}-${pad2(d.getMonth()+1)}-${pad2(d.getDate())}`; }

        function colorForMember(m){
            const key = (m?.id!=null?String(m.id):(m?.name||'x'));
            const h = seededHash(key)%360, s=65, l=55;
            return hslToHex(h,s,l);
        }
        function seededHash(str){ let h=2166136261>>>0; for(let i=0;i<str.length;i++){ h^=str.charCodeAt(i); h=(h*16777619)>>>0; } return h>>>0; }
        function hslToHex(h,s,l){
            s/=100; l/=100;
            const c=(1-Math.abs(2*l-1))*s;
            const x=c*(1-Math.abs((h/60)%2-1));
            const m=l-c/2;
            let r=0,g=0,b=0;
            if(0<=h&&h<60){ r=c; g=x; b=0; }
            else if(60<=h&&h<120){ r=x; g=c; b=0; }
            else if(120<=h&&h<180){ r=0; g=c; b=x; }
            else if(180<=h&&h<240){ r=0; g=x; b=c; }
            else if(240<=h&&h<300){ r=x; g=0; b=c; }
            else { r=c; g=0; b=x; }
            const toHex = v => Math.round((v+m)*255).toString(16).padStart(2,'0');
            return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
        }
        function escapeHtml(s){
            if(s==null) return '';
            return String(s)
                .replace(/&/g,'&amp;')
                .replace(/</g,'&lt;')
                .replace(/>/g,'&gt;')
                .replace(/"/g,'&quot;')
                .replace(/'/g,'&#39;');
        }

        function formatMins(mins){
            const v = Math.max(0, mins|0);
            const h=Math.floor(v/60), m=v%60;
            return m===0?`${h}시간`:`${h}시간 ${m}분`;
        }

        function normalizeActualDays(apiData){
            const map = {};
            const arr = Array.isArray(apiData?.days) ? apiData.days : [];
            arr.forEach(d=>{
                const date = String(d.date);
                const segments = Array.isArray(d.segments) ? d.segments : [];
                const minutes = (typeof d.minutes==='number')
                    ? d.minutes
                    : segments.reduce((acc,s)=> acc + (hmToMin(s.end) - hmToMin(s.start)), 0);
                map[date] = { segments, minutes };
            });
            return map;
        }

        function hmToMin(hm){
            if(!hm) return 0;
            const parts = String(hm).split(':').map(n=>parseInt(n,10));
            const h = parts[0] || 0;
            const m = parts[1] || 0;
            return h*60 + m;
        }
        function minToHm(min){
            const h=Math.floor(min/60), m=min%60;
            return `${pad2(h)}:${pad2(m)}`;
        }

        function syncStatusPeriodWithMonthRange(overrideText){
            const text = overrideText || monthRangeLabel.textContent || '';
            if(statusPeriodLabel) statusPeriodLabel.textContent = text;
        }
    })();
</script>

