        function statusLabelText(v){ return {WORKING:'근무중',WAITING:'시작전',RESTING:'휴식중',PAUSED:'일시중지',RESIGNED:'퇴사'}[v]||v; }

        function handleStatusChangeAll(){
            allFilteredMembers = (allMembers||[]).filter(m=>m.status===statusSelect.value);
            renderAllMemberPills();
            loadAllMembersTables();
        }

        function renderAllMemberPills(){
            const sorted = [...allFilteredMembers].sort((a,b)=>(a.name||'').localeCompare(b.name||'','ko'));
            if (!sorted.length){
                allMemberPillList.innerHTML = '<span class="small text-muted">해당 상태의 근무자가 없습니다.</span>';
                return;
            }
            allMemberPillList.innerHTML = sorted.map(m=>{
                const c = colorForMember(m);
                return `<span class="member-pill"><span class="pill-dot" style="background:${c}"></span>${escapeHtml(m.name||'-')}</span>`;
            }).join('');
        }

        function updateAllSummaryTitle(){
            const ms = firstDayOfMonth(currentMonthStart), me = lastDayOfMonth(currentMonthStart);
            const vl = currentViewType==='actual'?'근무시간':'일정(예상)';
            allSummaryTitleEl.textContent = `월합계 지급 내역 (${vl})`;
            allSummaryPeriodEl.textContent = `${ms.getFullYear()}.${pad2(ms.getMonth()+1)}.${pad2(ms.getDate())} ~ ${pad2(me.getMonth()+1)}.${pad2(me.getDate())}`;
        }

        async function loadAllMembersTables(){
            updateAllSummaryTitle();
            const ms = firstDayOfMonth(currentMonthStart), me = lastDayOfMonth(currentMonthStart);
            monthRangeLabel.textContent = `${ms.getFullYear()}.${pad2(ms.getMonth()+1)}.01 ~ ${pad2(me.getMonth()+1)}.${pad2(me.getDate())}`;
            const weekRangeLabelEl = document.getElementById('weekRangeLabel');
            if (weekRangeLabelEl) weekRangeLabelEl.textContent = monthRangeLabel.textContent;
            await Promise.all([loadAllWeeklyTable('actual'), loadAllWeeklyTable('plan')]);
            renderAllMonthlySummary();
        }

        async function loadAllWeeklyTable(type){
            const isActual = (type==='actual');
            const apiBase  = isActual ? API_BASE_ACTUAL : API_BASE_PLAN;
            const tbody    = isActual ? allWeeklyPayBody : allWeeklyPlanBody;

            if (isActual) allActualSummaryMap={}; else allPlanSummaryMap={};
            const sMap = isActual ? allActualSummaryMap : allPlanSummaryMap;

            const ms = firstDayOfMonth(currentMonthStart), me = lastDayOfMonth(currentMonthStart);
            tbody.innerHTML = '';
            setAllFooterSums(type, 0, 0, 0, 0);

            if (!allFilteredMembers.length){
                tbody.innerHTML = `<tr class="week-end-border"><td colspan="11" class="text-muted">표시할 멤버가 없습니다.</td></tr>`;
                return;
            }

            const fetchStart = toMonday(ms);
            const fetchEnd   = addDays(toMonday(me), 6);

            const memberDayMap = {};
            await Promise.all(allFilteredMembers.map(async m=>{
                try {
                    const resp = await fetch(`${apiBase}/${encodeURIComponent(m.id)}/${toIso(fetchStart)}/${toIso(fetchEnd)}`, { headers:{'Accept':'application/json'} });
                    memberDayMap[m.id] = resp.ok ? normalizeDays(await resp.json()) : {};
                } catch(e){ memberDayMap[m.id]={}; }
            }));

            const weeks = buildAllWeeks(ms, me);
            let mWP=0, mJP=0, mTx=0, mNt=0;
            let weekNum=0;

            weeks.forEach(weekStart=>{
                const weekEnd = addDays(weekStart, 6);
                const rows = buildAllWeekRows(allFilteredMembers, memberDayMap, weekStart, ms, me);
                if (!rows.length) return;

                weekNum++;
                rows.sort((a,b)=>(a.member.name||'').localeCompare(b.member.name||'','ko'));
                const clipS = weekStart<ms?ms:weekStart, clipE = weekEnd>me?me:weekEnd;
                const wl = allWeekLabelStr(clipS, clipE);

                rows.forEach((r,i)=>{
                    const tr = document.createElement('tr');
                    const wc = (i===0) ? `<td class="week-label week-label-border" rowspan="${rows.length}">${weekNum}주차<br><small class="text-muted">(${wl})</small></td>` : '';
                    const mc = colorForMember(r.member);
                    tr.innerHTML = `${wc}
                        <td class="text-start"><span class="name-dot" style="background:${mc}"></span>${escapeHtml(r.member.name||'-')}</td>
                        <td class="text-end"><span class="text-time">${formatMins(r.monthMinutes)}</span></td>
                        <td class="text-end">${r.wage?krw(r.wage):'-'}</td>
                        <td>${r.juhyuApplied?'<span class="text-success fw-bold">적용</span>':'<span class="text-muted">미적용</span>'}</td>
                        <td>${r.applyTax?'<span class="text-danger fw-bold">부과</span>':'<span class="text-muted">미부과</span>'}</td>
                        <td class="text-end">${krw(r.monthWorkPay)}</td>
                        <td class="text-end">${krw(r.monthJuhyuPay)}</td>
                        <td class="text-end">${r.applyTax?krw(r.monthTax):'-'}</td>
                        <td class="text-end"><span class="fw-bold text-primary">${krw(r.monthNet)}</span></td>
                        <td class="text-center small">(매월)${formatPayday(r.member.payday)}</td>`;
                    if (i===rows.length-1) tr.classList.add('week-end-border');
                    tbody.appendChild(tr);
                    accAllSummary(sMap, r);
                });

                mWP+=rows.reduce((s,r)=>s+r.monthWorkPay,0);
                mJP+=rows.reduce((s,r)=>s+r.monthJuhyuPay,0);
                mTx+=rows.reduce((s,r)=>s+r.monthTax,0);
                mNt+=rows.reduce((s,r)=>s+r.monthNet,0);
            });

            setAllFooterSums(type, mWP, mJP, mTx, mNt);
        }

        function buildAllWeekRows(members, dayMap, weekStart, ms, me){
            const rows=[];
            const weekEnd = addDays(weekStart, 6);
            const sundayInMonth = (weekEnd>=ms && weekEnd<=me);

            members.forEach(m=>{
                const wage = Number(m.hourlyWage)||0;
                const includeJuhyu = !!m.includeWeeklyHolidayAllowance;
                const applyTax = isTaxApplied(m);
                let fullMinutes=0, monthMinutes=0;

                for(let i=0;i<7;i++){
                    const d=addDays(weekStart,i);
                    const mins = ((dayMap[m.id]||{})[toIso(d)]||{minutes:0}).minutes||0;
                    fullMinutes+=mins;
                    if(d>=ms && d<=me) monthMinutes+=mins;
                }

                const monthWorkPay = Math.round((monthMinutes/60)*wage);
                let monthJuhyuPay=0, juhyuApplied=false;
                if(includeJuhyu && fullMinutes>=15*60 && sundayInMonth){
                    monthJuhyuPay = Math.round((Math.round(fullMinutes/5)/60)*wage);
                    juhyuApplied=true;
                }
                if(monthMinutes<=0 && monthJuhyuPay<=0) return;

                const monthGross = monthWorkPay+monthJuhyuPay;
                let monthTax=0, monthNet=monthGross;
                if(applyTax && monthGross>0){ monthTax=Math.round(monthGross*0.033); monthNet=monthGross-monthTax; }

                rows.push({ member:m, wage, juhyuApplied, applyTax, monthMinutes, monthWorkPay, monthJuhyuPay, monthTax, monthNet });
            });
            return rows;
        }

        function accAllSummary(map, r){
            let acc=map[r.member.id];
            if(!acc){ acc={member:r.member, minutesSum:0, workPaySum:0, juhyuPaySum:0, taxSum:0, netSum:0}; map[r.member.id]=acc; }
            acc.minutesSum+=r.monthMinutes; acc.workPaySum+=r.monthWorkPay;
            acc.juhyuPaySum+=r.monthJuhyuPay; acc.taxSum+=r.monthTax; acc.netSum+=r.monthNet;
        }

        function renderAllMonthlySummary(){
            allMonthlySummaryBody.innerHTML='';
            const map = (currentViewType==='actual') ? allActualSummaryMap : allPlanSummaryMap;
            const entries = Object.values(map||{}).filter(e=>(e.minutesSum||0)>0);
            if(!entries.length){
                allMonthlySummaryBody.innerHTML='<tr><td colspan="7" class="text-muted">표시할 데이터가 없습니다.</td></tr>';
                allSumTotalTimeEl.textContent='-'; allSumTotalWorkPayEl.textContent='-';
                allSumTotalJuhyuPayEl.textContent='-'; allSumTotalTaxEl.textContent='-'; allSumTotalNetEl.textContent='-';
                return;
            }
            entries.sort((a,b)=>(a.member.name||'').localeCompare(b.member.name||'','ko'));
            let tMin=0, tWP=0, tJP=0, tTx=0, tNt=0;
            entries.forEach(e=>{
                const m=e.member;
                tMin+=e.minutesSum; tWP+=e.workPaySum; tJP+=e.juhyuPaySum; tTx+=e.taxSum; tNt+=e.netSum;
                const c = colorForMember(m);
                const tr=document.createElement('tr');
                tr.innerHTML=`
                    <td class="text-start"><span class="name-dot" style="background:${c}"></span>${escapeHtml(m.name||'-')}</td>
                    <td class="text-end"><span class="text-time">${formatMins(e.minutesSum)}</span></td>
                    <td class="text-end">${m.hourlyWage?krw(m.hourlyWage):'-'}</td>
                    <td class="text-end">${krw(e.workPaySum)}</td>
                    <td class="text-end">${krw(e.juhyuPaySum)}</td>
                    <td class="text-end">${isTaxApplied(m)?krw(e.taxSum):'-'}</td>
                    <td class="text-end"><span class="fw-bold text-primary">${krw(e.netSum)}</span></td>`;
                allMonthlySummaryBody.appendChild(tr);
            });
            allSumTotalTimeEl.textContent=formatMins(tMin);
            allSumTotalWorkPayEl.textContent=krw(tWP);
            allSumTotalJuhyuPayEl.textContent=krw(tJP);
            allSumTotalTaxEl.textContent=tTx?krw(tTx):'-';
            allSumTotalNetEl.textContent=krw(tNt);
        }

        function setAllFooterSums(type, w, j, t, n){
            if(type==='actual'){
                allMonthWorkPaySumEl.textContent=krw(w|0); allMonthJuhyuPaySumEl.textContent=krw(j|0);
                allMonthTaxSumEl.textContent=t?krw(t|0):'-'; allMonthNetSumEl.textContent=krw(n|0);
            } else {
                allMonthPlanWorkPaySumEl.textContent=krw(w|0); allMonthPlanJuhyuPaySumEl.textContent=krw(j|0);
                allMonthPlanTaxSumEl.textContent=t?krw(t|0):'-'; allMonthPlanNetSumEl.textContent=krw(n|0);
            }
        }

        function buildAllWeeks(ms, me){ const weeks=[]; let w=toMonday(ms); while(w<=me){ weeks.push(new Date(w)); w.setDate(w.getDate()+7); } return weeks; }
        function allWeekLabelStr(s,e){ if(toIso(s)===toIso(e)) return `${pad2(s.getMonth()+1)}.${pad2(s.getDate())}`; return `${pad2(s.getMonth()+1)}.${pad2(s.getDate())} ~ ${pad2(e.getMonth()+1)}.${pad2(e.getDate())}`; }


    })();
</script>

