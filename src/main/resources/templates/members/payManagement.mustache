{{>layouts/header_}}

<main class="container my-4">

    <!-- ============ 상단: 아르바이트 상태별 보기 (컴팩트) ============ -->
    <div class="card mb-3">
        <div class="card-body p-0">
            <div class="status-panel-blue">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <div class="status-title">아르바이트 상태별 보기</div>
                        <div class="status-subtitle-small">
                            상태별로 아르바이트생을 필터링하고, 급여를 관리할 수 있습니다.
                        </div>
                    </div>
                    <div class="d-flex flex-column align-items-end">
                        <span class="status-period-label-caption">조회 월간</span>
                        <span id="weekRangeLabel" class="status-period-label-value">0000.00.01 ~ 00.00</span>
                    </div>
                </div>

                <div class="row g-2 align-items-start">
                    <!-- 보기 (개별/전체) -->
                    <div class="col-4 col-md-2">
                        <label class="form-label small status-label mb-1" style="font-size:.72rem;">보기</label>
                        <select id="mainViewSelect" class="form-select form-select-sm status-select">
                            <option value="individual" selected>개별</option>
                            <option value="all">전체</option>
                        </select>
                    </div>
                    <!-- 데이터 소스 선택 -->
                    <div class="col-4 col-md-2">
                        <label class="form-label small status-label mb-1" for="payViewSelect" style="font-size:.72rem;">데이터</label>
                        <select id="payViewSelect" class="form-select form-select-sm status-select">
                            <option value="actual" selected>근무시간</option>
                            <option value="plan">일정</option>
                        </select>
                    </div>
                    <!-- 상태 선택 -->
                    <div class="col-4 col-md-2">
                        <label class="form-label small status-label mb-1" for="statusSelect" style="font-size:.72rem;">상태</label>
                        <select id="statusSelect" class="form-select form-select-sm status-select">
                            <option value="WORKING" selected>근무중</option>
                            <option value="WAITING">시작전</option>
                            <option value="RESTING">휴식중</option>
                            <option value="PAUSED">일시중지</option>
                            <option value="RESIGNED">퇴사</option>
                        </select>
                    </div>

                    <!-- 필터된 아르바이트생 칩 리스트 -->
                    <div class="col-12 col-md-6">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="small status-subtitle" style="font-size:.72rem;">필터된 아르바이트생</span>
                            <span id="memberCountBadge" class="badge bg-light text-dark status-count-badge">0명</span>
                        </div>
                        <div id="memberPills" class="vlist status-pill-list">
                            <!-- JS 렌더 -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ============ 상단: 제목 + 월 내비 (공용, sticky) ============ -->
    <div class="pay-right-wrapper">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-2 gap-2 sticky-pay-header">
            <div class="d-flex flex-wrap align-items-center gap-2">
                <div>
                    <span class="fw-bold h5 mb-0" id="pageTitle">급여 관리</span>
                    <span id="selectedMemberName" class="ms-2 text-primary fw-semibold"></span>
                    <span id="selectedMemberStatus" class="badge bg-secondary ms-2 d-none">-</span>
                </div>
                <!-- ✅ 실근무(저장 상태) 배지 -->
                <span id="payrollStatusBadge" class="badge ms-2 d-none">-</span>
            </div>

            <!-- 월단위 내비 (공용) -->
            <div id="monthNav" class="d-flex align-items-center small text-muted gap-2">
                <span id="monthRangeLabel">0000.00.01 ~ 00.00</span>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="btnMonthPrev">◀ 이전 달</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="btnMonthThis">이번 달</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="btnMonthNext">다음 달 ▶</button>
            </div>
        </div>

        <!-- ===== 개별 모드 영역 ===== -->
        <div id="individualWrap">

        <!-- =========================================================
             1) 실근무시간급여관리 (월단위) + 세금 표시
        ========================================================== -->
        <div class="card mb-4 pay-card" id="cardActual">
            <div class="card-header fw-bold d-flex justify-content-between align-items-center">
                <span class="d-flex align-items-center gap-2">
                    <span>실근무시간급여관리</span>
                    <span class="badge bg-light small" id="juhyuApplyText" style="font-size:.68rem;color:#198754;">주휴수당(적용/미적용)</span>
                    <span class="badge small" id="taxApplyBadge" style="font-size:.68rem;background:rgba(255,255,255,.2);color:#fff;">세금(3.3%) 미적용</span>
                </span>
                <div class="d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-sm btn-outline-light" id="btnOpenPayPdf">PDF</button>
                    <button type="button" class="btn btn-sm btn-outline-light" id="btnSaveDraft">임시저장</button>
                    <button type="button" class="btn btn-sm btn-light" id="btnConfirm">확정</button>
                    <button type="button" class="btn btn-sm btn-success" id="btnMarkPaid">지급완료</button>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="pay-layout">
                    <!-- 좌: 테이블 -->
                    <div class="pay-layout-table">
                        <div class="table-responsive">
                            <table class="table table-bordered align-middle text-center mb-0" id="monthPayTableActual">
                                <thead class="table-pay-header">
                                <tr>
                                    <th style="width:55px;">주차</th>
                                    <th style="width:105px;">기간</th>
                                    <th>월</th>
                                    <th>화</th>
                                    <th>수</th>
                                    <th>목</th>
                                    <th>금</th>
                                    <th class="bg-light weekend-header">토</th>
                                    <th class="bg-light weekend-header">일</th>
                                    <th style="width:80px;" class="text-end">근무시간</th>
                                    <th style="width:90px;" class="text-end">주휴수당</th>
                                    <th style="width:90px;" class="text-end">근무수당</th>
                                </tr>
                                </thead>
                                <tbody id="monthPayBodyActual">
                                <!-- JS 렌더 -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <!-- 우: 요약 패널 -->
                    <div class="pay-side-panel">
                        <div class="psp-section">
                            <div class="psp-row">
                                <span class="psp-label">시급</span>
                                <span class="psp-value" id="summaryHourlyWageActual">-</span>
                            </div>
                            <div class="psp-row">
                                <span class="psp-label">월 근무시간</span>
                                <span class="psp-value" id="summaryMonthWorkTimeActual">0시간</span>
                            </div>
                        </div>
                        <div class="psp-section">
                            <div class="psp-row">
                                <span class="psp-label">근무수당</span>
                                <span class="psp-value text-money" id="summaryMonthWorkPayActual">-</span>
                            </div>
                            <div class="psp-row">
                                <span class="psp-label">주휴수당</span>
                                <span class="psp-value text-money" id="summaryMonthJuhyuPayActual">-</span>
                            </div>
                        </div>
                        <div class="psp-section">
                            <div class="psp-row">
                                <span class="psp-label">세금 (3.3%)</span>
                                <span class="psp-value" id="summaryTaxApplyActual">미적용</span>
                            </div>
                            <div class="psp-row">
                                <span class="psp-label">공제액</span>
                                <span class="psp-value" id="summaryTaxAmountActual">-</span>
                            </div>
                        </div>
                        <div class="psp-total">
                            <div class="psp-total-label">실 수령 예상액</div>
                            <div class="psp-total-amount" id="summaryMonthTotalActual">-</div>
                            <div class="psp-total-sub">
                                <span>세후</span>
                                <span id="summaryMonthTotalAfterTaxActual">-</span>
                            </div>
                        </div>
                        <div class="psp-meta">
                            <div>급여지급일 <b id="summaryPaydayActual">-</b></div>
                            <div>은행 <span id="bankName">-</span> · 계좌 <span id="bankAccount">-</span></div>
                            <span id="paidDateLabel" class="d-none" style="color:#198754;">
                                지급완료일 <span id="paidDateValue"></span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- =========================================================
             2) 계획일정급여관리 (월단위 예상) + 세금 표시
        ========================================================== -->
        <div class="card pay-card pay-card-plan d-none" id="cardPlan">
            <div class="card-header fw-bold">계획일정급여관리</div>
            <div class="card-body p-0">
                <div class="pay-layout">
                    <!-- 좌: 테이블 -->
                    <div class="pay-layout-table">
                        <div class="table-responsive">
                            <table class="table table-bordered align-middle text-center mb-0" id="monthPayTablePlan">
                                <thead class="table-plan-header">
                                <tr>
                                    <th style="width:55px;">주차</th>
                                    <th style="width:105px;">기간</th>
                                    <th>월</th>
                                    <th>화</th>
                                    <th>수</th>
                                    <th>목</th>
                                    <th>금</th>
                                    <th class="weekend-header">토</th>
                                    <th class="weekend-header">일</th>
                                    <th style="width:80px;" class="text-end">계획시간</th>
                                    <th style="width:90px;" class="text-end">주휴수당</th>
                                    <th style="width:90px;" class="text-end">근무수당</th>
                                </tr>
                                </thead>
                                <tbody id="monthPayBodyPlan">
                                <!-- JS 렌더 -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <!-- 우: 요약 패널 -->
                    <div class="pay-side-panel pay-side-panel-plan">
                        <div class="psp-section">
                            <div class="psp-row">
                                <span class="psp-label">시급</span>
                                <span class="psp-value" id="summaryHourlyWagePlan">-</span>
                            </div>
                            <div class="psp-row">
                                <span class="psp-label">월 계획시간</span>
                                <span class="psp-value" id="summaryMonthWorkTimePlan">0시간</span>
                            </div>
                        </div>
                        <div class="psp-section">
                            <div class="psp-row">
                                <span class="psp-label">근무수당</span>
                                <span class="psp-value text-money" id="summaryMonthWorkPayPlan">-</span>
                            </div>
                            <div class="psp-row">
                                <span class="psp-label">주휴수당</span>
                                <span class="psp-value text-money" id="summaryMonthJuhyuPayPlan">-</span>
                            </div>
                        </div>
                        <div class="psp-section">
                            <div class="psp-row">
                                <span class="psp-label">세금 (3.3%)</span>
                                <span class="psp-value" id="summaryTaxApplyPlan">미부과</span>
                            </div>
                            <div class="psp-row">
                                <span class="psp-label">공제액</span>
                                <span class="psp-value" id="summaryTaxAmountPlan">-</span>
                            </div>
                        </div>
                        <div class="psp-total psp-total-plan">
                            <div class="psp-total-label">예상 합계</div>
                            <div class="psp-total-amount" id="summaryMonthTotalPlan">-</div>
                            <div class="psp-total-sub">
                                <span>세후</span>
                                <span id="summaryMonthTotalAfterTaxPlan">-</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        </div><!-- /individualWrap -->

        <!-- ===== 전체 모드 영역 ===== -->
        <div id="allMembersWrap" class="d-none">

            <!-- 상태별 근무자 pill (정보용) -->
            <div class="mb-3">
                <div class="d-flex flex-wrap gap-1" id="allMemberPillList"></div>
            </div>

            <!-- 월합계 요약 테이블 -->
            <div class="mb-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="fw-bold" id="allSummaryTitle">월합계 지급 내역 (근무시간)</span>
                    <span class="small text-muted" id="allSummaryPeriod"></span>
                    <button type="button" class="btn btn-sm btn-outline-primary ms-auto" id="btnOpenAllDetail">주차별 상세보기</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered align-middle text-center all-pay-tbl" id="allMonthlySummaryTable">
                        <thead class="table-pay-header">
                        <tr>
                            <th style="width:140px;">근무자명</th>
                            <th style="width:120px;" class="text-end">근무시간</th>
                            <th style="width:100px;" class="text-end">시급</th>
                            <th style="width:120px;" class="text-end">근무수당</th>
                            <th style="width:120px;" class="text-end">주휴수당</th>
                            <th style="width:120px;" class="text-end">세금(3.3%)</th>
                            <th style="width:130px;" class="text-end">실수령액</th>
                        </tr>
                        </thead>
                        <tbody id="allMonthlySummaryBody"></tbody>
                        <tfoot>
                        <tr class="table-secondary fw-bold">
                            <td class="text-end">합계</td>
                            <td class="text-end" id="allSumTotalTime">-</td>
                            <td></td>
                            <td class="text-end" id="allSumTotalWorkPay">-</td>
                            <td class="text-end" id="allSumTotalJuhyuPay">-</td>
                            <td class="text-end" id="allSumTotalTax">-</td>
                            <td class="text-end" id="allSumTotalNet">-</td>
                        </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

        </div><!-- /allMembersWrap -->

    </div>
</main>

<!-- 주차별 상세 팝업 (전체 모드) -->
<div class="pmd-popup-overlay d-none" id="allDetailPopupOverlay">
    <div class="pmd-popup">
        <div class="pmd-popup-header">
            <div>
                <div class="pmd-popup-title" id="allPopupTitle">주차별 급여 상세</div>
                <div class="pmd-popup-subtitle" id="allPopupSubtitle"></div>
            </div>
            <button type="button" class="btn btn-sm btn-outline-dark" id="btnCloseAllDetail">닫기</button>
        </div>
        <div class="pmd-popup-body">
            <div id="allViewActual">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle text-center all-pay-tbl" id="allWeeklyPayTable">
                        <thead class="table-pay-header">
                        <tr>
                            <th style="width:100px;">주차</th>
                            <th style="width:130px;">근무자명</th>
                            <th style="width:110px;" class="text-end">근무시간</th>
                            <th style="width:90px;" class="text-end">시급</th>
                            <th style="width:80px;">주휴</th>
                            <th style="width:80px;">세금</th>
                            <th style="width:110px;" class="text-end">근무수당</th>
                            <th style="width:110px;" class="text-end">주휴수당</th>
                            <th style="width:110px;" class="text-end">세금(3.3%)</th>
                            <th style="width:120px;" class="text-end">실수령액</th>
                            <th style="width:90px;">지급일</th>
                        </tr>
                        </thead>
                        <tbody id="allWeeklyPayBody"></tbody>
                        <tfoot>
                        <tr class="table-secondary fw-bold">
                            <td colspan="6" class="text-end">월 합계</td>
                            <td class="text-end" id="allMonthWorkPaySum">-</td>
                            <td class="text-end" id="allMonthJuhyuPaySum">-</td>
                            <td class="text-end" id="allMonthTaxSum">-</td>
                            <td class="text-end" id="allMonthNetSum">-</td>
                            <td></td>
                        </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div id="allViewPlan" class="d-none">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle text-center all-pay-tbl" id="allWeeklyPlanTable">
                        <thead class="table-plan-header">
                        <tr>
                            <th style="width:100px;">주차</th>
                            <th style="width:130px;">근무자명</th>
                            <th style="width:110px;" class="text-end">계획시간</th>
                            <th style="width:90px;" class="text-end">시급</th>
                            <th style="width:80px;">주휴</th>
                            <th style="width:80px;">세금</th>
                            <th style="width:110px;" class="text-end">근무수당</th>
                            <th style="width:110px;" class="text-end">주휴수당</th>
                            <th style="width:110px;" class="text-end">세금(3.3%)</th>
                            <th style="width:120px;" class="text-end">실수령액</th>
                            <th style="width:90px;">지급일</th>
                        </tr>
                        </thead>
                        <tbody id="allWeeklyPlanBody"></tbody>
                        <tfoot>
                        <tr class="table-secondary fw-bold">
                            <td colspan="6" class="text-end">월 합계</td>
                            <td class="text-end" id="allMonthPlanWorkPaySum">-</td>
                            <td class="text-end" id="allMonthPlanJuhyuPaySum">-</td>
                            <td class="text-end" id="allMonthPlanTaxSum">-</td>
                            <td class="text-end" id="allMonthPlanNetSum">-</td>
                            <td></td>
                        </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* ===== 상단 컴팩트 패널 ===== */
    .status-panel-blue {
        background: linear-gradient(135deg, #0d6efd 0%, #3b82f6 100%);
        color: #fff;
        border-radius: 1rem;
        padding: 14px 18px 16px;
    }
    .status-title { font-size: .92rem; font-weight: 700; letter-spacing: .02em; }
    .status-subtitle-small { font-size: .72rem; opacity: .82; margin-top: 1px; }
    .status-period-label-caption { font-size: .65rem; opacity: .7; }
    .status-period-label-value { font-size: .82rem; font-weight: 600; }
    .status-label { color: rgba(255,255,255,.85) !important; }
    .status-select {
        background: #fff !important;
        color: #333 !important;
        border: 1px solid rgba(255,255,255,.3) !important;
        font-size: .8rem !important;
    }
    .status-subtitle { color: rgba(255,255,255,.85) !important; }
    .status-count-badge { font-size: .72rem; }

    .status-pill-list {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    /* ===== 칩 스타일 ===== */
    .vlist {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .pill {
        display:flex;
        align-items:center;
        gap:5px;
        padding:4px 10px;
        border-radius:999px;
        border:1px solid rgba(255,255,255,.3);
        background:rgba(255,255,255,.12);
        cursor:pointer;
        font-size:.78rem;
        color:#fff;
        transition: background .15s, box-shadow .15s, border-color .15s;
    }
    .pill:hover { background:rgba(255,255,255,.22); border-color:rgba(255,255,255,.5); }
    .pill.active {
        border-color: #fff;
        box-shadow: 0 0 0 2px rgba(255,255,255,.35) inset;
        background:rgba(255,255,255,.25);
        font-weight:700;
    }
    .pill .dot { width:10px; height:10px; border-radius:50%; border:1px solid rgba(255,255,255,.3); flex:0 0 10px; }
    .pill .name { font-weight:600; }

    .pay-right-wrapper { position: relative; }

    .sticky-pay-header {
        background:#ffffff;
        padding-top: .25rem;
        padding-bottom: .25rem;
    }

    /* ===== 카드 ===== */
    .pay-card {
        border-radius: 1rem;
        overflow: hidden;
        border: 1px solid #d0e2ff;
    }
    .pay-card .card-header {
        background: #0d6efd;
        color: #fff;
        border-bottom: none;
        border-radius: 1rem 1rem 0 0;
        font-size: .88rem;
    }
    .pay-card-plan .card-header {
        background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
    }

    /* ===== 테이블 헤더 ===== */
    .table-pay-header th {
        background: #0d6efd !important;
        color: #fff !important;
        border-color: #0b5ed7 !important;
        vertical-align: middle;
        font-size: .78rem;
    }
    .table-pay-header .weekend-header {
        background: #0b5ed7 !important;
    }
    .table-plan-header th {
        background: #6366f1 !important;
        color: #fff !important;
        border-color: #5558e6 !important;
        vertical-align: middle;
        font-size: .78rem;
    }
    .table-plan-header .weekend-header {
        background: #5558e6 !important;
    }

    /* ===== 셀 ===== */
    .day-cell { padding: 6px 4px; font-size: .8rem; line-height: 1.3; vertical-align: middle; }
    .dc-date { font-size: .72rem; font-weight: 700; color: #495057; }
    .dc-time { font-size: .72rem; margin-top: 2px; }

    .day-outside { color:#bbb; background:#fafafa; }
    .day-weekend { background:#fff8f0; }

    /* ===== 테이블 + 사이드 패널 레이아웃 ===== */
    .pay-layout {
        display: flex; gap: 0; align-items: stretch;
    }
    .pay-layout-table {
        flex: 1; min-width: 0; overflow-x: auto;
    }
    .pay-side-panel {
        width: 240px; min-width: 240px; flex-shrink: 0;
        background: #f8f9fa; border-left: 1px solid #dee2e6;
        display: flex; flex-direction: column;
        padding: 12px 14px; gap: 0;
        font-size: .78rem;
    }
    .pay-side-panel-plan { background: #f5f3ff; border-left-color: #c4b5fd; }

    .psp-section {
        display: flex; flex-direction: column; gap: 4px;
        padding-bottom: 8px; margin-bottom: 8px;
        border-bottom: 1px solid #e0e0e0;
    }
    .pay-side-panel-plan .psp-section { border-bottom-color: #ddd6fe; }

    .psp-row { display: flex; justify-content: space-between; align-items: center; }
    .psp-label { color: #6c757d; font-weight: 500; white-space: nowrap; }
    .psp-value { font-weight: 600; text-align: right; color: #212529; word-break: break-all; }

    .psp-total {
        background: linear-gradient(135deg, #0d6efd 0%, #3b82f6 100%);
        color: #fff; border-radius: 10px; padding: 14px 12px;
        margin-bottom: 8px;
    }
    .psp-total-plan {
        background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
    }
    .psp-total-label { font-size: .7rem; opacity: .8; }
    .psp-total-amount { font-size: 1.25rem; font-weight: 700; margin: 2px 0 4px; }
    .psp-total-sub { font-size: .75rem; opacity: .85; display: flex; justify-content: space-between; }

    .psp-meta {
        font-size: .7rem; color: #6c757d;
        display: flex; flex-direction: column; gap: 2px;
        margin-top: auto;
    }
    .psp-meta b, .psp-meta span { font-weight: 600; color: #495057; }

    @media (max-width: 991px) {
        .pay-layout { flex-direction: column; }
        .pay-side-panel { width: 100%; min-width: 0; border-left: none; border-top: 1px solid #dee2e6; flex-direction: row; flex-wrap: wrap; gap: 8px; }
        .psp-section { flex: 1; min-width: 140px; border-bottom: none; margin-bottom: 0; padding-bottom: 0; border-right: 1px solid #e0e0e0; padding-right: 8px; }
        .psp-total { flex: 1; min-width: 160px; }
        .psp-meta { flex: 1; min-width: 140px; }
    }

    .pay-action-next { box-shadow: 0 0 0 2px rgba(13,110,253,.35); transform: translateY(-1px); }

    .text-time { color:#198754; font-weight:600; }
    .text-money { color:#0d6efd; font-weight:600; }

    /* ===== 전체 모드 pill ===== */
    .member-pill{
        display:inline-flex; align-items:center; gap:5px;
        padding:3px 12px; border-radius:999px;
        font-size:.78rem; font-weight:600;
        background:#e9ecef; color:#374151;
        cursor:default; white-space:nowrap;
    }
    .member-pill .pill-dot{
        width:10px; height:10px; border-radius:50%;
        border:1px solid rgba(0,0,0,.08); flex:0 0 10px;
    }
    .name-dot{
        display:inline-block; width:10px; height:10px; border-radius:50%;
        border:1px solid rgba(0,0,0,.08); margin-right:6px; vertical-align:middle;
    }

    /* ===== 전체 모드 테이블 ===== */
    .all-pay-tbl{ border-collapse:separate; border-spacing:0; border-radius:.75rem; overflow:hidden; background:#fff; }
    .all-pay-tbl tbody tr.week-end-border td{ border-bottom-width:3px; border-bottom-color:#0d6efd; }
    .all-pay-tbl tbody td.week-label-border{ border-bottom-width:3px; border-bottom-color:#0d6efd; }
    .week-label{ white-space:nowrap; }

    /* ===== 전체 모드 팝업 ===== */
    .pmd-popup-overlay{
        position:fixed; inset:0; z-index:2000;
        background:rgba(0,0,0,.45);
        display:flex; align-items:center; justify-content:center;
        padding:20px;
    }
    .pmd-popup{
        background:#fff; border-radius:16px;
        width:100%; max-width:1400px; max-height:90vh;
        display:flex; flex-direction:column;
        box-shadow:0 12px 40px rgba(0,0,0,.15);
    }
    .pmd-popup-header{
        display:flex; justify-content:space-between; align-items:center;
        padding:16px 24px; border-bottom:1px solid #e9ecef; flex-shrink:0;
    }
    .pmd-popup-title{ font-size:1.05rem; font-weight:700; }
    .pmd-popup-subtitle{ font-size:.78rem; color:#6c757d; margin-top:2px; }
    .pmd-popup-body{ flex:1; overflow-y:auto; padding:20px 24px; }
</style>

<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1080;">
    <div id="mainToast" class="toast align-items-center text-bg-success border-0" role="alert"
         aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body" id="mainToastBody">처리되었습니다.</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<div class="modal fade" id="paidDateModal" tabindex="-1" aria-labelledby="paidDateModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="paidDateModalLabel">지급완료 일자</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="닫기"></button>
            </div>
            <div class="modal-body">
                <label for="paidDateInput" class="form-label small">지급완료 일자</label>
                <input type="date" class="form-control" id="paidDateInput">
                <div class="invalid-feedback">지급완료 일자를 선택해 주세요.</div>
                <div class="form-text">기본값은 오늘입니다.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">취소</button>
                <button type="button" class="btn btn-sm btn-primary" id="btnPaidDateConfirm">저장</button>
            </div>
        </div>
    </div>
</div>

<script id="membersData" type="application/json">
{{{membersJson}}}
</script>
<script id="initialSelectedMemberId" type="application/json">
{{#selectedMemberId}}{{selectedMemberId}}{{/selectedMemberId}}{{^selectedMemberId}}null{{/selectedMemberId}}
</script>

<script>
    (function() {
        const API_BASE_ACTUAL   = '/api/schedule';
        const API_BASE_PLAN     = '/api/schedule/work';
        const PAYROLL_SAVE_API  = '/api/payroll/month';

        const statusSelect         = document.getElementById('statusSelect');
        const memberPills          = document.getElementById('memberPills');
        const memberCountBadge     = document.getElementById('memberCountBadge');

        const pageTitle            = document.getElementById('pageTitle');
        const selectedMemberNameEl = document.getElementById('selectedMemberName');
        const selectedMemberStatus = document.getElementById('selectedMemberStatus');
        const payrollStatusBadge   = document.getElementById('payrollStatusBadge');
        const monthRangeLabel      = document.getElementById('monthRangeLabel');
        const btnMonthPrev         = document.getElementById('btnMonthPrev');
        const btnMonthThis         = document.getElementById('btnMonthThis');
        const btnMonthNext         = document.getElementById('btnMonthNext');

        const monthPayBodyActual         = document.getElementById('monthPayBodyActual');
        const summaryHourlyWageActual    = document.getElementById('summaryHourlyWageActual');
        const summaryMonthWorkTimeActual = document.getElementById('summaryMonthWorkTimeActual');
        const summaryMonthWorkPayActual  = document.getElementById('summaryMonthWorkPayActual');
        const summaryMonthJuhyuPayActual = document.getElementById('summaryMonthJuhyuPayActual');
        const summaryMonthTotalActual    = document.getElementById('summaryMonthTotalActual');

        const summaryTaxApplyActual           = document.getElementById('summaryTaxApplyActual');
        const summaryTaxAmountActual          = document.getElementById('summaryTaxAmountActual');
        const summaryMonthTotalAfterTaxActual = document.getElementById('summaryMonthTotalAfterTaxActual');

        const monthPayBodyPlan         = document.getElementById('monthPayBodyPlan');
        const summaryHourlyWagePlan    = document.getElementById('summaryHourlyWagePlan');
        const summaryMonthWorkTimePlan = document.getElementById('summaryMonthWorkTimePlan');
        const summaryMonthWorkPayPlan  = document.getElementById('summaryMonthWorkPayPlan');
        const summaryMonthJuhyuPayPlan = document.getElementById('summaryMonthJuhyuPayPlan');
        const summaryMonthTotalPlan    = document.getElementById('summaryMonthTotalPlan');

        const summaryTaxApplyPlan           = document.getElementById('summaryTaxApplyPlan');
        const summaryTaxAmountPlan          = document.getElementById('summaryTaxAmountPlan');
        const summaryMonthTotalAfterTaxPlan = document.getElementById('summaryMonthTotalAfterTaxPlan');

        const bankNameEl      = document.getElementById('bankName');
        const bankAccountEl   = document.getElementById('bankAccount');
        const paidDateLabelEl = document.getElementById('paidDateLabel');
        const paidDateValueEl = document.getElementById('paidDateValue');

        const summaryPaydayActual = document.getElementById('summaryPaydayActual');
        const juhyuApplyTextEl    = document.getElementById('juhyuApplyText');

        const btnSaveDraft        = document.getElementById('btnSaveDraft');
        const btnConfirm          = document.getElementById('btnConfirm');
        const btnMarkPaid         = document.getElementById('btnMarkPaid');
        const btnOpenPayPdf       = document.getElementById('btnOpenPayPdf');
        const taxApplyBadge       = document.getElementById('taxApplyBadge');

        const paidDateModalEl    = document.getElementById('paidDateModal');
        const paidDateInput      = document.getElementById('paidDateInput');
        const btnPaidDateConfirm = document.getElementById('btnPaidDateConfirm');

        const toastEl   = document.getElementById('mainToast');
        const toastBody = document.getElementById('mainToastBody');

        let allMembers = [];
        try {
            allMembers = JSON.parse(document.getElementById('membersData').textContent || '[]');
        } catch(e) {
            allMembers = [];
        }

        let _initSelectedId = null;
        try {
            const raw = (document.getElementById('initialSelectedMemberId')?.textContent || '').trim();
            if (raw && raw !== 'null') _initSelectedId = Number(raw);
        } catch(e) {}

        let currentMember     = null;
        let selectedMemberId  = null;
        let currentMonthStart = firstDayOfMonth(new Date());

        let lastPayrollPayload = null;
        let currentPayrollStatus = null;
        let currentPaidDate      = null;

        const mainViewSelect = document.getElementById('mainViewSelect');
        const payViewSelect  = document.getElementById('payViewSelect');
        const cardActual     = document.getElementById('cardActual');
        const cardPlan       = document.getElementById('cardPlan');
        const individualWrap = document.getElementById('individualWrap');
        const allMembersWrap = document.getElementById('allMembersWrap');
        let mainViewMode    = 'individual'; // 'individual' | 'all'
        let currentViewType = 'actual'; // 'actual' | 'plan'

        /* === 전체 모드 DOM refs === */
        const allMemberPillList     = document.getElementById('allMemberPillList');
        const allSummaryTitleEl     = document.getElementById('allSummaryTitle');
        const allSummaryPeriodEl    = document.getElementById('allSummaryPeriod');
        const allMonthlySummaryBody = document.getElementById('allMonthlySummaryBody');
        const allSumTotalTimeEl     = document.getElementById('allSumTotalTime');
        const allSumTotalWorkPayEl  = document.getElementById('allSumTotalWorkPay');
        const allSumTotalJuhyuPayEl = document.getElementById('allSumTotalJuhyuPay');
        const allSumTotalTaxEl      = document.getElementById('allSumTotalTax');
        const allSumTotalNetEl      = document.getElementById('allSumTotalNet');
        const allWeeklyPayBody      = document.getElementById('allWeeklyPayBody');
        const allMonthWorkPaySumEl  = document.getElementById('allMonthWorkPaySum');
        const allMonthJuhyuPaySumEl = document.getElementById('allMonthJuhyuPaySum');
        const allMonthTaxSumEl      = document.getElementById('allMonthTaxSum');
        const allMonthNetSumEl      = document.getElementById('allMonthNetSum');
        const allWeeklyPlanBody        = document.getElementById('allWeeklyPlanBody');
        const allMonthPlanWorkPaySumEl = document.getElementById('allMonthPlanWorkPaySum');
        const allMonthPlanJuhyuPaySumEl= document.getElementById('allMonthPlanJuhyuPaySum');
        const allMonthPlanTaxSumEl     = document.getElementById('allMonthPlanTaxSum');
        const allMonthPlanNetSumEl     = document.getElementById('allMonthPlanNetSum');
        const allDetailPopupOverlay = document.getElementById('allDetailPopupOverlay');
        const allPopupTitleEl       = document.getElementById('allPopupTitle');
        const allPopupSubtitleEl    = document.getElementById('allPopupSubtitle');
        const allViewActualDiv      = document.getElementById('allViewActual');
        const allViewPlanDiv        = document.getElementById('allViewPlan');

        let allFilteredMembers   = [];
        let allActualSummaryMap  = {};
        let allPlanSummaryMap    = {};

        // 기본 상태: URL에서 지정된 멤버의 상태 또는 근무중
        if (_initSelectedId) {
            const _im = allMembers.find(m => m.id === _initSelectedId);
            if (_im && _im.status) statusSelect.value = _im.status;
            else statusSelect.value = 'WORKING';
        } else {
            statusSelect.value = 'WORKING';
        }

        statusSelect.addEventListener('change', ()=>{
            if (mainViewMode === 'all') handleStatusChangeAll();
            else handleStatusChange();
        });

        // 메인 보기 전환 (개별/전체)
        mainViewSelect.addEventListener('change', ()=>{
            mainViewMode = mainViewSelect.value;
            applyMainViewMode();
        });

        // 데이터 소스 전환 (근무시간/일정)
        payViewSelect.addEventListener('change', function() {
            currentViewType = payViewSelect.value;
            if (mainViewMode === 'all') {
                allViewActualDiv.classList.toggle('d-none', currentViewType !== 'actual');
                allViewPlanDiv.classList.toggle('d-none', currentViewType !== 'plan');
                updateAllSummaryTitle();
                renderAllMonthlySummary();
            } else {
                if (cardActual) cardActual.classList.toggle('d-none', currentViewType !== 'actual');
                if (cardPlan)   cardPlan.classList.toggle('d-none', currentViewType !== 'plan');
            }
        });
        btnMonthPrev.addEventListener('click', () => {
            currentMonthStart = new Date(currentMonthStart.getFullYear(), currentMonthStart.getMonth()-1, 1);
            reloadForCurrentMode();
        });
        btnMonthThis.addEventListener('click', () => {
            currentMonthStart = firstDayOfMonth(new Date());
            reloadForCurrentMode();
        });
        btnMonthNext.addEventListener('click', () => {
            currentMonthStart = new Date(currentMonthStart.getFullYear(), currentMonthStart.getMonth()+1, 1);
            reloadForCurrentMode();
        });

        function reloadForCurrentMode(){
            if (mainViewMode === 'all') loadAllMembersTables();
            else reloadForCurrentMember();
        }

        btnSaveDraft.addEventListener('click', () => savePayrollWithStatus('DRAFT', '임시저장 되었습니다.'));
        btnConfirm.addEventListener('click', () => savePayrollWithStatus('CONFIRMED', '급여가 확정되었습니다.'));
        btnMarkPaid.addEventListener('click', onMarkPaidClick);

        // ✅ 월 실근무 PDF 버튼
        if (btnOpenPayPdf) {
            btnOpenPayPdf.addEventListener('click', openPayPdfPage);
        }

        function updateTaxBadge(member) {
            if (!taxApplyBadge) return;
            const applied = isTaxApplied(member);
            taxApplyBadge.textContent = applied ? '세금(3.3%) 적용' : '세금(3.3%) 미적용';
            taxApplyBadge.style.background = applied ? 'rgba(255,193,7,.85)' : 'rgba(255,255,255,.2)';
            taxApplyBadge.style.color = applied ? '#212529' : '#fff';
        }

        if (btnPaidDateConfirm) {
            btnPaidDateConfirm.addEventListener('click', () => {
                const dateValue = paidDateInput.value;
                if (!dateValue) {
                    paidDateInput.classList.add('is-invalid');
                    return;
                }
                paidDateInput.classList.remove('is-invalid');
                savePayrollWithStatus('PAID', '지급완료로 처리되었습니다.', dateValue);
                if (window.bootstrap && bootstrap.Modal && paidDateModalEl) {
                    bootstrap.Modal.getOrCreateInstance(paidDateModalEl).hide();
                }
            });
        }

        applyMainViewMode();

        function applyMainViewMode(){
            const isAll = (mainViewMode === 'all');
            individualWrap.classList.toggle('d-none', isAll);
            allMembersWrap.classList.toggle('d-none', !isAll);

            // 개별 모드 헤더 요소 표시/숨김
            selectedMemberNameEl.classList.toggle('d-none', isAll);
            if (isAll) {
                selectedMemberStatus.classList.add('d-none');
                payrollStatusBadge.classList.add('d-none');
            }

            if (isAll) {
                pageTitle.textContent = '급여 관리 (전체)';
                handleStatusChangeAll();
            } else {
                pageTitle.textContent = '급여 관리';
                handleStatusChange();
            }
        }

        function handleStatusChange() {
            const status = statusSelect.value;
            const filtered = (allMembers || []).filter(m => m.status === status);
            renderMembersByStatus(filtered);
        }

        function renderMembersByStatus(members) {
            memberPills.innerHTML = '';
            memberCountBadge.textContent = `${members.length}명`;

            if (!members.length) {
                memberPills.innerHTML = `<span class="text-muted small">해당 상태의 아르바이트생이 없습니다.</span>`;
                selectedMemberId = null;
                currentMember = null;
                clearTables();
                return;
            }

            let toSelect = null;
            if (_initSelectedId && members.some(m => m.id === _initSelectedId)) {
                toSelect = members.find(m => m.id === _initSelectedId);
                _initSelectedId = null; // 1회만 적용
            } else if (currentMember && members.some(m => String(m.id) === String(currentMember.id))) {
                toSelect = members.find(m => String(m.id) === String(currentMember.id));
            } else {
                toSelect = members[0];
            }

            members.slice()
                    .sort((a,b) => (a.name||'').localeCompare(b.name||'', 'ko'))
                    .forEach(m => {
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'pill';
                        btn.dataset.memberId = String(m.id);
                        const color = colorForMember(m);
                        btn.innerHTML = `
                        <span class="dot" style="background:${color}"></span>
                        <span class="name">${escapeHtml(m.name ?? '-')}</span>
                    `;
                        btn.addEventListener('click', (e) => {
                            e.preventDefault();
                            selectMember(m);
                        });
                        memberPills.appendChild(btn);
                    });

            selectMember(toSelect);
        }

        function selectMember(member) {
            currentMember = member;
            selectedMemberId = member.id;
            currentPayrollStatus = null;
            currentPaidDate = null;
            updateMemberListActive();
            renderMemberHeader(member);
            setBankInfo(member);
            setPayday(member);
            updateJuhyuApplyText(member);
            updateTaxBadge(member);
            reloadForCurrentMember();
        }

        function updateMemberListActive() {
            Array.from(memberPills.querySelectorAll('.pill')).forEach(el => {
                el.classList.toggle('active', el.dataset.memberId === String(selectedMemberId));
            });
        }

        function renderMemberHeader(member) {
            if (!member) {
                pageTitle.textContent = '급여 관리';
                selectedMemberNameEl.textContent = '';
                selectedMemberStatus.classList.add('d-none');
                selectedMemberStatus.textContent = '-';
                selectedMemberStatus.className = 'badge bg-secondary d-none';
                updatePayrollStatusUI(null);
                return;
            }
            pageTitle.textContent = '급여 관리';
            selectedMemberNameEl.textContent = `(${member.name ?? '-'})`;
            const badgeMap = {
                WORKING: 'bg-success',
                WAITING: 'bg-secondary',
                RESTING: 'bg-info',
                PAUSED:  'bg-warning',
                RESIGNED:'bg-danger'
            };
            selectedMemberStatus.classList.remove('d-none');
            selectedMemberStatus.textContent = member.status || '-';
            selectedMemberStatus.className = `badge ${badgeMap[member.status] || 'bg-secondary'} ms-2`;
            updatePayrollStatusUI(currentPayrollStatus);
        }

        function setBankInfo(member) {
            const bankName    = member?.bankName?.trim()    || '-';
            const bankAccount = member?.bankAccount?.trim() || '-';
            if (bankNameEl)    bankNameEl.textContent = bankName;
            if (bankAccountEl) bankAccountEl.textContent = bankAccount;
        }

        function setPayday(member) {
            if (!summaryPaydayActual) return;
            const v = member?.payday;
            summaryPaydayActual.textContent = formatPayday(v);
        }

        function formatPayday(v) {
            if (!v) return '미지정';
            const s = String(v).trim().toUpperCase();
            if (s === 'EOM') return '말일';
            if (/^\d+$/.test(s)) {
                const n = parseInt(s, 10);
                if (n >= 1 && n <= 31) return `${n}일`;
            }
            return s;
        }

        function updateJuhyuApplyText(member) {
            const applied = !!member?.includeWeeklyHolidayAllowance;
            if (juhyuApplyTextEl) {
                juhyuApplyTextEl.textContent = applied ? '주휴수당(적용)' : '주휴수당(미적용)';
            }
        }

        function clearTables() {
            monthRangeLabel.textContent = '0000.00.01 ~ 00.00';

            monthPayBodyActual.innerHTML = '';
            summaryHourlyWageActual.textContent    = '-';
            summaryMonthWorkTimeActual.textContent = '0시간';
            summaryMonthWorkPayActual.textContent  = '-';
            summaryMonthJuhyuPayActual.textContent = '-';
            summaryMonthTotalActual.textContent    = '-';

            if (summaryTaxApplyActual)      summaryTaxApplyActual.textContent      = '미적용';
            if (summaryTaxAmountActual)     summaryTaxAmountActual.textContent     = '-';
            if (summaryMonthTotalAfterTaxActual) summaryMonthTotalAfterTaxActual.textContent = '-';

            lastPayrollPayload   = null;
            currentPayrollStatus = null;
            currentPaidDate      = null;
            if (paidDateLabelEl)  paidDateLabelEl.classList.add('d-none');
            if (paidDateValueEl)  paidDateValueEl.textContent = '';
            if (summaryPaydayActual) summaryPaydayActual.textContent = '-';

            monthPayBodyPlan.innerHTML = '';
            summaryHourlyWagePlan.textContent    = '-';
            summaryMonthWorkTimePlan.textContent = '0시간';
            summaryMonthWorkPayPlan.textContent  = '-';
            summaryMonthJuhyuPayPlan.textContent = '-';
            summaryMonthTotalPlan.textContent    = '-';

            if (summaryTaxApplyPlan)          summaryTaxApplyPlan.textContent          = '미부과';
            if (summaryTaxAmountPlan)         summaryTaxAmountPlan.textContent         = '-';
            if (summaryMonthTotalAfterTaxPlan) summaryMonthTotalAfterTaxPlan.textContent = '-';

            renderMemberHeader(null);
            if (juhyuApplyTextEl) juhyuApplyTextEl.textContent = '주휴수당(적용/미적용)';

        }

        function reloadForCurrentMember() {
            if (!currentMember) {
                clearTables();
                return;
            }
            loadMonthDataBoth(currentMember, currentMonthStart);
        }

        async function loadMonthDataBoth(member, monthStartDate) {
            const ms    = firstDayOfMonth(monthStartDate);
            const me    = lastDayOfMonth(monthStartDate);
            const fetchStart = toMonday(ms);
            const fetchStartIso = toIso(fetchStart);
            const meIso = toIso(me);

            const rangeText = `${ms.getFullYear()}.${pad2(ms.getMonth()+1)}.01 ~ ${pad2(me.getMonth()+1)}.${pad2(me.getDate())}`;
            monthRangeLabel.textContent = rangeText;
            const weekRangeLabelEl = document.getElementById('weekRangeLabel');
            if (weekRangeLabelEl) weekRangeLabelEl.textContent = rangeText;

            let dayMapActual = {};
            let dayMapPlan   = {};

            try {
                const [respActual, respPlan] = await Promise.all([
                    fetch(`${API_BASE_ACTUAL}/${encodeURIComponent(member.id)}/${fetchStartIso}/${meIso}`, { headers: { 'Accept': 'application/json' }}),
                    fetch(`${API_BASE_PLAN}/${encodeURIComponent(member.id)}/${fetchStartIso}/${meIso}`,   { headers: { 'Accept': 'application/json' }})
                ]);

                if (respActual.ok) {
                    const dataA = await respActual.json();
                    dayMapActual = normalizeDays(dataA);
                }
                if (respPlan.ok) {
                    const dataP = await respPlan.json();
                    dayMapPlan = normalizeDays(dataP);
                }
            } catch (e) {
                console.error('loadMonthDataBoth error', e);
            }

            const includeJuhyu = !!member?.includeWeeklyHolidayAllowance;

            // 실근무/계획 각각 자기 데이터로 계산
            renderMonthPayTable('actual', currentMember, ms, me, dayMapActual, includeJuhyu);
            renderMonthPayTable('plan',   currentMember, ms, me, dayMapPlan,   includeJuhyu);

            await loadPayrollStatus(currentMember, ms);
        }

        async function loadPayrollStatus(member, monthStartDate) {
            const year  = monthStartDate.getFullYear();
            const month = monthStartDate.getMonth() + 1;
            try {
                const url  = `${PAYROLL_SAVE_API}/${encodeURIComponent(member.id)}/${year}/${month}`;
                const resp = await fetch(url, { headers: { 'Accept': 'application/json' } });
                if (!resp.ok) {
                    currentPayrollStatus = null;
                    currentPaidDate      = null;
                    updatePayrollStatusUI(null);
                    return;
                }
                const data = await resp.json();
                currentPayrollStatus = data?.status ? String(data.status).toUpperCase() : null;
                currentPaidDate      = data && (data.paidDate || data.paidAt) ? String(data.paidDate || data.paidAt) : null;
                updatePayrollStatusUI(currentPayrollStatus);
            } catch (e) {
                console.error('loadPayrollStatus error', e);
                currentPayrollStatus = null;
                currentPaidDate      = null;
                updatePayrollStatusUI(null);
            }
        }

        /**
         * type: 'actual' | 'plan'
         * includeJuhyu:
         *   - false: 주 15시간 이상 → hourlyWage, 15시간 미만 → hourlyWage2, 주휴 없음
         *   - true : 항상 hourlyWage2 기준, 15시간 이상인 주만 주휴수당 발생
         */
        function renderMonthPayTable(type, member, ms, me, dayMap, includeJuhyu) {
            const isActual = (type === 'actual');

            const tbodyEl   = isActual ? monthPayBodyActual   : monthPayBodyPlan;
            const wageEl    = isActual ? summaryHourlyWageActual    : summaryHourlyWagePlan;
            const timeEl    = isActual ? summaryMonthWorkTimeActual : summaryMonthWorkTimePlan;
            const workPayEl = isActual ? summaryMonthWorkPayActual  : summaryMonthWorkPayPlan;
            const juhyuEl   = isActual ? summaryMonthJuhyuPayActual : summaryMonthJuhyuPayPlan;
            const totalEl   = isActual ? summaryMonthTotalActual    : summaryMonthTotalPlan;

            tbodyEl.innerHTML = '';

            const wageMainRaw = (typeof member?.hourlyWage === 'number') ? member.hourlyWage : null;
            const wageSubRaw  = (typeof member?.hourlyWage2 === 'number') ? member.hourlyWage2 : null;

            const wageMain = wageMainRaw != null ? wageMainRaw : wageSubRaw; // 기본 시급
            const wageSub  = wageSubRaw  != null ? wageSubRaw  : wageMainRaw; // 보조 시급(없으면 기본)

            // 시급 표시
            if (wageMain == null && wageSub == null) {
                wageEl.textContent = '-';
            } else {
                if (!includeJuhyu) {
                    // 주휴 미적용: 15시간 기준으로 두 시급 사용
                    if (wageMainRaw != null && wageSubRaw != null && wageMainRaw !== wageSubRaw) {
                        wageEl.textContent = `${krw(wageMainRaw)} (>=15시간) / ${krw(wageSubRaw)} (<15시간)`;
                    } else {
                        wageEl.textContent = krw(wageMain);
                    }
                } else {
                    // 주휴 적용: 항상 hourlyWage2 기준(없으면 hourlyWage)
                    const base = wageSub != null ? wageSub : wageMain;
                    wageEl.textContent = krw(base) + ' (주휴 기준 시급)';
                }
            }

            let monthMinutes      = 0;
            let monthJuhyuMinutes = 0;
            let monthWorkPay      = 0;
            let monthJuhyuPay     = 0;

            const weeks   = [];
            let wStart    = toMonday(ms);
            const monthEnd = new Date(me);
            while (wStart <= monthEnd) {
                weeks.push(new Date(wStart));
                wStart.setDate(wStart.getDate() + 7);
            }

            let weekIndex = 0;
            const thresholdMinutes = 15 * 60;

            weeks.forEach(weekStart => {
                const weekEnd = addDays(weekStart, 6);

                const dayCells      = [];
                let weekMinutes     = 0;
                let fullWeekMinutes = 0;

                for (let i=0; i<7; i++) {
                    const dayDate  = addDays(weekStart, i);
                    const iso      = toIso(dayDate);
                    const inMonth  = (dayDate >= ms && dayDate <= me);
                    const fullInfo = dayMap[iso] || { segments:[], minutes:0 };
                    const fullDayMins = fullInfo.minutes || 0;
                    fullWeekMinutes += fullDayMins;
                    const info       = inMonth ? fullInfo : { segments:[], minutes:0 };
                    const dayMinutes = inMonth ? fullDayMins : 0;
                    const segments   = Array.isArray(info.segments) ? info.segments : [];

                    if (inMonth) {
                        weekMinutes  += dayMinutes;
                        monthMinutes += dayMinutes;
                    }

                    const dayNum    = dayDate.getDate();
                    const isWeekend = (i >= 5);

                    const clsArr = ['day-cell', 'text-center'];
                    if (!inMonth)            clsArr.push('day-outside');
                    if (inMonth && isWeekend) clsArr.push('day-weekend');
                    const cls = clsArr.join(' ');

                    if (!inMonth) {
                        dayCells.push(`<td class="${cls}"></td>`);
                        continue;
                    }

                    const timeLabel = dayMinutes > 0 ? formatMins(dayMinutes) : '-';
                    const cellHtml = `
                        <td class="${cls}">
                            <div class="dc-date">${dayNum}</div>
                            <div class="dc-time ${dayMinutes > 0 ? 'text-time' : 'text-muted'}">${timeLabel}</div>
                        </td>
                    `;
                    dayCells.push(cellHtml);
                }

                // === 주별 주휴시간/주휴수당/근무수당 계산 (주휴: 일요일 귀속 원칙) ===
                const sundayInMonth = (weekEnd >= ms && weekEnd <= me);
                let weekJuhyuMinutes = 0;
                let weekWorkPay  = null;
                let weekJuhyuPay = 0;

                const hasAnyWage = (wageMain != null || wageSub != null);

                // 주휴 적용 시: 전체 주 15시간 이상 + 일요일이 해당월에 포함될 때만 주휴 발생
                if (includeJuhyu && fullWeekMinutes >= thresholdMinutes && sundayInMonth) {
                    weekJuhyuMinutes = calcWeeklyJuhyuMinutes(fullWeekMinutes);
                }

                if (hasAnyWage && weekMinutes > 0) {
                    let hourlyForWeek;

                    if (!includeJuhyu) {
                        // 주휴 미적용: 전체 주 15시간 기준으로 시급 선택
                        if (fullWeekMinutes >= thresholdMinutes) {
                            hourlyForWeek = (wageMainRaw != null ? wageMainRaw : wageSubRaw);
                        } else {
                            hourlyForWeek = (wageSubRaw != null ? wageSubRaw : wageMainRaw);
                        }
                    } else {
                        // 주휴 적용: 항상 hourlyWage2 기준(없으면 hourlyWage)
                        hourlyForWeek = (wageSubRaw != null ? wageSubRaw : wageMainRaw);
                    }

                    if (hourlyForWeek != null) {
                        weekWorkPay = Math.round((weekMinutes / 60) * hourlyForWeek);
                        if (includeJuhyu && weekJuhyuMinutes > 0) {
                            weekJuhyuPay = Math.round((weekJuhyuMinutes / 60) * hourlyForWeek);
                        }
                    } else {
                        weekWorkPay  = 0;
                        weekJuhyuPay = 0;
                    }
                } else {
                    weekWorkPay  = 0;
                    weekJuhyuPay = 0;
                }

                monthJuhyuMinutes += weekJuhyuMinutes;
                monthWorkPay      += (weekWorkPay  || 0);
                monthJuhyuPay     += (weekJuhyuPay || 0);

                const weekWorkLabel  = formatMins(weekMinutes);
                const clipS = weekStart < ms ? ms : weekStart;
                const clipE = weekEnd > me ? me : weekEnd;
                const weekLabelRange = (toIso(clipS) === toIso(clipE))
                        ? `${pad2(clipS.getMonth()+1)}.${pad2(clipS.getDate())}`
                        : `${pad2(clipS.getMonth()+1)}.${pad2(clipS.getDate())} ~ ${pad2(clipE.getMonth()+1)}.${pad2(clipE.getDate())}`;

                let weekJuhyuCellHtml = '-';
                if (includeJuhyu) {
                    if (weekJuhyuPay > 0) {
                        weekJuhyuCellHtml = `<span class="text-money">${krw(weekJuhyuPay)}</span>`;
                    }
                } else {
                    weekJuhyuCellHtml = `<span class="text-muted">미적용</span>`;
                }

                const weekPayLabel = (weekWorkPay != null) ? krw(weekWorkPay) : '-';
                const weekWorkCellHtml = `<span class="text-time">${weekWorkLabel}</span>`;

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="text-center align-middle fw-bold" style="font-size:.8rem;">${++weekIndex}주차</td>
                    <td class="text-center align-middle small text-muted" style="font-size:.72rem;">${weekLabelRange}</td>
                    ${dayCells.join('')}
                    <td class="text-end align-middle">${weekWorkCellHtml}</td>
                    <td class="text-end align-middle">${weekJuhyuCellHtml}</td>
                    <td class="text-end align-middle">
                        ${weekPayLabel !== '-' ? `<span class="text-money">${weekPayLabel}</span>` : '-'}
                    </td>
                `;
                tbodyEl.appendChild(tr);
            });

            timeEl.textContent = formatMins(monthMinutes);

            let monthTotal = null;
            if (wageMain != null || wageSub != null) {
                monthTotal = monthWorkPay + (includeJuhyu ? monthJuhyuPay : 0);
            }

            workPayEl.textContent = (monthWorkPay > 0) ? krw(monthWorkPay) : '-';

            if (!includeJuhyu) {
                juhyuEl.textContent = '미적용';
            } else {
                juhyuEl.textContent = (monthJuhyuPay > 0) ? krw(monthJuhyuPay) : '-';
            }

            totalEl.textContent   = (monthTotal != null && monthTotal > 0) ? krw(monthTotal) : '-';

            const applyTax  = isTaxApplied(member);
            const taxRate   = 0.033;
            let taxAmount   = null;
            let totalAfterTax = null;

            if (applyTax && monthTotal != null && monthTotal > 0) {
                taxAmount    = Math.round(monthTotal * taxRate);
                totalAfterTax = monthTotal - taxAmount;
            }

            if (isActual) {
                if (summaryTaxApplyActual) {
                    summaryTaxApplyActual.textContent = applyTax ? '적용 (3.3%)' : '미적용';
                }
                if (summaryTaxAmountActual) {
                    summaryTaxAmountActual.textContent = (applyTax && taxAmount != null) ? krw(taxAmount) : '-';
                }
                if (summaryMonthTotalAfterTaxActual) {
                    summaryMonthTotalAfterTaxActual.textContent =
                            (applyTax && totalAfterTax != null) ? krw(totalAfterTax) : '-';
                }

                lastPayrollPayload = (member && (wageMain != null || wageSub != null) && monthTotal != null)
                        ? {
                            memberId:          member.id,
                            payYear:           ms.getFullYear(),
                            payMonth:          ms.getMonth() + 1,
                            hourlyWage:        wageMainRaw,
                            hourlyWage2:       wageSubRaw,
                            monthWorkMinutes:  monthMinutes,
                            monthJuhyuMinutes: includeJuhyu ? monthJuhyuMinutes : 0,
                            monthWorkPay:      monthWorkPay,
                            monthJuhyuPay:     includeJuhyu ? monthJuhyuPay : 0,
                            monthTotalPay:     monthTotal
                        }
                        : null;
            } else {
                if (summaryTaxApplyPlan) {
                    summaryTaxApplyPlan.textContent = applyTax ? '부과 (3.3%)' : '미부과';
                }
                if (summaryTaxAmountPlan) {
                    summaryTaxAmountPlan.textContent = (applyTax && taxAmount != null) ? krw(taxAmount) : '-';
                }
                if (summaryMonthTotalAfterTaxPlan) {
                    summaryMonthTotalAfterTaxPlan.textContent =
                            (applyTax && totalAfterTax != null) ? krw(totalAfterTax) : '-';
                }
            }
        }

        async function savePayrollWithStatus(status, successMessage, paidDate) {
            if (!currentMember) {
                showToast('먼저 근무자를 선택해주세요.', 'danger');
                return;
            }
            if (!lastPayrollPayload) {
                showToast('급여 데이터가 없습니다. 먼저 월 데이터를 불러와주세요.', 'warning');
                return;
            }

            const payload = { ...lastPayrollPayload, status };
            if (status === 'PAID' && paidDate) payload.paidDate = paidDate;

            try {
                const resp = await fetch(PAYROLL_SAVE_API, {
                    method: 'POST',
                    headers: { 'Accept':'application/json', 'Content-Type':'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!resp.ok) {
                    const text = await resp.text().catch(() => '');
                    console.error('payroll save error', resp.status, text);
                    showToast('저장 중 오류가 발생했습니다.', 'danger');
                    return;
                }
                await loadPayrollStatus(currentMember, currentMonthStart);
                showToast(successMessage || '처리되었습니다.', 'success');
            } catch (e) {
                console.error('payroll save fetch error', e);
                showToast('통신 오류가 발생했습니다.', 'danger');
            }
        }

        function onMarkPaidClick() {
            if (!currentMember) {
                showToast('먼저 근무자를 선택해주세요.', 'danger');
                return;
            }
            if (!lastPayrollPayload) {
                showToast('급여 데이터가 없습니다. 먼저 월 데이터를 불러와주세요.', 'warning');
                return;
            }

            if (!paidDateModalEl || !paidDateInput || !window.bootstrap || !bootstrap.Modal) {
                savePayrollWithStatus('PAID', '지급완료로 처리되었습니다.');
                return;
            }
            const today = new Date();
            paidDateInput.value = toIso(today);
            paidDateInput.classList.remove('is-invalid');
            bootstrap.Modal.getOrCreateInstance(paidDateModalEl).show();
        }

        function updatePayrollStatusUI(status) {
            if (!payrollStatusBadge) return;

            const upper    = status ? String(status).toUpperCase() : null;
            const labelMap = { DRAFT:'임시저장', CONFIRMED:'확정', PAID:'지급완료' };
            const classMap = { DRAFT:'bg-secondary', CONFIRMED:'bg-info', PAID:'bg-success' };

            if (!upper) {
                payrollStatusBadge.className   = 'badge ms-2 bg-light text-muted';
                payrollStatusBadge.textContent = '미저장';
                payrollStatusBadge.classList.remove('d-none');
            } else {
                payrollStatusBadge.className   = `badge ms-2 ${classMap[upper] || 'bg-secondary'}`;
                payrollStatusBadge.textContent = labelMap[upper] || upper;
                payrollStatusBadge.classList.remove('d-none');
            }

            btnSaveDraft.disabled = false;
            btnConfirm.disabled   = false;
            btnMarkPaid.disabled  = false;

            if (!upper) {
                btnConfirm.disabled  = true;
                btnMarkPaid.disabled = true;
            } else if (upper === 'DRAFT') {
                btnMarkPaid.disabled = true;
            } else if (upper === 'CONFIRMED') {
                btnSaveDraft.disabled = true;
                btnConfirm.disabled   = true;
            } else if (upper === 'PAID') {
                btnSaveDraft.disabled = true;
                btnConfirm.disabled   = true;
                btnMarkPaid.disabled  = true;
            }

            [btnSaveDraft, btnConfirm, btnMarkPaid].forEach(btn => btn.classList.remove('pay-action-next'));
            if (!upper)              btnSaveDraft.classList.add('pay-action-next');
            else if (upper === 'DRAFT')     btnConfirm.classList.add('pay-action-next');
            else if (upper === 'CONFIRMED') btnMarkPaid.classList.add('pay-action-next');

            if (paidDateLabelEl && paidDateValueEl) {
                if (upper === 'PAID' && currentPaidDate) {
                    paidDateValueEl.textContent = String(currentPaidDate).substring(0,10);
                    paidDateLabelEl.classList.remove('d-none');
                } else {
                    paidDateValueEl.textContent = '';
                    paidDateLabelEl.classList.add('d-none');
                }
            }
        }

