        function openAllDetailPopup(){
            const ms = firstDayOfMonth(currentMonthStart), me = lastDayOfMonth(currentMonthStart);
            const vl = currentViewType==='actual'?'근무시간':'일정(예상)';
            allPopupTitleEl.textContent = `주차별 급여 상세 (${vl})`;
            allPopupSubtitleEl.textContent = `${ms.getFullYear()}.${pad2(ms.getMonth()+1)}.${pad2(ms.getDate())} ~ ${pad2(me.getMonth()+1)}.${pad2(me.getDate())} · ${statusLabelText(statusSelect.value)}`;
