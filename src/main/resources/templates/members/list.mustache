        async function selectMember(member){
            currentMember   = member;
            selectedMemberId= member.id;
            updateMemberListActive();
            await renderAll(member);
        }

        function updateMemberListActive(){
            Array.from(memberList.querySelectorAll('.member-card')).forEach(c=>{
                c.classList.toggle('active', c.dataset.memberId===String(selectedMemberId));
            });
        }

        // ===== 멤버 선택 시 전체 렌더 =====
        async function renderAll(member){
            if(!member) return;

            if (selectedMemberStatus) {
                selectedMemberStatus.classList.remove('d-none');
                selectedMemberStatus.textContent = statusLabel(member?.status);
                selectedMemberStatus.className   = `status-chip ${statusClass(member?.status)}`;
            }

            const { weekStartIso, weekEndIso, weekDates } = parseWeekRangeToDates(weekRangeLabelEl?.textContent || '');
            currentWeekDates = weekDates;
            renderWeekHeadDates(weekDates);

            lastPlanMap = {};

            try{
                const urlPlan = `${API_BASE_PLAN}/${encodeURIComponent(member.id)}/schedule`;
                const respPlan = await fetch(urlPlan, { headers:{'Accept':'application/json'} });
                if(respPlan.ok){
                    const data = await respPlan.json();
                    lastPlanMap = normalizeWeeklyTemplate(data, currentWeekDates);
                }
            }catch(e){
                console.error('plan fetch error', e);
            }

            rebuildWeekGridAndPaint();

            if (selectedMemberTitle) selectedMemberTitle.textContent = `${member.name ?? '-'} — 주간 템플릿`;
            updateSaveButtonByStep();
        }

        function rebuildWeekGridAndPaint(){
            buildWeekGrid();
            paintPlanFromMap(lastPlanMap, currentWeekDates);
            attachCellDragHandlers();
        }

        // ===== 슬롯 단위 버튼 처리 =====
        function attachGridSlotHandlers(){
            if(!gridSlotButtonsWrapper) return;
            gridSlotButtonsWrapper.querySelectorAll('button[data-grid-slot]').forEach(btn=>{
                btn.addEventListener('click', ()=>{
                    const mins = parseInt(btn.dataset.gridSlot, 10);
                    if(!mins || mins === gridStepMinutes) return;

                    gridStepMinutes = mins;

                    gridSlotButtonsWrapper.querySelectorAll('button[data-grid-slot]').forEach(b=>b.classList.remove('active'));
                    btn.classList.add('active');

                    rebuildWeekGridAndPaint();
                    updateSaveButtonByStep();
                });
            });
        }

        function updateSaveButtonByStep(){
            if(!btnSaveTemplate) return;
            const enable = (gridStepMinutes === 10 && !!currentMember && currentWeekDates.length);
            btnSaveTemplate.disabled = !enable;
            btnSaveTemplate.title = enable ? '' : '템플릿 저장은 10분 단위에서만 가능합니다.';
        }

        // ===== 주간 템플릿 그리드 =====
        function buildWeekGrid(){
            if (!tbodyWeek) return;
            tbodyWeek.innerHTML = '';
            const totalMinutes = (HOUR_END - HOUR_START) * 60;
            const totalRows    = totalMinutes / gridStepMinutes;

            for(let idx=0; idx<totalRows; idx++){
                const absMin = HOUR_START*60 + idx*gridStepMinutes;
                const h = Math.floor(absMin/60), m = absMin%60;
                const hm = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;

                const tr = document.createElement('tr');
                if(m===0) tr.classList.add('hour-start');
                tr.innerHTML = `
                    <th class="time-col" scope="row">${hm}</th>
                    <td data-col="1"><div class="cell-10m"></div></td>
                    <td data-col="2"><div class="cell-10m"></div></td>
                    <td data-col="3"><div class="cell-10m"></div></td>
                    <td data-col="4"><div class="cell-10m"></div></td>
                    <td data-col="5"><div class="cell-10m"></div></td>
                    <td data-col="6"><div class="cell-10m"></div></td>
                    <td data-col="7"><div class="cell-10m"></div></td>
                `;
                tbodyWeek.appendChild(tr);
            }
        }

        function renderWeekHeadDates(weekDates){
            if (!theadWeek) return;
            const ths = theadWeek.querySelectorAll('th');
            for(let i=0; i<7; i++){
                const th = ths[i+1];
                if(!th) continue;
                const d = new Date(weekDates[i]);
                th.innerHTML = `${DOW_LABELS[i]}<br><small class="text-muted">(${d.getMonth()+1}/${d.getDate()})</small>`;
            }
        }

        function rowToInterval(rIdx){
            const startMin = HOUR_START*60 + rIdx*gridStepMinutes;
            const endMin   = startMin + gridStepMinutes;
            return { startMin, endMin };
        }

        function paintPlanFromMap(planMap, weekDates){
            if(!tbodyWeek) return;

            tbodyWeek.querySelectorAll('.cell-10m').forEach(c=>{
                c.classList.remove('schedule-on');
            });

            if(!weekDates || !weekDates.length) return;
            const rows = Array.from(tbodyWeek.querySelectorAll('tr'));

            for(let dayIdx=0; dayIdx<7; dayIdx++){
                const iso   = weekDates[dayIdx];
                const entry = planMap[iso];
                const segs  = entry?.segments || [];
                if(!segs.length) continue;

                rows.forEach((tr, rIdx)=>{
                    const cellDiv = tr.querySelector(`td[data-col="${dayIdx+1}"] .cell-10m`);
                    if(!cellDiv) return;
                    const { startMin, endMin } = rowToInterval(rIdx);

                    const overlaps = segs.some(seg=>{
                        const ss = hmToMin(seg.start);
                        const ee = hmToMin(seg.end);
                        return !(ee <= startMin || ss >= endMin);
                    });
                    if(overlaps){
                        cellDiv.classList.add('schedule-on');
                    }
                });
            }
        }

        // ===== 드래그/클릭으로 템플릿 선택/해제 =====
        let cellDragHandlersBound = false;

        function attachCellDragHandlers(){
            if (!tbodyWeek || cellDragHandlersBound) return;
            cellDragHandlersBound = true;

            tbodyWeek.addEventListener('mousedown', (e)=>{
                const cell = e.target.closest('.cell-10m');
                if (!cell || !tbodyWeek.contains(cell)) return;

                e.preventDefault();
                gridDragging = true;

                const nowOn  = cell.classList.contains('schedule-on');
                const nextOn = !nowOn;
                gridDragAdding = nextOn;

                togglePlanCell(cell, nextOn);
            });

            tbodyWeek.addEventListener('mouseover', (e)=>{
                if (!gridDragging) return;

                const cell = e.target.closest('.cell-10m');
                if (!cell || !tbodyWeek.contains(cell)) return;

                togglePlanCell(cell, gridDragAdding);
            });

            window.addEventListener('mouseup', ()=>{
                if (gridDragging){
                    gridDragging = false;
                }
            }, { passive:true });
        }

        function togglePlanCell(cell, on){
            if(on){
                cell.classList.add('schedule-on');
            }else{
                cell.classList.remove('schedule-on');
            }
        }

        // ===== 템플릿 저장 =====
        async function onClickSaveTemplate(){
            if(gridStepMinutes !== 10){
                alert('템플릿 저장은 10분 단위에서만 가능합니다. 슬롯 단위를 10분으로 변경해 주세요.');
                return;
            }
            if(!currentMember || !currentWeekDates.length){
                alert('저장할 아르바이트와 주간 범위가 없습니다.');
                return;
            }

            const byDate = collectPlanSegmentsFromGrid();

            const summaryLines = currentWeekDates.map((iso, idx)=>{
                const label = `${DOW_LABELS[idx]} (${iso})`;
                const segs  = byDate[iso] || [];
                if(!segs.length) return `${label}: 휴무`;
                return `${label}: ${segs.map(s=>`${s.start}~${s.end}`).join(', ')}`;
            });

            const ok = confirm(
                    `다음과 같이 주간 템플릿(계획)을 저장합니다:\n\n`+
                    summaryLines.join('\n')+
                    `\n\n이대로 저장하시겠습니까?`
            );
            if(!ok) return;

            try{
                for(let idx = 0; idx < currentWeekDates.length; idx++){
                    const iso      = currentWeekDates[idx];
                    const dayCode  = DAY_CODES[idx];
                    const segments = byDate[iso] || [];

                    const payload = {
                        memberId: currentMember.id,
                        day: dayCode,
                        segments: segments
                    };

                    const url = `${API_BASE_PLAN}/${encodeURIComponent(currentMember.id)}/update`;

                    const resp = await fetch(url, {
                        method:'POST',
                        headers:{ 'Content-Type':'application/json', 'Accept':'application/json' },
                        body: JSON.stringify(payload)
                    });
                    if(!resp.ok){
                        const txt = await resp.text().catch(()=> '');
                        alert(`저장 실패 (${iso}): ${resp.status} ${txt}`);
                        return;
                    }
                }

                alert('주간 템플릿(계획)이 저장되었습니다.');
                await renderAll(currentMember);
            }catch(e){
                console.error('템플릿 저장 중 예외:', e);
                alert('템플릿 저장 중 오류가 발생했습니다.\n' + (e.message || e));
            }
        }

        function collectPlanSegmentsFromGrid(){
            const result = {};
            if(!currentWeekDates.length || !tbodyWeek) return result;

            const rows = Array.from(tbodyWeek.querySelectorAll('tr'));
            for(let dayIdx=0; dayIdx<7; dayIdx++){
                const indices = [];
                rows.forEach((tr, rIdx)=>{
                    const cellDiv = tr.querySelector(`td[data-col="${dayIdx+1}"] .cell-10m`);
                    if(cellDiv && cellDiv.classList.contains('schedule-on')){
                        indices.push(rIdx);
                    }
                });
                if(!indices.length) continue;

                const merged = mergeConsecutive(indices);
                const iso    = currentWeekDates[dayIdx];
                result[iso] = merged.map(([sIdx, eIdx])=>{
                    const startMin = HOUR_START*60 + sIdx*gridStepMinutes;
                    const endMin   = HOUR_START*60 + (eIdx+1)*gridStepMinutes;
                    return { start: minToHm(startMin), end: minToHm(endMin) };
                });
            }
            return result;
        }

        function mergeConsecutive(arr){
            if(!arr.length) return [];
            const sorted = arr.slice().sort((a,b)=>a-b);
            const out = [];
            let s = sorted[0], prev = sorted[0];
            for(let i=1;i<sorted.length;i++){
                const v = sorted[i];
                if(v === prev+1){
                    prev = v;
                    continue;
                }
                out.push([s, prev]);
                s = prev = v;
            }
            out.push([s, prev]);
            return out;
        }

        // ===== 템플릿 간트 팝업 =====
        const tplOverlay     = document.getElementById('templatePopupOverlay');
        const tplGanttWrap   = document.getElementById('tplGanttWrap');
        const tplSaveBtn     = document.getElementById('tplSaveBtn');
        const tplCancelBtn   = document.getElementById('tplCancelBtn');
        const tplDeleteBtn   = document.getElementById('tplDeleteBarBtn');
        const tplCloseBtn    = document.getElementById('tplPopupCloseBtn');
        const tplPopupTitle  = document.getElementById('tplPopupTitle');

        let tplOrigData   = {};   // { MON: [{start,end}], ... }
        let tplPending    = {};   // 변경사항
        let tplMemberId   = null;
        let tplSelectedBar = null;

        const TPL_HOUR_START = 6, TPL_HOUR_END = 24;
        const TPL_SNAP_MIN = 10;

        if (tplCloseBtn)  tplCloseBtn.addEventListener('click', closeTplPopup);
        if (tplCancelBtn) tplCancelBtn.addEventListener('click', ()=>{
            tplPending = {};
            tplSelectedBar = null;
            buildTplGantt();
        });
        if (tplSaveBtn) tplSaveBtn.addEventListener('click', saveTplPopup);
        if (tplDeleteBtn) tplDeleteBtn.addEventListener('click', deleteTplSelectedBar);
        if (tplOverlay) tplOverlay.addEventListener('click', (e)=>{
            if (e.target === tplOverlay) closeTplPopup();
        });

        async function openTemplatePopup(memberId) {
            tplMemberId = memberId;
            const m = (allMembers||[]).find(x=>String(x.id)===String(memberId));
            tplPopupTitle.textContent = `${m?.name ?? ''} - 주간 근무 템플릿`;
            tplOverlay.style.display = 'flex';
            tplGanttWrap.innerHTML = '<div class="text-center text-muted py-4">로딩 중...</div>';
            tplOrigData = {};
            tplPending = {};
            tplSelectedBar = null;

            try {
                const resp = await fetch(`/api/member/${encodeURIComponent(memberId)}/schedule`, {headers:{'Accept':'application/json'}});
                if (resp.ok) {
                    const rows = await resp.json();
                    const dayMap = {};
                    (rows||[]).forEach(r => {
                        const d = String(r.day||'').toUpperCase();
                        if (!d) return;
                        if (!dayMap[d]) dayMap[d] = [];
                        dayMap[d].push({start:(r.start||'').slice(0,5), end:(r.end||'').slice(0,5)});
                    });
                    tplOrigData = dayMap;
                }
            } catch(e) { console.error(e); }

            buildTplGantt();
        }

        function closeTplPopup() {
            tplOverlay.style.display = 'none';
        }

        function getTplDaySegs(dayCode) {
            return tplPending[dayCode] || tplOrigData[dayCode] || [];
        }

        function buildTplGantt() {
            tplGanttWrap.innerHTML = '';
            const totalMin = (TPL_HOUR_END - TPL_HOUR_START) * 60;

            // 시간 레이블 행
            const headerRow = document.createElement('div');
            headerRow.className = 'tpl-gantt-row';
            headerRow.innerHTML = '<div class="tpl-gantt-day-label"></div>';
            const headerTrack = document.createElement('div');
            headerTrack.className = 'tpl-gantt-track';
            headerTrack.style.height = '16px';
            headerTrack.style.background = 'transparent';
            headerTrack.style.cursor = 'default';
            for (let h = TPL_HOUR_START; h <= TPL_HOUR_END; h++) {
                const pct = ((h - TPL_HOUR_START) * 60 / totalMin) * 100;
                const lbl = document.createElement('span');
                lbl.className = 'tpl-gantt-hour-label';
                lbl.style.left = pct + '%';
                lbl.style.top = '0';
                lbl.textContent = h;
                headerTrack.appendChild(lbl);
            }
            headerRow.appendChild(headerTrack);
            headerRow.innerHTML += '<div class="tpl-gantt-total" style="font-size:0.7rem;color:#9ca3af">합계</div>';
            tplGanttWrap.appendChild(headerRow);

            DAY_CODES.forEach((code, idx) => {
                const segs = getTplDaySegs(code);
                const dayMin = segs.reduce((acc,s)=> acc + (hmToMin(s.end) - hmToMin(s.start)), 0);

                const row = document.createElement('div');
                row.className = 'tpl-gantt-row';

                const dayLabel = document.createElement('div');
                dayLabel.className = 'tpl-gantt-day-label';
                dayLabel.textContent = DOW_LABELS[idx];
                row.appendChild(dayLabel);

                const track = document.createElement('div');
                track.className = 'tpl-gantt-track';
                track.dataset.day = code;

                // 시간 눈금선
                for (let h = TPL_HOUR_START; h <= TPL_HOUR_END; h++) {
                    const pct = ((h - TPL_HOUR_START) * 60 / totalMin) * 100;
                    const line = document.createElement('div');
                    line.className = 'tpl-gantt-hour-line';
                    line.style.left = pct + '%';
                    track.appendChild(line);
                }

                // 바 렌더링
                segs.forEach((seg, sIdx) => {
                    const sMin = hmToMin(seg.start) - TPL_HOUR_START * 60;
                    const eMin = hmToMin(seg.end) - TPL_HOUR_START * 60;
                    const leftPct = (sMin / totalMin) * 100;
                    const widthPct = ((eMin - sMin) / totalMin) * 100;

                    const bar = document.createElement('div');
                    bar.className = 'tpl-gantt-bar';
                    bar.style.left = leftPct + '%';
                    bar.style.width = widthPct + '%';
                    bar.dataset.day = code;
                    bar.dataset.idx = sIdx;
                    bar.innerHTML = `
                        <div class="bar-label">${seg.start}~${seg.end}</div>
                        <div class="resize-handle left"></div>
                        <div class="resize-handle right"></div>
                    `;
                    track.appendChild(bar);
                });

                // 빈 공간 클릭 → 1시간 바 생성
                track.addEventListener('mousedown', (e) => {
                    if (e.target.closest('.tpl-gantt-bar')) return;
                    const rect = track.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const pct = x / rect.width;
                    let startMin = TPL_HOUR_START * 60 + Math.round(pct * totalMin / TPL_SNAP_MIN) * TPL_SNAP_MIN;
                    let endMin = startMin + 60;
                    if (endMin > TPL_HOUR_END * 60) endMin = TPL_HOUR_END * 60;
                    if (startMin >= endMin) return;

                    ensureTplPending(code);
                    tplPending[code].push({start: minToHm(startMin), end: minToHm(endMin)});
                    tplPending[code] = mergeTplOverlapping(tplPending[code]);
                    buildTplGantt();
                });

                row.appendChild(track);

                const total = document.createElement('div');
                total.className = 'tpl-gantt-total';
                total.textContent = formatMins(dayMin);
                row.appendChild(total);

                tplGanttWrap.appendChild(row);
            });

            initTplGanttDrag();
            updateTplDeleteBtn();
        }

        function ensureTplPending(dayCode) {
            if (!tplPending[dayCode]) {
                tplPending[dayCode] = JSON.parse(JSON.stringify(tplOrigData[dayCode] || []));
            }
        }

        function mergeTplOverlapping(segs) {
            if (!segs.length) return [];
            const sorted = segs.slice().sort((a,b) => hmToMin(a.start) - hmToMin(b.start));
            const merged = [sorted[0]];
            for (let i = 1; i < sorted.length; i++) {
                const last = merged[merged.length - 1];
                if (hmToMin(sorted[i].start) <= hmToMin(last.end)) {
                    last.end = hmToMin(sorted[i].end) > hmToMin(last.end) ? sorted[i].end : last.end;
                } else {
                    merged.push(sorted[i]);
                }
            }
            return merged;
        }

        function initTplGanttDrag() {
            const totalMin = (TPL_HOUR_END - TPL_HOUR_START) * 60;
            const bars = tplGanttWrap.querySelectorAll('.tpl-gantt-bar');

            bars.forEach(bar => {
                let dragType = null; // 'move' | 'resize-left' | 'resize-right'
                let startX = 0, origLeft = 0, origWidth = 0;
                let hasMoved = false;
                const dayCode = bar.dataset.day;
                const barIdx = parseInt(bar.dataset.idx, 10);

                // 바 클릭 → 선택/해제
                bar.addEventListener('click', (e) => {
                    e.stopPropagation();
                    if (hasMoved) return; // 드래그 후에는 선택 무시
                    if (tplSelectedBar === `${dayCode}-${barIdx}`) {
                        tplSelectedBar = null;
                    } else {
                        tplSelectedBar = `${dayCode}-${barIdx}`;
                    }
                    tplGanttWrap.querySelectorAll('.tpl-gantt-bar').forEach(b => b.classList.remove('selected'));
                    if (tplSelectedBar) bar.classList.add('selected');
                    updateTplDeleteBtn();
                });

                bar.addEventListener('mousedown', (e) => {
                    e.stopPropagation();
                    e.preventDefault();
                    hasMoved = false;
                    const handle = e.target.closest('.resize-handle');
                    if (handle) {
                        dragType = handle.classList.contains('left') ? 'resize-left' : 'resize-right';
                    } else {
                        dragType = 'move';
                    }

                    const track = bar.closest('.tpl-gantt-track');
                    const trackW = track.getBoundingClientRect().width;
                    startX = e.clientX;
                    origLeft = parseFloat(bar.style.left);
                    origWidth = parseFloat(bar.style.width);

                    const onMove = (ev) => {
                        hasMoved = true;
                        const dx = ev.clientX - startX;
                        const dPct = (dx / trackW) * 100;
                        const snapPct = (TPL_SNAP_MIN / totalMin) * 100;

                        if (dragType === 'move') {
                            let newLeft = origLeft + dPct;
                            newLeft = Math.round(newLeft / snapPct) * snapPct;
                            newLeft = Math.max(0, Math.min(100 - origWidth, newLeft));
                            bar.style.left = newLeft + '%';
                        } else if (dragType === 'resize-left') {
                            let newLeft = origLeft + dPct;
                            newLeft = Math.round(newLeft / snapPct) * snapPct;
                            newLeft = Math.max(0, newLeft);
                            const newWidth = origWidth + (origLeft - newLeft);
                            if (newWidth >= snapPct) {
                                bar.style.left = newLeft + '%';
                                bar.style.width = newWidth + '%';
                            }
                        } else if (dragType === 'resize-right') {
                            let newWidth = origWidth + dPct;
                            newWidth = Math.round(newWidth / snapPct) * snapPct;
                            newWidth = Math.max(snapPct, newWidth);
                            if (origLeft + newWidth <= 100.1) {
                                bar.style.width = newWidth + '%';
                            }
                        }

                        // 레이블 업데이트
                        const lPct = parseFloat(bar.style.left);
                        const wPct = parseFloat(bar.style.width);
                        const sM = TPL_HOUR_START * 60 + Math.round(lPct / 100 * totalMin);
                        const eM = TPL_HOUR_START * 60 + Math.round((lPct + wPct) / 100 * totalMin);
                        const lbl = bar.querySelector('.bar-label');
                        if (lbl) lbl.textContent = `${minToHm(sM)}~${minToHm(eM)}`;
                    };

                    const onUp = () => {
                        window.removeEventListener('mousemove', onMove);
                        window.removeEventListener('mouseup', onUp);

                        // 실제 드래그가 있었을 때만 pending 반영 + rebuild
                        if (!hasMoved) return;

                        const lPct = parseFloat(bar.style.left);
                        const wPct = parseFloat(bar.style.width);
                        const sM = TPL_HOUR_START * 60 + Math.round(lPct / 100 * totalMin);
                        const eM = TPL_HOUR_START * 60 + Math.round((lPct + wPct) / 100 * totalMin);

                        ensureTplPending(dayCode);
                        tplPending[dayCode][barIdx] = {start: minToHm(sM), end: minToHm(eM)};
                        tplPending[dayCode] = mergeTplOverlapping(tplPending[dayCode]);
                        buildTplGantt();
                    };

                    window.addEventListener('mousemove', onMove);
                    window.addEventListener('mouseup', onUp);
                });
            });
        }

        function updateTplDeleteBtn() {
            if (tplDeleteBtn) tplDeleteBtn.disabled = !tplSelectedBar;
        }

        function deleteTplSelectedBar() {
            if (!tplSelectedBar) return;
            const [dayCode, idxStr] = tplSelectedBar.split('-');
            const idx = parseInt(idxStr, 10);
            ensureTplPending(dayCode);
            tplPending[dayCode].splice(idx, 1);
            tplSelectedBar = null;
            buildTplGantt();
        }

        async function saveTplPopup() {
            if (!tplMemberId) return;
