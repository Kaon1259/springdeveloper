                        alert(`저장 실패 (${dayCode}): ${resp.status}`);
                        return;
                    }
                }
                alert('템플릿이 저장되었습니다.');
                const newOrigData = {};
                DAY_CODES.forEach(c => {
                    newOrigData[c] = tplPending[c] || tplOrigData[c] || [];
                });
                tplOrigData = newOrigData;
                tplPending = {};
                buildTplGantt();

                // 하단 패널도 갱신
