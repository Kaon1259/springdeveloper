        }

        // ===== 일정보기 팝업 =====
        const schedViewOverlay  = document.getElementById('scheduleViewOverlay');
        const schedViewBody     = document.getElementById('schedViewBody');
        const schedViewTitle    = document.getElementById('schedViewTitle');
        const schedViewSub      = document.getElementById('schedViewSub');
        const schedViewClose    = document.getElementById('schedViewCloseBtn');
        const svWeekRangeLabel  = document.getElementById('svWeekRangeLabel');
        const svBtnPrevWeek     = document.getElementById('svBtnPrevWeek');
        const svBtnThisWeek     = document.getElementById('svBtnThisWeek');
        const svBtnNextWeek     = document.getElementById('svBtnNextWeek');

        let svMemberId = null;
        let svBaseMonday = null;
        let svPendingChanges = {};   // key: dateIso, value: { memberId, iso, segments }
        let svOrigSchedMap = {};     // 원본 스냅샷 (취소 용)
        let svOrigActualMap = {};
        let svDragState = null;
        let svSelectedBar = null;    // { iso, segIdx, start, end }
        let svJustDragged = false;

        const svSaveBar  = document.getElementById('svSaveBar');
        const svSaveInfo = document.getElementById('svSaveInfo');
        const svBtnSave  = document.getElementById('svBtnSave');
        const svBtnCancel= document.getElementById('svBtnCancel');
        const svBtnDelete= document.getElementById('svBtnDelete');
        const svDragTooltip = document.getElementById('svDragTooltip');

        const SV_HOUR_START = 6, SV_HOUR_END = 24;
        const SV_TOTAL_MIN = (SV_HOUR_END - SV_HOUR_START) * 60;

        function svMergeOverlapping(segments) {
            if (!segments || segments.length <= 1) return segments;
            const sorted = [...segments].sort((a, b) => hmToMin(a.start) - hmToMin(b.start));
            const merged = [{ ...sorted[0] }];
            for (let i = 1; i < sorted.length; i++) {
                const last = merged[merged.length - 1];
                const curr = sorted[i];
                if (hmToMin(curr.start) <= hmToMin(last.end)) {
                    if (hmToMin(curr.end) > hmToMin(last.end)) last.end = curr.end;
                } else {
                    merged.push({ ...curr });
                }
            }
            return merged;
        }
        function svPxToMin(px, trackWidth) {
            return Math.round(px / trackWidth * SV_TOTAL_MIN / 10) * 10;
        }
        function svClampMin(m) {
            return Math.max(0, Math.min(m, SV_TOTAL_MIN));
        }
        function svGetSegments(iso) {
            if (svPendingChanges[iso]) return svPendingChanges[iso].segments.map(s => ({ ...s }));
            const d = svOrigSchedMap[iso];
            return d ? d.segments.map(s => ({ ...s })) : [];
        }
        function svUpdateSaveBar() {
            const cnt = Object.keys(svPendingChanges).length;
            if (cnt > 0) {
                svSaveBar.classList.add('visible');
                svSaveInfo.textContent = `${cnt}건의 일정이 변경되었습니다`;
            } else {
                svSaveBar.classList.remove('visible');
            }
        }
        function svClearSelection() {
            svSelectedBar = null;
            if (svBtnDelete) svBtnDelete.classList.add('d-none');
            schedViewBody.querySelectorAll('.sv-gantt-bar.sv-selected').forEach(b => b.classList.remove('sv-selected'));
        }

        function svClosePopup() {
            if (Object.keys(svPendingChanges).length > 0) {
                if (!confirm('저장하지 않은 변경사항이 있습니다. 닫으시겠습니까?')) return;
            }
            svPendingChanges = {};
            svSaveBar.classList.remove('visible');
            svClearSelection();
            schedViewOverlay.style.display = 'none';
        }
        if (schedViewClose) schedViewClose.addEventListener('click', svClosePopup);
        if (schedViewOverlay) schedViewOverlay.addEventListener('click', (e) => {
            if (e.target === schedViewOverlay) svClosePopup();
        });

        // 주간 네비게이션
        if (svBtnPrevWeek) svBtnPrevWeek.addEventListener('click', () => { svNavigateWeek(-7); });
        if (svBtnThisWeek) svBtnThisWeek.addEventListener('click', () => { svBaseMonday = toMonday(new Date()); svLoadWeek(); });
        if (svBtnNextWeek) svBtnNextWeek.addEventListener('click', () => { svNavigateWeek(7); });

        function svNavigateWeek(offset) {
            if (!svBaseMonday) return;
            svBaseMonday = addDays(svBaseMonday, offset);
            svLoadWeek();
        }

        async function openScheduleViewPopup(memberId) {
            svMemberId = memberId;
            const m = (allMembers || []).find(x => String(x.id) === String(memberId));
            if (!m) return;

            schedViewTitle.textContent = `${m.name ?? ''} — 주간 타임테이블 (월~일)`;
            schedViewSub.textContent = '근무자의 주간 일정을 시간대별로 표시 · 바를 드래그하여 일정 수정';
            schedViewOverlay.style.display = 'flex';

            // 현재 조회 중인 주를 기준으로
            const { weekDates } = parseWeekRangeToDates(weekRangeLabelEl?.textContent || '');
            svBaseMonday = weekDates.length ? new Date(weekDates[0]) : toMonday(new Date());

            await svLoadWeek();
        }

        /* normalizeDays: API 응답을 날짜 키 맵으로 정규화 */
        function svNormalizeDays(apiData) {
            const map = {};
            if (!apiData) return map;
            if (Array.isArray(apiData.days)) {
                apiData.days.forEach(d => {
                    const date = String(d.date);
                    const segments = Array.isArray(d.segments) ? d.segments : [];
                    const minutes = (typeof d.minutes === 'number') ? d.minutes
                        : segments.reduce((acc, s) => acc + (hmToMin(s.end) - hmToMin(s.start)), 0);
                    map[date] = { segments, minutes };
                });
                return map;
            }
            if (Array.isArray(apiData)) {
                apiData.forEach(d => {
                    const date = String(d.date);
                    const segments = Array.isArray(d.segments) ? d.segments : [];
                    const minutes = (typeof d.minutes === 'number') ? d.minutes
                        : segments.reduce((acc, s) => acc + (hmToMin(s.end) - hmToMin(s.start)), 0);
                    map[date] = { segments, minutes };
                });
                return map;
            }
            if (typeof apiData === 'object') {
                Object.keys(apiData).forEach(date => {
                    const v = apiData[date] || {};
                    const segments = Array.isArray(v.segments) ? v.segments : [];
                    const minutes = (typeof v.minutes === 'number') ? v.minutes
                        : segments.reduce((acc, s) => acc + (hmToMin(s.end) - hmToMin(s.start)), 0);
                    map[String(date)] = { segments, minutes };
                });
                return map;
            }
            return map;
        }

        async function svLoadWeek() {
            if (!svMemberId || !svBaseMonday) return;
            const m = (allMembers || []).find(x => String(x.id) === String(svMemberId));
            if (!m) return;

            // 주 변경 시 pending 리셋
            svPendingChanges = {};
            svClearSelection();
            svUpdateSaveBar();

            const weekDates = Array.from({ length: 7 }, (_, i) => toIso(addDays(svBaseMonday, i)));
            const startIso = weekDates[0], endIso = weekDates[6];
            const startStr = startIso.slice(5).replace('-', '.');
            const endStr = endIso.slice(5).replace('-', '.');
            svWeekRangeLabel.textContent = `${startIso.slice(0,4)}.${startStr} ~ ${endStr}`;

            schedViewBody.innerHTML = '<div class="text-center text-muted py-4">로딩 중...</div>';

            // 일정 데이터 (WorkSchedule - 날짜별)
            let schedMap = {};
            try {
                const resp = await fetch(`/api/schedule/work/${encodeURIComponent(svMemberId)}/${startIso}/${endIso}`, { headers: { 'Accept': 'application/json' } });
                if (resp.ok) {
                    const data = await resp.json();
                    schedMap = svNormalizeDays(data);
                }
            } catch (e) { console.error('[svLoadWeek] schedule fetch error:', e); }

            // 실제근무 데이터 (ActualWorkSchedule - 날짜별)
            let actualMap = {};
            try {
                const resp2 = await fetch(`/api/schedule/${encodeURIComponent(svMemberId)}/${startIso}/${endIso}`, { headers: { 'Accept': 'application/json' } });
                if (resp2.ok) {
                    const data2 = await resp2.json();
                    actualMap = svNormalizeDays(data2);
                }
            } catch (e) { /* 실제근무 API 없을 수 있음 */ }

            svOrigSchedMap = schedMap;
            svOrigActualMap = actualMap;
            const color = colorForMember(m);
            renderScheduleViewGantt(m, schedMap, actualMap, weekDates, color);
        }

        /* 현재 주간 데이터를 참조해 재렌더 */
        function svRerender() {
            const m = (allMembers || []).find(x => String(x.id) === String(svMemberId));
            if (!m) return;
            const weekDates = Array.from({ length: 7 }, (_, i) => toIso(addDays(svBaseMonday, i)));
            renderScheduleViewGantt(m, svOrigSchedMap, svOrigActualMap, weekDates, colorForMember(m));
        }

        function renderScheduleViewGantt(member, schedMap, actualMap, weekDates, color) {
            const todayIso = toIso(new Date());
            let html = '';

            // 요약 (pending 반영)
            let weekTotalMin = 0, workDays = 0;
            weekDates.forEach(dateIso => {
                const segs = svGetSegments(dateIso);
                if (segs.length) workDays++;
                segs.forEach(s => { weekTotalMin += hmToMin(s.end) - hmToMin(s.start); });
            });

            html += '<div class="sv-summary-row mb-3">';
            html += `<div class="sv-summary-item"><span class="sv-lbl">근무자</span><span class="sv-val">${escapeHtml(member.name)}</span></div>`;
            html += `<div class="sv-summary-item"><span class="sv-lbl">주간 총 일정</span><span class="sv-val">${formatMins(weekTotalMin)}</span></div>`;
            html += `<div class="sv-summary-item"><span class="sv-lbl">근무일</span><span class="sv-val">${workDays}일</span></div>`;
            if (typeof member.hourlyWage === 'number' && member.hourlyWage > 0) {
                const est = Math.round(weekTotalMin / 60 * member.hourlyWage);
                html += `<div class="sv-summary-item"><span class="sv-lbl">주간 예상급여</span><span class="sv-val">${krw(est)}</span></div>`;
            }
            html += '</div>';

            // 간트 차트
            html += '<div class="sv-gantt-outer"><div class="sv-gantt-wrap" id="svGanttWrap">';

            // 시간 헤더
            html += '<div class="sv-gantt-header-row">';
            html += '<div class="sv-gantt-label-cell"></div>';
            html += '<div class="sv-gantt-track-header">';
            for (let h = SV_HOUR_START; h <= SV_HOUR_END; h++) {
                const pct = ((h - SV_HOUR_START) * 60 / SV_TOTAL_MIN) * 100;
                html += `<div class="sv-gantt-time-label" style="left:${pct}%">${h}</div>`;
                if (h < SV_HOUR_END) {
                    const halfPct = ((h - SV_HOUR_START) * 60 + 30) / SV_TOTAL_MIN * 100;
                    html += `<div class="sv-gantt-time-label minor" style="left:${halfPct}%">:30</div>`;
                }
            }
            html += '</div>';
            html += '<div class="sv-gantt-hours-cell">합계</div>';
            html += '</div>';

            // 요일별 행
            DAY_CODES.forEach((code, idx) => {
                const dateIso = weekDates[idx] || '';
                const segs = svGetSegments(dateIso);
                const dateObj = dateIso ? new Date(dateIso) : null;
                const dayMin = segs.reduce((acc, s) => acc + (hmToMin(s.end) - hmToMin(s.start)), 0);
                const isToday = dateIso === todayIso;
                const actData = actualMap[dateIso];
                const actSegs = actData ? actData.segments : [];

                html += `<div class="sv-gantt-row${isToday ? ' sv-today-row' : ''}" data-iso="${dateIso}">`;
                html += '<div class="sv-gantt-label-cell">';
                html += `<span class="sv-gantt-day-name">${DOW_LABELS[idx]}</span>`;
                html += `<span class="sv-gantt-day-date">${dateObj ? `${dateObj.getMonth()+1}/${dateObj.getDate()}` : ''}</span>`;
                html += '</div>';
                html += '<div class="sv-gantt-track-cell">';

                // 눈금선
                for (let h = SV_HOUR_START; h <= SV_HOUR_END; h++) {
                    const pct = ((h - SV_HOUR_START) * 60 / SV_TOTAL_MIN) * 100;
                    html += `<div class="sv-gantt-grid-line major" style="left:${pct}%"></div>`;
                    if (h < SV_HOUR_END) {
                        const halfPct = ((h - SV_HOUR_START) * 60 + 30) / SV_TOTAL_MIN * 100;
                        html += `<div class="sv-gantt-grid-line minor" style="left:${halfPct}%"></div>`;
                    }
                }

                // 일정 바 (편집 가능)
                segs.forEach((seg, segIdx) => {
                    const sMin = hmToMin(seg.start) - SV_HOUR_START * 60;
                    const eMin = hmToMin(seg.end) - SV_HOUR_START * 60;
                    if (eMin <= 0 || sMin >= SV_TOTAL_MIN) return;
                    const leftPct = Math.max(0, sMin / SV_TOTAL_MIN * 100);
                    const widthPct = (Math.min(SV_TOTAL_MIN, eMin) - Math.max(0, sMin)) / SV_TOTAL_MIN * 100;
                    const isSel = svSelectedBar && svSelectedBar.iso === dateIso && svSelectedBar.segIdx === segIdx;
                    html += `<div class="sv-gantt-bar${isSel ? ' sv-selected' : ''}" data-iso="${dateIso}" data-seg-idx="${segIdx}" data-start="${seg.start}" data-end="${seg.end}" style="left:${leftPct}%;width:${widthPct}%;background:rgba(102,187,106,0.45);border-color:rgba(46,160,67,0.6);color:#1b5e20;">`;
                    html += '<div class="bar-handle bar-handle-left"></div>';
                    html += `<span>${seg.start}~${seg.end}</span>`;
                    html += '<div class="bar-handle bar-handle-right"></div>';
                    html += '</div>';
                });

                // 실제근무 바 (읽기 전용)
                actSegs.forEach(seg => {
                    if (!seg.start || !seg.end) return;
                    const sMin = hmToMin(seg.start) - SV_HOUR_START * 60;
                    const eMin = hmToMin(seg.end) - SV_HOUR_START * 60;
                    if (eMin <= 0 || sMin >= SV_TOTAL_MIN) return;
                    const leftPct = Math.max(0, sMin / SV_TOTAL_MIN * 100);
                    const widthPct = (Math.min(SV_TOTAL_MIN, eMin) - Math.max(0, sMin)) / SV_TOTAL_MIN * 100;
                    html += `<div class="sv-gantt-bar sv-bar-actual" style="left:${leftPct}%;width:${widthPct}%;background:${color};border-color:rgba(0,0,0,0.15);color:#fff;">${seg.start}~${seg.end}</div>`;
                });

                html += '</div>'; // track-cell
                html += `<div class="sv-gantt-hours-cell${dayMin > 0 ? ' has-hours' : ''}">${dayMin > 0 ? formatMins(dayMin) : '-'}</div>`;
                html += '</div>'; // row
            });

            html += '</div></div>'; // sv-gantt-wrap, sv-gantt-outer

            // 범례
            html += '<div class="d-flex gap-3 small text-muted align-items-center mt-2">';
            html += '<span><span style="display:inline-block;width:14px;height:10px;border-radius:3px;background:rgba(102,187,106,0.45);border:1px solid rgba(46,160,67,0.6);vertical-align:middle;margin-right:3px;"></span> 일정</span>';
            html += `<span><span style="display:inline-block;width:14px;height:10px;border-radius:3px;background:${color};opacity:0.7;border:1px solid rgba(0,0,0,0.15);vertical-align:middle;margin-right:3px;"></span> 실제근무</span>`;
            html += '<span class="ms-auto text-secondary" style="font-size:0.72rem;">빈 공간을 클릭하면 새 일정이 생성됩니다</span>';
            html += '</div>';

            schedViewBody.innerHTML = html;
        }

        // ===== 일정보기 팝업 — 드래그/선택/삭제/생성/저장 =====
        (function initSvInteraction() {

            function getTrackRect(bar) {
                const track = bar.closest('.sv-gantt-track-cell');
                return track ? track.getBoundingClientRect() : null;
            }

            /* ---- mousedown (드래그 시작) ---- */
            document.addEventListener('mousedown', function(e) {
                const bar = e.target.closest('.sv-gantt-bar');
                if (!bar || bar.classList.contains('sv-bar-actual')) return;
                if (!bar.closest('#svGanttWrap')) return;
                e.preventDefault(); e.stopPropagation();

                const trackRect = getTrackRect(bar);
                if (!trackRect) return;

                const iso = bar.dataset.iso;
                const segIdx = parseInt(bar.dataset.segIdx, 10);
                const startMin = hmToMin(bar.dataset.start) - SV_HOUR_START * 60;
                const endMin = hmToMin(bar.dataset.end) - SV_HOUR_START * 60;

                let mode = 'move';
                if (e.target.classList.contains('bar-handle-left')) mode = 'resize-left';
                if (e.target.classList.contains('bar-handle-right')) mode = 'resize-right';

                bar.classList.add(mode === 'move' ? 'dragging' : 'resizing');

                svDragState = {
                    bar, iso, segIdx, mode, trackRect,
                    origStartMin: startMin, origEndMin: endMin, origDuration: endMin - startMin,
                    mouseStartX: e.clientX, startX: e.clientX, startY: e.clientY,
                    hasMoved: false,
                    currentStartMin: startMin, currentEndMin: endMin
                };

                // 툴팁 초기 표시
                if (svDragTooltip) {
                    const s = minToHm(startMin + SV_HOUR_START * 60);
                    const en = minToHm(endMin + SV_HOUR_START * 60);
                    svDragTooltip.innerHTML = `${s} <span class="dtt-arrow">&rarr;</span> ${en}`;
                    svDragTooltip.style.left = (e.clientX + 14) + 'px';
                    svDragTooltip.style.top = (e.clientY - 36) + 'px';
                    svDragTooltip.classList.add('visible');
                }
            });

            /* ---- mousemove (드래그 중) ---- */
            document.addEventListener('mousemove', function(e) {
                if (!svDragState) return;
                const st = svDragState;
                if (!st.hasMoved) {
                    if (Math.abs(e.clientX - st.startX) + Math.abs(e.clientY - st.startY) < 3) return;
                    st.hasMoved = true;
                }
                e.preventDefault();

                const dx = e.clientX - st.mouseStartX;
                const deltaMin = svPxToMin(dx, st.trackRect.width);
                let ns, ne;

                if (st.mode === 'move') {
                    ns = svClampMin(st.origStartMin + deltaMin);
                    ne = ns + st.origDuration;
                    if (ne > SV_TOTAL_MIN) { ne = SV_TOTAL_MIN; ns = ne - st.origDuration; }
                    if (ns < 0) { ns = 0; ne = st.origDuration; }
                } else if (st.mode === 'resize-left') {
                    ns = svClampMin(st.origStartMin + deltaMin);
                    ne = st.origEndMin;
                    if (ns >= ne - 10) ns = ne - 10;
                } else {
                    ns = st.origStartMin;
                    ne = svClampMin(st.origEndMin + deltaMin);
                    if (ne <= ns + 10) ne = ns + 10;
                }

                st.currentStartMin = ns;
                st.currentEndMin = ne;
                st.bar.style.left = (ns / SV_TOTAL_MIN * 100).toFixed(3) + '%';
                st.bar.style.width = ((ne - ns) / SV_TOTAL_MIN * 100).toFixed(3) + '%';

                // 바 텍스트 업데이트
                const span = st.bar.querySelector('span');
                if (span) span.textContent = `${minToHm(ns + SV_HOUR_START * 60)}~${minToHm(ne + SV_HOUR_START * 60)}`;

                // 툴팁
                if (svDragTooltip) {
                    const newS = minToHm(ns + SV_HOUR_START * 60);
                    const newE = minToHm(ne + SV_HOUR_START * 60);
                    const origS = minToHm(st.origStartMin + SV_HOUR_START * 60);
                    const origE = minToHm(st.origEndMin + SV_HOUR_START * 60);
                    const changed = (newS !== origS || newE !== origE);
                    svDragTooltip.innerHTML = changed
                        ? `<span class="dtt-changed">${newS} <span class="dtt-arrow">&rarr;</span> ${newE}</span>`
                        : `${newS} <span class="dtt-arrow">&rarr;</span> ${newE}`;
                    svDragTooltip.style.left = (e.clientX + 14) + 'px';
                    svDragTooltip.style.top = (e.clientY - 36) + 'px';
                }
            });

            /* ---- mouseup (드래그 끝) ---- */
            document.addEventListener('mouseup', function(e) {
                if (!svDragState) return;
                const st = svDragState;
                st.bar.classList.remove('dragging', 'resizing');
                if (svDragTooltip) svDragTooltip.classList.remove('visible');

                if (!st.hasMoved) {
                    svDragState = null;
                    return; // click으로 처리
                }

                svJustDragged = true;
                setTimeout(function() { svJustDragged = false; }, 0);

                const newStart = minToHm(st.currentStartMin + SV_HOUR_START * 60);
                const newEnd = minToHm(st.currentEndMin + SV_HOUR_START * 60);
                const origStart = st.bar.dataset.start;
                const origEnd = st.bar.dataset.end;

                if (newStart !== origStart || newEnd !== origEnd) {
                    const iso = st.iso;
                    const segs = svGetSegments(iso);
                    segs[st.segIdx] = { start: newStart, end: newEnd };
                    segs.sort((a, b) => hmToMin(a.start) - hmToMin(b.start));
                    svPendingChanges[iso] = { memberId: svMemberId, iso, segments: svMergeOverlapping(segs) };
                    svClearSelection();
                    svUpdateSaveBar();
                    svRerender();
                }
                svDragState = null;
            });

            /* ---- click: 바 선택 / 빈 공간 클릭으로 새 바 생성 ---- */
            document.addEventListener('click', function(e) {
                if (svJustDragged) return;

                // 바 클릭 → 선택/해제
                const bar = e.target.closest('.sv-gantt-bar');
                if (bar && !bar.classList.contains('sv-bar-actual') && bar.closest('#svGanttWrap')) {
                    e.stopPropagation();
                    const iso = bar.dataset.iso;
                    const segIdx = parseInt(bar.dataset.segIdx, 10);
                    const isSame = svSelectedBar && svSelectedBar.iso === iso && svSelectedBar.segIdx === segIdx;

                    // 기존 선택 해제
                    schedViewBody.querySelectorAll('.sv-gantt-bar.sv-selected').forEach(b => b.classList.remove('sv-selected'));

                    if (isSame) {
                        svSelectedBar = null;
                        if (svBtnDelete) svBtnDelete.classList.add('d-none');
                    } else {
                        bar.classList.add('sv-selected');
                        svSelectedBar = { iso, segIdx, start: bar.dataset.start, end: bar.dataset.end };
                        if (svBtnDelete) svBtnDelete.classList.remove('d-none');
                    }
                    return;
                }

                // 빈 공간 클릭 → 새 바 생성
                const track = e.target.closest('.sv-gantt-track-cell');
                if (track && track.closest('#svGanttWrap')) {
                    const row = track.closest('.sv-gantt-row');
                    if (!row) return;
                    const iso = row.dataset.iso;
                    if (!iso) return;

                    svClearSelection();

                    const rect = track.getBoundingClientRect();
                    const clickX = e.clientX - rect.left;
                    let clickMin = Math.round(clickX / rect.width * SV_TOTAL_MIN / 10) * 10;
                    clickMin = Math.max(0, Math.min(clickMin, SV_TOTAL_MIN - 60));
                    const startHm = minToHm(clickMin + SV_HOUR_START * 60);
                    const endHm = minToHm(clickMin + 60 + SV_HOUR_START * 60);

                    const segs = svGetSegments(iso);
                    segs.push({ start: startHm, end: endHm });
                    segs.sort((a, b) => hmToMin(a.start) - hmToMin(b.start));
                    svPendingChanges[iso] = { memberId: svMemberId, iso, segments: svMergeOverlapping(segs) };
                    svUpdateSaveBar();
                    svRerender();
                }
            });

            /* ---- 삭제 버튼 ---- */
            if (svBtnDelete) svBtnDelete.addEventListener('click', function() {
                if (!svSelectedBar) return;
                const iso = svSelectedBar.iso;
                const segs = svGetSegments(iso);
                const idx = segs.findIndex(s => s.start === svSelectedBar.start && s.end === svSelectedBar.end);
                if (idx >= 0) segs.splice(idx, 1);

                const origSegs = (svOrigSchedMap[iso] && svOrigSchedMap[iso].segments) || [];
                if (segs.length === 0 && origSegs.length === 0) {
                    delete svPendingChanges[iso];
                } else {
                    svPendingChanges[iso] = { memberId: svMemberId, iso, segments: segs };
                }

                svClearSelection();
                svUpdateSaveBar();
                svRerender();
            });

            /* ---- 저장 버튼 ---- */
            if (svBtnSave) svBtnSave.addEventListener('click', async function() {
                const entries = Object.entries(svPendingChanges);
                if (entries.length === 0) return;
                svBtnSave.disabled = true;
                svBtnSave.textContent = '저장 중...';
                try {
                    for (const [key, data] of entries) {
                        const body = { memberId: Number(data.memberId), date: data.iso, segments: data.segments };
                        const resp = await fetch('/api/schedule/work/update', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                            body: JSON.stringify(body)
                        });
                        if (!resp.ok) {
                            const txt = await resp.text().catch(() => '');
                            alert(`저장 실패 (${data.iso}): ${resp.status} ${txt}`);
                            svBtnSave.disabled = false;
                            svBtnSave.textContent = '저장';
                            return;
                        }
                    }
                    svPendingChanges = {};
                    svClearSelection();
                    svUpdateSaveBar();
                    await svLoadWeek(); // 최신 데이터 리로드
                } catch (err) {
                    console.error(err);
                    alert('저장 중 오류가 발생했습니다.');
                } finally {
                    svBtnSave.disabled = false;
                    svBtnSave.textContent = '저장';
                }
            });

            /* ---- 취소 버튼 ---- */
            if (svBtnCancel) svBtnCancel.addEventListener('click', function() {
                svPendingChanges = {};
                svClearSelection();
                svUpdateSaveBar();
                svRerender();
            });

        })(); // end initSvInteraction

        // ===== 급여관리 iframe 팝업 =====
        const payMgmtOverlay = document.getElementById('payMgmtPopupOverlay');
        const payMgmtTitle   = document.getElementById('payMgmtPopupTitle');
        const payMgmtClose   = document.getElementById('payMgmtCloseBtn');
        const payMgmtIframe  = document.getElementById('payMgmtIframe');

        if (payMgmtClose) payMgmtClose.addEventListener('click', () => {
            payMgmtOverlay.style.display = 'none';
            payMgmtIframe.src = '';
        });
        if (payMgmtOverlay) payMgmtOverlay.addEventListener('click', (e) => {
            if (e.target === payMgmtOverlay) {
                payMgmtOverlay.style.display = 'none';
                payMgmtIframe.src = '';
            }
        });

        // ===== 수정 iframe 팝업 =====
        const editOverlay = document.getElementById('editPopupOverlay');
        const editTitle   = document.getElementById('editPopupTitle');
        const editClose   = document.getElementById('editPopupCloseBtn');
        const editIframe  = document.getElementById('editPopupIframe');

        function openEditPopup(memberId) {
            const m = (allMembers||[]).find(x => String(x.id) === String(memberId));
            editTitle.textContent = (m ? m.name + ' — ' : '') + '아르바이트 정보 수정';
            editIframe.src = `/members/${encodeURIComponent(memberId)}/edit`;
            editOverlay.style.display = 'flex';
        }

        if (editClose) editClose.addEventListener('click', () => {
            editOverlay.style.display = 'none';
            editIframe.src = '';
        });
        if (editOverlay) editOverlay.addEventListener('click', (e) => {
            if (e.target === editOverlay) {
                editOverlay.style.display = 'none';
                editIframe.src = '';
            }
        });



        // ===== 팝업 호출 =====
        function openMonthSummaryPopupWindow() {
            if (!currentMember || !currentWeekDates.length) {
                alert('선택된 아르바이트 또는 주간 정보가 없습니다.');
                return;
            }

            const memberId  = currentMember.id;
            const anchor    = currentWeekDates[0];

            const url =
                    `/members/showworkmonthdashboardpopup` +
                    `?memberId=${encodeURIComponent(memberId)}` +
                    `&week=${encodeURIComponent(anchor)}` +
                    `&month=${encodeURIComponent(anchor)}`;

            window.open(
                    url,
                    'monthSummaryPopup',
                    'width=1600,height=800,scrollbars=yes,resizable=yes'
            );
        }

        function openWeekSummaryPopupWindow() {
            if (!currentMember || !currentWeekDates.length) {
                alert('선택된 아르바이트 또는 주간 정보가 없습니다.');
                return;
            }

            const memberId   = currentMember.id;
            const startDate  = currentWeekDates[0];
            const endDate    = currentWeekDates[6];

            const url =
                    `/members/showworktimedashboardpopup` +
                    `?memberId=${encodeURIComponent(memberId)}` +
                    `&startDate=${encodeURIComponent(startDate)}` +
                    `&endDate=${encodeURIComponent(endDate)}`;

            window.open(
                    url,
                    'weekSummaryPopup',
                    'width=1600,height=800,scrollbars=yes,resizable=yes'
            );
        }

        // 급여관리 팝업 (iframe 오버레이)
        function openPaymentIndividualPopupWindow() {
            if (!currentMember) {
                alert('선택된 아르바이트가 없습니다.');
                return;
            }

            let anchorIso = null;
            if (currentWeekDates && currentWeekDates.length) {
                anchorIso = currentWeekDates[0];
            } else if (weekRangeLabelEl && weekRangeLabelEl.textContent) {
                const parsed = parseWeekRangeToDates(weekRangeLabelEl.textContent);
                anchorIso = parsed.weekStartIso;
            }
            if (!anchorIso) anchorIso = toIso(new Date());

            const memberId = currentMember.id;
            const url =
                `${PAYMENT_POPUP_URL}` +
                `?memberId=${encodeURIComponent(memberId)}` +
                `&month=${encodeURIComponent(anchorIso)}` +
                `&week=${encodeURIComponent(anchorIso)}`;

            payMgmtTitle.textContent = `${currentMember.name ?? ''} — 급여관리`;
            payMgmtIframe.src = url;
            payMgmtOverlay.style.display = 'flex';
        }

        // ===== 초기화 =====
        function clearRight(){
            if (selectedMemberTitle)  selectedMemberTitle.textContent   = '주간 템플릿 (월~일)';
            if (selectedMemberStatus) {
                selectedMemberStatus.textContent  = '-';
                selectedMemberStatus.className    = 'status-chip d-none';
            }

            if (tbodyWeek) tbodyWeek.innerHTML = '';
            if(tbodyWeekSummary) tbodyWeekSummary.innerHTML        = '';
            if(calendarGrid) calendarGrid.innerHTML                = '';

            if(weekPlannedTotalCell) weekPlannedTotalCell.textContent  = '0시간';
            if(weekActualTotalCell)  weekActualTotalCell.textContent   = '0시간';
            if(weekDeltaCell)        weekDeltaCell.textContent         = '0분';
            if(weekPayCell)          weekPayCell.textContent           = '-';
            if(weekJuhyuPayCell)     weekJuhyuPayCell.textContent      = '-';
            if(hourlyWageCellW)      hourlyWageCellW.textContent       = '-';

            if(monthActualTotalCell) monthActualTotalCell.textContent  = '0시간';
            if(monthJuhyuPayCell)    monthJuhyuPayCell.textContent     = '-';
            if(monthPayCell)         monthPayCell.textContent          = '-';
            if(hourlyWageCellM)      hourlyWageCellM.textContent       = '-';
            if(monthRangeLabel)      monthRangeLabel.textContent       = '0000.00.01 ~ 00.00';

            currentWeekDates = [];
            lastPlanMap      = {};
            updateSaveButtonByStep();
        }

        // ===== 유틸 =====
        function hmToMin(hm){
            const [h,m]=String(hm).split(':').map(n=>parseInt(n,10));
            return (h||0)*60+(m||0);
        }

        function parseWeekRangeToDates(label){
            const m = String(label).match(/(\d{4})\.(\d{2})\.(\d{2})/);
            let start;
            if(m){ start = new Date(+m[1], +m[2]-1, +m[3]); }
            else { const today = new Date(); start = toMonday(today); }
            const weekDates = Array.from({length:7}, (_,i)=>toIso(addDays(start,i)));
            return { weekStartIso: weekDates[0], weekEndIso: weekDates[6], weekDates };
        }
        function toMonday(date){
            const d=new Date(date.getFullYear(),date.getMonth(),date.getDate());
            const off=(d.getDay()+6)%7;
            d.setDate(d.getDate()-off);
            return d;
        }
        function addDays(d,n){ const x=new Date(d); x.setDate(x.getDate()+n); return x; }
        function toIso(d){ return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }

        function formatMins(mins){
            const v = Math.max(0, mins|0);
            const h = Math.floor(v/60), m=v%60;
            return m===0 ? `${h}시간` : `${h}시간 ${m}분`;
        }
        function deltaString(min){
            const sign = min>0?'+':min<0?'-':'';
            const v=Math.abs(min);
            const h=Math.floor(v/60), m=v%60;
            return `${sign}${h}시간${m?` ${m}분`:''}`;
        }
        function krw(v){
            return new Intl.NumberFormat('ko-KR',{style:'currency',currency:'KRW',maximumFractionDigits:0}).format(v);
        }

        function normalizeWeeklyTemplate(apiRows, weekDates){
            const map = {};
            const arr = Array.isArray(apiRows) ? apiRows : [];

            const dates = Array.isArray(weekDates) ? weekDates : [];
            const dayOrder = ['MON','TUE','WED','THU','FRI','SAT','SUN'];

            const byDayCode = {};

            arr.forEach(row => {
                const dayCode = String(row.day || '').toUpperCase();
                if(!dayCode) return;

                if(!byDayCode[dayCode]) {
                    byDayCode[dayCode] = [];
                }

                const startHm = (row.start || '').slice(0,5);
                const endHm   = (row.end   || '').slice(0,5);

                byDayCode[dayCode].push({
                    start: startHm,
                    end: endHm
                });
            });

            dates.forEach((iso, idx) => {
                const dayCode = dayOrder[idx];
                const segs    = byDayCode[dayCode] || [];

                const minutes = segs.reduce((acc, s) => {
                    return acc + diffMinutes(s.start, s.end);
                }, 0);

                map[iso] = {
                    segments: segs,
                    minutes: minutes
                };
            });

            return map;
        }

        function diffMinutes(start, end){
            const s = parseHm(start), e = parseHm(end);
            return (e.h*60+e.m) - (s.h*60+s.m);
        }
        function parseHm(hm){
            if(!hm||typeof hm!=='string') return {h:0,m:0};
            const [h,m] = hm.split(':').map(n=>parseInt(n,10));
            return {h:isNaN(h)?0:h, m:isNaN(m)?0:m};
        }

        function statusClass(s){
            const map = {
                WORKING :'bg-success text-white',
                WAITING :'bg-secondary text-white',
                RESTING :'bg-info text-white',
                PAUSED  :'bg-warning text-dark',
                RESIGNED:'bg-danger text-white'
            };
            return map[s] || '';
        }

        function statusLabel(s){
            const map = {
                WORKING :'근무중',
                WAITING :'시작전',
                RESTING :'휴식중',
                PAUSED  :'일시중지',
                RESIGNED:'퇴사'
            };
            return map[s] || (s || '-');
        }

        function colorForMember(m){
            const key = (m?.id!=null?String(m.id):(m?.name||'x'));
            const h = seededHash(key)%360, s=65, l=55;
            return hslToHex(h,s,l);
        }
        function seededHash(str){ let h=2166136261>>>0; for(let i=0;i<str.length;i++){ h^=str.charCodeAt(i); h=(h*16777619)>>>0; } return h>>>0; }
        function hslToHex(h,s,l){
            s/=100; l/=100;
            const k=n=>(n+h/30)%12, a=s*Math.min(l,1-l);
            const f=n=>l-a*Math.max(-1,Math.min(k(n)-3,Math.min(9-k(n),1)));
            const toHex=x=>Math.round(255*x).toString(16).padStart(2,'0');
            return `#${toHex(f(0))}${toHex(f(8))}${toHex(f(4))}`;
        }

        function escapeHtml(s){
            if(s==null) return '';
            return String(s)
                    .replace(/&/g,'&amp;')
                    .replace(/</g,'&lt;')
                    .replace(/>/g,'&gt;')
                    .replace(/"/g,'&quot;')
                    .replace(/'/g,'&#39;');
        }

        function getCreatedAt(m){
            const v = m?.created_at ?? m?.createdAt ?? null;
            if(v==null) return null;
            if(typeof v === 'number'){
                const ms = v < 1e12 ? v * 1000 : v;
                const d = new Date(ms);
                return isNaN(d.getTime()) ? null : d;
            }
            if(typeof v === 'string'){
                const d = new Date(v);
                return isNaN(d.getTime()) ? null : d;
            }
            return null;
        }
        function pad2(n){ return String(n).padStart(2,'0'); }
        function formatYmdHm(d){
            const y=d.getFullYear();
            const M=pad2(d.getMonth()+1);
            const D=pad2(d.getDate());
            const h=pad2(d.getHours());
            const m=pad2(d.getMinutes());
            return `${y}-${M}-${D} ${h}:${m}`;
        }

        function minToHm(min){
            const h = Math.floor(min/60);
            const m = min%60;
            return `${pad2(h)}:${pad2(m)}`;
        }

        function formatPayday(code){
            if(code == null || String(code).trim() === '') return '-';
            if(String(code).toUpperCase() === 'EOM') return '말일';
            const n = parseInt(code, 10);
            return isNaN(n) ? String(code) : `${n}일`;
        }
        function yesNoLabel(v){
            return Boolean(v) ? '적용' : '미적용';
        }

        function healthLabel(m){
            if (!m || !m.hasHealthCertificate) return '미보유';
            if (m.healthCertExpiry) return `보유 (${m.healthCertExpiry}까지)`;
            return '보유';
        }

        function createdAtStr(m){
            const d = getCreatedAt(m);
            return d ? formatYmdHm(d) : '-';
        }

    })();
</script>

