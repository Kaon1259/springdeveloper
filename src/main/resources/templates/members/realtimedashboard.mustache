{{>layouts/header}}

<main class="container my-4">
    <!-- 1. 현재 시각 + 상단 컨트롤 -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div class="d-flex align-items-baseline gap-2 flex-wrap">
            <span id="nowClockBig" class="realtime-clock-big fw-bold">--:--:--</span>
            <span class="text-muted fs-6">현재 시각</span>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <label class="small text-muted mb-0">자동저장</label>
            <input type="number" id="autoSaveMin" class="form-control form-control-sm"
                   value="10" min="1" max="60" style="width:56px;text-align:center;">
            <span class="small text-muted">분</span>
            <button id="btnAutoSaveAdd" class="btn btn-sm btn-outline-success rounded-pill px-3">10분 추기</button>
            <button id="btnRegisterActual" class="btn btn-sm btn-success rounded-pill px-3 fw-semibold" disabled>
                실시간 반영
            </button>
        </div>
    </div>

    <!-- 2. 요약 배지 -->
    <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
        <span class="rt-summary-badge">
            <strong id="totalCount">0</strong> 전체
        </span>
        <span class="rt-summary-badge rt-badge-working">
            <strong id="workingCount">0</strong> 근무중
        </span>
        <span class="rt-summary-badge rt-badge-waiting">
            <strong id="waitingCount">0</strong> 예정/대기
        </span>
        <span class="rt-summary-badge rt-badge-done">
            <strong id="doneCount">0</strong> 완료
        </span>
    </div>

    <!-- 3. 멤버 카드 영역 -->
    <div class="member-cards-outer mb-4">
        <div id="miniCalendars" class="mini-cal-wrapper">
            <!-- JS 렌더링 -->
        </div>
    </div>

    <!-- 4. 시간대별 근무 현황 (간트) -->
    <div class="gantt-section">
        <div class="gantt-section-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="d-flex align-items-center gap-2">
                <span style="font-size:1.1rem;">&#x1F4C5;</span>
                <span class="fw-semibold">시간대별 근무 현황</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button id="btnSaveSchedule" class="btn btn-sm btn-success rounded-pill px-3">일정 저장</button>
                <div class="btn-group btn-group-sm" id="scaleButtons">
                    <button class="btn btn-dark scale-btn active" data-scale="10">10분</button>
                    <button class="btn btn-outline-secondary scale-btn" data-scale="30">30분</button>
                    <button class="btn btn-outline-secondary scale-btn" data-scale="60">1시간</button>
                </div>
            </div>
        </div>
        <div id="rtGanttContainer" class="rt-gantt-container mt-2">
            <!-- JS 간트 차트 렌더링 -->
        </div>
    </div>
</main>

<style>
    /* ===== 1. 큰 시계 ===== */
    .realtime-clock-big {
        font-size: 3rem;
        line-height: 1;
        letter-spacing: 0.03em;
        font-variant-numeric: tabular-nums;
        color: #1e293b;
    }
    @media (max-width: 576px) {
        .realtime-clock-big { font-size: 2rem; }
    }

    /* ===== 2. 요약 배지 ===== */
    .rt-summary-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 16px;
        border-radius: 999px;
        border: 1px solid #d1d5db;
        background: #fff;
        font-size: 0.85rem;
        color: #374151;
        white-space: nowrap;
    }
    .rt-summary-badge strong {
        font-size: 1rem;
    }
    .rt-badge-working {
        border-color: #22c55e;
        color: #16a34a;
    }
    .rt-badge-working strong { color: #16a34a; }
    .rt-badge-waiting {
        border-color: #f59e0b;
        color: #d97706;
    }
    .rt-badge-waiting strong { color: #d97706; }
    .rt-badge-done {
        border-color: #9ca3af;
        color: #6b7280;
    }
    .rt-badge-done strong { color: #6b7280; }

    /* ===== 3. 멤버 카드 영역 ===== */
    .member-cards-outer {
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        background: #fff;
        padding: 16px;
        box-shadow: 0 4px 12px rgba(15,23,42,.04);
    }

    .mini-cal-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .mini-cal-card {
        flex: 0 0 calc((100% - 24px) / 3);
        max-width: calc((100% - 24px) / 3);
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        background: #ffffff;
        display: flex;
        flex-direction: column;
        min-height: 130px;
        overflow: hidden;
        transition: box-shadow .15s ease, border-color .15s ease, transform .12s ease;
    }
    .mini-cal-card:hover {
        border-color: #d1d5db;
        box-shadow: 0 8px 20px rgba(15,23,42,.08);
        transform: translateY(-1px);
    }
    .mini-cal-card.current-working {
        border-color: #22c55e;
        box-shadow: 0 0 0 1px rgba(34,197,94,.4), 0 12px 28px rgba(34,197,94,.15);
    }

    @media (max-width: 992px) {
        .mini-cal-card {
            flex: 0 0 calc((100% - 12px) / 2);
            max-width: calc((100% - 12px) / 2);
        }
    }
    @media (max-width: 576px) {
        .mini-cal-card {
            flex: 1 1 100%;
            max-width: 100%;
        }
    }

    /* 카드 헤더 */
    .mini-cal-header {
        padding: 10px 14px;
        background: var(--card-gradient);
        color: #fff;
        display: flex;
        flex-direction: column;
        gap: 3px;
    }
    .mini-cal-header-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 6px;
    }
    .mini-cal-name {
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 700;
        font-size: 0.92rem;
    }
    .mini-cal-name-text {
        color: #f9fafb;
    }
    .mini-cal-dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        border: 2px solid rgba(239,246,255,0.95);
        box-shadow: 0 0 0 1px rgba(191,219,254,0.9);
        flex: 0 0 auto;
    }
    .mini-cal-status-pill {
        border-radius: 999px;
        padding: 2px 10px;
        font-size: 0.72rem;
        font-weight: 600;
        border: 1px solid rgba(239,246,255,.9);
        color: #f9fafb;
        background: rgba(15,23,42,0.15);
        white-space: nowrap;
    }
    .mini-cal-status-pill.status-working {
        background: rgba(34,197,94,0.2);
        border-color: rgba(34,197,94,0.9);
    }
    .mini-cal-status-pill.status-done {
        background: rgba(148,163,184,0.25);
        border-color: rgba(148,163,184,0.9);
    }
    .mini-cal-status-pill.status-rest {
        background: rgba(251,191,36,0.2);
        border-color: rgba(251,191,36,0.9);
    }
    .mini-cal-header-sub {
        font-size: 0.75rem;
        color: #e5e7eb;
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }
    .mini-cal-header-sub span + span::before {
        content: "\00B7";
        margin: 0 4px;
        opacity: .7;
    }

    /* 카드 바디 */
    .mini-cal-body {
        padding: 10px 14px 6px 14px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
    }
    .mini-cal-seg {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 5px 0;
        border-bottom: 1px solid #f3f4f6;
        font-size: 0.82rem;
    }
    .mini-cal-seg:last-child {
        border-bottom: none;
    }
    .mini-cal-seg-time {
        font-weight: 600;
        font-size: 0.82rem;
        color: #374151;
    }
    .mini-cal-seg-label {
        font-size: 0.75rem;
        color: #9ca3af;
        font-weight: 500;
    }
    .mini-cal-seg-label.seg-done { color: #6b7280; }
    .mini-cal-seg-label.seg-working { color: #16a34a; font-weight: 600; }
    .mini-cal-seg-label.seg-pending { color: #d97706; }

    /* 카드 프로그레스 바 */
    .mini-cal-progress-wrap {
        padding: 0 14px;
        margin-top: auto;
    }
    .mini-cal-progress {
        height: 4px;
        border-radius: 2px;
        background: #f3f4f6;
        overflow: hidden;
    }
    .mini-cal-progress-bar {
        height: 100%;
        border-radius: 2px;
        transition: width 1s linear;
        background: var(--bar-color, #64748b);
    }

    /* 카드 푸터 */
    .mini-cal-footer {
        padding: 4px 14px 8px 14px;
        text-align: right;
        font-size: 0.75rem;
        color: #9ca3af;
    }
    .mini-cal-footer.footer-done {
        color: #6b7280;
    }

    /* 카드 비활성 상태 */
    .mini-cal-card.done-card {
        opacity: 0.55;
        filter: grayscale(0.3);
    }
    .mini-cal-card.done-card .mini-cal-header {
        background: linear-gradient(135deg, #94a3b8, #64748b) !important;
    }

    /* ===== 4. 간트 섹션 ===== */
    .gantt-section {
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        background: #fff;
        padding: 16px;
        box-shadow: 0 4px 12px rgba(15,23,42,.04);
    }
    .gantt-section-header {
        padding-bottom: 10px;
        border-bottom: 1px solid #f3f4f6;
    }

    .rt-gantt-container {
        border: 1px solid #edf0f4;
        border-radius: 0.5rem;
        background: #fff;
        overflow-x: auto;
        overflow-y: auto;
        max-height: calc(100vh - 300px);
    }

    /* 간트 시간 헤더 행 */
    .rt-gantt-time-row {
        display: flex;
        align-items: flex-end;
        height: 32px;
        border-bottom: 2px solid #d1d5db;
        position: sticky;
        top: 0;
        z-index: 5;
        background: #f8fafc;
    }

    /* 간트 멤버 행 */
    .rt-gantt-row {
        display: flex;
        align-items: center;
        height: 38px;
        border-bottom: 1px solid #edf0f4;
        transition: background 0.15s;
    }
    .rt-gantt-row:hover {
        background: #f8fafc;
    }

    /* 간트 라벨 셀 */
    .rt-gantt-label-cell {
        width: 110px;
        min-width: 110px;
        flex: 0 0 110px;
        font-size: 0.8rem;
        padding: 0 8px;
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
        border-right: 1px solid #edf0f4;
        position: sticky;
        left: 0;
        background: inherit;
        z-index: 2;
    }
    .rt-gantt-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex: 0 0 auto;
        border: 1px solid rgba(0,0,0,0.08);
    }
    .rt-gantt-name {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* 간트 트랙 셀 */
    .rt-gantt-track-cell {
        flex: 1;
        position: relative;
        height: 100%;
        min-width: 600px;
    }

    /* 간트 시간 눈금 */
    .rt-gantt-grid-line {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 1px;
        background: #edf0f4;
        pointer-events: none;
    }
    .rt-gantt-grid-line.grid-hour {
        background: #d1d5db;
    }
    .rt-gantt-grid-line.grid-half {
        background: #e5e7eb;
    }

    /* 간트 시간 마크 */
    .rt-gantt-hour-mark {
        position: absolute;
        font-size: 0.68rem;
        color: #6b7280;
        transform: translateX(-50%);
        bottom: 4px;
        font-weight: 500;
    }
    .rt-gantt-half-mark {
        color: #9ca3af;
        font-weight: 400;
    }

    /* 간트 바 */
    .rt-gantt-bar {
        position: absolute;
        top: 6px;
        bottom: 6px;
        border-radius: 5px;
        border: none;
        background: var(--bar-color-light, rgba(148,163,184,0.25));
        overflow: hidden;
        z-index: 1;
    }
    .rt-gantt-bar-fill {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        border-radius: 5px 0 0 5px;
        background: var(--bar-color, #94a3b8);
        opacity: 0.65;
        transition: width 1s linear;
    }
    .rt-gantt-bar.fully-done {
        background: var(--bar-color, #94a3b8);
        opacity: 0.45;
    }
    .rt-gantt-bar.fully-done .rt-gantt-bar-fill {
        display: none;
    }
    .rt-gantt-bar.active-now {
        box-shadow: 0 0 6px rgba(0,0,0,0.08);
    }
    .rt-gantt-bar-label {
        position: absolute;
        left: 6px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.65rem;
        color: #374151;
        white-space: nowrap;
        pointer-events: none;
        z-index: 2;
        font-weight: 500;
        text-shadow: 0 0 3px rgba(255,255,255,0.8);
    }

    /* 현재 시간 라인 */
    .rt-gantt-now-line {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 2px;
        background: #ef4444;
        z-index: 4;
        pointer-events: none;
    }
    .rt-gantt-now-line::before {
        content: '';
        position: absolute;
        top: -3px;
        left: -3px;
        width: 8px;
        height: 8px;
        background: #ef4444;
        border-radius: 50%;
    }

    /* 간트 합계 셀 */
    .rt-gantt-hours-cell {
        width: 60px;
        min-width: 60px;
        flex: 0 0 60px;
        text-align: center;
        font-size: 0.78rem;
        font-weight: 600;
        color: #64748b;
        border-left: 1px solid #edf0f4;
    }

    /* ===== 스케일 버튼 활성 상태 ===== */
    .scale-btn.active {
        pointer-events: none;
    }
</style>

<script id="membersData" type="application/json">
{{{membersJson}}}
</script>

<script>
(function () {
    /* ===== 유틸 함수 ===== */
    function todayStr() {
        const d = new Date();
        return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
    }
    function parseHm(hm) {
        const [h,m] = (hm||'0:0').split(':').map(n => parseInt(n,10));
        return { h: h||0, m: m||0 };
    }
    function getSchedules(m) {
        if (Array.isArray(m?.schedule)) return m.schedule;
        if (Array.isArray(m?.schedules)) return m.schedules;
        return [];
    }
    function dayKeyOf(d) {
        return ['SUN','MON','TUE','WED','THU','FRI','SAT'][d.getDay()];
    }
    function escapeHtml(s) {
        if (s == null) return '';
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
    function hexToRgb(hex) {
        return { r: parseInt(hex.slice(1,3),16), g: parseInt(hex.slice(3,5),16), b: parseInt(hex.slice(5,7),16) };
    }
    function colorForMember(m) {
        const key = (m.id != null ? String(m.id) : (m.name || 'x'));
        return hslToHex(seededHash(key) % 360, 65, 55);
    }
    function seededHash(str) {
        let h = 2166136261 >>> 0;
        for (let i = 0; i < str.length; i++) { h ^= str.charCodeAt(i); h = (h * 16777619) >>> 0; }
        return h >>> 0;
    }
    function hslToHex(h,s,l) {
        s /= 100; l /= 100;
        const k = n => (n + h/30) % 12;
        const a = s * Math.min(l, 1-l);
        const f = n => l - a * Math.max(-1, Math.min(k(n)-3, Math.min(9-k(n), 1)));
        const toHex = x => Math.round(255*x).toString(16).padStart(2,'0');
        return `#${toHex(f(0))}${toHex(f(8))}${toHex(f(4))}`;
    }
    function todaySpanLabel(segs) {
        if (!segs || !segs.length) return '';
        const first = segs.reduce((min, s) => s.start < min.start ? s : min, segs[0]);
        const last  = segs.reduce((max, s) => s.end   > max.end   ? s : max, segs[0]);
        return `${first.start} ~ ${last.end}`;
    }

    /* ===== 상수 & DOM ===== */
    const API_ENDPOINT = '/api/schedule/actual-bulk-register';
    const TARGET_DATE_STR = todayStr();
    const HOUR_START = 6, HOUR_END = 22;
    const TOTAL_MIN = (HOUR_END - HOUR_START) * 60;

    const nowClockBig      = document.getElementById('nowClockBig');
    const btnRegisterActual = document.getElementById('btnRegisterActual');
    const btnAutoSaveAdd   = document.getElementById('btnAutoSaveAdd');
    const autoSaveMinInput = document.getElementById('autoSaveMin');
    const btnSaveSchedule  = document.getElementById('btnSaveSchedule');
    const miniCalendars    = document.getElementById('miniCalendars');
    const ganttContainer   = document.getElementById('rtGanttContainer');

    /* ===== 데이터 ===== */
    let allMembers = [];
    try { allMembers = JSON.parse(document.getElementById('membersData').textContent || '[]'); } catch(e) { allMembers = []; }

    const targetDate = new Date(`${TARGET_DATE_STR}T00:00:00`);
    const DAY_KEY = dayKeyOf(targetDate);

    const todayMembers = (allMembers || [])
        .filter(m => getSchedules(m).some(s => s.day === DAY_KEY))
        .sort((a,b) => (a.name||'').localeCompare(b.name||'', 'ko'));

    const colorMap = {};
    todayMembers.forEach(m => { colorMap[m.id] = colorForMember(m); });

    let currentScale = 10; // 기본 10분 스케일

    /* ===== 초기 렌더링 ===== */
    renderNow();
    renderMiniCalendars(todayMembers);
    renderGantt(todayMembers);
    updateGanttBars();
    updateMiniCalendarState(todayMembers);
    updateSummaryBadges(todayMembers);
    updateActualButtonState();

    /* ===== 1초 타이머 ===== */
    setInterval(() => {
        renderNow();
        updateGanttBars();
        updateMiniCalendarState(todayMembers);
        updateSummaryBadges(todayMembers);
    }, 1000);

    /* ===== 시계 ===== */
    function renderNow() {
        const d = new Date();
        const text = `${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}:${String(d.getSeconds()).padStart(2,'0')}`;
        if (nowClockBig) nowClockBig.textContent = text;
    }

    /* ===== 요약 배지 업데이트 ===== */
    function updateSummaryBadges(members) {
        const now = new Date();
        const nowMin = now.getHours() * 60 + now.getMinutes();
        let working = 0, waiting = 0, done = 0;

        members.forEach(m => {
            const segs = getSchedules(m).filter(s => s.day === DAY_KEY);
            let isWorking = false, hasFuture = false, allDone = true;
            segs.forEach(s => {
                const stMin = parseHm(s.start).h * 60 + parseHm(s.start).m;
                const edMin = parseHm(s.end).h * 60 + parseHm(s.end).m;
                if (nowMin >= stMin && nowMin < edMin) isWorking = true;
                if (nowMin < edMin) allDone = false;
                if (nowMin < stMin) hasFuture = true;
            });
            if (isWorking) working++;
            else if (allDone && segs.length) done++;
            else waiting++;
        });

        document.getElementById('totalCount').textContent = members.length;
        document.getElementById('workingCount').textContent = working;
        document.getElementById('waitingCount').textContent = waiting;
        document.getElementById('doneCount').textContent = done;
    }

    /* ===== 버튼 활성화 ===== */
    function updateActualButtonState() {
        const enable = todayMembers.length > 0;
        btnRegisterActual.disabled = !enable;
        btnRegisterActual.title = enable ? '' : '금일 근무자가 없습니다.';
    }

    /* ===== 실시간 반영 버튼 ===== */
    btnRegisterActual.addEventListener('click', async () => {
        if (!todayMembers.length) return alert('금일 근무자가 없습니다.');
        if (!confirm('현재까지의 실제 근무 구간을 서버에 등록하시겠습니까?')) return;

        const now = new Date();
        const nowMin = now.getHours() * 60 + now.getMinutes();

        const items = todayMembers.map(m => {
            const segs = getSchedules(m).filter(s => s.day === DAY_KEY);
            const segments = [];
            segs.forEach(s => {
                const stMin = parseHm(s.start).h * 60 + parseHm(s.start).m;
                const edMin = parseHm(s.end).h * 60 + parseHm(s.end).m;
                if (nowMin > stMin) {
                    const endMin = Math.min(nowMin, edMin);
                    segments.push({ start: s.start, end: `${String(Math.floor(endMin/60)).padStart(2,'0')}:${String(endMin%60).padStart(2,'0')}` });
                }
            });
            return { memberId: m.id, segments };
        }).filter(x => x.segments.length > 0);

        if (!items.length) return alert('등록할 실제 근무 구간이 없습니다.');

        try {
            const res = await fetch(API_ENDPOINT, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ date: todayStr(), segments: items })
            });
            const data = await res.json().catch(() => ({}));
            if (res.ok && (data.success === undefined || data.success === true)) {
                alert('실시간 반영 완료');
            } else {
                alert('반영 실패: ' + (data.message || res.statusText || '알 수 없는 오류'));
            }
        } catch (err) {
            alert('네트워크 오류로 반영에 실패했습니다.');
            console.error(err);
        }
    });

    /* ===== 자동저장 추기 버튼 ===== */
    btnAutoSaveAdd.addEventListener('click', () => {
        const cur = parseInt(autoSaveMinInput.value, 10) || 10;
        autoSaveMinInput.value = cur + 10;
        btnAutoSaveAdd.textContent = `${cur + 10}분 추기`;
    });

    /* ===== 일정 저장 버튼 ===== */
    btnSaveSchedule.addEventListener('click', async () => {
        if (!todayMembers.length) return alert('금일 근무자가 없습니다.');
        if (!confirm('현재까지의 실제 근무 구간을 저장하시겠습니까?')) return;

        const now = new Date();
        const nowMin = now.getHours() * 60 + now.getMinutes();

        const items = todayMembers.map(m => {
            const segs = getSchedules(m).filter(s => s.day === DAY_KEY);
            const segments = [];
            segs.forEach(s => {
                const stMin = parseHm(s.start).h * 60 + parseHm(s.start).m;
                const edMin = parseHm(s.end).h * 60 + parseHm(s.end).m;
                if (nowMin > stMin) {
                    const endMin = Math.min(nowMin, edMin);
                    segments.push({ start: s.start, end: `${String(Math.floor(endMin/60)).padStart(2,'0')}:${String(endMin%60).padStart(2,'0')}` });
                }
            });
            return { memberId: m.id, segments };
        }).filter(x => x.segments.length > 0);

        if (!items.length) return alert('등록할 실제 근무 구간이 없습니다.');

        try {
            const res = await fetch(API_ENDPOINT, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ date: todayStr(), segments: items })
            });
            const data = await res.json().catch(() => ({}));
            if (res.ok && (data.success === undefined || data.success === true)) {
                alert('일정 저장 완료');
            } else {
                alert('저장 실패: ' + (data.message || res.statusText || '알 수 없는 오류'));
            }
        } catch (err) {
            alert('네트워크 오류로 저장에 실패했습니다.');
            console.error(err);
        }
    });

    /* ===== 스케일 버튼 토글 ===== */
    document.getElementById('scaleButtons').addEventListener('click', e => {
        const btn = e.target.closest('.scale-btn');
        if (!btn || btn.classList.contains('active')) return;

        document.querySelectorAll('.scale-btn').forEach(b => {
            b.classList.remove('active', 'btn-dark');
            b.classList.add('btn-outline-secondary');
        });
        btn.classList.add('active', 'btn-dark');
        btn.classList.remove('btn-outline-secondary');

        currentScale = parseInt(btn.dataset.scale, 10);
        renderGantt(todayMembers);
        updateGanttBars();
    });

    /* ===== 멤버 카드 렌더링 ===== */
    function renderMiniCalendars(members) {
        miniCalendars.innerHTML = '';
        if (!members.length) {
            miniCalendars.innerHTML = '<div class="text-muted small p-3">금일 근무자가 없습니다.</div>';
            return;
        }

        members.forEach(m => {
            const segs = getSchedules(m).filter(s => s.day === DAY_KEY);
            const color = colorMap[m.id];
            const rgb = hexToRgb(color);

            const card = document.createElement('div');
            card.className = 'mini-cal-card';
            card.dataset.memberId = String(m.id);
            card.style.setProperty('--card-gradient',
                `linear-gradient(135deg, rgba(${rgb.r},${rgb.g},${rgb.b},0.85), rgba(${Math.max(0,rgb.r-40)},${Math.max(0,rgb.g-40)},${Math.max(0,rgb.b-40)},0.95))`);
            card.style.setProperty('--bar-color', color);

            const segHtml = segs.map(s => `
                <div class="mini-cal-seg" data-start="${s.start}" data-end="${s.end}">
                    <span class="mini-cal-seg-time">${s.start} ~ ${s.end}</span>
                    <span class="mini-cal-seg-label">예정</span>
                </div>
            `).join('');

            const spanLabel = todaySpanLabel(segs);
            const segCountLabel = segs.length ? `${segs.length}개 스케줄` : '스케줄 없음';

            card.innerHTML = `
                <div class="mini-cal-header">
                    <div class="mini-cal-header-top">
                        <div class="mini-cal-name">
                            <span class="mini-cal-dot" style="background:${color};"></span>
                            <span class="mini-cal-name-text">${escapeHtml(m.name || '-')}</span>
                        </div>
                        <span class="mini-cal-status-pill" data-status-pill>대기중</span>
                    </div>
                    <div class="mini-cal-header-sub">
                        ${spanLabel ? `<span>오늘: ${spanLabel}</span>` : ''}
                        <span>${segCountLabel}</span>
                    </div>
                </div>
                <div class="mini-cal-body">
                    ${segHtml || '<span class="text-muted small">등록된 스케줄이 없습니다.</span>'}
                </div>
                <div class="mini-cal-progress-wrap">
                    <div class="mini-cal-progress">
                        <div class="mini-cal-progress-bar" data-progress-bar style="width:0%"></div>
                    </div>
                </div>
                <div class="mini-cal-footer" data-footer-text></div>
            `;
            miniCalendars.appendChild(card);
        });
    }

    /* ===== 카드 상태 업데이트 ===== */
    function updateMiniCalendarState(members) {
        const now = new Date();
        const nowMin = now.getHours() * 60 + now.getMinutes();

        members.forEach(m => {
            const card = miniCalendars.querySelector(`.mini-cal-card[data-member-id="${CSS.escape(String(m.id))}"]`);
            if (!card) return;

            const segs = getSchedules(m).filter(s => s.day === DAY_KEY);
            const segEls = card.querySelectorAll('.mini-cal-seg');
            let isWorking = false, hasFuture = false, hasPast = false;
            let totalMin = 0, elapsedMin = 0;

            segEls.forEach(seg => {
                const st = parseHm(seg.dataset.start);
                const ed = parseHm(seg.dataset.end);
                const stMin = st.h*60 + st.m;
                const edMin = ed.h*60 + ed.m;
                const dur = edMin - stMin;
                totalMin += dur;

                const labelEl = seg.querySelector('.mini-cal-seg-label');

                if (nowMin >= edMin) {
                    hasPast = true;
                    elapsedMin += dur;
                    if (labelEl) { labelEl.textContent = '완료'; labelEl.className = 'mini-cal-seg-label seg-done'; }
                } else if (nowMin >= stMin) {
                    isWorking = true;
                    elapsedMin += (nowMin - stMin);
                    if (labelEl) { labelEl.textContent = '진행중'; labelEl.className = 'mini-cal-seg-label seg-working'; }
                } else {
                    hasFuture = true;
                    if (labelEl) { labelEl.textContent = '예정'; labelEl.className = 'mini-cal-seg-label seg-pending'; }
                }
            });

            /* 프로그레스 바 */
            const progressBar = card.querySelector('[data-progress-bar]');
            if (progressBar && totalMin > 0) {
                progressBar.style.width = Math.min(100, elapsedMin / totalMin * 100) + '%';
            }

            /* 상태 pill */
            const pill = card.querySelector('[data-status-pill]');
            card.classList.remove('current-working', 'done-card');

            const footer = card.querySelector('[data-footer-text]');

            if (isWorking) {
                if (pill) { pill.textContent = '근무중'; pill.className = 'mini-cal-status-pill status-working'; }
                card.classList.add('current-working');
                if (footer) { footer.textContent = ''; footer.className = 'mini-cal-footer'; }
            } else if (!hasFuture && hasPast) {
                if (pill) { pill.textContent = '근무 완료'; pill.className = 'mini-cal-status-pill status-done'; }
                card.classList.add('done-card');
                if (footer) { footer.textContent = '근무 완료 \u2713'; footer.className = 'mini-cal-footer footer-done'; }
            } else {
                if (pill) { pill.textContent = '예정/대기'; pill.className = 'mini-cal-status-pill status-rest'; }
                if (footer) { footer.textContent = ''; footer.className = 'mini-cal-footer'; }
            }
        });
    }

    /* ===== 간트 차트 렌더링 ===== */
    function renderGantt(members) {
        if (!ganttContainer) return;
        let html = '';

        /* 시간 헤더 */
        html += '<div class="rt-gantt-time-row">';
        html += '<div class="rt-gantt-label-cell" style="font-size:0.7rem;color:#9ca3af;">근무자</div>';
        html += '<div class="rt-gantt-track-cell" style="position:relative">';

        for (let h = HOUR_START; h <= HOUR_END; h++) {
            const pct = (h - HOUR_START) * 60 / TOTAL_MIN * 100;
            html += `<span class="rt-gantt-hour-mark" style="left:${pct}%">${String(h).padStart(2,'0')}:00</span>`;
            if (h < HOUR_END) {
                const halfPct = ((h - HOUR_START) * 60 + 30) / TOTAL_MIN * 100;
                html += `<span class="rt-gantt-hour-mark rt-gantt-half-mark" style="left:${halfPct}%">:30</span>`;
            }
        }

        html += '</div>';
        html += '<div class="rt-gantt-hours-cell" style="font-size:0.68rem;color:#9ca3af;"></div>';
        html += '</div>';

        /* 멤버별 행 */
        members.forEach(m => {
            const color = colorMap[m.id];
            const segs = getSchedules(m).filter(s => s.day === DAY_KEY);
            const totalMins = segs.reduce((sum, s) => {
                const st = parseHm(s.start), ed = parseHm(s.end);
                return sum + (ed.h*60+ed.m) - (st.h*60+st.m);
            }, 0);

            const rgb = hexToRgb(color);
            html += `<div class="rt-gantt-row" data-member-id="${m.id}" style="--bar-color:${color};--bar-color-light:rgba(${rgb.r},${rgb.g},${rgb.b},0.2)">`;
            html += `<div class="rt-gantt-label-cell">`;
            html += `<span class="rt-gantt-dot" style="background:${color}"></span>`;
            html += `<span class="rt-gantt-name">${escapeHtml(m.name || '-')}</span>`;
            html += `</div>`;
            html += `<div class="rt-gantt-track-cell">`;

            /* 그리드 라인 */
            for (let h = HOUR_START; h <= HOUR_END; h++) {
                const pct = (h - HOUR_START) * 60 / TOTAL_MIN * 100;
                html += `<div class="rt-gantt-grid-line grid-hour" style="left:${pct}%"></div>`;

                if (h < HOUR_END) {
                    if (currentScale <= 30) {
                        const halfPct = ((h - HOUR_START) * 60 + 30) / TOTAL_MIN * 100;
                        html += `<div class="rt-gantt-grid-line grid-half" style="left:${halfPct}%"></div>`;
                    }
                    if (currentScale <= 10) {
                        for (let tick = 10; tick < 60; tick += 10) {
                            if (tick === 30) continue;
                            const tickPct = ((h - HOUR_START) * 60 + tick) / TOTAL_MIN * 100;
                            html += `<div class="rt-gantt-grid-line" style="left:${tickPct}%"></div>`;
                        }
                    }
                }
            }

            /* 스케줄 바 */
            segs.forEach((s, si) => {
                const st = parseHm(s.start), ed = parseHm(s.end);
                const stMin = st.h*60 + st.m, edMin = ed.h*60 + ed.m;
                const clampStart = Math.max(stMin, HOUR_START*60);
                const clampEnd = Math.min(edMin, HOUR_END*60);
                if (clampEnd <= clampStart) return;

                const leftPct = (clampStart - HOUR_START*60) / TOTAL_MIN * 100;
                const widthPct = (clampEnd - clampStart) / TOTAL_MIN * 100;

                html += `<div class="rt-gantt-bar" data-seg-idx="${si}" data-start="${s.start}" data-end="${s.end}" style="left:${leftPct}%;width:${widthPct}%">`;
                html += `<div class="rt-gantt-bar-fill"></div>`;
                if (widthPct > 5) {
                    html += `<span class="rt-gantt-bar-label">${s.start}~${s.end}</span>`;
                }
                html += `</div>`;
            });

            /* 현재 시간 라인 */
            html += `<div class="rt-gantt-now-line"></div>`;
            html += `</div>`; /* track-cell */
            html += `<div class="rt-gantt-hours-cell"></div>`;
            html += `</div>`; /* row */
        });

        ganttContainer.innerHTML = html;
    }

    /* ===== 간트 바 업데이트 ===== */
    function updateGanttBars() {
        if (!ganttContainer) return;
        const now = new Date();
        const nowMin = now.getHours() * 60 + now.getMinutes();
        const nowPct = Math.max(0, Math.min(100, (nowMin - HOUR_START*60) / TOTAL_MIN * 100));

        ganttContainer.querySelectorAll('.rt-gantt-now-line').forEach(el => {
            el.style.left = nowPct + '%';
            el.style.display = (nowMin >= HOUR_START*60 && nowMin <= HOUR_END*60) ? '' : 'none';
        });

        ganttContainer.querySelectorAll('.rt-gantt-bar').forEach(bar => {
            const st = parseHm(bar.dataset.start);
            const ed = parseHm(bar.dataset.end);
            const stMin = st.h*60 + st.m;
            const edMin = ed.h*60 + ed.m;
            const fill = bar.querySelector('.rt-gantt-bar-fill');
            if (!fill) return;

            if (nowMin >= edMin) {
                fill.style.width = '100%';
                bar.classList.add('fully-done');
                bar.classList.remove('active-now');
            } else if (nowMin <= stMin) {
                fill.style.width = '0%';
                bar.classList.remove('fully-done', 'active-now');
            } else {
                fill.style.width = ((nowMin - stMin) / (edMin - stMin) * 100) + '%';
                bar.classList.remove('fully-done');
                bar.classList.add('active-now');
            }
        });
    }
})();
</script>

