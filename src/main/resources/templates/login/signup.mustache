<!doctype html>
<html lang="ko">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{#pageTitle}}{{pageTitle}}{{/pageTitle}}{{^pageTitle}}Cafe Friends Manager - 회원가입{{/pageTitle}}</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" crossorigin="anonymous">
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --cafe-bg: #fff7ec;
            --cafe-bg-accent: #fde7c7;
            --cafe-brown: #5b3a29;
            --cafe-brown-dark: #3d261a;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Noto Sans KR', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: radial-gradient(circle at top left, var(--cafe-bg-accent), var(--cafe-bg));
            min-height: 100vh;
            color: var(--cafe-brown);
        }

        /* 로딩 오버레이 */
        #loading-overlay {
            position: fixed;
            inset: 0;
            background: rgba(255, 247, 236, 0.9);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 0.4s ease;
        }

        #loading-overlay.hidden {
            opacity: 0;
            pointer-events: none;
        }

        .spinner-cup {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            border: 4px solid #f0d2aa;
            border-top-color: var(--cafe-brown);
            animation: spin 0.9s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* 메인 컨텐츠 레이아웃 */
        .main-wrapper {
            min-height: 100vh;
        }

        .welcome-card {
            max-width: 560px;
            width: 100%;
            background: rgba(255, 255, 255, 0.94);
            border-radius: 20px;
            box-shadow:
                    0 18px 45px rgba(0, 0, 0, 0.08),
                    0 0 0 1px rgba(255, 255, 255, 0.8);
            padding: 2.3rem 2.25rem 2rem;
            animation: fadeUp 0.7s ease-out both;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .welcome-title {
            color: var(--cafe-brown-dark);
            letter-spacing: 0.03em;
        }

        .welcome-sub {
            color: #8a5e43;
        }

        .brand-badge {
            font-size: 0.8rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #d5a67b;
        }

        /* 폼 레이아웃 */
        .form-section-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: #7a533a;
            margin-bottom: 0.15rem;
        }

        .form-section-sub {
            font-size: 0.8rem;
            color: #b08a6b;
            margin-bottom: 0.6rem;
        }

        .form-label {
            font-size: 0.86rem;
            color: #6b4c36;
            margin-bottom: 0.25rem;
        }

        .required-badge {
            font-size: 0.75rem;
            color: #c2410c;
            margin-left: 0.25rem;
        }

        .optional-badge {
            font-size: 0.75rem;
            color: #9ca3af;
            margin-left: 0.25rem;
        }

        .form-control {
            border-radius: 999px;
            border: 1px solid #e2d3c3;
            padding: 0.45rem 1rem;
            font-size: 0.95rem;
        }

        .form-control:focus {
            border-color: #b87336;
            box-shadow: 0 0 0 0.15rem rgba(184, 115, 54, 0.25);
        }

        .form-text {
            font-size: 0.78rem;
            color: #b08a6b;
        }

        /* 회원가입 버튼 */
        .btn-signup {
            background: linear-gradient(135deg, #b87336, #8b4a24);
            border: none;
            color: #fff;
            font-weight: 600;
            font-size: 0.98rem;
            padding: 0.65rem 1.5rem;
            border-radius: 999px;
            width: 100%;
            box-shadow: 0 8px 20px rgba(139, 74, 36, 0.30);
            transition:
                    transform 0.15s ease-out,
                    box-shadow 0.15s ease-out,
                    filter 0.15s ease-out;
        }

        .btn-signup:hover,
        .btn-signup:focus {
            transform: translateY(-1px);
            box-shadow: 0 12px 26px rgba(139, 74, 36, 0.40);
            filter: brightness(1.03);
        }

        .btn-signup:active {
            transform: translateY(0);
            box-shadow: 0 5px 14px rgba(139, 74, 36, 0.32);
        }

        /* 하단 링크 */
        .helper-text {
            font-size: 0.85rem;
            color: #b08a6b;
        }

        .link-muted {
            font-size: 0.85rem;
            color: #9c7a5d;
            text-decoration: none;
        }

        .link-muted:hover {
            color: #7b5a3e;
            text-decoration: underline;
        }

        @media (max-width: 576px) {
            .welcome-card {
                margin: 1.5rem;
                padding: 1.8rem 1.5rem 1.4rem;
            }
        }
    </style>
</head>
<body>

<!-- 로딩 오버레이 -->
<div id="loading-overlay">
    <div class="d-flex flex-column align-items-center gap-3">
        <div class="spinner-cup"></div>
        <div class="fw-semibold" style="color: #8b5a35;">Cafe Friends Manager 로딩 중...</div>
    </div>
</div>

<div class="container-fluid main-wrapper d-flex align-items-center justify-content-center">
    <div class="welcome-card">
        <!-- 상단 타이틀 -->
        <div class="mb-3 text-center">
            <div class="brand-badge mb-1">CAFE FRIENDS MANAGER</div>
            <h1 class="welcome-title h4 mb-1">
                회원가입
            </h1>
            <p class="welcome-sub mb-0">
                매장 동행 관리를 위해 기본 정보를 입력해 주세요.
            </p>
        </div>

        <!-- 회원가입 폼 -->
        <form id="signupForm" method="post" action="/signup">
            {{#_csrf}}
                <input type="hidden" name="{{parameterName}}" value="{{token}}">
            {{/_csrf}}

            <!-- 필수 정보 -->
            <div class="mb-2">
                <div class="form-section-title">필수 정보</div>
                <div class="form-section-sub">
                    로그인에 사용할 이메일과 닉네임, 비밀번호를 설정합니다.
                </div>
            </div>

            <!-- 이메일 / 닉네임 (둘 다 필수) -->
            <div class="row g-3 mb-1">
                <div class="col-sm-6">
                    <label for="email" class="form-label">
                        이메일
                        <span class="required-badge">(필수)</span>
                    </label>
                    <input type="email"
                           class="form-control"
                           id="email"
                           name="email"
                           placeholder="example@cafe.com"
                           required>
                </div>
                <div class="col-sm-6">
                    <label for="nickname" class="form-label">
                        닉네임
                        <span class="required-badge">(필수)</span>
                    </label>
                    <input type="text"
                           class="form-control"
                           id="nickname"
                           name="nickname"
                           placeholder="근무표에 표시될 이름"
                           required>
                </div>
            </div>

            <!-- 비밀번호 -->
            <div class="row g-3 mb-2">
                <div class="col-sm-6">
                    <label for="password" class="form-label">
                        비밀번호
                        <span class="required-badge">(필수)</span>
                    </label>
                    <input type="password"
                           class="form-control"
                           id="password"
                           name="password"
                           placeholder="영문/숫자 포함 8자 이상"
                           required>
                    <div id="pw-error" class="form-text" style="color:#c2410c; display:none;"></div>
                </div>
                <div class="col-sm-6">
                    <label for="passwordConfirm" class="form-label">
                        비밀번호 확인
                        <span class="required-badge">(필수)</span>
                    </label>
                    <input type="password"
                           class="form-control"
                           id="passwordConfirm"
                           name="passwordConfirm"
                           placeholder="비밀번호를 다시 입력"
                           required>
                    <div id="pw-confirm-error" class="form-text" style="color:#c2410c; display:none;"></div>
                </div>
            </div>

            <div class="mb-3">
                <small class="form-text">
                    비밀번호는 영문 대/소문자, 숫자를 조합하여 8자 이상을 권장합니다.
                </small>
            </div>

            <!-- 선택 정보 -->
            <div class="mb-2 mt-3">
                <div class="form-section-title">선택 정보</div>
                <div class="form-section-sub">
                    알림 발송 및 연락용 정보입니다. 추후 마이페이지에서 수정할 수 있습니다.
                </div>
            </div>

            <!-- 전화번호 (선택) -->
            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label for="phone" class="form-label">
                        전화번호
                        <span class="optional-badge">(선택)</span>
                    </label>
                    <input type="tel"
                           class="form-control"
                           id="phone"
                           name="phone"
                           placeholder="010-1234-5678">
                </div>
            </div>

            <!-- 약관 (간단 체크) -->
            <div class="mb-3">
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           value="true"
                           id="agreedTerms"
                           name="agreedTerms"
                           required>
                    <label class="form-check-label" for="agreedTerms" style="font-size:0.85rem;">
                        <span class="required-badge">(필수)</span>
                        서비스 이용 약관 및 개인정보 처리방침에 동의합니다.
                    </label>
                </div>
            </div>

            <!-- 회원가입 버튼 -->
            <button type="submit" class="btn btn-signup mb-2">
                회원가입
            </button>

            <!-- 하단 링크 -->
            <div class="d-flex justify-content-between align-items-center mt-1">
                <span class="helper-text">
                    이미 계정이 있으신가요?
                </span>
                <a href="/login" class="link-muted">
                    로그인 페이지로 이동
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    // 페이지 로드 후 로딩 오버레이 제거
    window.addEventListener('load', function () {
        const overlay = document.getElementById('loading-overlay');
        if (!overlay) return;

        overlay.classList.add('hidden');
        setTimeout(function () {
            overlay.style.display = 'none';
        }, 400);
    });

    // 회원가입 폼 클라이언트 측 유효성 검사 (인라인 에러 표시)
    const pwInput = document.getElementById("password");
    const pw2Input = document.getElementById("passwordConfirm");
    const pwError = document.getElementById("pw-error");
    const pw2Error = document.getElementById("pw-confirm-error");

    function clearErrors() {
        pwError.style.display = "none";
        pw2Error.style.display = "none";
        pwInput.classList.remove("is-invalid");
        pw2Input.classList.remove("is-invalid");
    }

    pwInput.addEventListener("input", function () {
        if (pwInput.value.length >= 8) {
            pwError.style.display = "none";
            pwInput.classList.remove("is-invalid");
        }
    });

    pw2Input.addEventListener("input", function () {
        if (pw2Input.value === pwInput.value) {
            pw2Error.style.display = "none";
            pw2Input.classList.remove("is-invalid");
        }
    });

    document.getElementById("signupForm").addEventListener("submit", function (e) {
        clearErrors();
        const pw = pwInput.value.trim();
        const pw2 = pw2Input.value.trim();
        let valid = true;

        if (pw.length < 8) {
            pwError.textContent = "비밀번호는 최소 8자 이상이어야 합니다.";
            pwError.style.display = "block";
            pwInput.classList.add("is-invalid");
            pwInput.focus();
            valid = false;
        }

        if (pw !== pw2) {
            pw2Error.textContent = "비밀번호와 비밀번호 확인이 서로 다릅니다.";
            pw2Error.style.display = "block";
            pw2Input.classList.add("is-invalid");
            if (valid) pw2Input.focus();
            valid = false;
        }

        if (!valid) e.preventDefault();
    });
</script>

</body>
</html>
