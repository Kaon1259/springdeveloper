<!doctype html>
<html lang="ko">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Cafe Friends Manager</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Noto Sans KR', system-ui, sans-serif;
            background: radial-gradient(ellipse at top left, #fde7c7, #fff7ec 60%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #5b3a29;
        }

        .splash {
            text-align: center;
            animation: fadeUp 0.8s ease-out both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* 로고 이미지 */
        .logo-link {
            display: inline-block;
            cursor: pointer;
            border-radius: 20px;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .logo-link:hover {
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 20px 50px rgba(91, 58, 41, 0.20);
        }

        .logo-link:active {
            transform: translateY(0) scale(0.99);
        }

        .logo-img {
            width: 280px;
            max-width: 90vw;
            border-radius: 20px;
            box-shadow: 0 12px 36px rgba(91, 58, 41, 0.15);
            display: block;
        }

        /* 앱 이름 */
        .app-name {
            margin-top: 1.6rem;
            font-size: 1.3rem;
            font-weight: 700;
            color: #3d261a;
            letter-spacing: 0.04em;
        }

        /* 안내 문구 */
        .hint {
            margin-top: 0.6rem;
            font-size: 0.9rem;
            color: #b08a6b;
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.5; }
        }

        /* 입장 버튼 */
        .enter-btn {
            display: inline-block;
            margin-top: 1.8rem;
            padding: 0.7rem 2.4rem;
            background: linear-gradient(135deg, #b87336, #8b4a24);
            color: #fff;
            font-size: 1rem;
            font-weight: 600;
            font-family: inherit;
            border: none;
            border-radius: 999px;
            cursor: pointer;
            text-decoration: none;
            box-shadow: 0 8px 22px rgba(139, 74, 36, 0.28);
            transition: transform 0.15s, box-shadow 0.15s, filter 0.15s;
        }

        .enter-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 30px rgba(139, 74, 36, 0.36);
            filter: brightness(1.05);
            color: #fff;
            text-decoration: none;
        }

        .enter-btn:active {
            transform: translateY(0);
        }
    </style>
</head>
<body>

<div class="splash">

    <!-- 로고 클릭 → 메인 진입 -->
    <a href="/members" class="logo-link" aria-label="메인 화면으로 이동">
        <img src="/img/mainTitle.jpg" alt="Cafe Friends Manager" class="logo-img">
    </a>

    <div class="app-name">Cafe Friends Manager</div>
    <div class="hint">로고를 클릭하거나 아래 버튼을 눌러 입장하세요</div>

    <a href="/members" class="enter-btn">입장하기</a>
</div>

</body>
</html>
